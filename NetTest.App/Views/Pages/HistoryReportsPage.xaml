<UserControl x:Class="NetTest.App.Views.Pages.HistoryReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource SectionPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="运行历史" />
                    <TextBlock Margin="0,2,0,0"
                               Style="{StaticResource SectionHintTextStyle}"
                               Text="这里集中回看最近执行过的测试记录，帮助你快速定位上一次做过什么。" />
                </StackPanel>

                <TextBox Grid.Row="1"
                         Margin="0,6,0,0"
                         Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                         Text="{Binding HistorySummary, Mode=OneWay}" />
            </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource SectionPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="报告归档" />
                    <TextBlock Margin="0,2,0,0"
                               Style="{StaticResource SectionHintTextStyle}"
                               Text="导出后的结构化报告会集中显示在这里，便于回看和归档管理。" />
                </StackPanel>

                <Button Grid.Row="1"
                        Margin="0,6,0,0"
                        HorizontalAlignment="Left"
                        Command="{Binding ExportCurrentReportCommand}"
                        Content="导出当前报告" />
                <TextBox Grid.Row="2"
                         Margin="0,6,0,0"
                         Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                         Text="{Binding ReportArchiveSummary, Mode=OneWay}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
