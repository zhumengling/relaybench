<UserControl x:Class="NetTest.App.Views.Pages.SingleStationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SectionPanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x76EE;&#x6807;&#x5730;&#x5740;" />
                    <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                             Text="{Binding ProxyBaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="API Key" />
                    <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                             Text="{Binding ProxyApiKey, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x6A21;&#x578B;" />
                    <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                             Text="{Binding ProxyModel, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <Button Grid.Column="6"
                        VerticalAlignment="Bottom"
                        Command="{Binding FetchProxyModelsCommand}"
                        Content="&#x62C9;&#x53D6;&#x6A21;&#x578B;" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,4,0,0"
                Style="{StaticResource SectionPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="&#x5F53;&#x524D;&#x6A21;&#x5F0F;&#x53C2;&#x6570;&#x4E0E;&#x6267;&#x884C;" />
                    <TextBlock Margin="0,2,0,0"
                               Style="{StaticResource SectionHintTextStyle}"
                               Text="{Binding SingleStationModeDescription}" />
                </StackPanel>

                <Button Grid.Row="0"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Command="{Binding RunSelectedSingleStationModeCommand}"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Content="{Binding SingleStationPrimaryButtonText}" />

                <ComboBox Grid.Row="1"
                          Grid.ColumnSpan="3"
                          Margin="0,6,0,0"
                          Style="{StaticResource CompactComboBoxStyle}"
                          ItemsSource="{Binding SingleStationModeOptions}"
                          TextSearch.TextPath="DisplayName"
                          SelectedValuePath="Key"
                          SelectedValue="{Binding SelectedSingleStationModeKey, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Foreground="#101828"
                                       FontSize="11.1"
                                       FontWeight="SemiBold"
                                       Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Grid Grid.Row="2"
                      Grid.ColumnSpan="3"
                      Margin="0,6,0,0"
                      Visibility="{Binding IsSingleStationStabilityMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="160" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x8F6E;&#x6B21;" />
                        <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                 Text="{Binding ProxySeriesRoundsText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x95F4;&#x9694;&#xFF08;ms&#xFF09;" />
                        <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                 Text="{Binding ProxySeriesDelayMsText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2"
                        Grid.ColumnSpan="3"
                        Margin="0,6,0,0"
                        Style="{StaticResource InsetPanelBorderStyle}"
                        Visibility="{Binding IsSingleStationDeepMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x6DF1;&#x5EA6;&#x6D4B;&#x8BD5;&#x9879;" />

                        <ComboBox Style="{StaticResource CompactComboBoxStyle}"
                                  Margin="0,6,0,0"
                                  ItemsSource="{Binding ProxyDiagnosticPresetOptions}"
                                  TextSearch.TextPath="DisplayName"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding SelectedProxyDiagnosticPresetKey, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="#101828"
                                               FontSize="11.1"
                                               FontWeight="SemiBold"
                                               Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <WrapPanel Margin="0,6,0,0">
                            <CheckBox Content="&#x534F;&#x8BAE;&#x517C;&#x5BB9;" IsChecked="{Binding ProxyEnableProtocolCompatibilityTest, Mode=TwoWay}" />
                            <CheckBox Content="&#x9519;&#x8BEF;&#x900F;&#x4F20;" IsChecked="{Binding ProxyEnableErrorTransparencyTest, Mode=TwoWay}" />
                            <CheckBox Content="&#x6D41;&#x5F0F;&#x5B8C;&#x6574;&#x6027;" IsChecked="{Binding ProxyEnableStreamingIntegrityTest, Mode=TwoWay}" />
                            <CheckBox Content="&#x591A;&#x6A21;&#x6001;" IsChecked="{Binding ProxyEnableMultiModalTest, Mode=TwoWay}" />
                            <CheckBox Content="&#x7F13;&#x5B58;&#x673A;&#x5236;" IsChecked="{Binding ProxyEnableCacheMechanismTest, Mode=TwoWay}" />
                            <CheckBox Content="&#x7F13;&#x5B58;&#x9694;&#x79BB;" IsChecked="{Binding ProxyEnableCacheIsolationTest, Mode=TwoWay}" />
                            <CheckBox Content="&#x5B98;&#x65B9;&#x5BF9;&#x7167;" IsChecked="{Binding ProxyEnableOfficialReferenceIntegrityTest, Mode=TwoWay}" />
                        </WrapPanel>

                        <Border Margin="0,6,0,0"
                                Style="{StaticResource InsetPanelBorderStyle}"
                                Visibility="{Binding ProxyEnableCacheIsolationTest, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x7F13;&#x5B58;&#x9694;&#x79BB;&#x5907;&#x7528; Key" />
                                <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                           Text="&#x586B;&#x5199;&#x7B2C;&#x4E8C;&#x4E2A; API Key&#xFF0C;&#x7528;&#x4E8E; A / B Key &#x9694;&#x79BB;&#x9A8C;&#x8BC1;&#xFF1B;&#x4E0D;&#x8981;&#x4E0E;&#x4E0A;&#x65B9;&#x4E3B; Key &#x76F8;&#x540C;&#x3002;" />
                                <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                         Text="{Binding ProxyCacheIsolationAlternateApiKey, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,6,0,0"
                                Style="{StaticResource InsetPanelBorderStyle}"
                                Visibility="{Binding ProxyEnableOfficialReferenceIntegrityTest, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="1.2*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.ColumnSpan="3">
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x5B98;&#x65B9;&#x5BF9;&#x7167;&#x53C2;&#x8003;&#x5165;&#x53E3;" />
                                    <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                               Text="&#x586B;&#x5199;&#x5B98;&#x65B9;&#x6216;&#x53C2;&#x8003;&#x5165;&#x53E3;&#x7684; Base URL &#x4E0E; API Key&#xFF1B;&#x6A21;&#x578B;&#x53EF;&#x9009;&#xFF0C;&#x4E0D;&#x586B;&#x5219;&#x6CBF;&#x7528;&#x5F53;&#x524D;&#x6A21;&#x578B;&#x3002;" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,6,0,0">
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x53C2;&#x8003; Base URL" />
                                    <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                             Text="{Binding ProxyOfficialReferenceBaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,6,0,0">
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x53C2;&#x8003; API Key" />
                                    <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                             Text="{Binding ProxyOfficialReferenceApiKey, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,6,0,0">
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x53C2;&#x8003;&#x6A21;&#x578B;&#xFF08;&#x53EF;&#x9009;&#xFF09;" />
                                    <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                             Text="{Binding ProxyOfficialReferenceModel, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,4,0,0"
                Style="{StaticResource SectionPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="&#x7ED3;&#x679C;&#x4E0E;&#x7EDF;&#x4E00;&#x8F93;&#x51FA;" />
                <TextBox Grid.Row="1"
                         Margin="0,4,0,0"
                         MinHeight="104"
                         Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                         Text="{Binding SingleStationResultSummary, Mode=OneWay}" />
                <TextBox Grid.Row="2"
                         Margin="0,4,0,0"
                         Style="{StaticResource ReadOnlyConsoleTextBoxStyle}"
                         Text="{Binding ProxyUnifiedOutput, Mode=OneWay}"
                         TextChanged="LiveOutputTextBox_OnTextChanged" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
