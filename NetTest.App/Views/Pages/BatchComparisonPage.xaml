<UserControl x:Class="NetTest.App.Views.Pages.BatchComparisonPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="ChartPreviewOverlayTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SectionHintTextStyle}">
            <Setter Property="Foreground" Value="#344054" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="BatchRankingApplyButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="#F8FBFF" />
            <Setter Property="BorderBrush" Value="#C7DAFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF4FF" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#84ADFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#DBEAFE" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#528BFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#98A2B3" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F2F4F7" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#E4E7EC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BatchRankingApplyToastStyle"
               TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="-6" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBatchRankingApplyToastVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="0" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BatchRankingUrlTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SectionHintTextStyle}">
            <Setter Property="FontSize" Value="9.8" />
            <Setter Property="Foreground" Value="#667085" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="BatchRankingMetricBorderStyle"
               TargetType="Border">
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="#F8FBFF" />
            <Setter Property="BorderBrush" Value="#D6E4FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="BatchRankingMetricTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SectionHintTextStyle}">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="10.2" />
            <Setter Property="Foreground" Value="#344054" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1.05*" />
            <RowDefinition Height="1.15*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SectionPanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="入口组" />
                    <WrapPanel Margin="0,4,0,0">
                        <Border Margin="0,0,6,0"
                                Padding="8,2"
                                Background="#F8FAFC"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                       FontWeight="SemiBold"
                                       Text="入口组" />
                        </Border>
                        <TextBlock Margin="0,2,6,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="→" />
                        <Border Margin="0,0,6,0"
                                Padding="8,2"
                                Background="#F8FAFC"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                       FontWeight="SemiBold"
                                       Text="快测" />
                        </Border>
                        <TextBlock Margin="0,2,6,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="→" />
                        <Border Margin="0,0,6,0"
                                Padding="8,2"
                                Background="#F8FAFC"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                       FontWeight="SemiBold"
                                       Text="候选" />
                        </Border>
                        <TextBlock Margin="0,2,6,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="→" />
                        <Border Padding="8,2"
                                Background="#EEF4FF"
                                BorderBrush="#C7DAFF"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       Text="深测" />
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <Button Command="{Binding OpenProxyBatchEditorCommand}" Content="管理入口组" />
                    <Button Command="{Binding RunProxyBatchCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Content="开始快速对比" />
                    <Button Command="{Binding OpenBatchComparisonChartCommand}" Content="放大图表" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.08*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="0.92*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="排行榜" />
                        <TextBlock Margin="0,2,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="{Binding BatchComparisonChartStatusSummary, Mode=OneWay}" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,6,0,0"
                            Style="{StaticResource InsetPanelBorderStyle}">
                        <Grid x:Name="BatchComparisonChartPreviewHost"
                              Background="Transparent"
                              ClipToBounds="True"
                              SizeChanged="BatchComparisonChartPreviewHost_OnSizeChanged">
                            <Border Cursor="Hand"
                                    Visibility="{Binding HasBatchComparisonChart, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Border.InputBindings>
                                    <MouseBinding Gesture="LeftClick"
                                                  Command="{Binding OpenBatchComparisonChartCommand}" />
                                </Border.InputBindings>
                                <Grid>
                                    <Image Margin="4"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           Stretch="Uniform"
                                           Source="{Binding BatchComparisonChartImage, Mode=OneWay}" />
                                    <Border HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,10,10"
                                            Padding="8,3"
                                            Background="#F9FAFBEA"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <TextBlock Style="{StaticResource ChartPreviewOverlayTextStyle}"
                                                   Text="点击放大" />
                                    </Border>
                                </Grid>
                            </Border>

                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="快测后显示排行榜预览。">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasBatchComparisonChart}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="候选列表" />
                        <TextBlock Margin="0,2,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="在这里勾选候选项" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,6,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                        <ItemsControl ItemsSource="{Binding ProxyBatchRankingRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,4"
                                            Padding="7,5"
                                            Background="{StaticResource InputBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      Margin="0,1,8,0"
                                                      VerticalAlignment="Top"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}" />

                                            <Border Grid.Column="1"
                                                    Width="34"
                                                    Height="20"
                                                    Margin="0,1,8,0"
                                                    VerticalAlignment="Top"
                                                    Background="Transparent"
                                                    BorderBrush="{StaticResource AccentBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Rank}" />
                                            </Border>

                                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding EntryName}" />
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Style="{StaticResource SectionHintTextStyle}"
                                                               Text="{Binding Model, StringFormat=模型：{0}}" />
                                                </DockPanel>
                                                <TextBlock Style="{StaticResource BatchRankingUrlTextStyle}" Text="{Binding BaseUrl}" />
                                                <WrapPanel Margin="0,2,0,0">
                                                    <Border Margin="0,0,6,0"
                                                            Padding="6,1"
                                                            Background="{StaticResource InputBrush}"
                                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8">
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Text="{Binding QuickVerdict}" />
                                                    </Border>
                                                    <Border Padding="6,1"
                                                            Background="{StaticResource InputBrush}"
                                                            BorderBrush="{StaticResource AccentBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8">
                                                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding DeepStatus}" />
                                                    </Border>
                                                </WrapPanel>
                                                <Border Style="{StaticResource BatchRankingMetricBorderStyle}">
                                                    <TextBlock Style="{StaticResource BatchRankingMetricTextStyle}"
                                                               Text="{Binding QuickMetrics}" />
                                                </Border>
                                                <Expander Margin="0,3,0,0"
                                                          IsExpanded="False">
                                                    <Expander.Header>
                                                        <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                                                   Text="详情" />
                                                    </Expander.Header>
                                                    <StackPanel Margin="0,6,0,0">
                                                        <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                                                   Text="{Binding CapabilitySummary}" />
                                                        <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                                                   Text="{Binding DeepSummary}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Expander>
                                            </StackPanel>

                                            <Button Grid.Column="3"
                                                    VerticalAlignment="Center"
                                                    Style="{StaticResource BatchRankingApplyButtonStyle}"
                                                    Command="{Binding DataContext.ApplyRankingRowToCodexAppsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="&#x5E94;&#x7528;&#x5230; Codex &#x7CFB;&#x5217;&#x8F6F;&#x4EF6;">
                                                <TextBlock FontSize="13.4"
                                                           FontWeight="SemiBold"
                                                           Text="&#x2726;" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Panel.ZIndex="9"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,10,0"
                Padding="10,7"
                MaxWidth="420"
                Background="#ECFDF3"
                BorderBrush="#ABEFC6"
                BorderThickness="1"
                CornerRadius="12"
                Style="{StaticResource BatchRankingApplyToastStyle}">
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center"
                           FontSize="12.6"
                           Foreground="#067647"
                           Text="&#x2713;" />
                <TextBlock Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#067647"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Text="{Binding BatchRankingApplyToastMessage, Mode=OneWay}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="快测摘要" />
                        <TextBlock Margin="0,2,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="保留本轮快测摘要，方便对照。" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Margin="0,6,0,0"
                             Style="{StaticResource ReadOnlyConsoleTextBoxStyle}"
                             Text="{Binding ProxyBatchSummary, Mode=OneWay}" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1.18*" />
                        <RowDefinition Height="0.82*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="深度测试" />
                            <TextBlock Margin="0,2,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="{Binding BatchSelectionSummary, Mode=OneWay}" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                VerticalAlignment="Center"
                                Command="{Binding RunSelectedBatchDeepTestsCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                IsEnabled="{Binding CanRunSelectedBatchDeepTests, Mode=OneWay}"
                                Content="开始深测" />
                    </Grid>

                    <Expander Grid.Row="1"
                              Margin="0,6,0,0"
                              IsExpanded="False">
                        <Expander.Header>
                            <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                       Text="说明" />
                        </Expander.Header>
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="只复用已勾选项的 Base URL / Key / Model" />
                    </Expander>

                    <TextBlock Grid.Row="2"
                               Margin="0,4,0,0"
                               Style="{StaticResource SectionHintTextStyle}"
                               Text="{Binding BatchDeepComparisonChartStatusSummary, Mode=OneWay}" />

                    <Border Grid.Row="3"
                            Margin="0,6,0,0"
                            Style="{StaticResource InsetPanelBorderStyle}">
                        <Grid>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="开始深测后，这里会显示总览图。">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasBatchDeepComparisonChart}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Border x:Name="BatchDeepComparisonChartPreviewHost"
                                    Background="Transparent"
                                    ClipToBounds="True"
                                    Cursor="Hand"
                                    SizeChanged="BatchDeepComparisonChartPreviewHost_OnSizeChanged"
                                    Visibility="{Binding HasBatchDeepComparisonChart, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Border.InputBindings>
                                    <MouseBinding Gesture="LeftClick"
                                                  Command="{Binding OpenBatchDeepComparisonChartCommand}" />
                                </Border.InputBindings>
                                <Grid>
                                    <Image Margin="4"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           Stretch="Uniform"
                                           Source="{Binding BatchDeepComparisonChartImage, Mode=OneWay}" />
                                    <Border HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,10,10"
                                            Padding="8,3"
                                            Background="#F9FAFBEA"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <TextBlock Style="{StaticResource ChartPreviewOverlayTextStyle}"
                                                   Text="点击放大" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <TextBox Grid.Row="4"
                             Margin="0,6,0,0"
                             Style="{StaticResource ReadOnlyConsoleTextBoxStyle}"
                             Text="{Binding BatchDeepTestSummary, Mode=OneWay}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
