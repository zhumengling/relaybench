<Window x:Class="RelayBench.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:pages="clr-namespace:RelayBench.App.Views.Pages"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="RelayBench &#x63A5;&#x53E3;&#x6D4B;&#x8BD5;&#x5DE5;&#x4F5C;&#x53F0;"
        Width="1366"
        Height="900"
        MinWidth="1120"
        MinHeight="700"
        Background="#F8FAFC"
        FontFamily="Microsoft YaHei UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        Icon="Assets/Brand/relaybench-logo.png"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="10"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid Margin="0">
        <Border x:Name="MainShellBorder"
                Background="{StaticResource AppBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="0"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="12,8,8,8"
                        Background="{StaticResource PanelBrushStrong}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="10,10,0,0">
                    <Border.Resources>
                        <Style x:Key="TitleBarButtonStyle"
                               TargetType="Button"
                               BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Width" Value="38" />
                            <Setter Property="Height" Value="28" />
                            <Setter Property="MinWidth" Value="38" />
                            <Setter Property="Margin" Value="4,0,0,0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="FontSize" Value="11.4" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </Border.Resources>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              Background="Transparent"
                              ClipToBounds="True"
                              MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="28"
                                    Height="28"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource AccentBrush}"
                                    CornerRadius="8">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#FFFFFF"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Text="R" />
                            </Border>

                            <TextBlock Grid.Column="1"
                                       Margin="9,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       MaxWidth="220"
                                       ClipToBounds="True"
                                       Text="RelayBench &#x63A5;&#x53E3;&#x6D4B;&#x8BD5;&#x5DE5;&#x4F5C;&#x53F0;"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="RelayBench &#x63A5;&#x53E3;&#x6D4B;&#x8BD5;&#x5DE5;&#x4F5C;&#x53F0;" />

                            <Border x:Name="GlobalTaskProgressBorder"
                                    Grid.Column="3"
                                    MinWidth="0"
                                    MaxWidth="620"
                                    Height="28"
                                    Margin="0,0,10,0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    Padding="10,0"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    IsHitTestVisible="False"
                                    Opacity="0"
                                    Visibility="Collapsed">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#FBFDFF" />
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="BorderBrush" Value="#D9E7FF" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGlobalTaskProgressCompleted, Mode=OneWay}"
                                                         Value="True">
                                                <Setter Property="Background" Value="#F3FFF7" />
                                                <Setter Property="BorderBrush" Value="#9ADAB4" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsGlobalTaskProgressStopped, Mode=OneWay}"
                                                         Value="True">
                                                <Setter Property="Background" Value="#FFF8EE" />
                                                <Setter Property="BorderBrush" Value="#F8C77C" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsGlobalTaskProgressFailed, Mode=OneWay}"
                                                         Value="True">
                                                <Setter Property="Background" Value="#FFF5F5" />
                                                <Setter Property="BorderBrush" Value="#F7B0B0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="88" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="#0F172A"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               MaxWidth="150"
                                               Text="{Binding GlobalTaskProgressTitle, Mode=OneWay}"
                                               TextTrimming="CharacterEllipsis" />

                                    <Border Grid.Column="2"
                                            Height="6"
                                            VerticalAlignment="Center"
                                            Background="#E0EAFF"
                                            BorderBrush="#CBD9FF"
                                            BorderThickness="1"
                                            CornerRadius="999">
                                        <Grid ClipToBounds="True">
                                            <Border Margin="1"
                                                    Background="#1FFFFFFF"
                                                    CornerRadius="999" />
                                            <Border x:Name="GlobalTaskProgressFill"
                                                    HorizontalAlignment="Stretch"
                                                    CornerRadius="999"
                                                    RenderTransformOrigin="0,0.5">
                                                <Border.RenderTransform>
                                                    <ScaleTransform ScaleX="0" ScaleY="1" />
                                                </Border.RenderTransform>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush StartPoint="0,0"
                                                                                     EndPoint="1,0">
                                                                    <GradientStop Color="#2563EB" Offset="0" />
                                                                    <GradientStop Color="#0EA5E9" Offset="1" />
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsGlobalTaskProgressCompleted, Mode=OneWay}"
                                                                         Value="True">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <LinearGradientBrush StartPoint="0,0"
                                                                                             EndPoint="1,0">
                                                                            <GradientStop Color="#16A34A" Offset="0" />
                                                                            <GradientStop Color="#22C55E" Offset="1" />
                                                                        </LinearGradientBrush>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsGlobalTaskProgressStopped, Mode=OneWay}"
                                                                         Value="True">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <LinearGradientBrush StartPoint="0,0"
                                                                                             EndPoint="1,0">
                                                                            <GradientStop Color="#F59E0B" Offset="0" />
                                                                            <GradientStop Color="#FB923C" Offset="1" />
                                                                        </LinearGradientBrush>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsGlobalTaskProgressFailed, Mode=OneWay}"
                                                                         Value="True">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <LinearGradientBrush StartPoint="0,0"
                                                                                             EndPoint="1,0">
                                                                            <GradientStop Color="#EF4444" Offset="0" />
                                                                            <GradientStop Color="#F97373" Offset="1" />
                                                                        </LinearGradientBrush>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <TextBlock Grid.Column="4"
                                               MinWidth="72"
                                               MaxWidth="118"
                                               VerticalAlignment="Center"
                                               Foreground="#475467"
                                               FontSize="11.5"
                                               FontWeight="SemiBold"
                                               Text="{Binding GlobalTaskProgressStatusText, Mode=OneWay}"
                                               TextAlignment="Right"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Style="{StaticResource TitleBarButtonStyle}"
                                    Click="MinimizeWindowButton_OnClick"
                                    ToolTip="&#x6700;&#x5C0F;&#x5316;"
                                    Content="&#x2014;" />
                            <Button Click="MaximizeRestoreWindowButton_OnClick">
                                <Button.Style>
                                    <Style TargetType="Button"
                                           BasedOn="{StaticResource TitleBarButtonStyle}">
                                        <Setter Property="ToolTip" Value="&#x6700;&#x5927;&#x5316;" />
                                        <Setter Property="Content" Value="&#x25A1;" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}"
                                                         Value="Maximized">
                                                <Setter Property="ToolTip" Value="&#x8FD8;&#x539F;" />
                                                <Setter Property="Content" Value="&#x2752;" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Style="{StaticResource TitleBarButtonStyle}"
                                    Click="CloseWindowButton_OnClick"
                                    ToolTip="&#x5173;&#x95ED;"
                                    Content="&#x2715;" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Margin="10,8,10,10">
                    <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="1"
                        Margin="0,0,0,6"
                        Padding="10,6"
                        Background="{StaticResource InputBrush}"
                        CornerRadius="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="{Binding StatusMessage, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource AccentBrush}"
                                   Text="{Binding LastRunAt, StringFormat=上次运行：{0}}"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Border>

                <Grid Grid.Row="0"
                      Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding NavigationRailWidth}" />
                        <ColumnDefinition Width="{Binding NavigationRailGapWidth}" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource NavigationRailBorderStyle}">
                                <Setter Property="Padding" Value="14" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNavigationRailCollapsed}" Value="True">
                                        <Setter Property="Padding" Value="6" />
                                        <Setter Property="CornerRadius" Value="10" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="{Binding NavigationRailHeaderGapWidth}" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Width="30"
                                        Height="30"
                                        Command="{Binding ToggleNavigationRailCommand}"
                                        Content="{Binding NavigationRailToggleGlyph}"
                                        Style="{StaticResource WorkbenchIconButtonStyle}"
                                        ToolTip="{Binding NavigationRailToggleToolTip}" />
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Text="&#x5DE5;&#x4F5C;&#x53F0;&#x5BFC;&#x822A;"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SectionTitleTextStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsNavigationRailCollapsed}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <TextBlock Grid.Row="1"
                                       Margin="0,5,0,0"
                                       Text="按任务切换页面：先做单站测试，再做数据安全、批量评测、对话实测、应用接入与网络复核。">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNavigationRailCollapsed}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ListBox Grid.Row="2"
                                     Margin="0,8,0,0"
                                     ItemContainerStyle="{StaticResource NavigationListBoxItemStyle}"
                                     ItemsSource="{Binding WorkbenchPageOptions}"
                                     SelectedValuePath="Key"
                                     SelectedValue="{Binding SelectedWorkbenchPageKey, Mode=TwoWay}">
                                <ListBox.Style>
                                    <Style TargetType="ListBox" BasedOn="{StaticResource NavigationListBoxStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNavigationRailCollapsed}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ToolTip="{Binding DisplayName}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Width="18"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14.5"
                                                       TextAlignment="Center"
                                                       Text="{Binding IconGlyph}" />
                                            <TextBlock Grid.Column="2"
                                                       VerticalAlignment="Center"
                                                       FontSize="11.2"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding DisplayName}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.IsNavigationRailCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <ListBox Grid.Row="2"
                                     Margin="0,8,0,0"
                                     HorizontalContentAlignment="Center"
                                     ItemContainerStyle="{StaticResource NavigationCollapsedListBoxItemStyle}"
                                     ItemsSource="{Binding WorkbenchPageOptions}"
                                     SelectedValuePath="Key"
                                     SelectedValue="{Binding SelectedWorkbenchPageKey, Mode=TwoWay}">
                                <ListBox.Style>
                                    <Style TargetType="ListBox" BasedOn="{StaticResource NavigationCollapsedListBoxStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNavigationRailCollapsed}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Width="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14.5"
                                                   TextAlignment="Center"
                                                   ToolTip="{Binding DisplayName}"
                                                   Text="{Binding IconGlyph}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Grid.Row="3"
                                    Margin="0,10,0,0">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource NavigationAboutBorderStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNavigationRailCollapsed}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="关于">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource FieldLabelTextStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsNavigationRailCollapsed}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Margin="0,4,0,0"
                                            Command="{Binding OpenAboutDialogCommand}"
                                            Style="{StaticResource NavigationAboutLinkButtonStyle}"
                                            ToolTip="查看项目信息">
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="15"
                                                     Height="15"
                                                     Margin="0,0,6,0">
                                                <Canvas Width="16" Height="16">
                                                    <Path Fill="#111827"
                                                          Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.65 7.65 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock VerticalAlignment="Center"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="10.2"
                                                       FontWeight="SemiBold"
                                                       Text="查看项目信息">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsNavigationRailCollapsed}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource CommandBarBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Margin="0,0,12,0"
                                            ClipToBounds="True">
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                               Text="{Binding CurrentPageTitle}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,2,0,0"
                                               Style="{StaticResource SectionHintTextStyle}"
                                               Text="{Binding CurrentPageSubtitle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            MaxWidth="320"
                                            HorizontalAlignment="Right">
                                    <TextBlock HorizontalAlignment="Right"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="{Binding StatusMessage, Mode=OneWay}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,2,0,0"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource AccentBrush}"
                                               Text="{Binding LastRunAt, StringFormat=上次运行：{0}}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid x:Name="WorkbenchPageHost"
                              Grid.Row="1"
                              Margin="0,6,0,0">
                            <pages:SingleStationPage Visibility="{Binding IsInterfaceDiagnosticsPageActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <pages:ModelChatPage Visibility="{Binding IsModelChatPageActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <pages:AdvancedTestLabPage Visibility="{Binding IsAdvancedTestLabPageActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <pages:BatchComparisonPage Visibility="{Binding IsBatchEvaluationPageActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <pages:TransparentProxyPage Visibility="{Binding IsTransparentProxyPageActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <pages:ApplicationCenterPage Visibility="{Binding IsApplicationCenterPageActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <pages:NetworkReviewPage Visibility="{Binding IsNetworkReviewPageActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <pages:HistoryReportsPage Visibility="{Binding IsHistoryReportsPageActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Grid>
                </Grid>

        <Grid x:Name="ProxyChartOverlay"
              Panel.ZIndex="20"
              Background="#660F172A"
              Visibility="Collapsed">
            <Border x:Name="ProxyChartOverlayPanel"
                    Style="{StaticResource DashboardOverlayPanelStyle}"
                    Margin="14"
                    Padding="10"
                    Background="{StaticResource PanelBrushStrong}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1.5"
                    CornerRadius="12"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleTextStyle}"
                                       Text="{Binding ProxyChartDialogTitle, Mode=OneWay}" />
                            <WrapPanel Margin="0,4,0,0">
                                <Border Style="{StaticResource DialogTagBorderStyle}">
                                    <TextBlock Style="{StaticResource DialogTagTextStyle}"
                                               Text="图表总览" />
                                </Border>
                                <Border Style="{StaticResource DialogAccentTagBorderStyle}">
                                    <TextBlock Style="{StaticResource DialogTagTextStyle}"
                                               Foreground="{StaticResource AccentBrush}"
                                               Text="双击切图" />
                                </Border>
                            </WrapPanel>
                            <Expander Margin="0,2,0,0"
                                      IsExpanded="False">
                                <Expander.Style>
                                    <Style TargetType="Expander">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsProxyChartImageOnlyMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Expander.Style>
                                <Expander.Header>
                                    <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                               Text="说明" />
                                </Expander.Header>
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource SectionHintTextStyle}"
                                           Text="{Binding ProxyChartDialogIntro, Mode=OneWay}" />
                            </Expander>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button MinWidth="120"
                                    Margin="12,0,0,0"
                                    Command="{Binding ToggleProxyChartImageOnlyModeCommand}"
                                    Content="{Binding ProxyChartImageOnlyModeButtonText, Mode=OneWay}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanToggleProxyChartImageOnlyMode}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button MinWidth="112"
                                    Margin="12,0,0,0"
                                    Command="{Binding RetryProxyChartCommand}"
                                    Content="{Binding ProxyChartRetryButtonText, Mode=OneWay}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasProxyChartRetryAction}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button MinWidth="112"
                                    Margin="12,0,0,0"
                                    Command="{Binding StopCurrentProxyTestCommand}"
                                    IsEnabled="{Binding CanStopCurrentProxyTest, Mode=OneWay}"
                                    Content="停止测试" />
                            <Button MinWidth="96"
                                    Margin="12,0,0,0"
                                    Command="{Binding CloseProxyTrendChartCommand}"
                                    Content="关闭" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource DialogSectionBorderStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProxyChartImageOnlyMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="检测明细" />
                                <Button Grid.Column="1"
                                        MinWidth="128"
                                        Margin="12,0,0,0"
                                        Command="{Binding ToggleProxyChartViewCommand}"
                                        Content="{Binding ProxyChartToggleButtonText, Mode=OneWay}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanToggleProxyChartView}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                            <TextBox Grid.Row="1"
                                      Margin="0,4,0,0"
                                      MinHeight="92"
                                      MaxHeight="118"
                                     Style="{StaticResource ReadOnlyConsoleTextBoxStyle}"
                                     Text="{Binding ProxyChartDialogCapabilityDetail, Mode=OneWay}" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="4"
                          Margin="0"
                          Background="Transparent"
                          ClipToBounds="True">
                        <Grid.InputBindings>
                            <MouseBinding Gesture="LeftDoubleClick"
                                          Command="{Binding ToggleProxyChartImageOnlyModeCommand}" />
                        </Grid.InputBindings>
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   Text="{Binding ProxyChartDialogEmptyStateText, Mode=OneWay}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasProxyChartDialogImage}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ScrollViewer Style="{StaticResource WorkbenchScrollViewerStyle}"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      CanContentScroll="False"
                                      Visibility="{Binding IsNativeSingleCapabilityChartVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl Margin="0,0,0,4"
                                          ItemsSource="{Binding ProxyChartDialogSingleCapabilityRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="NativeChartRow"
                                                Margin="0,0,0,5"
                                                Padding="10,7"
                                                Background="{StaticResource PanelBrushStrong}"
                                                BorderBrush="{StaticResource PanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                ClipToBounds="False">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2.15*" />
                                                    <ColumnDefinition Width="0.7*" />
                                                    <ColumnDefinition Width="0.55*" />
                                                    <ColumnDefinition Width="1.55*" />
                                                    <ColumnDefinition Width="2.85*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border x:Name="RunningPulse"
                                                        Grid.ColumnSpan="6"
                                                        Margin="-6,-4,-6,-4"
                                                        Background="#EAF5FF"
                                                        BorderBrush="#93C5FD"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        IsHitTestVisible="False"
                                                        Opacity="0"
                                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Border.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.18"
                                                                                     To="0.46"
                                                                                     Duration="0:0:0.78" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Border.Triggers>
                                                </Border>

                                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                    <TextBlock FontSize="12.2"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Text="{Binding Name}" />
                                                    <TextBlock Margin="0,3,0,0"
                                                               FontSize="10.4"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Text="{Binding DetailText}" />
                                                </StackPanel>
                                                <Border x:Name="StatusBadge"
                                                        Grid.Column="1"
                                                        Margin="0,1,10,0"
                                                        Padding="8,2"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Background="#F1F5F9"
                                                        BorderBrush="#CBD5E1"
                                                        BorderThickness="1"
                                                        CornerRadius="999">
                                                    <TextBlock x:Name="StatusBadgeText"
                                                               FontSize="10.3"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               Text="{Binding StatusText}" />
                                                </Border>
                                                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                                    <TextBlock FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextBrush}"
                                                               Text="{Binding StatusCodeText}" />
                                                    <TextBlock Margin="0,3,0,0"
                                                               FontSize="10"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               Text="{Binding ReceivedDoneText}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="3" Margin="0,0,14,0">
                                                    <DockPanel LastChildFill="True">
                                                        <TextBlock DockPanel.Dock="Left"
                                                                   FontSize="10.8"
                                                                   Foreground="{StaticResource MutedBrush}"
                                                                   Text="综合" />
                                                        <StackPanel HorizontalAlignment="Right"
                                                                    Orientation="Horizontal">
                                                            <TextBlock FontSize="12.4"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Text="{Binding MetricText}" />
                                                            <TextBlock Margin="4,0,0,0"
                                                                       FontSize="12.4"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextBrush}"
                                                                       Text="实时中"
                                                                       Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                        </StackPanel>
                                                    </DockPanel>
                                                    <ProgressBar Margin="0,4,0,0"
                                                                 Tag="{Binding IsRunning}"
                                                                 Height="12"
                                                                 Minimum="0"
                                                                 Maximum="1"
                                                                 Value="{Binding MetricRatio, Mode=OneWay}"
                                                                 Background="#E5EDF7"
                                                                 BorderThickness="0">
                                                        <ProgressBar.Template>
                                                            <ControlTemplate TargetType="ProgressBar">
                                                                <Grid x:Name="PART_Track" Height="12" ClipToBounds="False">
                                                                    <Border Height="4" VerticalAlignment="Bottom" Background="#DCEAF4" CornerRadius="999" />
                                                                    <Grid x:Name="PART_Indicator" Height="12" MinWidth="12" HorizontalAlignment="Left" VerticalAlignment="Bottom" ClipToBounds="False" RenderTransformOrigin="0,0.5">
                                                                        <Grid.RenderTransform>
                                                                            <ScaleTransform x:Name="MetricGrowScale" ScaleX="1" ScaleY="1" />
                                                                        </Grid.RenderTransform>
                                                                        <Grid Height="4" MinWidth="12" VerticalAlignment="Bottom" ClipToBounds="True">
                                                                            <Border CornerRadius="999">
                                                                                <Border.Background>
                                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                                        <GradientStop Color="#22C55E" Offset="0" />
                                                                                        <GradientStop Color="#10B981" Offset="0.62" />
                                                                                        <GradientStop Color="#06B6D4" Offset="1" />
                                                                                    </LinearGradientBrush>
                                                                                </Border.Background>
                                                                            </Border>
                                                                            <Rectangle x:Name="MetricStripeLayer" Opacity="0.18">
                                                                                <Rectangle.RenderTransform>
                                                                                    <TranslateTransform x:Name="MetricStripeShift" X="-22" />
                                                                                </Rectangle.RenderTransform>
                                                                                <Rectangle.Fill>
                                                                                    <DrawingBrush TileMode="Tile" Viewport="0,0,22,4" ViewportUnits="Absolute" Stretch="None">
                                                                                        <DrawingBrush.Drawing>
                                                                                            <GeometryDrawing Brush="#F8FDFF">
                                                                                                <GeometryDrawing.Geometry>
                                                                                                    <GeometryGroup>
                                                                                                        <RectangleGeometry Rect="-6,0,7,8"><RectangleGeometry.Transform><SkewTransform AngleX="-28" /></RectangleGeometry.Transform></RectangleGeometry>
                                                                                                        <RectangleGeometry Rect="11,0,7,8"><RectangleGeometry.Transform><SkewTransform AngleX="-28" /></RectangleGeometry.Transform></RectangleGeometry>
                                                                                                    </GeometryGroup>
                                                                                                </GeometryDrawing.Geometry>
                                                                                            </GeometryDrawing>
                                                                                        </DrawingBrush.Drawing>
                                                                                    </DrawingBrush>
                                                                                </Rectangle.Fill>
                                                                            </Rectangle>
                                                                            <Border BorderBrush="#22C55E" BorderThickness="0" CornerRadius="999" />
                                                                        </Grid>
                                                                    </Grid>
                                                                </Grid>
                                                                <ControlTemplate.Triggers>

                                                                    <DataTrigger Binding="{Binding ShouldAnimateMetricReveal}" Value="True">
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation Storyboard.TargetName="MetricGrowScale"
                                                                                                     Storyboard.TargetProperty="ScaleX"
                                                                                                     From="0"
                                                                                                     To="1"
                                                                                                     Duration="0:0:0.95">
                                                                                        <DoubleAnimation.EasingFunction>
                                                                                            <CubicEase EasingMode="EaseOut" />
                                                                                        </DoubleAnimation.EasingFunction>
                                                                                    </DoubleAnimation>
                                                                                    <DoubleAnimation Storyboard.TargetName="MetricStripeShift"
                                                                                                     Storyboard.TargetProperty="X"
                                                                                                     From="-44"
                                                                                                     To="0"
                                                                                                     Duration="0:0:0.95" />
                                                                                    <DoubleAnimation Storyboard.TargetName="MetricStripeLayer"
                                                                                                     Storyboard.TargetProperty="Opacity"
                                                                                                     From="0.5"
                                                                                                     To="0.18"
                                                                                                     Duration="0:0:0.95" />
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                    </DataTrigger>                                                                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                                        <Setter TargetName="MetricStripeLayer" Property="Opacity" Value="0.32" />
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard x:Name="MetricActiveStoryboard">
                                                                                <Storyboard RepeatBehavior="Forever">
                                                                                    <DoubleAnimation Storyboard.TargetName="MetricStripeShift" Storyboard.TargetProperty="X" From="-22" To="0" Duration="0:0:0.74" />
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                        <DataTrigger.ExitActions>
                                                                            <StopStoryboard BeginStoryboardName="MetricActiveStoryboard" />
                                                                        </DataTrigger.ExitActions>
                                                                    </DataTrigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </ProgressBar.Template>
                                                    </ProgressBar>
                                                </StackPanel>
                                                <TextBlock Grid.Column="4"
                                                           FontSize="11.2"
                                                           Foreground="{StaticResource TextBrush}"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxHeight="48"
                                                           Text="{Binding PreviewText}" />
                                                <Button Grid.Column="5"
                                                        Width="48"
                                                        MinWidth="48"
                                                        Height="28"
                                                        Margin="10,0,0,0"
                                                        Padding="0"
                                                        VerticalAlignment="Center"
                                                        Background="#F8FBFF"
                                                        BorderBrush="#BFD7FF"
                                                        Foreground="{StaticResource AccentBrush}"
                                                        FontSize="11"
                                                        Command="{Binding DataContext.OpenProbeTraceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Content="详情"
                                                        ToolTip="查看输入输出与判定证据"
                                                        Visibility="{Binding HasTrace, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding StatusTone}" Value="Success">
                                                <Setter TargetName="StatusBadge" Property="Background" Value="#ECFDF3" />
                                                <Setter TargetName="StatusBadge" Property="BorderBrush" Value="#A6F4C5" />
                                                <Setter TargetName="StatusBadgeText" Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusTone}" Value="Running">
                                                <Setter TargetName="NativeChartRow" Property="Background" Value="#F8FBFF" />
                                                <Setter TargetName="NativeChartRow" Property="BorderBrush" Value="#93C5FD" />
                                                <Setter TargetName="StatusBadge" Property="Background" Value="#EFF6FF" />
                                                <Setter TargetName="StatusBadge" Property="BorderBrush" Value="#BFDBFE" />
                                                <Setter TargetName="StatusBadgeText" Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusTone}" Value="Error">
                                                <Setter TargetName="StatusBadge" Property="Background" Value="#FEF2F2" />
                                                <Setter TargetName="StatusBadge" Property="BorderBrush" Value="#FECACA" />
                                                <Setter TargetName="StatusBadgeText" Property="Foreground" Value="#DC2626" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <ScrollViewer Style="{StaticResource WorkbenchScrollViewerStyle}"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      CanContentScroll="False"
                                      Visibility="{Binding IsNativeStabilityTrendChartVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl Margin="0,0,0,4"
                                          ItemsSource="{Binding ProxyChartDialogStabilityTrendRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="StabilityTrendRow"
                                                Margin="0,0,0,8"
                                                Padding="12,9"
                                                Background="{StaticResource PanelBrushStrong}"
                                                BorderBrush="{StaticResource PanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="15">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <DockPanel LastChildFill="True">
                                                    <StackPanel DockPanel.Dock="Left"
                                                                Orientation="Horizontal">
                                                        <TextBlock FontSize="13.2"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   Text="{Binding Title}" />
                                                        <Border x:Name="StabilityStatusBadge"
                                                                Margin="8,0,0,0"
                                                                Padding="7,2"
                                                                Background="#EFF6FF"
                                                                BorderBrush="#BFDBFE"
                                                                BorderThickness="1"
                                                                CornerRadius="999">
                                                            <TextBlock x:Name="StabilityStatusText"
                                                                       FontSize="10.5"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource AccentBrush}"
                                                                       Text="{Binding StatusText}" />
                                                        </Border>
                                                    </StackPanel>
                                                    <StackPanel HorizontalAlignment="Right"
                                                                Orientation="Horizontal">
                                                        <TextBlock FontSize="13.2"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   Text="{Binding ValueText}" />
                                                        <TextBlock Margin="5,0,0,0"
                                                                   FontSize="13.2"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   Text="{Binding RunningText}" />
                                                    </StackPanel>
                                                </DockPanel>

                                                <Border Grid.Row="1"
                                                        Margin="0,6,0,0"
                                                        Height="64"
                                                        Background="#F8FBFF"
                                                        BorderBrush="#E4EAF2"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        ClipToBounds="True">
                                                    <Grid Margin="10,2">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <Border Grid.Row="0" Height="1" VerticalAlignment="Center" Background="#E4EAF2" />
                                                        <Border Grid.Row="1" Height="1" VerticalAlignment="Center" Background="#E4EAF2" />
                                                        <Border Grid.Row="2" Height="1" VerticalAlignment="Center" Background="#E4EAF2" />
                                                        <Viewbox Stretch="Fill"
                                                                 StretchDirection="Both"
                                                                 HorizontalAlignment="Stretch"
                                                                 VerticalAlignment="Center">
                                                        <Canvas Width="520" Height="46">
                                                                <Polyline Points="{Binding SparklinePoints}"
                                                                          Stroke="{Binding StrokeBrush}"
                                                                          StrokeThickness="2.2"
                                                                          StrokeLineJoin="Round"
                                                                          StrokeStartLineCap="Round"
                                                                          StrokeEndLineCap="Round" />
                                                                <Polyline Points="{Binding SparklinePoints}"
                                                                          Stroke="{Binding StrokeBrush}"
                                                                          StrokeThickness="5"
                                                                          Opacity="0.14"
                                                                          StrokeLineJoin="Round"
                                                                          StrokeStartLineCap="Round"
                                                                          StrokeEndLineCap="Round" />
                                                                <ItemsControl ItemsSource="{Binding SparklineMarkers}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <Canvas />
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemContainerStyle>
                                                                        <Style TargetType="ContentPresenter">
                                                                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                                        </Style>
                                                                    </ItemsControl.ItemContainerStyle>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Ellipse x:Name="SparklineMarker"
                                                                                     Width="7"
                                                                                     Height="7"
                                                                                     Margin="-3.5,-3.5,0,0"
                                                                                     Fill="#2563EB"
                                                                                     Stroke="White"
                                                                                     StrokeThickness="1.3" />
                                                                            <DataTemplate.Triggers>
                                                                                <DataTrigger Binding="{Binding IsLatest}" Value="True">
                                                                                    <Setter TargetName="SparklineMarker" Property="Width" Value="9" />
                                                                                    <Setter TargetName="SparklineMarker" Property="Height" Value="9" />
                                                                                    <Setter TargetName="SparklineMarker" Property="Margin" Value="-4.5,-4.5,0,0" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsAbnormal}" Value="True">
                                                                                    <Setter TargetName="SparklineMarker" Property="Fill" Value="#EF4444" />
                                                                                </DataTrigger>
                                                                            </DataTemplate.Triggers>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Canvas>
                                                        </Viewbox>
                                                    </Grid>
                                                </Border>

                                                <DockPanel Grid.Row="2"
                                                           Margin="0,4,0,0"
                                                           LastChildFill="True">
                                                    <TextBlock DockPanel.Dock="Left"
                                                               FontSize="11"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               Text="{Binding HintText}" />
                                                    <TextBlock HorizontalAlignment="Right"
                                                               FontSize="11"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               Text="{Binding ValueSummaryText}" />
                                                </DockPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <ScrollViewer Style="{StaticResource WorkbenchScrollViewerStyle}"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      CanContentScroll="False"
                                      Visibility="{Binding IsNativeBatchComparisonChartVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl Margin="0,0,0,4"
                                          ItemsSource="{Binding ProxyChartDialogBatchComparisonRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="BatchChartRow"
                                                Margin="0,0,0,6"
                                                Padding="12,9"
                                                Background="{StaticResource PanelBrushStrong}"
                                                BorderBrush="{StaticResource PanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="15"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                                    <TranslateTransform Y="0" />
                                                </TransformGroup>
                                            </Border.RenderTransform>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="2.15*" />
                                                    <ColumnDefinition Width="1.1*" />
                                                    <ColumnDefinition Width="3.55*" />
                                                    <ColumnDefinition Width="2.05*" />
                                                </Grid.ColumnDefinitions>

                                                <Border x:Name="BatchRunningPulse"
                                                        Grid.ColumnSpan="5"
                                                        Margin="-7,-5,-7,-5"
                                                        Background="#EAF5FF"
                                                        BorderBrush="#93C5FD"
                                                        BorderThickness="1"
                                                        CornerRadius="15"
                                                        IsHitTestVisible="False"
                                                        Opacity="0"
                                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Border.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.14"
                                                                                     To="0.38"
                                                                                     Duration="0:0:0.9" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Border.Triggers>
                                                </Border>

                                                <Border x:Name="BatchRankBadge"
                                                        Grid.Column="0"
                                                        Width="48"
                                                        Height="28"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Background="#F2F4F7"
                                                        BorderBrush="#D0D5DD"
                                                        BorderThickness="1"
                                                        CornerRadius="14">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextBrush}"
                                                               Text="{Binding RankText}" />
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            Margin="0,0,14,0"
                                                            VerticalAlignment="Center">
                                                    <TextBlock FontSize="13.5"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Text="{Binding Name}" />
                                                    <TextBlock Margin="0,3,0,0"
                                                               FontSize="11"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Text="{Binding BaseUrl}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2"
                                                            Margin="0,0,14,0"
                                                            VerticalAlignment="Center">
                                                    <Border x:Name="BatchStatusBadge"
                                                            HorizontalAlignment="Left"
                                                            Padding="9,4"
                                                            Background="#F8FAFC"
                                                            BorderBrush="#D0D5DD"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                        <TextBlock x:Name="BatchStatusBadgeText"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource MutedBrush}"
                                                                   Text="{Binding StatusText}" />
                                                    </Border>
                                                    <TextBlock Margin="2,5,0,0"
                                                               FontSize="10.8"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               Text="{Binding RunCountText}" />
                                                </StackPanel>

                                                <Grid Grid.Column="3"
                                                      Margin="0,0,22,0"
                                                      VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.08*" />
                                                        <ColumnDefinition Width="1.12*" />
                                                        <ColumnDefinition Width="1.08*" />
                                                        <ColumnDefinition Width="1.18*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Grid.Column="0" Margin="0,0,18,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="6" />
                                                        </Grid.RowDefinitions>
                                                        <DockPanel LastChildFill="True">
                                                            <TextBlock DockPanel.Dock="Left" FontSize="10.2" Foreground="{StaticResource MutedBrush}" Text="综合" />
                                                            <TextBlock FontSize="12.2" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextAlignment="Right" Text="{Binding CompositeText}" />
                                                        </DockPanel>
                                                        <ProgressBar Grid.Row="1" Height="6" Margin="0,3,0,0" Minimum="0" Maximum="1" Value="{Binding CompositeRatio, Mode=OneWay}" />
                                                    </Grid>

                                                    <Grid Grid.Column="1" Margin="0,0,18,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="6" />
                                                        </Grid.RowDefinitions>
                                                        <DockPanel LastChildFill="True">
                                                            <TextBlock DockPanel.Dock="Left" FontSize="10.2" Foreground="{StaticResource MutedBrush}" Text="对话" />
                                                            <TextBlock FontSize="12.2" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextAlignment="Right" Text="{Binding ChatLatencyText}" />
                                                        </DockPanel>
                                                        <ProgressBar Grid.Row="1" Height="6" Margin="0,3,0,0" Minimum="0" Maximum="1" Value="{Binding ChatLatencyRatio, Mode=OneWay}" />
                                                    </Grid>

                                                    <Grid Grid.Column="2" Margin="0,0,18,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="6" />
                                                        </Grid.RowDefinitions>
                                                        <DockPanel LastChildFill="True">
                                                            <TextBlock DockPanel.Dock="Left" FontSize="10.2" Foreground="{StaticResource MutedBrush}" Text="TTFT" />
                                                            <TextBlock FontSize="12.2" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextAlignment="Right" Text="{Binding TtftText}" />
                                                        </DockPanel>
                                                        <ProgressBar Grid.Row="1" Height="6" Margin="0,3,0,0" Minimum="0" Maximum="1" Value="{Binding TtftRatio, Mode=OneWay}" />
                                                    </Grid>

                                                    <Grid Grid.Column="3">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="6" />
                                                        </Grid.RowDefinitions>
                                                        <DockPanel LastChildFill="True">
                                                            <TextBlock DockPanel.Dock="Left" FontSize="10.2" Foreground="{StaticResource MutedBrush}" Text="吞吐" />
                                                            <TextBlock FontSize="12.2" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextAlignment="Right" Text="{Binding TokensPerSecondText}" />
                                                        </DockPanel>
                                                        <ProgressBar Grid.Row="1" Height="6" Margin="0,3,0,0" Minimum="0" Maximum="1" Value="{Binding TokensPerSecondRatio, Mode=OneWay}" />
                                                    </Grid>
                                                </Grid>

                                                <UniformGrid Grid.Column="3"
                                                             Visibility="Collapsed"
                                                             Columns="4"
                                                             Margin="0,0,16,0"
                                                             VerticalAlignment="Center">
                                                    <StackPanel Margin="0,0,8,0">
                                                        <TextBlock FontSize="10.2" Foreground="{StaticResource MutedBrush}" Text="综合" />
                                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="{Binding CompositeText}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,8,0">
                                                        <TextBlock FontSize="10.2" Foreground="{StaticResource MutedBrush}" Text="对话" />
                                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="{Binding ChatLatencyText}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,8,0">
                                                        <TextBlock FontSize="10.2" Foreground="{StaticResource MutedBrush}" Text="TTFT" />
                                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="{Binding TtftText}" />
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock FontSize="10.2" Foreground="{StaticResource MutedBrush}" Text="吞吐" />
                                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="{Binding TokensPerSecondText}" />
                                                    </StackPanel>
                                                </UniformGrid>

                                                <StackPanel Grid.Column="4"
                                                            VerticalAlignment="Center">
                                                    <TextBlock FontSize="12.4"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextBrush}"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxHeight="36"
                                                               Text="{Binding Verdict}" />
                                                    <TextBlock Margin="0,3,0,0"
                                                               FontSize="10.8"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxHeight="34"
                                                               Text="{Binding SecondaryText}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding ShouldAnimateReveal}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="BatchChartRow"
                                                                             Storyboard.TargetProperty="Opacity"
                                                                             From="0.58"
                                                                             To="1"
                                                                             Duration="0:0:0.32" />
                                                            <DoubleAnimation Storyboard.TargetName="BatchChartRow"
                                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                                             From="8"
                                                                             To="0"
                                                                             Duration="0:0:0.32">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <ColorAnimation Storyboard.TargetName="BatchChartRow"
                                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                                            To="#60A5FA"
                                                                            Duration="0:0:0.18"
                                                                            AutoReverse="True" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusTone}" Value="Success">
                                                <Setter TargetName="BatchRankBadge" Property="Background" Value="#ECFDF3" />
                                                <Setter TargetName="BatchRankBadge" Property="BorderBrush" Value="#A6F4C5" />
                                                <Setter TargetName="BatchStatusBadge" Property="Background" Value="#ECFDF3" />
                                                <Setter TargetName="BatchStatusBadge" Property="BorderBrush" Value="#A6F4C5" />
                                                <Setter TargetName="BatchStatusBadgeText" Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusTone}" Value="Running">
                                                <Setter TargetName="BatchChartRow" Property="Background" Value="#F8FBFF" />
                                                <Setter TargetName="BatchChartRow" Property="BorderBrush" Value="#93C5FD" />
                                                <Setter TargetName="BatchStatusBadge" Property="Background" Value="#EFF6FF" />
                                                <Setter TargetName="BatchStatusBadge" Property="BorderBrush" Value="#BFDBFE" />
                                                <Setter TargetName="BatchStatusBadgeText" Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusTone}" Value="Warn">
                                                <Setter TargetName="BatchStatusBadge" Property="Background" Value="#FFFAEB" />
                                                <Setter TargetName="BatchStatusBadge" Property="BorderBrush" Value="#FEDF89" />
                                                <Setter TargetName="BatchStatusBadgeText" Property="Foreground" Value="#B54708" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusTone}" Value="Error">
                                                <Setter TargetName="BatchStatusBadge" Property="Background" Value="#FEF2F2" />
                                                <Setter TargetName="BatchStatusBadge" Property="BorderBrush" Value="#FECACA" />
                                                <Setter TargetName="BatchStatusBadgeText" Property="Foreground" Value="#DC2626" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <ScrollViewer Style="{StaticResource WorkbenchScrollViewerStyle}"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      CanContentScroll="False"
                                      Visibility="{Binding IsNativeConcurrencyChartVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl Margin="0,0,0,4"
                                          ItemsSource="{Binding ProxyChartDialogConcurrencyRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="ConcurrencyChartRow"
                                                Margin="0,0,0,8"
                                                Padding="12,10"
                                                Background="{StaticResource PanelBrushStrong}"
                                                BorderBrush="{StaticResource PanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="15"
                                                Opacity="0"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <TranslateTransform Y="8" />
                                            </Border.RenderTransform>
                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.22" />
                                                            <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.26">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Border.Triggers>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="88" />
                                                    <ColumnDefinition Width="1.45*" />
                                                    <ColumnDefinition Width="2.55*" />
                                                    <ColumnDefinition Width="2.1*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="{Binding ConcurrencyText}" />
                                                    <TextBlock Margin="0,2,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding SuccessText}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="0,0,12,0" VerticalAlignment="Center">
                                                    <Border x:Name="ConcurrencyStatusBadge" HorizontalAlignment="Left" Padding="9,4" Background="#ECFDF3" BorderBrush="#A6F4C5" BorderThickness="1" CornerRadius="999">
                                                        <TextBlock x:Name="ConcurrencyStatusBadgeText" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" Text="{Binding Verdict}" />
                                                    </Border>
                                                    <WrapPanel Margin="0,7,0,0">
                                                        <Border Margin="0,0,5,4" Padding="6,2" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="999" Visibility="{Binding IsStableLimit, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBlock FontSize="10.5" Foreground="{StaticResource AccentBrush}" Text="稳定上限" />
                                                        </Border>
                                                        <Border Margin="0,0,5,4" Padding="6,2" Background="#FFFAEB" BorderBrush="#FEDF89" BorderThickness="1" CornerRadius="999" Visibility="{Binding IsRateLimitStart, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBlock FontSize="10.5" Foreground="#B54708" Text="限流起点" />
                                                        </Border>
                                                        <Border Margin="0,0,5,4" Padding="6,2" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="999" Visibility="{Binding IsHighRisk, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBlock FontSize="10.5" Foreground="#DC2626" Text="高风险" />
                                                        </Border>
                                                    </WrapPanel>
                                                </StackPanel>
                                                <Grid Grid.Column="2" Margin="0,0,14,0" VerticalAlignment="Center">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /><ColumnDefinition Width="72" /></Grid.ColumnDefinitions>
                                                        <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="成功率" />
                                                        <ProgressBar Grid.Column="1" Height="6" Maximum="1" Value="{Binding SuccessRatio, Mode=OneWay}" Foreground="{StaticResource SuccessBrush}" Background="{StaticResource InputBrush}" BorderThickness="0" />
                                                        <TextBlock Grid.Column="2" HorizontalAlignment="Right" FontSize="11" Foreground="{StaticResource TextBrush}" Text="{Binding SuccessRateText}" />
                                                    </Grid>
                                                    <Grid Grid.Row="1" Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /><ColumnDefinition Width="72" /></Grid.ColumnDefinitions>
                                                        <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="p50 延迟" />
                                                        <ProgressBar Grid.Column="1" Height="6" Maximum="1" Value="{Binding P50ChatLatencyRatio, Mode=OneWay}" Foreground="{StaticResource AccentBrush}" Background="{StaticResource InputBrush}" BorderThickness="0" />
                                                        <TextBlock Grid.Column="2" HorizontalAlignment="Right" FontSize="11" Foreground="{StaticResource TextBrush}" Text="{Binding P50ChatLatencyText}" />
                                                    </Grid>
                                                    <Grid Grid.Row="2" Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /><ColumnDefinition Width="72" /></Grid.ColumnDefinitions>
                                                        <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="p95 TTFT" />
                                                        <ProgressBar Grid.Column="1" Height="6" Maximum="1" Value="{Binding P95TtftRatio, Mode=OneWay}" Foreground="#F59E0B" Background="{StaticResource InputBrush}" BorderThickness="0" />
                                                        <TextBlock Grid.Column="2" HorizontalAlignment="Right" FontSize="11" Foreground="{StaticResource TextBrush}" Text="{Binding P95TtftText}" />
                                                    </Grid>
                                                    <Grid Grid.Row="3">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /><ColumnDefinition Width="72" /></Grid.ColumnDefinitions>
                                                        <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="吞吐" />
                                                        <ProgressBar Grid.Column="1" Height="6" Maximum="1" Value="{Binding TokensPerSecondRatio, Mode=OneWay}" Foreground="#0EA5E9" Background="{StaticResource InputBrush}" BorderThickness="0" />
                                                        <TextBlock Grid.Column="2" HorizontalAlignment="Right" FontSize="11" Foreground="{StaticResource TextBrush}" Text="{Binding TokensPerSecondText}" />
                                                    </Grid>
                                                </Grid>
                                                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                    <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding FailureText}" />
                                                    <TextBlock Margin="0,5,0,0" FontSize="11.5" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="42" Text="{Binding Summary}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding StatusTone}" Value="Running">
                                                <Setter TargetName="ConcurrencyChartRow" Property="Background" Value="#F8FBFF" />
                                                <Setter TargetName="ConcurrencyChartRow" Property="BorderBrush" Value="#BFDBFE" />
                                                <Setter TargetName="ConcurrencyStatusBadge" Property="Background" Value="#EFF6FF" />
                                                <Setter TargetName="ConcurrencyStatusBadge" Property="BorderBrush" Value="#BFDBFE" />
                                                <Setter TargetName="ConcurrencyStatusBadgeText" Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusTone}" Value="Warn">
                                                <Setter TargetName="ConcurrencyChartRow" Property="BorderBrush" Value="#FEDF89" />
                                                <Setter TargetName="ConcurrencyStatusBadge" Property="Background" Value="#FFFAEB" />
                                                <Setter TargetName="ConcurrencyStatusBadge" Property="BorderBrush" Value="#FEDF89" />
                                                <Setter TargetName="ConcurrencyStatusBadgeText" Property="Foreground" Value="#B54708" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusTone}" Value="Error">
                                                <Setter TargetName="ConcurrencyChartRow" Property="BorderBrush" Value="#FECACA" />
                                                <Setter TargetName="ConcurrencyStatusBadge" Property="Background" Value="#FEF2F2" />
                                                <Setter TargetName="ConcurrencyStatusBadge" Property="BorderBrush" Value="#FECACA" />
                                                <Setter TargetName="ConcurrencyStatusBadgeText" Property="Foreground" Value="#DC2626" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <ScrollViewer x:Name="ProxyChartImageScrollViewer"
                                      Style="{StaticResource WorkbenchScrollViewerStyle}"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      SizeChanged="ProxyChartImageScrollViewer_OnSizeChanged"
                                      CanContentScroll="False"
                                      Visibility="{Binding IsBitmapProxyChartVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ScrollViewer.InputBindings>
                                <MouseBinding Gesture="LeftDoubleClick"
                                              Command="{Binding ToggleProxyChartImageOnlyModeCommand}" />
                            </ScrollViewer.InputBindings>
                                                        <Grid>
                                <Image x:Name="ProxyChartDialogImageControl"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       MouseMove="ProxyChartDialogImage_OnMouseMove"
                                       MouseLeave="ProxyChartDialogImage_OnMouseLeave"
                                       Stretch="None"
                                       Source="{Binding ProxyChartDialogImage, Mode=OneWay}" />
                                <Canvas x:Name="ProxyChartActivityOverlayCanvas"
                                        Width="{Binding ActualWidth, ElementName=ProxyChartDialogImageControl}"
                                        Height="{Binding ActualHeight, ElementName=ProxyChartDialogImageControl}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        IsHitTestVisible="False" />
                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <Border Grid.Row="5"
                            Margin="0,6,0,0"
                            Padding="8,5"
                            Background="{StaticResource InputBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProxyChartImageOnlyMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding ProxyChartDialogStatusSummary, Mode=OneWay}" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="ProxyModelPickerOverlay"
              Panel.ZIndex="35"
              Background="#660F172A"
              Visibility="Collapsed">
            <Border x:Name="ProxyModelPickerOverlayPanel"
                    Style="{StaticResource DashboardOverlayPanelStyle}"
                    Width="920"
                    MaxHeight="660"
                    Padding="14"
                    Background="{StaticResource PanelBrushStrong}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1.5"
                    CornerRadius="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.ColumnSpan="3">
                        <TextBlock Style="{StaticResource DialogTitleTextStyle}" Text="选择模型" />
                        <WrapPanel Margin="0,6,0,0">
                            <Border Style="{StaticResource DialogTagBorderStyle}">
                                <TextBlock Style="{StaticResource DialogTagTextStyle}" Text="单模型" />
                            </Border>
                            <Border Style="{StaticResource DialogAccentTagBorderStyle}">
                                <TextBlock Style="{StaticResource DialogTagTextStyle}"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="回填当前模型" />
                            </Border>
                        </WrapPanel>
                        <Border Margin="0,6,0,0"
                                Style="{StaticResource DialogMetaStripBorderStyle}">
                            <TextBlock Foreground="{StaticResource AccentBrush}"
                                       Text="{Binding ProxyModelPickerTargetSummary, Mode=OneWay}" />
                        </Border>
                        <Expander Margin="0,6,0,0"
                                  IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Style="{StaticResource SectionHintTextStyle}" Text="说明" />
                            </Expander.Header>
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="{Binding ProxyModelPickerInstruction, Mode=OneWay}" />
                        </Expander>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Grid.Column="0"
                            Style="{StaticResource DialogSectionBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="模型列表" />
                            <TextBox Grid.Row="1"
                                     Margin="0,6,0,6"
                                     Style="{StaticResource CompactInputTextBoxStyle}"
                                     Text="{Binding ProxyModelCatalogFilterText, UpdateSourceTrigger=PropertyChanged}" />
                            <ListBox Grid.Row="2"
                                     Margin="0,8,0,0"
                                     ItemsSource="{Binding VisibleProxyCatalogModels}"
                                     SelectedItem="{Binding SelectedProxyCatalogModel, Mode=TwoWay}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.Column="2"
                            Style="{StaticResource DialogSectionBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="130" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="拉取摘要" />
                            <TextBox Grid.Row="1"
                                     Margin="0,8,0,0"
                                     Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                                     Text="{Binding ProxyModelCatalogSummary, Mode=OneWay}" />
                            <Expander Grid.Row="3"
                                      Margin="0,8,0,0"
                                      IsExpanded="False">
                                <Expander.Header>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                               Text="拉取明细 / 原始返回" />
                                </Expander.Header>
                                <TextBox Margin="0,8,0,0"
                                         Style="{StaticResource ReadOnlyRawLogTextBoxStyle}"
                                         Text="{Binding ProxyModelCatalogDetail, Mode=OneWay}" />
                            </Expander>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Grid.ColumnSpan="3"
                            Margin="0,12,0,0"
                            Style="{StaticResource DialogMetaStripBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="筛选后直接点击模型即可回填。" />
                            <Button Grid.Column="1"
                                    MinWidth="96"
                                    Margin="8,0,0,0"
                                    Command="{Binding CloseProxyModelPickerCommand}"
                                    Content="关闭" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="ProxyMultiModelPickerOverlay"
              Panel.ZIndex="35"
              Background="#660F172A"
              Visibility="Collapsed">
            <Border x:Name="ProxyMultiModelPickerOverlayPanel"
                    Style="{StaticResource DashboardOverlayPanelStyle}"
                    Width="980"
                    MaxHeight="700"
                    Padding="14"
                    Background="{StaticResource PanelBrushStrong}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1.5"
                    CornerRadius="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
