                    </Border>

                    <Border Grid.Row="3"
                            Margin="0,12,0,0"
                            Style="{StaticResource DialogMetaStripBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="只会写入勾选的软件；修改前会自动备份配置。" />
                            <WrapPanel Grid.Column="1"
                                       HorizontalAlignment="Right">
                                <Button MinWidth="88"
                                        Command="{Binding SelectAllClientApplyTargetsCommand}"
                                        Content="全选" />
                                <Button MinWidth="88"
                                        Margin="8,0,0,0"
                                        Command="{Binding InvertClientApplyTargetsCommand}"
                                        Content="反选" />
                                <Button MinWidth="112"
                                        Margin="8,0,0,0"
                                        Command="{Binding ConfirmClientApplyTargetDialogCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Content="应用到所选" />
                                <Button MinWidth="88"
                                        Margin="8,0,0,0"
                                        Command="{Binding CancelClientApplyTargetDialogCommand}"
                                        Content="取消" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="ConfirmationDialogOverlay"
              Panel.ZIndex="40"
              Background="#660F172A"
              Visibility="Collapsed">
            <Border x:Name="ConfirmationDialogOverlayPanel"
                    Style="{StaticResource DashboardOverlayPanelStyle}"
                    Width="620"
                    MaxHeight="520"
                    Padding="14"
                    Background="{StaticResource PanelBrushStrong}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1.5"
                    CornerRadius="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource DialogTitleTextStyle}"
                                   Text="{Binding ConfirmationDialogTitle, Mode=OneWay}" />
                        <Border Margin="0,6,0,0"
                                Style="{StaticResource DialogAccentTagBorderStyle}">
                            <TextBlock Style="{StaticResource DialogTagTextStyle}"
                                       Foreground="{StaticResource AccentBrush}"
                                       Text="请先确认" />
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Style="{StaticResource DialogSectionBorderStyle}">
                        <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="{Binding ConfirmationDialogMessage, Mode=OneWay}" />
                    </Border>

                    <Border Grid.Row="4"
                            Style="{StaticResource DialogSectionBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="说明" />
                            <TextBox Grid.Row="1"
                                     Margin="0,8,0,0"
                                     MinHeight="120"
                                     MaxHeight="220"
                                     Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                                     Text="{Binding ConfirmationDialogDetail, Mode=OneWay}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="5"
                            Margin="0,10,0,0"
                            Style="{StaticResource DialogMetaStripBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="确认后继续。" />
                            <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                <Button MinWidth="104"
                                        Margin="8,0,0,0"
                                        Command="{Binding CancelConfirmationDialogCommand}"
                                        Content="{Binding ConfirmationDialogCancelText, Mode=OneWay}" />
                                <Button MinWidth="128"
                                        Margin="8,0,0,0"
                                        Command="{Binding ConfirmConfirmationDialogCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Content="{Binding ConfirmationDialogConfirmText, Mode=OneWay}" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="ProxyBatchEditorOverlay"
              Panel.ZIndex="30"
              Background="#660F172A"
              Visibility="Collapsed">
            <Border x:Name="ProxyBatchEditorOverlayPanel"
                    Style="{StaticResource DashboardOverlayPanelStyle}"
                    Width="1120"
                    MaxHeight="720"
                    Padding="14"
                    Background="{StaticResource PanelBrushStrong}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1.5"
                    CornerRadius="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.ColumnSpan="3">
                        <TextBlock Style="{StaticResource DialogTitleTextStyle}" Text="入口组维护" />
                        <WrapPanel Margin="0,6,0,0">
                            <Border Style="{StaticResource DialogTagBorderStyle}">
                                <TextBlock Style="{StaticResource DialogTagTextStyle}" Text="按站点" />
                            </Border>
                            <Border Style="{StaticResource DialogAccentTagBorderStyle}">
                                <TextBlock Style="{StaticResource DialogTagTextStyle}"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="批量录入" />
                            </Border>
                        </WrapPanel>
                        <Border Margin="0,6,0,0"
                                Style="{StaticResource DialogMetaStripBorderStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource AccentBrush}"
                                           Text="{Binding ProxyBatchTargetDigestSummary, Mode=OneWay}" />
                                <TextBlock Margin="0,3,0,0"
                                           Foreground="{StaticResource AccentBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding ProxyBatchExecutionPlanSummary, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                        <Expander Margin="0,6,0,0"
                                  IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Style="{StaticResource SectionHintTextStyle}" Text="说明" />
                            </Expander.Header>
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="左侧按站点管理，右侧一次录一个站点。右侧表格里的所有行会作为同一个站点保存；点完“加入入口组”后，会自动清空，只保留第一行空白继续下一个。" />
                        </Expander>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Grid.Column="0"
                            Style="{StaticResource DialogSectionBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="已录入站点" />
                            <TextBlock Grid.Row="1"
                                       Margin="0,6,0,6"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="{Binding ProxyBatchEditorListSummaryDisplay, Mode=OneWay}" />
                            <ListBox Grid.Row="2"
                                     Margin="0,4,0,0"
                                     ItemsSource="{Binding ProxyBatchSiteGroups}"
                                     SelectedItem="{Binding SelectedProxyBatchSiteGroup, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding DisplayTitle}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           Text="{Binding SiteGroupDisplay}" />
                                            </DockPanel>
                                            <TextBlock Margin="0,2,0,0"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding BaseUrl}" />
                                            <TextBlock Margin="0,1,0,0"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding KeyDisplay}" />
                                            <TextBlock Margin="0,1,0,0"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding ModelDisplay}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.Column="2"
                            Style="{StaticResource DialogSectionBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="当前站点录入" />
                            <StackPanel Grid.Row="1" Margin="0,6,0,0">
                                <TextBlock Foreground="{StaticResource AccentBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding ProxyBatchEditorFormModeSummary, Mode=OneWay}" />
                                <TextBlock Margin="0,2,0,0"
                                           Style="{StaticResource SectionHintTextStyle}"
                                           Text="{Binding ProxyBatchEditorSelectionSummary, Mode=OneWay}" />
                            </StackPanel>

                            <Expander Grid.Row="2"
                                      Margin="0,8,0,0"
                                      IsExpanded="False">
                                <Expander.Header>
                                    <TextBlock Style="{StaticResource SectionHintTextStyle}" Text="填写规则" />
                                </Expander.Header>
                                <Border Margin="0,6,0,0"
                                        Padding="10,8"
                                        Background="#F8FAFC"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                               TextWrapping="Wrap"
                                               Text="直接按表格填写“名称 / URL / Key / 模型”即可。可以一行一行录，也可以从剪贴板粘贴 Excel、整表或零散数据；如果只粘贴了 URL 或 key，空白列会自动沿用上一行。站点名留空时，会按第一条有效名称或域名命名。" />
                                </Border>
                            </Expander>

                            <Grid Grid.Row="3"
                                  Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <WrapPanel>
                                    <Button MinWidth="104"
                                            Command="{Binding AddProxyBatchTemplateRowCommand}"
                                            Content="新增一行" />
                                    <Button MinWidth="128"
                                            Margin="8,0,0,0"
                                            Command="{Binding PasteProxyBatchTemplateRowsCommand}"
                                            Content="从剪贴板粘贴" />
                                    <Button MinWidth="120"
                                            Margin="8,0,0,0"
                                            Command="{Binding ClearProxyBatchTemplateEmptyRowsCommand}"
                                            Content="清理空白行" />
                                    <Button MinWidth="104"
                                            Margin="8,0,0,0"
                                            Command="{Binding ToggleProxyBatchTemplateRowsTestInclusionCommand}"
                                            Content="{Binding ProxyBatchTemplateToggleAllTestText, Mode=OneWay}" />
                                </WrapPanel>

                                <Border Grid.Row="1"
                                        Margin="0,8,0,0"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Background="#FFFFFF">
                                    <DataGrid AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              GridLinesVisibility="Horizontal"
                                              HeadersVisibility="Column"
                                              ItemsSource="{Binding ProxyBatchTemplateDraftItems}"
                                              PreviewMouseLeftButtonDown="ProxyBatchDraftDataGrid_OnPreviewMouseLeftButtonDown"
                                              RowHeaderWidth="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Width="1.15*"
                                                                Binding="{Binding EntryName, UpdateSourceTrigger=PropertyChanged}"
                                                                Header="名称" />
                                            <DataGridTextColumn Width="2.15*"
                                                                Binding="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                                                Header="URL" />
                                            <DataGridTextColumn Width="1.45*"
                                                                Binding="{Binding EntryApiKey, UpdateSourceTrigger=PropertyChanged}"
                                                                Header="Key" />
                                            <DataGridTemplateColumn Width="0.8*"
                                                                    Header="状态"
                                                                    IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock VerticalAlignment="Center"
                                                                   Text="{Binding TemplateStatus}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding TemplateStatus}" Value="缺 URL">
                                                                            <Setter Property="Foreground" Value="#D97706" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TemplateStatus}" Value="URL 无效">
                                                                            <Setter Property="Foreground" Value="#DC2626" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="1.05*"
                                                                    Header="测试">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  MinWidth="58"
                                                                  Focusable="False"
                                                                  Content="{Binding BatchTestShortDisplay}"
                                                                  IsChecked="{Binding IncludeInBatchTest, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  ToolTip="打开后才会参与批量快速测试和深度测试。" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="1.9*"
                                                                    Header="模型">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <DockPanel LastChildFill="True">
                                                            <Button DockPanel.Dock="Right"
                                                                    Width="28"
                                                                    Height="24"
                                                                    Margin="6,0,0,0"
                                                                    Command="{Binding DataContext.FetchProxyBatchTemplateRowModelsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="⟳"
                                                                    ToolTip="按本行 URL + key 拉取模型；如果本行 key 为空，会自动沿用上一行已填写 key。" />
                                                            <TextBlock VerticalAlignment="Center"
                                                                       Text="{Binding EntryModel}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <DockPanel LastChildFill="True">
                                                            <Button DockPanel.Dock="Right"
                                                                    Width="28"
                                                                    Height="24"
                                                                    Margin="6,0,0,0"
                                                                    Command="{Binding DataContext.FetchProxyBatchTemplateRowModelsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="⟳"
                                                                    ToolTip="按本行 URL + key 拉取模型；如果本行 key 为空，会自动沿用上一行已填写 key。" />
                                                            <TextBox Padding="0"
                                                                     BorderThickness="0"
                                                                     Background="Transparent"
                                                                     Text="{Binding EntryModel, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="0.9*"
                                                                    Header="操作"
                                                                    IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button MinWidth="54"
                                                                Padding="8,2"
                                                                HorizontalAlignment="Center"
                                                                Command="{Binding DataContext.DeleteProxyBatchTemplateRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}"
                                                                Content="删行"
                                                                ToolTip="删除当前这一行；如果删到只剩最后一行，会自动保留 1 个空白行。" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Grid>

                            <Border Grid.Row="4"
                                    Margin="0,8,0,0"
                                    Padding="10,8"
                                    Background="#F5F7FA"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                           Text="{Binding ProxyBatchTemplateSummary, Mode=OneWay}" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Grid.ColumnSpan="3"
                            Margin="0,10,0,0"
                            Style="{StaticResource DialogMetaStripBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="先录站点，再回批量对比继续。" />
                            <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                <Button MinWidth="144" Command="{Binding AddCurrentProxyBaseUrlToBatchCommand}" Content="带入主页网址 / Key" />
                                <Button MinWidth="120"
                                        Command="{Binding CommitProxyBatchEditorItemCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Content="{Binding ProxyBatchPrimaryActionText}" />
                                <Button MinWidth="104"
                                        Command="{Binding DeleteProxyBatchEditorItemCommand}"
                                        Content="删除选中"
                                        IsEnabled="{Binding IsProxyBatchEditorItemSelected}" />
                                <Button MinWidth="116" Command="{Binding ResetProxyBatchEditorFormCommand}" Content="清空当前站点" />
                                <Button MinWidth="128"
                                        Command="{Binding RunProxyBatchCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Content="开始快速对比" />
                                <Button MinWidth="88" Margin="0" Command="{Binding CloseProxyBatchEditorCommand}" Content="关闭" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
                </Grid>
            </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>





