<Window x:Class="RelayBench.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:pages="clr-namespace:RelayBench.App.Views.Pages"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="RelayBench &#x63A5;&#x53E3;&#x6D4B;&#x8BD5;&#x5DE5;&#x4F5C;&#x53F0;"
        Width="1440"
        Height="860"
        MinWidth="1120"
        MinHeight="700"
        Background="#F5F7FA"
        FontFamily="Microsoft YaHei UI"
        FontSize="11"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid Margin="3">
        <Border x:Name="MainShellBorder"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="10,6,6,6"
                        Background="{StaticResource PanelBrushStrong}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="14,14,0,0">
                    <Border.Resources>
                        <Style x:Key="TitleBarButtonStyle"
                               TargetType="Button"
                               BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Width" Value="38" />
                            <Setter Property="Height" Value="28" />
                            <Setter Property="MinWidth" Value="38" />
                            <Setter Property="Margin" Value="4,0,0,0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="FontSize" Value="11.4" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </Border.Resources>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              Background="Transparent"
                              MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="22"
                                    Height="22"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource AccentBrush}"
                                    CornerRadius="7">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#FFFFFF"
                                           FontSize="10.8"
                                           FontWeight="Bold"
                                           Text="R" />
                            </Border>

                            <TextBlock Grid.Column="1"
                                       Margin="9,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Text="RelayBench &#x63A5;&#x53E3;&#x6D4B;&#x8BD5;&#x5DE5;&#x4F5C;&#x53F0;" />

                            <Border x:Name="GlobalTaskProgressBorder"
                                    Grid.Column="3"
                                    MinWidth="260"
                                    MaxWidth="620"
                                    Height="28"
                                    Margin="0,0,10,0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    Padding="10,0"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    IsHitTestVisible="False"
                                    Opacity="0"
                                    Visibility="Collapsed">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0"
                                                                     EndPoint="1,1">
                                                    <GradientStop Color="#FBFDFF" Offset="0" />
                                                    <GradientStop Color="#F3F7FF" Offset="1" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="BorderBrush" Value="#D9E7FF" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGlobalTaskProgressCompleted, Mode=OneWay}"
                                                         Value="True">
                                                <Setter Property="Background" Value="#F3FFF7" />
                                                <Setter Property="BorderBrush" Value="#9ADAB4" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsGlobalTaskProgressStopped, Mode=OneWay}"
                                                         Value="True">
                                                <Setter Property="Background" Value="#FFF8EE" />
                                                <Setter Property="BorderBrush" Value="#F8C77C" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsGlobalTaskProgressFailed, Mode=OneWay}"
                                                         Value="True">
                                                <Setter Property="Background" Value="#FFF5F5" />
                                                <Setter Property="BorderBrush" Value="#F7B0B0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="120" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="#0F172A"
                                               FontSize="10.6"
                                               FontWeight="SemiBold"
                                               Text="{Binding GlobalTaskProgressTitle, Mode=OneWay}"
                                               TextTrimming="CharacterEllipsis" />

                                    <Border Grid.Column="2"
                                            Height="6"
                                            VerticalAlignment="Center"
                                            Background="#EAF0FF"
                                            BorderBrush="#D6E1FB"
                                            BorderThickness="1"
                                            CornerRadius="999">
                                        <Grid ClipToBounds="True">
                                            <Border Margin="1"
                                                    Background="#1FFFFFFF"
                                                    CornerRadius="999" />
                                            <Border x:Name="GlobalTaskProgressFill"
                                                    HorizontalAlignment="Stretch"
                                                    CornerRadius="999"
                                                    RenderTransformOrigin="0,0.5">
                                                <Border.RenderTransform>
                                                    <ScaleTransform ScaleX="0" ScaleY="1" />
                                                </Border.RenderTransform>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush StartPoint="0,0"
                                                                                     EndPoint="1,0">
                                                                    <GradientStop Color="#2F6BFF" Offset="0" />
                                                                    <GradientStop Color="#7C3AED" Offset="1" />
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsGlobalTaskProgressCompleted, Mode=OneWay}"
                                                                         Value="True">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <LinearGradientBrush StartPoint="0,0"
                                                                                             EndPoint="1,0">
                                                                            <GradientStop Color="#16A34A" Offset="0" />
                                                                            <GradientStop Color="#22C55E" Offset="1" />
                                                                        </LinearGradientBrush>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsGlobalTaskProgressStopped, Mode=OneWay}"
                                                                         Value="True">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <LinearGradientBrush StartPoint="0,0"
                                                                                             EndPoint="1,0">
                                                                            <GradientStop Color="#F59E0B" Offset="0" />
                                                                            <GradientStop Color="#FB923C" Offset="1" />
                                                                        </LinearGradientBrush>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsGlobalTaskProgressFailed, Mode=OneWay}"
                                                                         Value="True">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <LinearGradientBrush StartPoint="0,0"
                                                                                             EndPoint="1,0">
                                                                            <GradientStop Color="#EF4444" Offset="0" />
                                                                            <GradientStop Color="#F97373" Offset="1" />
                                                                        </LinearGradientBrush>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <TextBlock Grid.Column="4"
                                               MinWidth="116"
                                               VerticalAlignment="Center"
                                               Foreground="#475467"
                                               FontSize="10.2"
                                               FontWeight="SemiBold"
                                               Text="{Binding GlobalTaskProgressStatusText, Mode=OneWay}"
                                               TextAlignment="Right"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Style="{StaticResource TitleBarButtonStyle}"
                                    Click="MinimizeWindowButton_OnClick"
                                    ToolTip="&#x6700;&#x5C0F;&#x5316;"
                                    Content="&#x2014;" />
                            <Button Click="MaximizeRestoreWindowButton_OnClick">
                                <Button.Style>
                                    <Style TargetType="Button"
                                           BasedOn="{StaticResource TitleBarButtonStyle}">
                                        <Setter Property="ToolTip" Value="&#x6700;&#x5927;&#x5316;" />
                                        <Setter Property="Content" Value="&#x25A1;" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}"
                                                         Value="Maximized">
                                                <Setter Property="ToolTip" Value="&#x8FD8;&#x539F;" />
                                                <Setter Property="Content" Value="&#x2752;" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Style="{StaticResource TitleBarButtonStyle}"
                                    Click="CloseWindowButton_OnClick"
                                    ToolTip="&#x5173;&#x95ED;"
                                    Content="&#x2715;" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Margin="7,6,7,7">
                    <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Visibility="Collapsed"
                        Margin="0,0,0,18"
                        Padding="18"
                        Background="{StaticResource InputBrush}"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock FontSize="24" FontWeight="Bold" Text="RelayBench &#x63A5;&#x53E3;&#x6D4B;&#x8BD5;&#x5DE5;&#x4F5C;&#x53F0;" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Text="菜单入口已并排收进左上角主区域，左侧独立栏不再显示，当前状态和实时输出集中在右侧工作区查看。" />
                        <TextBlock Margin="0,10,0,0"
                                   Foreground="{StaticResource AccentBrush}"
                                   Text="{Binding LastRunAt, StringFormat=上次运行：{0}}" />
                        <TextBox Margin="0,12,0,0"
                                 Height="96"
                                 IsReadOnly="True"
                                 Text="{Binding StatusMessage, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Top"
                        Visibility="Collapsed"
                        Margin="0,0,0,18"
                        Padding="18"
                        Background="{StaticResource InputBrush}"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock FontSize="19" FontWeight="Bold" Text="诊断控制台" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Text="左侧现在只承担标题、菜单和状态展示；右侧继续负责实时输出与各模块详细结果。" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,0,0,4"
                        Padding="7,4"
                        Background="{StaticResource InputBrush}"
                        CornerRadius="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="{Binding StatusMessage, Mode=OneWay}" />
                        <TextBlock Grid.Column="1"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource AccentBrush}"
                                   Text="{Binding LastRunAt, StringFormat=上次运行：{0}}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="0"
                      Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource NavigationRailBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="&#x5DE5;&#x4F5C;&#x53F0;&#x5BFC;&#x822A;" />
                        <TextBlock Grid.Row="1"
                                       Margin="0,3,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="&#x6309;&#x4EFB;&#x52A1;&#x5207;&#x6362;&#x9875;&#x9762;&#xFF1A;&#x5148;&#x505A;&#x63A5;&#x53E3;&#x8BCA;&#x65AD;&#xFF0C;&#x518D;&#x505A;&#x6279;&#x91CF;&#x8BC4;&#x6D4B;&#x3001;&#x5E94;&#x7528;&#x63A5;&#x5165;&#x4E0E;&#x7F51;&#x7EDC;&#x590D;&#x6838;&#x3002;" />

                            <ListBox Grid.Row="2"
                                     Margin="0,8,0,0"
                                     ItemContainerStyle="{StaticResource NavigationListBoxItemStyle}"
                                     ItemsSource="{Binding WorkbenchPageOptions}"
                                     SelectedValuePath="Key"
                                     SelectedValue="{Binding SelectedWorkbenchPageKey, Mode=TwoWay}"
                                     Style="{StaticResource NavigationListBoxStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="11.2"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Grid.Row="3"
                                    Margin="0,10,0,0"
                                    Style="{StaticResource NavigationAboutBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                               Text="关于" />
                                    <Button Margin="0,4,0,0"
                                            Command="{Binding OpenAboutDialogCommand}"
                                            Style="{StaticResource NavigationAboutLinkButtonStyle}"
                                            ToolTip="查看项目信息">
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="15"
                                                     Height="15"
                                                     Margin="0,0,6,0">
                                                <Canvas Width="16" Height="16">
                                                    <Path Fill="#111827"
                                                          Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.65 7.65 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock VerticalAlignment="Center"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="10.2"
                                                       FontWeight="SemiBold"
                                                       Text="查看项目信息" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource SectionPanelBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                               Text="{Binding CurrentPageTitle}" />
                                    <TextBlock Margin="0,2,0,0"
                                               Style="{StaticResource SectionHintTextStyle}"
                                               Text="{Binding CurrentPageSubtitle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            HorizontalAlignment="Right">
                                    <TextBlock HorizontalAlignment="Right"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="{Binding StatusMessage, Mode=OneWay}" />
                                    <TextBlock Margin="0,2,0,0"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource AccentBrush}"
                                               Text="{Binding LastRunAt, StringFormat=上次运行：{0}}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid x:Name="WorkbenchPageHost"
                              Grid.Row="1"
                              Margin="0,4,0,0">
                            <pages:SingleStationPage Visibility="{Binding IsInterfaceDiagnosticsPageActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <pages:BatchComparisonPage Visibility="{Binding IsBatchEvaluationPageActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <pages:ApplicationCenterPage Visibility="{Binding IsApplicationCenterPageActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <pages:NetworkReviewPage Visibility="{Binding IsNetworkReviewPageActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <pages:HistoryReportsPage Visibility="{Binding IsHistoryReportsPageActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Grid>
                </Grid>

        <Grid x:Name="ProxyChartOverlay"
              Panel.ZIndex="21"
              Background="#660F172A"
              Visibility="Collapsed">
            <Border x:Name="ProxyChartOverlayPanel"
                    Margin="18"
                    Padding="12"
                    Background="{StaticResource PanelBrushStrong}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1.5"
                    CornerRadius="18"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleTextStyle}"
                                       Text="{Binding ProxyChartDialogTitle, Mode=OneWay}" />
                            <WrapPanel Margin="0,6,0,0">
                                <Border Style="{StaticResource DialogTagBorderStyle}">
                                    <TextBlock Style="{StaticResource DialogTagTextStyle}"
                                               Text="图表总览" />
                                </Border>
                                <Border Style="{StaticResource DialogAccentTagBorderStyle}">
                                    <TextBlock Style="{StaticResource DialogTagTextStyle}"
                                               Foreground="{StaticResource AccentBrush}"
                                               Text="双击切图" />
                                </Border>
                            </WrapPanel>
                            <Expander Margin="0,4,0,0"
                                      IsExpanded="False">
                                <Expander.Style>
                                    <Style TargetType="Expander">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsProxyChartImageOnlyMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Expander.Style>
                                <Expander.Header>
                                    <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                               Text="说明" />
                                </Expander.Header>
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource SectionHintTextStyle}"
                                           Text="{Binding ProxyChartDialogIntro, Mode=OneWay}" />
                            </Expander>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button MinWidth="120"
                                    Margin="12,0,0,0"
                                    Command="{Binding ToggleProxyChartImageOnlyModeCommand}"
                                    Content="{Binding ProxyChartImageOnlyModeButtonText, Mode=OneWay}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanToggleProxyChartImageOnlyMode}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button MinWidth="112"
                                    Margin="12,0,0,0"
                                    Command="{Binding RetryProxyChartCommand}"
                                    Content="{Binding ProxyChartRetryButtonText, Mode=OneWay}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasProxyChartRetryAction}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button MinWidth="112"
                                    Margin="12,0,0,0"
                                    Command="{Binding StopCurrentProxyTestCommand}"
                                    IsEnabled="{Binding CanStopCurrentProxyTest, Mode=OneWay}"
                                    Content="停止测试" />
                            <Button MinWidth="96"
                                    Margin="12,0,0,0"
                                    Command="{Binding CloseProxyTrendChartCommand}"
                                    Content="关闭" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProxyChartImageOnlyMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.25*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource DialogSectionBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="图表摘要" />
                                    <TextBox Grid.Row="1"
                                             Margin="0,8,0,0"
                                             Height="72"
                                             Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                                             Text="{Binding ProxyChartDialogSummary, Mode=OneWay}" />
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource DialogSectionBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="检测摘要" />
                                    <TextBox Grid.Row="1"
                                             Margin="0,8,0,0"
                                             Height="88"
                                             Style="{StaticResource ReadOnlyConsoleTextBoxStyle}"
                                             Text="{Binding ProxyChartDialogCapabilitySummary, Mode=OneWay}" />
                                </Grid>
                            </Border>
                            <Border Grid.Column="4" Style="{StaticResource DialogSectionBorderStyle}">
                                <Expander IsExpanded="False">
                                    <Expander.Header>
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="读图说明" />
                                    </Expander.Header>
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource SectionHintTextStyle}"
                                               Text="{Binding ProxyChartDialogGuideSummary, Mode=OneWay}" />
                                </Expander>
