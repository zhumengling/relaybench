<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="AdvancedLabPanelStyle"
           TargetType="Border"
           BasedOn="{StaticResource MotionPanelStyle}">
        <Setter Property="Padding" Value="12" />
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#E2E8F0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Effect" Value="{StaticResource ShadowSm}" />
    </Style>

    <Style x:Key="AdvancedLabSoftPanelStyle"
           TargetType="Border"
           BasedOn="{StaticResource AdvancedLabPanelStyle}">
        <Setter Property="Background" Value="#F8FAFC" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Effect" Value="{x:Null}" />
    </Style>

    <Style x:Key="AdvancedLabMetricCardStyle"
           TargetType="Border"
           BasedOn="{StaticResource AdvancedLabPanelStyle}">
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="MinHeight" Value="86" />
        <Setter Property="CornerRadius" Value="14" />
    </Style>

    <Style x:Key="AdvancedLabBadgeStyle" TargetType="Border">
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#D8E3F2" />
        <Setter Property="Background" Value="#F8FAFC" />
    </Style>

    <Style x:Key="AdvancedLabIconButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource WorkbenchIconButtonStyle}">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <Style x:Key="AdvancedLabConfigIconButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource AdvancedLabIconButtonStyle}">
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Margin" Value="0,17,6,0" />
    </Style>

    <Style x:Key="AdvancedLabModelPickerBorderStyle" TargetType="Border">
        <Setter Property="Height" Value="34" />
        <Setter Property="Margin" Value="0,0,0,3" />
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="AdvancedLabModelPickerTextBoxStyle" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="AcceptsReturn" Value="False" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="{TemplateBinding Padding}"
                                  HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"
                                  VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AdvancedLabModelDropDownToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="ToggleChrome"
                            Width="26"
                            Height="26"
                            Background="#EFF6FF"
                            CornerRadius="999">
                        <Path x:Name="ToggleGlyph"
                              Width="10"
                              Height="6"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0 0 L 6 6 L 12 0"
                              RenderTransformOrigin="0.5,0.5"
                              Stroke="{StaticResource AccentBrush}"
                              StrokeThickness="2.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round">
                            <Path.RenderTransform>
                                <RotateTransform Angle="0" />
                            </Path.RenderTransform>
                        </Path>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ToggleChrome" Property="Background" Value="#DBEAFE" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="ToggleChrome" Property="Background" Value="#DBEAFE" />
                            <Setter TargetName="ToggleGlyph" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="180" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ToggleChrome" Property="Background" Value="#F1F5F9" />
                            <Setter TargetName="ToggleGlyph" Property="Stroke" Value="#94A3B8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AdvancedLabModelOptionListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MaxHeight" Value="260" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
    </Style>

    <Style x:Key="AdvancedLabPrimaryIconButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource WorkbenchIconButtonPrimaryStyle}">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <Style x:Key="AdvancedLabSuiteListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0,0,14,0" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

    <Style x:Key="AdvancedLabSuiteListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,6,8" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ItemBorder"
                            Padding="10"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="12"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="ItemScale" ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#F8FBFF" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#93C5FD" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleX" To="1.012" Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleY" To="1.012" Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.16" />
                                        <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.16" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#EFF6FF" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2563EB" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AdvancedLabProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="8" />
        <Setter Property="Background" Value="#E2E8F0" />
        <Setter Property="Foreground" Value="#2563EB" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid ClipToBounds="True">
                        <Border Background="{TemplateBinding Background}" CornerRadius="999" />
                        <Border x:Name="PART_Indicator"
                                HorizontalAlignment="Left"
                                Background="{TemplateBinding Foreground}"
                                CornerRadius="999" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
