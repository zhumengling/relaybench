<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:infra="clr-namespace:RelayBench.App.Infrastructure">
    <Duration x:Key="MotionInstant">0:0:0.08</Duration>
    <Duration x:Key="MotionFast">0:0:0.12</Duration>
    <Duration x:Key="MotionNormal">0:0:0.18</Duration>
    <Duration x:Key="MotionPanel">0:0:0.22</Duration>
    <Duration x:Key="MotionDialog">0:0:0.26</Duration>
    <Duration x:Key="MotionSlow">0:0:0.32</Duration>

    <CubicEase x:Key="MotionEaseOut" EasingMode="EaseOut" />
    <CubicEase x:Key="MotionEaseIn" EasingMode="EaseIn" />
    <QuinticEase x:Key="MotionQuintEaseOut" EasingMode="EaseOut" />
    <QuadraticEase x:Key="MotionQuadEaseOut" EasingMode="EaseOut" />

    <Style x:Key="MotionPageRootStyle" TargetType="{x:Type UserControl}">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="infra:MotionAssist.UseVisibilityTransition" Value="True" />
        <Setter Property="infra:MotionAssist.LoadedOffsetY" Value="10" />
        <Setter Property="infra:MotionAssist.TransitionDurationMs" Value="180" />
    </Style>

    <Style x:Key="MotionPanelStyle" TargetType="{x:Type Border}">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="infra:MotionAssist.UseVisibilityTransition" Value="True" />
        <Setter Property="infra:MotionAssist.LoadedOffsetY" Value="8" />
        <Setter Property="infra:MotionAssist.TransitionDurationMs" Value="220" />
    </Style>

    <Style x:Key="MotionDialogPanelStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource MotionPanelStyle}">
        <Setter Property="infra:MotionAssist.LoadedOffsetY" Value="14" />
        <Setter Property="infra:MotionAssist.TransitionDurationMs" Value="260" />
    </Style>
</ResourceDictionary>
