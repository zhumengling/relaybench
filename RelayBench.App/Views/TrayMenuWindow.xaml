<Window x:Class="RelayBench.App.Views.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="274"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Topmost="True"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        Deactivated="Window_OnDeactivated"
        Loaded="Window_OnLoaded"
        PreviewKeyDown="Window_OnPreviewKeyDown">
    <Window.Resources>
        <CubicEase x:Key="TrayMenuEaseOut" EasingMode="EaseOut" />
        <CubicEase x:Key="TrayMenuEaseIn" EasingMode="EaseIn" />

        <Style x:Key="TrayMenuGlyphTextStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Foreground" Value="#2563EB" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="TrayMenuItemButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45" />
            <Setter Property="Margin" Value="0,1,0,0" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#EFF6FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#DBEAFE" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Cursor" Value="Arrow" />
                                <Setter Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                 To="1.012"
                                                 Duration="0:0:0.12"
                                                 EasingFunction="{StaticResource TrayMenuEaseOut}" />
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                 To="1.012"
                                                 Duration="0:0:0.12"
                                                 EasingFunction="{StaticResource TrayMenuEaseOut}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                 To="1"
                                                 Duration="0:0:0.12"
                                                 EasingFunction="{StaticResource TrayMenuEaseOut}" />
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                 To="1"
                                                 Duration="0:0:0.12"
                                                 EasingFunction="{StaticResource TrayMenuEaseOut}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TrayMenuDangerItemButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TrayMenuItemButtonStyle}">
            <Setter Property="Foreground" Value="#B42318" />
        </Style>
    </Window.Resources>

    <Border x:Name="RootChrome"
            Opacity="0"
            Padding="9"
            Background="#FBFFFFFF"
            BorderBrush="#D7E3F1"
            BorderThickness="1"
            CornerRadius="14"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30"
                              Direction="270"
                              Opacity="0.22"
                              ShadowDepth="8"
                              Color="#1E293B" />
        </Border.Effect>
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="RootScale" ScaleX="0.985" ScaleY="0.985" />
                <TranslateTransform x:Name="RootTranslate" Y="8" />
            </TransformGroup>
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="4,2,4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="34"
                        Height="34"
                        Background="#EFF6FF"
                        CornerRadius="10">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="15"
                               Foreground="#2563EB"
                               Text="&#xE946;" />
                </Border>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="13.2"
                               FontWeight="SemiBold"
                               Foreground="#101828"
                               Text="RelayBench" />
                    <TextBlock x:Name="ProxyStatusTextBlock"
                               Margin="0,1,0,0"
                               FontSize="10.6"
                               Foreground="#667085"
                               Text="后台运行中" />
                </StackPanel>

                <Border Grid.Column="3"
                        Padding="7,3"
                        VerticalAlignment="Center"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="999">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="ProxyStatusDot"
                                 Width="6"
                                 Height="6"
                                 Margin="0,0,5,0"
                                 VerticalAlignment="Center"
                                 Fill="#94A3B8" />
                        <TextBlock x:Name="ProxyStatusPillTextBlock"
                                   FontSize="10.2"
                                   FontWeight="SemiBold"
                                   Foreground="#475467"
                                   Text="待命" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Height="1"
                    Margin="4,0"
                    Background="#EEF2F7" />

            <StackPanel Grid.Row="4">
                <Button Style="{StaticResource TrayMenuItemButtonStyle}"
                        Click="OpenMainWindowButton_OnClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="26" Height="26" Background="#EFF6FF" CornerRadius="8">
                            <TextBlock Style="{StaticResource TrayMenuGlyphTextStyle}" Text="&#xE8A7;" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="12.6" FontWeight="SemiBold" Foreground="#101828" Text="打开 RelayBench" />
                            <TextBlock FontSize="10.6" Foreground="#667085" Text="恢复主窗口" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Button x:Name="ProxyActionButton"
                        Style="{StaticResource TrayMenuItemButtonStyle}"
                        Click="ProxyActionButton_OnClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="26" Height="26" Background="#EFF6FF" CornerRadius="8">
                            <TextBlock x:Name="ProxyActionGlyphTextBlock"
                                       Style="{StaticResource TrayMenuGlyphTextStyle}"
                                       Text="&#xE768;" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="ProxyActionTitleTextBlock"
                                       FontSize="12.6"
                                       FontWeight="SemiBold"
                                       Foreground="#101828"
                                       Text="启动透明代理" />
                            <TextBlock x:Name="ProxyActionMetaTextBlock"
                                       FontSize="10.6"
                                       Foreground="#667085"
                                       Text="打开本地透明代理入口" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Button x:Name="TokenMeterActionButton"
                        Style="{StaticResource TrayMenuItemButtonStyle}"
                        Click="TokenMeterActionButton_OnClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="26" Height="26" Background="#EFF6FF" CornerRadius="8">
                            <TextBlock Style="{StaticResource TrayMenuGlyphTextStyle}" Text="&#xE9D2;" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TokenMeterTitleTextBlock"
                                       FontSize="12.6"
                                       FontWeight="SemiBold"
                                       Foreground="#101828"
                                       Text="显示 Token 悬浮窗" />
                            <TextBlock x:Name="TokenMeterMetaTextBlock"
                                       FontSize="10.6"
                                       Foreground="#667085"
                                       Text="实时 token / tok/s" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Button Style="{StaticResource TrayMenuItemButtonStyle}" IsEnabled="False">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="26" Height="26" Background="#F1F5F9" CornerRadius="8">
                            <TextBlock Style="{StaticResource TrayMenuGlyphTextStyle}"
                                       Foreground="#64748B"
                                       Text="&#xE73E;" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="12.6" FontWeight="SemiBold" Foreground="#101828" Text="后台运行" />
                            <TextBlock FontSize="10.6" Foreground="#667085" Text="关闭窗口后仍保留托盘" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#16A34A"
                                   Text="开启" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource TrayMenuItemButtonStyle}"
                        Click="OpenLogDirectoryButton_OnClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="26" Height="26" Background="#EFF6FF" CornerRadius="8">
                            <TextBlock Style="{StaticResource TrayMenuGlyphTextStyle}" Text="&#xE838;" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="12.6" FontWeight="SemiBold" Foreground="#101828" Text="打开日志目录" />
                            <TextBlock FontSize="10.6" Foreground="#667085" Text="查看运行和诊断日志" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Border Height="1"
                        Margin="4,7,4,6"
                        Background="#EEF2F7" />

                <Button Style="{StaticResource TrayMenuDangerItemButtonStyle}"
                        Click="ExitButton_OnClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="26" Height="26" Background="#FEF3F2" CornerRadius="8">
                            <TextBlock Style="{StaticResource TrayMenuGlyphTextStyle}"
                                       Foreground="#B42318"
                                       Text="&#xE711;" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="12.6" FontWeight="SemiBold" Foreground="#B42318" Text="退出 RelayBench" />
                            <TextBlock FontSize="10.6" Foreground="#9A3412" Text="停止代理并关闭程序" />
                        </StackPanel>
                    </Grid>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
