<Window x:Class="RelayBench.App.Views.FloatingTokenMeterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="136"
        Height="42"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        SizeToContent="Manual"
        Topmost="True"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        Loaded="Window_OnLoaded"
        MouseLeftButtonDown="Window_OnMouseLeftButtonDown">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="打开 RelayBench" Click="OpenMainWindowMenuItem_OnClick" />
            <MenuItem x:Name="LockPositionMenuItem"
                      Header="锁定位置"
                      IsCheckable="True"
                      Click="LockPositionMenuItem_OnClick" />
            <MenuItem x:Name="MousePassThroughMenuItem"
                      Header="鼠标穿透"
                      IsCheckable="True"
                      Click="MousePassThroughMenuItem_OnClick" />
            <MenuItem Header="重置阶段计数" Click="ResetCounterMenuItem_OnClick" />
            <Separator />
            <MenuItem Header="隐藏悬浮窗" Click="HideMenuItem_OnClick" />
        </ContextMenu>
    </Window.ContextMenu>

    <Border Padding="8,5"
            Background="#F2101820"
            BorderBrush="#40FFFFFF"
            BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True"
            ToolTip="{Binding TransparentProxyMetricsSummary, Mode=OneWay}"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14"
                              Direction="270"
                              Opacity="0.22"
                              ShadowDepth="4"
                              Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="7" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Ellipse Grid.Column="0"
                     Width="5.5"
                     Height="5.5"
                     VerticalAlignment="Center"
                     Fill="{Binding TransparentProxyTokenMeterAccentBrush, Mode=OneWay}" />

            <Grid Grid.Column="2" ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock FontFamily="Cascadia Mono, Consolas"
                           FontSize="14.8"
                           FontWeight="SemiBold"
                           Foreground="#F8FAFC"
                           LineHeight="17"
                           MaxHeight="18"
                           Text="{Binding TransparentProxyTokenMeterPrimaryText, Mode=OneWay}"
                           TextOptions.TextFormattingMode="Display"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Row="1"
                           FontFamily="Segoe UI, Microsoft YaHei UI"
                           FontSize="9.2"
                           Foreground="#CBD5E1"
                           LineHeight="11"
                           MaxHeight="12"
                           Text="{Binding TransparentProxyTokenMeterSecondaryText, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Grid>
    </Border>
</Window>
