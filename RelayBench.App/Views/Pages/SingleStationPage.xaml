<UserControl x:Class="RelayBench.App.Views.Pages.SingleStationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:infra="clr-namespace:RelayBench.App.Infrastructure"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Style="{StaticResource MotionPageRootStyle}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="SingleStationToolbarIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkbenchIconButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="SingleStationMotionInsetPanelStyle"
               TargetType="Border"
               BasedOn="{StaticResource MotionDialogPanelStyle}">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="{StaticResource PanelBrushStrong}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
    </UserControl.Resources>

    <Grid MinHeight="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CommandBarBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.ColumnSpan="5">
                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x63A5;&#x53E3;&#x5730;&#x5740;" />
                    <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                             ToolTip="{Binding ProxyBaseUrl}"
                             Text="{Binding ProxyBaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.Column="0">
                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="API Key" />
                    <PasswordBox Style="{StaticResource CompactSecretInputPasswordBoxStyle}"
                                 infra:PasswordBoxAssistant.BoundPassword="{Binding ProxyApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x6A21;&#x578B;" />
                    <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                             ToolTip="{Binding ProxyModel}"
                             Text="{Binding ProxyModel, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <Button Grid.Row="2"
                        Grid.Column="4"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource SingleStationToolbarIconButtonStyle}"
                        Command="{Binding FetchProxyModelsCommand}"
                        Content="&#xE72C;"
                        ToolTip="&#x62C9;&#x53D6;&#x6A21;&#x578B;" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,8,0,0"
                Style="{StaticResource SectionPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="测试模式" />
                    <TextBlock Margin="0,2,0,0"
                               Style="{StaticResource SectionHintTextStyle}"
                               ToolTip="{Binding SingleStationModeDescription}"
                               Text="{Binding SingleStationModeDescription}" />
                </StackPanel>

                <WrapPanel Grid.Row="0"
                           Grid.Column="2"
                           VerticalAlignment="Center">
                    <Button Command="{Binding OpenProxyEndpointHistoryCommand}"
                            Style="{StaticResource SingleStationToolbarIconButtonStyle}"
                            Content="&#xE81C;"
                            ToolTip="&#x5386;&#x53F2;&#x63A5;&#x53E3;" />
                    <Button Command="{Binding OpenProxySingleChartCommand}"
                            Style="{StaticResource SingleStationToolbarIconButtonStyle}"
                            Content="&#xE9D2;"
                            ToolTip="&#x67E5;&#x770B;&#x56FE;&#x8868;" />
                    <Button Command="{Binding RunSelectedSingleStationModeCommand}"
                            Style="{StaticResource WorkbenchIconButtonPrimaryStyle}"
                            Content="&#xE768;"
                            ToolTip="{Binding SingleStationPrimaryButtonText}" />
                    <Button Margin="6,0,0,0"
                            Command="{Binding StopCurrentProxyTestCommand}"
                            Style="{StaticResource SingleStationToolbarIconButtonStyle}"
                            Content="&#xE71A;"
                            ToolTip="&#x505C;&#x6B62;&#x6D4B;&#x8BD5;" />
                </WrapPanel>

                <ComboBox Grid.Row="1"
                          Grid.ColumnSpan="3"
                          Margin="0,6,0,0"
                          Style="{StaticResource CompactComboBoxStyle}"
                          ItemsSource="{Binding SingleStationModeOptions}"
                          TextSearch.TextPath="DisplayName"
                          SelectedValuePath="Key"
                          SelectedValue="{Binding SelectedSingleStationModeKey, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Foreground="#101828"
                                       FontSize="11.1"
                                       FontWeight="SemiBold"
                                       Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Grid Grid.Row="2"
                      Grid.ColumnSpan="3"
                      Margin="0,6,0,0"
                      Visibility="{Binding IsSingleStationStabilityMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="160" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x8F6E;&#x6B21;" />
                        <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                 Text="{Binding ProxySeriesRoundsText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x95F4;&#x9694;&#xFF08;ms&#xFF09;" />
                        <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                 Text="{Binding ProxySeriesDelayMsText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <CheckBox Grid.Row="1"
                              Grid.ColumnSpan="3"
                              Margin="0,8,0,0"
                              Content="语义抽样"
                              IsChecked="{Binding ProxyEnableSemanticStabilitySampling, Mode=TwoWay}" />
                </Grid>

                <Border Grid.Row="2"
                        Grid.ColumnSpan="3"
                        Margin="0,6,0,0"
                        Style="{StaticResource InsetPanelBorderStyle}"
                        Visibility="{Binding IsSingleStationDeepMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="测试项" />

                        <ComboBox Style="{StaticResource CompactComboBoxStyle}"
                                  Margin="0,6,0,0"
                                  ItemsSource="{Binding ProxyDiagnosticPresetOptions}"
                                  TextSearch.TextPath="DisplayName"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding SelectedProxyDiagnosticPresetKey, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="#101828"
                                               FontSize="11.1"
                                               FontWeight="SemiBold"
                                               Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <WrapPanel Margin="0,6,0,0">
                            <CheckBox Content="&#x534F;&#x8BAE;&#x517C;&#x5BB9;" IsChecked="{Binding ProxyEnableProtocolCompatibilityTest, Mode=TwoWay}" />
                            <CheckBox Content="&#x9519;&#x8BEF;&#x900F;&#x4F20;" IsChecked="{Binding ProxyEnableErrorTransparencyTest, Mode=TwoWay}" />
                            <CheckBox Content="&#x6D41;&#x5F0F;&#x5B8C;&#x6574;&#x6027;" IsChecked="{Binding ProxyEnableStreamingIntegrityTest, Mode=TwoWay}" />
                            <CheckBox Content="&#x591A;&#x6A21;&#x6001;" IsChecked="{Binding ProxyEnableMultiModalTest, Mode=TwoWay}" />
                            <CheckBox Content="&#x7F13;&#x5B58;&#x673A;&#x5236;" IsChecked="{Binding ProxyEnableCacheMechanismTest, Mode=TwoWay}" />
                            <CheckBox Content="指令遵循" IsChecked="{Binding ProxyEnableInstructionFollowingTest, Mode=TwoWay}" />
                            <CheckBox Content="数据抽取" IsChecked="{Binding ProxyEnableDataExtractionTest, Mode=TwoWay}" />
                            <CheckBox Content="结构化边界" IsChecked="{Binding ProxyEnableStructuredOutputEdgeTest, Mode=TwoWay}" />
                            <CheckBox Content="ToolCall 深测" IsChecked="{Binding ProxyEnableToolCallDeepTest, Mode=TwoWay}" />
                            <CheckBox Content="推理一致性" IsChecked="{Binding ProxyEnableReasonMathConsistencyTest, Mode=TwoWay}" />
                            <CheckBox Content="代码块纪律" IsChecked="{Binding ProxyEnableCodeBlockDisciplineTest, Mode=TwoWay}" />
                            <Button Margin="8,0,0,0"
                                    Style="{StaticResource SingleStationToolbarIconButtonStyle}"
                                    Command="{Binding OpenProxyMultiModelPickerCommand}"
                                    Content="&#xE8F9;"
                                    ToolTip="&#x591A;&#x6A21;&#x578B;" />
                            <Button Margin="8,0,0,0"
                                    Style="{StaticResource SingleStationToolbarIconButtonStyle}"
                                    Command="{Binding ToggleProxyCapabilityConfigCommand}"
                                    Content="&#xE713;"
                                    ToolTip="{Binding ProxyCapabilityConfigButtonText, Mode=OneWay}" />
                            <TextBlock Margin="8,4,0,0"
                                       VerticalAlignment="Center"
                                       MaxWidth="260"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       ToolTip="{Binding ProxyMultiModelSelectionSummary, Mode=OneWay}"
                                       Text="{Binding ProxyMultiModelSelectionSummary, Mode=OneWay}" />
                            <TextBlock Margin="8,4,0,0"
                                       VerticalAlignment="Center"
                                       MaxWidth="260"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       ToolTip="{Binding ProxyCapabilityModelConfigSummary, Mode=OneWay}"
                                       Text="{Binding ProxyCapabilityModelConfigSummary, Mode=OneWay}" />
                        </WrapPanel>

                        <Border Margin="0,6,0,0"
                                Style="{StaticResource SingleStationMotionInsetPanelStyle}"
                                Visibility="{Binding IsProxyCapabilityConfigOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="能力模型" />
                                <Border Margin="0,4,0,0"
                                        Style="{StaticResource DialogMetaStripBorderStyle}">
                                    <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                               ToolTip="{Binding ProxyCapabilityModelConfigSummary, Mode=OneWay}"
                                               Text="{Binding ProxyCapabilityModelConfigSummary, Mode=OneWay}" />
                                </Border>

                                <ScrollViewer Margin="0,8,0,0"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                <Grid MinWidth="760">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Embeddings" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Style="{StaticResource CompactInputTextBoxStyle}"
                                                 ToolTip="{Binding ProxyEmbeddingsModel}"
                                                 Text="{Binding ProxyEmbeddingsModel, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="1"
                                                Margin="6,0,0,0"
                                                Style="{StaticResource SingleStationToolbarIconButtonStyle}"
                                                Command="{Binding FetchProxyCapabilityModelsCommand}"
                                                CommandParameter="embeddings"
                                                Content="&#xE72C;"
                                                ToolTip="&#x62C9;&#x53D6;&#x6A21;&#x578B;" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Images" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Style="{StaticResource CompactInputTextBoxStyle}"
                                                 ToolTip="{Binding ProxyImagesModel}"
                                                 Text="{Binding ProxyImagesModel, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="1"
                                                Margin="6,0,0,0"
                                                Style="{StaticResource SingleStationToolbarIconButtonStyle}"
                                                Command="{Binding FetchProxyCapabilityModelsCommand}"
                                                CommandParameter="images"
                                                Content="&#xE72C;"
                                                ToolTip="&#x62C9;&#x53D6;&#x6A21;&#x578B;" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="4">
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Audio Transcription" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Style="{StaticResource CompactInputTextBoxStyle}"
                                                 ToolTip="{Binding ProxyAudioTranscriptionModel}"
                                                 Text="{Binding ProxyAudioTranscriptionModel, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="1"
                                                Margin="6,0,0,0"
                                                Style="{StaticResource SingleStationToolbarIconButtonStyle}"
                                                Command="{Binding FetchProxyCapabilityModelsCommand}"
                                                CommandParameter="audio-transcription"
                                                Content="&#xE72C;"
                                                ToolTip="&#x62C9;&#x53D6;&#x6A21;&#x578B;" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,6,0,0">
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Moderation" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Style="{StaticResource CompactInputTextBoxStyle}"
                                                 ToolTip="{Binding ProxyModerationModel}"
                                                 Text="{Binding ProxyModerationModel, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="1"
                                                Margin="6,0,0,0"
                                                Style="{StaticResource SingleStationToolbarIconButtonStyle}"
                                                Command="{Binding FetchProxyCapabilityModelsCommand}"
                                                CommandParameter="moderation"
                                                Content="&#xE72C;"
                                                ToolTip="&#x62C9;&#x53D6;&#x6A21;&#x578B;" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,6,0,0">
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Audio Speech / TTS" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Style="{StaticResource CompactInputTextBoxStyle}"
                                                 ToolTip="{Binding ProxyAudioSpeechModel}"
                                                 Text="{Binding ProxyAudioSpeechModel, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="1"
                                                Margin="6,0,0,0"
                                                Style="{StaticResource SingleStationToolbarIconButtonStyle}"
                                                Command="{Binding FetchProxyCapabilityModelsCommand}"
                                                CommandParameter="audio-speech"
                                                Content="&#xE72C;"
                                                ToolTip="&#x62C9;&#x53D6;&#x6A21;&#x578B;" />
                                    </Grid>
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Grid.Column="4"
                                        Margin="0,6,0,0"
                                        Padding="10,8"
                                        Background="#F8FAFC"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Visibility="Collapsed">
                                    <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                               TextWrapping="Wrap"
                                               Text="每个能力可单独填模型；留空则不参与本轮测试。" />
                                </Border>
                                <Expander Grid.Row="1"
                                          Grid.Column="4"
                                          Margin="0,6,0,0"
                                          IsExpanded="False">
                                    <Expander.Header>
                                        <TextBlock Style="{StaticResource SectionHintTextStyle}" Text="规则" />
                                    </Expander.Header>
                                    <Border Margin="0,6,0,0"
                                            Style="{StaticResource DialogMetaStripBorderStyle}">
                                        <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Text="每个能力可单独填模型；留空则不参与本轮测试。" />
                                    </Border>
                                </Expander>
                                </Grid>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Grid.ColumnSpan="3"
                        Margin="0,6,0,0"
                        Style="{StaticResource InsetPanelBorderStyle}"
                        Visibility="{Binding IsSingleStationConcurrencyMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x5E76;&#x53D1;&#x538B;&#x6D4B;&#x8BA1;&#x5212;" />
                        <Border Margin="0,4,0,0"
                                Style="{StaticResource DialogMetaStripBorderStyle}">
                            <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                       Text="{Binding ProxyConcurrencyPlanSummary}" />
                        </Border>
                        <Expander Margin="0,6,0,0"
                                  IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Style="{StaticResource SectionHintTextStyle}" Text="阈值说明" />
                            </Expander.Header>
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="{Binding ProxyConcurrencyThresholdHint}" />
                        </Expander>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource MetricCardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="总判定" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource MetricValueTextStyle}"
                               Text="{Binding SingleStationKpiVerdictText}" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource SectionHintTextStyle}"
                               Text="{Binding SingleStationModeDescription}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource MetricCardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="普通延迟" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource MetricValueTextStyle}"
                               Foreground="{StaticResource AccentBrush}"
                               Text="{Binding SingleStationKpiLatencyText}" />
                    <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintTextStyle}" Text="Chat Completions" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource MetricCardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="TTFT" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource MetricValueTextStyle}"
                               Foreground="{StaticResource WarningBrush}"
                               Text="{Binding SingleStationKpiTtftText}" />
                    <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintTextStyle}" Text="首 Token 响应" />
                </StackPanel>
            </Border>

            <Border Grid.Column="6" Style="{StaticResource MetricCardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="吞吐" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource MetricValueTextStyle}"
                               Foreground="{StaticResource SuccessBrush}"
                               Text="{Binding SingleStationKpiThroughputText}" />
                    <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintTextStyle}" Text="tok/s 参考" />
                </StackPanel>
            </Border>

            <Border Grid.Column="8" Style="{StaticResource MetricCardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="协议支持" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource MetricValueTextStyle}"
                               Foreground="{StaticResource LiveBrush}"
                               Text="{Binding SingleStationKpiProtocolText}" />
                    <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintTextStyle}" Text="能力矩阵" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,8,0,0"
                Style="{StaticResource SectionPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.ColumnSpan="3"
                           Style="{StaticResource SectionTitleTextStyle}"
                           Text="测试结果" />

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Margin="0,6,0,0"
                        Padding="10,8"
                        Background="#F8FBFF"
                        BorderBrush="#D6E4FF"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Grid.RowSpan" Value="3" />
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSingleStationConcurrencyMode}" Value="True">
                                    <Setter Property="Grid.RowSpan" Value="1" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource SingleStationToolbarIconButtonStyle}"
                                    Command="{Binding OpenProxySingleChartCommand}"
                                    Content="&#xE740;"
                                    ToolTip="&#x653E;&#x5927;&#x56FE;&#x8868;" />
                            <StackPanel>
                                <TextBlock FontSize="12.2"
                                           FontWeight="SemiBold"
                                           Text="接口实时图表" />
                                <TextBlock Margin="0,2,18,0"
                                           Style="{StaticResource SectionHintTextStyle}"
                                           Text="{Binding SingleStationInlineChartStatusSummary, Mode=OneWay}" />
                            </StackPanel>
                        </DockPanel>

                        <Border Grid.Row="1"
                                Margin="0,7,0,0"
                                Padding="6"
                                Background="#FFFFFF"
                                BorderBrush="#E3ECF7"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Grid MinHeight="178">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Padding="10,4"
                                        Background="#F8FBFF"
                                        BorderBrush="#E3ECF7"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="8,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.0*" />
                                            <ColumnDefinition Width="112" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="1.45*" />
                                            <ColumnDefinition Width="2.35*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="检测项" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource FieldLabelTextStyle}" Text="状态" />
                                        <TextBlock Grid.Column="2" Style="{StaticResource FieldLabelTextStyle}" Text="HTTP" />
                                        <TextBlock Grid.Column="3" Style="{StaticResource FieldLabelTextStyle}" Text="指标" />
                                        <TextBlock Grid.Column="4" Style="{StaticResource FieldLabelTextStyle}" Text="结果" />
                                        <TextBlock Grid.Column="5" Style="{StaticResource FieldLabelTextStyle}" Text="证据" />
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1"
                                              Style="{StaticResource WorkbenchScrollViewerStyle}"
                                              Margin="0,6,0,0"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding HasSingleStationInlineChartRows, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl ItemsSource="{Binding SingleStationInlineChartRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="InlineSingleChartRow"
                                                        Margin="0,0,0,6"
                                                        Padding="10,7"
                                                        Background="#FBFDFF"
                                                        BorderBrush="#D9E6F7"
                                                        BorderThickness="1"
                                                        CornerRadius="13"
                                                        Opacity="0"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <TranslateTransform Y="6" />
                                                    </Border.RenderTransform>
                                                    <Border.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18" />
                                                                    <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.22">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseOut" />
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Border.Triggers>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="2.0*" />
                                                            <ColumnDefinition Width="112" />
                                                            <ColumnDefinition Width="70" />
                                                            <ColumnDefinition Width="1.45*" />
                                                            <ColumnDefinition Width="2.35*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                                                            <TextBlock FontSize="12.5"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Text="{Binding Name}" />
                                                            <TextBlock Margin="0,3,0,0"
                                                                       FontSize="10.3"
                                                                       Foreground="{StaticResource MutedBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Text="{Binding SectionName}" />
                                                        </StackPanel>

                                                        <Border x:Name="InlineSingleStatusBadge"
                                                                Grid.Column="1"
                                                                Margin="0,0,12,0"
                                                                Padding="8,3"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Center"
                                                                Background="#EFF6FF"
                                                                BorderBrush="#BFDBFE"
                                                                BorderThickness="1"
                                                                CornerRadius="999">
                                                            <TextBlock x:Name="InlineSingleStatusText"
                                                                       FontSize="10.5"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource AccentBrush}"
                                                                       Text="{Binding StatusText}" />
                                                        </Border>

                                                        <StackPanel Grid.Column="2" Margin="0,0,12,0" VerticalAlignment="Center">
                                                            <TextBlock FontSize="11.2"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextBrush}"
                                                                       Text="{Binding StatusCodeText}" />
                                                            <TextBlock Margin="0,3,0,0"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource MutedBrush}"
                                                                       Text="{Binding ReceivedDoneText}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="3" Margin="0,0,16,0" VerticalAlignment="Center">
                                                            <DockPanel LastChildFill="True">
                                                                <TextBlock DockPanel.Dock="Left" FontSize="10.5" Foreground="{StaticResource MutedBrush}" Text="指标" />
                                                                <TextBlock HorizontalAlignment="Right"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TextBrush}"
                                                                           Text="{Binding MetricText}" />
                                                            </DockPanel>
                                                            <ProgressBar Margin="0,5,0,0"
                                                                         Height="5"
                                                                         Maximum="1"
                                                                         Value="{Binding MetricRatio, Mode=OneWay}"
                                                                         Foreground="{StaticResource AccentBrush}"
                                                                         Background="#E7EDF5"
                                                                         BorderThickness="0" />
                                                        </StackPanel>

                                                        <TextBlock Grid.Column="4"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxHeight="38"
                                                                   Text="{Binding PreviewText}" />
                                                        <Button Grid.Column="5"
                                                                Margin="10,0,0,0"
                                                                Style="{StaticResource SingleStationToolbarIconButtonStyle}"
                                                                VerticalAlignment="Center"
                                                                Command="{Binding DataContext.OpenProbeTraceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="&#xE946;"
                                                                ToolTip="查看输入输出与判定证据"
                                                                Visibility="{Binding HasTrace, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding StatusTone}" Value="Success">
                                                        <Setter TargetName="InlineSingleStatusBadge" Property="Background" Value="#ECFDF3" />
                                                        <Setter TargetName="InlineSingleStatusBadge" Property="BorderBrush" Value="#A6F4C5" />
                                                        <Setter TargetName="InlineSingleStatusText" Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusTone}" Value="Error">
                                                        <Setter TargetName="InlineSingleChartRow" Property="BorderBrush" Value="#FECACA" />
                                                        <Setter TargetName="InlineSingleStatusBadge" Property="Background" Value="#FEF2F2" />
                                                        <Setter TargetName="InlineSingleStatusBadge" Property="BorderBrush" Value="#FECACA" />
                                                        <Setter TargetName="InlineSingleStatusText" Property="Foreground" Value="#DC2626" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <TextBlock Grid.RowSpan="2"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="填写接口地址后，这里会常驻显示当前接口的测试图表。">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSingleStationInlineChartRows}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Grid.RowSpan="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Margin="0,4,0,0"
                        Padding="10,8"
                        Style="{StaticResource InsetPanelBorderStyle}"
                        Visibility="{Binding IsSingleStationConcurrencyMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource SingleStationToolbarIconButtonStyle}"
                                    VerticalAlignment="Center"
                                    Command="{Binding OpenProxyConcurrencyChartCommand}"
                                    Content="&#xE740;"
                                    ToolTip="&#x653E;&#x5927;&#x56FE;&#x8868;" />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="分档结果" />
                                <TextBlock Margin="10,0,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center"
                                           Text="完成后实时补全成功率、429 / 5xx、延迟、TTFT、tok/s" />
                            </StackPanel>
                        </DockPanel>

                        <Border Grid.Row="1"
                                Margin="0,6,0,0"
                                Padding="6"
                                Background="#F8FAFC"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid MinHeight="250">
                                <ScrollViewer Style="{StaticResource WorkbenchScrollViewerStyle}"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding IsNativeConcurrencyChartVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl ItemsSource="{Binding ProxyChartDialogConcurrencyRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="InlineConcurrencyChartRow"
                                                        Margin="0,0,0,5"
                                                        Padding="8,6"
                                                        MinHeight="56"
                                                        Background="{StaticResource PanelBrushStrong}"
                                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Opacity="0"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <TranslateTransform Y="5" />
                                                    </Border.RenderTransform>
                                                    <Border.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18" />
                                                                    <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.20">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseOut" />
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Border.Triggers>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="92" />
                                                            <ColumnDefinition Width="1.25*" />
                                                            <ColumnDefinition Width="3.2*" />
                                                            <ColumnDefinition Width="2.2*" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                                                            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="{Binding ConcurrencyText}" />
                                                            <TextBlock Margin="8,3,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding SuccessText}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1" Margin="0,0,10,0" VerticalAlignment="Center">
                                                            <Border x:Name="InlineConcurrencyStatusBadge" HorizontalAlignment="Left" Padding="8,3" Background="#ECFDF3" BorderBrush="#A6F4C5" BorderThickness="1" CornerRadius="999">
                                                                <TextBlock x:Name="InlineConcurrencyStatusBadgeText" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" Text="{Binding Verdict}" />
                                                            </Border>
                                                            <TextBlock Margin="0,4,0,0" FontSize="10.5" Foreground="{StaticResource MutedBrush}" Text="{Binding FailureText}" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>

                                                        <Grid Grid.Column="2" Margin="0,0,12,0" VerticalAlignment="Center">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="10" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,5">
                                                                <Grid.ColumnDefinitions><ColumnDefinition Width="52" /><ColumnDefinition Width="*" /><ColumnDefinition Width="62" /></Grid.ColumnDefinitions>
                                                                <TextBlock FontSize="10.5" Foreground="{StaticResource MutedBrush}" Text="成功率" />
                                                                <ProgressBar Grid.Column="1" Height="5" Maximum="1" Value="{Binding SuccessRatio, Mode=OneWay}" Foreground="{StaticResource SuccessBrush}" Background="{StaticResource InputBrush}" BorderThickness="0" />
                                                                <TextBlock Grid.Column="2" HorizontalAlignment="Right" FontSize="10.5" Foreground="{StaticResource TextBrush}" Text="{Binding SuccessRateText}" />
                                                            </Grid>
                                                            <Grid Grid.Row="0" Grid.Column="2" Margin="0,0,0,5">
                                                                <Grid.ColumnDefinitions><ColumnDefinition Width="52" /><ColumnDefinition Width="*" /><ColumnDefinition Width="62" /></Grid.ColumnDefinitions>
                                                                <TextBlock FontSize="10.5" Foreground="{StaticResource MutedBrush}" Text="p50" />
                                                                <ProgressBar Grid.Column="1" Height="5" Maximum="1" Value="{Binding P50ChatLatencyRatio, Mode=OneWay}" Foreground="{StaticResource AccentBrush}" Background="{StaticResource InputBrush}" BorderThickness="0" />
                                                                <TextBlock Grid.Column="2" HorizontalAlignment="Right" FontSize="10.5" Foreground="{StaticResource TextBrush}" Text="{Binding P50ChatLatencyText}" />
                                                            </Grid>
                                                            <Grid Grid.Row="1" Grid.Column="0">
                                                                <Grid.ColumnDefinitions><ColumnDefinition Width="52" /><ColumnDefinition Width="*" /><ColumnDefinition Width="62" /></Grid.ColumnDefinitions>
                                                                <TextBlock FontSize="10.5" Foreground="{StaticResource MutedBrush}" Text="TTFT" />
                                                                <ProgressBar Grid.Column="1" Height="5" Maximum="1" Value="{Binding P95TtftRatio, Mode=OneWay}" Foreground="#F59E0B" Background="{StaticResource InputBrush}" BorderThickness="0" />
                                                                <TextBlock Grid.Column="2" HorizontalAlignment="Right" FontSize="10.5" Foreground="{StaticResource TextBrush}" Text="{Binding P95TtftText}" />
                                                            </Grid>
                                                            <Grid Grid.Row="1" Grid.Column="2">
                                                                <Grid.ColumnDefinitions><ColumnDefinition Width="52" /><ColumnDefinition Width="*" /><ColumnDefinition Width="62" /></Grid.ColumnDefinitions>
                                                                <TextBlock FontSize="10.5" Foreground="{StaticResource MutedBrush}" Text="吞吐" />
                                                                <ProgressBar Grid.Column="1" Height="5" Maximum="1" Value="{Binding TokensPerSecondRatio, Mode=OneWay}" Foreground="#0EA5E9" Background="{StaticResource InputBrush}" BorderThickness="0" />
                                                                <TextBlock Grid.Column="2" HorizontalAlignment="Right" FontSize="10.5" Foreground="{StaticResource TextBrush}" Text="{Binding TokensPerSecondText}" />
                                                            </Grid>
                                                        </Grid>

                                                        <TextBlock Grid.Column="3"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxHeight="34"
                                                                   Text="{Binding Summary}" />
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding StatusTone}" Value="Running">
                                                        <Setter TargetName="InlineConcurrencyChartRow" Property="Background" Value="#F8FBFF" />
                                                        <Setter TargetName="InlineConcurrencyChartRow" Property="BorderBrush" Value="#BFDBFE" />
                                                        <Setter TargetName="InlineConcurrencyStatusBadge" Property="Background" Value="#EFF6FF" />
                                                        <Setter TargetName="InlineConcurrencyStatusBadge" Property="BorderBrush" Value="#BFDBFE" />
                                                        <Setter TargetName="InlineConcurrencyStatusBadgeText" Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusTone}" Value="Warn">
                                                        <Setter TargetName="InlineConcurrencyChartRow" Property="BorderBrush" Value="#FEDF89" />
                                                        <Setter TargetName="InlineConcurrencyStatusBadge" Property="Background" Value="#FFFAEB" />
                                                        <Setter TargetName="InlineConcurrencyStatusBadge" Property="BorderBrush" Value="#FEDF89" />
                                                        <Setter TargetName="InlineConcurrencyStatusBadgeText" Property="Foreground" Value="#B54708" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusTone}" Value="Error">
                                                        <Setter TargetName="InlineConcurrencyChartRow" Property="BorderBrush" Value="#FECACA" />
                                                        <Setter TargetName="InlineConcurrencyStatusBadge" Property="Background" Value="#FEF2F2" />
                                                        <Setter TargetName="InlineConcurrencyStatusBadge" Property="BorderBrush" Value="#FECACA" />
                                                        <Setter TargetName="InlineConcurrencyStatusBadgeText" Property="Foreground" Value="#DC2626" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Text="{Binding ProxyConcurrencyChartStatusSummary, Mode=OneWay}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsNativeConcurrencyChartVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <TextBox Grid.Row="4"
                         Grid.ColumnSpan="3"
                         Margin="0,8,0,0"
                         MinHeight="112"
                         MaxHeight="150"
                         Style="{StaticResource ReadOnlyConsoleTextBoxStyle}"
                         Text="{Binding SingleStationResultSummary, Mode=OneWay}" />
                <Border Grid.Row="5"
                        Grid.ColumnSpan="3"
                        Margin="0,8,0,0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource InsetPanelBorderStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsSingleStationDeepMode}" Value="True" />
                                        <Condition Binding="{Binding HasProxyCapabilityMatrixCells}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="能力矩阵" />
                        <TextBlock Margin="0,3,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="点选单元格后，下方显示路径、模型、状态和结论。" />
                        </StackPanel>

                        <Grid Grid.Row="1"
                              Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ListBox ItemsSource="{Binding VisibleProxyCapabilityMatrixCells}"
                                      SelectedItem="{Binding SelectedProxyCapabilityMatrixCell, Mode=TwoWay}"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      HorizontalContentAlignment="Stretch"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,6,6"
                                                Padding="10,8"
                                                Width="148"
                                                BorderBrush="#D0D5DD"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Background="#FFFFFF">
                                            <StackPanel>
                                                <TextBlock FontSize="11.2"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Name}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           FontSize="10.6"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding StateText}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#475467" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StateText}" Value="&#x652F;&#x6301;">
                                                                    <Setter Property="Foreground" Value="#15803D" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StateText}" Value="&#x5F85;&#x6267;&#x884C;">
                                                                    <Setter Property="Foreground" Value="#175CD3" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StateText}" Value="&#x672A;&#x914D;&#x7F6E;">
                                                                    <Setter Property="Foreground" Value="#667085" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StateText}" Value="&#x9650;&#x6D41;">
                                                                    <Setter Property="Foreground" Value="#B54708" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StateText}" Value="&#x9274;&#x6743;&#x5931;&#x8D25;">
                                                                    <Setter Property="Foreground" Value="#B42318" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StateText}" Value="&#x5931;&#x8D25;">
                                                                    <Setter Property="Foreground" Value="#B42318" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StateText}" Value="&#x5F02;&#x5E38;">
                                                                    <Setter Property="Foreground" Value="#B42318" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StateText}" Value="&#x4E0D;&#x652F;&#x6301;">
                                                                    <Setter Property="Foreground" Value="#B54708" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Margin="0,2,0,0"
                                                           Foreground="#667085"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding ModelText}" />
                                                <TextBlock Margin="0,2,0,0"
                                                           Foreground="#667085"
                                                           Text="{Binding StatusCodeText, StringFormat=HTTP {0}}" />
                                                <TextBlock Margin="0,2,0,0"
                                                           Foreground="#667085"
                                                           Text="{Binding LatencyText}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="#344054"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Summary}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBox Grid.Row="1"
                                     Margin="0,2,0,0"
                                     MinHeight="118"
                                     Style="{StaticResource ReadOnlyConsoleTextBoxStyle}"
                                     Text="{Binding ProxyCapabilityMatrixDetailText, Mode=OneWay}" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
