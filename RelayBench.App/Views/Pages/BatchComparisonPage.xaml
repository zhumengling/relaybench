<UserControl x:Class="RelayBench.App.Views.Pages.BatchComparisonPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Style="{StaticResource MotionPageRootStyle}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="ChartPreviewOverlayTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SectionHintTextStyle}">
            <Setter Property="Foreground" Value="#344054" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="BatchToolbarIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkbenchIconButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>
        <Style x:Key="BatchMotionInsetPanelStyle"
               TargetType="Border"
               BasedOn="{StaticResource MotionDialogPanelStyle}">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="{StaticResource PanelBrushStrong}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
        <Style x:Key="BatchRankingApplyButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="#F8FBFF" />
            <Setter Property="BorderBrush" Value="#C7DAFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="ButtonChrome"
                              Margin="2"
                              RenderTransformOrigin="0.5,0.5"
                              SnapsToDevicePixels="True">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1" />
                            </Grid.RenderTransform>
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="17" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Mouse.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1.08" Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1.08" Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Mouse.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.16" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.16" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF4FF" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#84ADFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="0.9" Duration="0:0:0.07" />
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="0.9" Duration="0:0:0.07" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1.08" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1.08" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#DBEAFE" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#528BFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#98A2B3" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F2F4F7" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#E4E7EC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BatchRankingApplyToastStyle"
               TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="-6" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBatchRankingApplyToastVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="0" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BatchRankingUrlTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SectionHintTextStyle}">
            <Setter Property="FontSize" Value="9.8" />
            <Setter Property="Foreground" Value="#667085" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="BatchRankingMetricBorderStyle"
               TargetType="Border">
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="#F8FBFF" />
            <Setter Property="BorderBrush" Value="#D6E4FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="BatchRankingMetricTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SectionHintTextStyle}">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="10.2" />
            <Setter Property="Foreground" Value="#344054" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="BatchMergedRankingRowBorderStyle"
               TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="MinHeight" Value="70" />
            <Setter Property="Background" Value="#FBFDFF" />
            <Setter Property="BorderBrush" Value="#D9E6F7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0"
                                             To="1"
                                             Duration="0:0:0.26" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                             From="8"
                                             To="0"
                                             Duration="0:0:0.32">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#A9C9F8" />
                    <Setter Property="Background" Value="#F7FBFF" />
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BorderBrush" Value="#86B7FF" />
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#EAF3FF" Offset="0" />
                                <GradientStop Color="#F8FBFF" Offset="1" />
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BatchMergedRankBadgeStyle"
               TargetType="Border">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="#F8FBFF" />
            <Setter Property="BorderBrush" Value="#C9D8EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Rank}" Value="1">
                    <Setter Property="Background" Value="#ECFFF5" />
                    <Setter Property="BorderBrush" Value="#93E7B6" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BatchRankingStatusPillStyle"
               TargetType="Border">
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Background" Value="#FFF7E8" />
            <Setter Property="BorderBrush" Value="#FFD49A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Rank}" Value="1">
                    <Setter Property="Background" Value="#ECFFF5" />
                    <Setter Property="BorderBrush" Value="#9DEBBB" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BatchMetricProgressBarStyle"
               TargetType="ProgressBar">
            <Setter Property="Height" Value="4" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="#E7EDF5" />
            <Setter Property="Foreground" Value="#12A150" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="BatchMergedApplyButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="52" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="ButtonChrome"
                              Margin="2"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Grid.RenderTransform>
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1D4ED8" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#1E40AF" />
                                <Setter TargetName="ButtonChrome" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.04" ScaleY="1.04" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BatchDeepResultCardStyle"
               TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="MinHeight" Value="68" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#F8FBFF" Offset="0" />
                        <GradientStop Color="#FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#D9E6F7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#A9C9F8" />
                    <Setter Property="Background" Value="#F7FBFF" />
                </Trigger>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0"
                                             To="1"
                                             Duration="0:0:0.24" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                             From="6"
                                             To="0"
                                             Duration="0:0:0.28">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BatchDeepStatusPillStyle"
               TargetType="Border">
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Background" Value="#EEF4FF" />
            <Setter Property="BorderBrush" Value="#BBD2FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
    </UserControl.Resources>
    <Grid MinHeight="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1.05*" />
            <RowDefinition Height="1.15*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CommandBarBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="入口组" />
                    <WrapPanel Margin="0,4,0,0">
                        <Border Margin="0,0,6,0"
                                Padding="8,2"
                                Background="#F8FAFC"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                       FontWeight="SemiBold"
                                       Text="入口组" />
                        </Border>
                        <TextBlock Margin="0,2,6,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="→" />
                        <Border Margin="0,0,6,0"
                                Padding="8,2"
                                Background="#F8FAFC"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                       FontWeight="SemiBold"
                                       Text="快测" />
                        </Border>
                        <TextBlock Margin="0,2,6,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="→" />
                        <Border Margin="0,0,6,0"
                                Padding="8,2"
                                Background="#F8FAFC"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                       FontWeight="SemiBold"
                                       Text="候选" />
                        </Border>
                        <TextBlock Margin="0,2,6,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="→" />
                        <Border Padding="8,2"
                                Background="#EEF4FF"
                                BorderBrush="#C7DAFF"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       Text="深测" />
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <Button Command="{Binding OpenProxyBatchEditorCommand}"
                            Style="{StaticResource BatchToolbarIconButtonStyle}"
                            Content="&#xE713;"
                            ToolTip="&#x7BA1;&#x7406;&#x5165;&#x53E3;&#x7EC4;" />
                    <Button Command="{Binding RunProxyBatchCommand}"
                            Style="{StaticResource WorkbenchIconButtonPrimaryStyle}"
                            Content="&#xE768;"
                            ToolTip="&#x5F00;&#x59CB;&#x5FEB;&#x901F;&#x5BF9;&#x6BD4;" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,8,0,0" MinHeight="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="0" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="快速对比" />
                            <TextBlock Margin="0,2,12,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="{Binding BatchComparisonChartStatusSummary, Mode=OneWay}" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Margin="12,0,0,0"
                                Style="{StaticResource BatchToolbarIconButtonStyle}"
                                VerticalAlignment="Center"
                                Command="{Binding OpenBatchComparisonChartCommand}"
                                Content="&#xE740;"
                                ToolTip="&#x653E;&#x5927;&#x56FE;&#x8868;" />
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,6,0,0"
                            Style="{StaticResource BatchMotionInsetPanelStyle}">
                        <Grid x:Name="BatchComparisonChartPreviewHost"
                              Background="Transparent"
                              ClipToBounds="True"
                              SizeChanged="BatchComparisonChartPreviewHost_OnSizeChanged">
                            <Border Cursor="Hand"
                                    Visibility="Collapsed">
                                <Border.InputBindings>
                                    <MouseBinding Gesture="LeftClick"
                                                  Command="{Binding OpenBatchComparisonChartCommand}" />
                                </Border.InputBindings>
                                <Grid>
                                    <Image Margin="4"
                                           Style="{StaticResource AnimatedChartImageStyle}"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           Stretch="Uniform"
                                           Source="{Binding BatchComparisonChartImage, Mode=OneWay, NotifyOnTargetUpdated=True}" />
                                    <Border HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,10,10"
                                            Padding="8,3"
                                            Background="#F9FAFBEA"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <TextBlock Style="{StaticResource ChartPreviewOverlayTextStyle}"
                                                   Text="点击放大" />
                                    </Border>
                                </Grid>
                            </Border>

                            <TextBlock HorizontalAlignment="Center"
                                       Visibility="Collapsed"
                                       VerticalAlignment="Center"
                                       Text="快测后显示排行榜预览。">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasBatchComparisonChart}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Margin="2,0,12,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="78" />
                                        <ColumnDefinition Width="1.55*" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="0.86*" />
                                        <ColumnDefinition Width="0.86*" />
                                        <ColumnDefinition Width="0.86*" />
                                        <ColumnDefinition Width="0.86*" />
                                        <ColumnDefinition Width="0.95*" />
                                        <ColumnDefinition Width="76" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="候选 / 排名" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource FieldLabelTextStyle}" Text="API URL" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource FieldLabelTextStyle}" Text="状态" />
                                    <TextBlock Grid.Column="3" Style="{StaticResource FieldLabelTextStyle}" Text="综合" />
                                    <TextBlock Grid.Column="4" Style="{StaticResource FieldLabelTextStyle}" Text="对话" />
                                    <TextBlock Grid.Column="5" Style="{StaticResource FieldLabelTextStyle}" Text="TTFT" />
                                    <TextBlock Grid.Column="6" Style="{StaticResource FieldLabelTextStyle}" Text="吞吐" />
                                    <TextBlock Grid.Column="7" Style="{StaticResource FieldLabelTextStyle}" Text="结论" />
                                    <TextBlock Grid.Column="8" Style="{StaticResource FieldLabelTextStyle}" Text="操作" />
                                </Grid>

                                <ScrollViewer Grid.Row="1"
                                              Style="{StaticResource WorkbenchScrollViewerStyle}"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              CanContentScroll="False">
                                    <ItemsControl ItemsSource="{Binding ProxyBatchRankingRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource BatchMergedRankingRowBorderStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="78" />
                                                            <ColumnDefinition Width="1.55*" />
                                                            <ColumnDefinition Width="110" />
                                                            <ColumnDefinition Width="0.86*" />
                                                            <ColumnDefinition Width="0.86*" />
                                                            <ColumnDefinition Width="0.86*" />
                                                            <ColumnDefinition Width="0.86*" />
                                                            <ColumnDefinition Width="0.95*" />
                                                            <ColumnDefinition Width="76" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0"
                                                                    Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <CheckBox Margin="0,0,8,0"
                                                                      VerticalAlignment="Center"
                                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                            <Border Style="{StaticResource BatchMergedRankBadgeStyle}">
                                                                <TextBlock HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding RankText}" />
                                                            </Border>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1"
                                                                    Margin="4,0,14,0"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock FontSize="12.4"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding EntryName}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Margin="0,2,0,0"
                                                                       Style="{StaticResource BatchRankingUrlTextStyle}"
                                                                       Text="{Binding BaseUrl}" />
                                                            <TextBlock Margin="0,2,0,0"
                                                                       Style="{StaticResource SectionHintTextStyle}"
                                                                       Text="{Binding CandidateHint}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="2"
                                                                    VerticalAlignment="Center">
                                                            <Border Style="{StaticResource BatchRankingStatusPillStyle}">
                                                                <TextBlock FontWeight="SemiBold"
                                                                           Foreground="#0F7A42"
                                                                           Text="{Binding QuickVerdict}" />
                                                            </Border>
                                                            <TextBlock Margin="2,5,0,0"
                                                                       Style="{StaticResource SectionHintTextStyle}"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding RunCountText}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="3"
                                                                    Margin="0,0,14,0"
                                                                    VerticalAlignment="Center">
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock DockPanel.Dock="Left"
                                                                           Style="{StaticResource SectionHintTextStyle}"
                                                                           Text="综合" />
                                                                <TextBlock DockPanel.Dock="Right"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding CompositeScoreText}" />
                                                            </DockPanel>
                                                             <ProgressBar Margin="0,6,0,0"
                                                                          Style="{StaticResource BatchMetricProgressBarStyle}"
                                                                          Foreground="#12A150"
                                                                          Value="{Binding CompositeProgressValue, Mode=OneWay}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="4"
                                                                    Margin="0,0,14,0"
                                                                    VerticalAlignment="Center">
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock DockPanel.Dock="Left"
                                                                           Style="{StaticResource SectionHintTextStyle}"
                                                                           Text="对话" />
                                                                <TextBlock DockPanel.Dock="Right"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding ChatLatencyText}" />
                                                            </DockPanel>
                                                             <ProgressBar Margin="0,6,0,0"
                                                                          Style="{StaticResource BatchMetricProgressBarStyle}"
                                                                          Foreground="#2563EB"
                                                                          Value="{Binding ChatLatencyProgressValue, Mode=OneWay}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="5"
                                                                    Margin="0,0,14,0"
                                                                    VerticalAlignment="Center">
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock DockPanel.Dock="Left"
                                                                           Style="{StaticResource SectionHintTextStyle}"
                                                                           Text="TTFT" />
                                                                <TextBlock DockPanel.Dock="Right"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding TtftText}" />
                                                            </DockPanel>
                                                             <ProgressBar Margin="0,6,0,0"
                                                                          Style="{StaticResource BatchMetricProgressBarStyle}"
                                                                          Foreground="#F59E0B"
                                                                          Value="{Binding TtftProgressValue, Mode=OneWay}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="6"
                                                                    Margin="0,0,14,0"
                                                                    VerticalAlignment="Center">
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock DockPanel.Dock="Left"
                                                                           Style="{StaticResource SectionHintTextStyle}"
                                                                           Text="吞吐" />
                                                                <TextBlock DockPanel.Dock="Right"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding TokensPerSecondText}" />
                                                            </DockPanel>
                                                             <ProgressBar Margin="0,6,0,0"
                                                                          Style="{StaticResource BatchMetricProgressBarStyle}"
                                                                          Foreground="#16A34A"
                                                                          Value="{Binding TokensPerSecondProgressValue, Mode=OneWay}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="7"
                                                                    Margin="0,0,14,0"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding Verdict}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Margin="0,3,0,0"
                                                                       Style="{StaticResource SectionHintTextStyle}"
                                                                       Text="{Binding SecondaryText}" />
                                                        </StackPanel>

                                                        <Button Grid.Column="8"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Right"
                                                                Style="{StaticResource BatchMergedApplyButtonStyle}"
                                                                Command="{Binding DataContext.ApplyRankingRowToCodexAppsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="应用" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Visibility="Collapsed"
                    Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="候选列表" />
                        <TextBlock Margin="0,2,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="在这里勾选候选项" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  Style="{StaticResource WorkbenchScrollViewerStyle}"
                                  Margin="0,6,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                        <ItemsControl ItemsSource="{Binding ProxyBatchRankingRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,4"
                                            Padding="7,5"
                                            Background="{StaticResource InputBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      Margin="0,1,8,0"
                                                      VerticalAlignment="Top"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}" />

                                            <Border Grid.Column="1"
                                                    Width="34"
                                                    Height="20"
                                                    Margin="0,1,8,0"
                                                    VerticalAlignment="Top"
                                                    Background="Transparent"
                                                    BorderBrush="{StaticResource AccentBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Rank}" />
                                            </Border>

                                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding EntryName}" />
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Style="{StaticResource SectionHintTextStyle}"
                                                               Text="{Binding Model, StringFormat=模型：{0}}" />
                                                </DockPanel>
                                                <TextBlock Style="{StaticResource BatchRankingUrlTextStyle}" Text="{Binding BaseUrl}" />
                                                <WrapPanel Margin="0,2,0,0">
                                                    <Border Margin="0,0,6,0"
                                                            Padding="6,1"
                                                            Background="{StaticResource InputBrush}"
                                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8">
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Text="{Binding QuickVerdict}" />
                                                    </Border>
                                                    <Border Padding="6,1"
                                                            Background="{StaticResource InputBrush}"
                                                            BorderBrush="{StaticResource AccentBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8">
                                                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding DeepStatus}" />
                                                    </Border>
                                                </WrapPanel>
                                                <Border Style="{StaticResource BatchRankingMetricBorderStyle}">
                                                    <TextBlock Style="{StaticResource BatchRankingMetricTextStyle}"
                                                               Text="{Binding QuickMetrics}" />
                                                </Border>
                                                <Expander Margin="0,3,0,0"
                                                          Visibility="Collapsed"
                                                          IsExpanded="False">
                                                    <Expander.Header>
                                                        <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                                                   Text="详情" />
                                                    </Expander.Header>
                                                    <StackPanel Margin="0,6,0,0">
                                                        <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                                                   Text="{Binding CapabilitySummary}" />
                                                        <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                                                   Text="{Binding DeepSummary}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Expander>
                                            </StackPanel>

                                            <Button Grid.Column="3"
                                                    VerticalAlignment="Center"
                                                    Style="{StaticResource BatchRankingApplyButtonStyle}"
                                                    Command="{Binding DataContext.ApplyRankingRowToCodexAppsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="&#x5E94;&#x7528;&#x5230; Codex &#x7CFB;&#x5217;&#x8F6F;&#x4EF6;">
                                                <TextBlock FontSize="13.4"
                                                           FontWeight="SemiBold"
                                                           Text="&#x2726;" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Panel.ZIndex="9"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,10,0"
                Padding="10,7"
                MaxWidth="420"
                Background="#ECFDF3"
                BorderBrush="#ABEFC6"
                BorderThickness="1"
                CornerRadius="12"
                Style="{StaticResource BatchRankingApplyToastStyle}">
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center"
                           FontSize="12.6"
                           Foreground="#067647"
                           Text="&#x2713;" />
                <TextBlock Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#067647"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Text="{Binding BatchRankingApplyToastMessage, Mode=OneWay}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,8,0,0" MinHeight="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="0" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Visibility="Collapsed"
                    Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="快测摘要" />
                        <TextBlock Margin="0,2,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="保留本轮快测摘要，方便对照。" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Margin="0,6,0,0"
                             Style="{StaticResource ReadOnlyConsoleTextBoxStyle}"
                             Text="{Binding ProxyBatchSummary, Mode=OneWay}" />
                </Grid>
            </Border>

            <Border Grid.Column="0" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="深度测试" />
                            <TextBlock Margin="0,2,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="{Binding BatchSelectionSummary, Mode=OneWay}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button MinWidth="78"
                                    Margin="0,0,10,0"
                                    Style="{StaticResource BatchToolbarIconButtonStyle}"
                                    Command="{Binding ToggleBatchDeepSelectionCommand}"
                                    IsEnabled="{Binding CanToggleBatchDeepSelection, Mode=OneWay}"
                                    Content="&#xE8EF;"
                                    ToolTip="{Binding BatchDeepSelectionToggleText, Mode=OneWay}" />
                            <Button Command="{Binding RunSelectedBatchDeepTestsCommand}"
                                    Style="{StaticResource WorkbenchIconButtonPrimaryStyle}"
                                    IsEnabled="{Binding CanRunSelectedBatchDeepTests, Mode=OneWay}"
                                    Content="&#xE768;"
                                    ToolTip="&#x5F00;&#x59CB;&#x6DF1;&#x6D4B;" />
                        </StackPanel>
                    </Grid>

                    <Expander Grid.Row="1"
                              Visibility="Collapsed"
                              Margin="0,6,0,0"
                              IsExpanded="False">
                        <Expander.Header>
                            <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                       Text="说明" />
                        </Expander.Header>
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="只复用已勾选项的 Base URL / Key / Model" />
                    </Expander>

                    <Border x:Name="BatchDeepComparisonChartPreviewHost"
                            Grid.Row="2"
                            Margin="0,8,0,0"
                            Style="{StaticResource BatchMotionInsetPanelStyle}"
                            Padding="10"
                            Background="#F8FBFF"
                            BorderBrush="#D6E4FF"
                            BorderThickness="1"
                            CornerRadius="10"
                            SizeChanged="BatchDeepComparisonChartPreviewHost_OnSizeChanged">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Margin="2,0,2,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="12.2"
                                               FontWeight="SemiBold"
                                               Text="候选深测结果" />
                                    <TextBlock Margin="0,2,18,0"
                                               Style="{StaticResource SectionHintTextStyle}"
                                               Text="{Binding BatchDeepComparisonChartStatusSummary, Mode=OneWay}" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Style="{StaticResource BatchToolbarIconButtonStyle}"
                                        VerticalAlignment="Center"
                                        Command="{Binding OpenBatchDeepComparisonChartCommand}"
                                        Content="&#xE9D2;"
                                        ToolTip="&#x67E5;&#x770B;&#x603B;&#x89C8;" />
                            </Grid>

                            <ScrollViewer Grid.Row="1"
                                          Style="{StaticResource WorkbenchScrollViewerStyle}"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="False">
                                <ItemsControl ItemsSource="{Binding ProxyBatchRankingRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource BatchDeepResultCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="78" />
                                                        <ColumnDefinition Width="1.65*" />
                                                        <ColumnDefinition Width="112" />
                                                        <ColumnDefinition Width="1.1*" />
                                                        <ColumnDefinition Width="2.2*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <Border Style="{StaticResource BatchMergedRankBadgeStyle}">
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding RankText}" />
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1"
                                                                Margin="4,0,14,0"
                                                                VerticalAlignment="Center">
                                                        <TextBlock FontSize="12.4"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding EntryName}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Margin="0,2,0,0"
                                                                   Style="{StaticResource BatchRankingUrlTextStyle}"
                                                                   Text="{Binding BaseUrl}" />
                                                        <TextBlock Margin="0,2,0,0"
                                                                   Style="{StaticResource SectionHintTextStyle}"
                                                                   Text="{Binding DeepSelectionText}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2"
                                                                VerticalAlignment="Center">
                                                        <Border Style="{StaticResource BatchDeepStatusPillStyle}">
                                                            <TextBlock FontWeight="SemiBold"
                                                                       Foreground="{StaticResource AccentBrush}"
                                                                       Text="{Binding DeepStatus}" />
                                                        </Border>
                                                        <TextBlock Margin="2,5,0,0"
                                                                   Style="{StaticResource SectionHintTextStyle}"
                                                                   Text="{Binding DeepCheckedAtText}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="3"
                                                                Margin="0,0,18,0"
                                                                VerticalAlignment="Center">
                                                        <DockPanel LastChildFill="False">
                                                            <TextBlock DockPanel.Dock="Left"
                                                                       Style="{StaticResource SectionHintTextStyle}"
                                                                       Text="通过概况" />
                                                            <TextBlock DockPanel.Dock="Right"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding DeepPassText}" />
                                                        </DockPanel>
                                                        <ProgressBar Margin="0,7,0,0"
                                                                     Style="{StaticResource BatchMetricProgressBarStyle}"
                                                                     Foreground="#2563EB"
                                                                     Value="{Binding DeepProgressValue, Mode=OneWay}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="4"
                                                                VerticalAlignment="Center">
                                                        <TextBlock FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding DeepHeadline}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Margin="0,3,0,0"
                                                                   Style="{StaticResource SectionHintTextStyle}"
                                                                   Text="{Binding DeepCompactSummary}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="1"
                               Visibility="Collapsed"
                               Margin="0,3,0,0"
                               Style="{StaticResource SectionHintTextStyle}"
                               Text="{Binding BatchDeepComparisonChartStatusSummary, Mode=OneWay}" />

                    <Border Grid.Row="2"
                            Visibility="Collapsed"
                            Margin="0,6,0,0"
                            Style="{StaticResource InsetPanelBorderStyle}">
                        <Grid>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="开始深测后，这里会显示总览图。">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasBatchDeepComparisonChart}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Border x:Name="BatchDeepComparisonChartPreviewHostLegacy"
                                    Background="Transparent"
                                    ClipToBounds="True"
                                    Cursor="Hand"
                                    SizeChanged="BatchDeepComparisonChartPreviewHost_OnSizeChanged"
                                    Visibility="{Binding HasBatchDeepComparisonChart, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Border.InputBindings>
                                    <MouseBinding Gesture="LeftClick"
                                                  Command="{Binding OpenBatchDeepComparisonChartCommand}" />
                                </Border.InputBindings>
                                <Grid>
                                    <Image Margin="4"
                                           Style="{StaticResource AnimatedChartImageStyle}"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           Stretch="Uniform"
                                           Source="{Binding BatchDeepComparisonChartImage, Mode=OneWay, NotifyOnTargetUpdated=True}" />
                                    <Border HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,10,10"
                                            Padding="8,3"
                                            Background="#F9FAFBEA"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <TextBlock Style="{StaticResource ChartPreviewOverlayTextStyle}"
                                                   Text="点击放大" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <TextBox Grid.Row="2"
                             Visibility="Collapsed"
                             Margin="0,6,0,0"
                             Style="{StaticResource ReadOnlyConsoleTextBoxStyle}"
                             Text="{Binding BatchDeepTestSummary, Mode=OneWay}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
