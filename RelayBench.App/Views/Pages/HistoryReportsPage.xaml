<UserControl x:Class="RelayBench.App.Views.Pages.HistoryReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="HistoryRunListBoxStyle"
               TargetType="ListBox"
               BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="HistoryRunListBoxItemStyle"
               TargetType="ListBoxItem"
               BasedOn="{StaticResource ListBoxItemStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Padding" Value="9,8" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource TabHoverBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#84ADFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EEF4FF" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryMetaStripBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource InsetPanelBorderStyle}">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#DCE6F8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource SectionPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="历史报告" />
                    <TextBlock Margin="0,3,0,0"
                               Style="{StaticResource SectionHintTextStyle}"
                               Text="按运行时间倒序显示" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,6,0,0"
                        Style="{StaticResource HistoryMetaStripBorderStyle}">
                    <TextBlock Style="{StaticResource SectionHintTextStyle}"
                               Text="左侧看预览，右侧看详情。" />
                </Border>

                <Border Grid.Row="2"
                        Margin="0,6,0,0"
                        Style="{StaticResource InsetPanelBorderStyle}">
                    <Grid>
                        <ListBox ItemsSource="{Binding HistoryRunItems}"
                                 SelectedItem="{Binding SelectedHistoryRunItem, Mode=TwoWay}"
                                 ItemContainerStyle="{StaticResource HistoryRunListBoxItemStyle}"
                                 Style="{StaticResource HistoryRunListBoxStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="34"
                                                Height="20"
                                                Margin="0,0,10,0"
                                                VerticalAlignment="Top"
                                                Background="Transparent"
                                                BorderBrush="{StaticResource AccentBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Rank}" />
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding DisplayTitle}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="1"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Top"
                                                           Style="{StaticResource SectionHintTextStyle}"
                                                           Text="{Binding TimestampText}" />
                                            </Grid>

                                            <WrapPanel Margin="0,4,0,0">
                                                <Border Margin="0,0,6,0"
                                                        Padding="6,1"
                                                        Background="#F8FAFC"
                                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding ScopeTag}" />
                                                </Border>
                                                <Border Padding="6,1"
                                                        Background="#EEF4FF"
                                                        BorderBrush="#C7DAFF"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                    <TextBlock Foreground="{StaticResource AccentBrush}"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding CategoryTag}" />
                                                </Border>
                                            </WrapPanel>

                                            <TextBlock Margin="0,4,0,0"
                                                       Style="{StaticResource SectionHintTextStyle}"
                                                       Text="{Binding PreviewText}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="暂无历史记录。">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasHistoryRunItems}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.14*" />
                <RowDefinition Height="6" />
                <RowDefinition Height="0.86*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="运行详情" />
                        <TextBlock Margin="0,3,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="默认选中最新记录" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,6,0,0"
                            Style="{StaticResource HistoryMetaStripBorderStyle}">
                        <StackPanel>
                            <TextBlock FontSize="11.8"
                                       FontWeight="SemiBold"
                                       Text="{Binding SelectedHistoryRunTitle, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,3,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="{Binding SelectedHistoryRunMeta, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <Expander Margin="0,6,0,0"
                                      IsExpanded="False">
                                <Expander.Header>
                                    <TextBlock Style="{StaticResource SectionHintTextStyle}" Text="补充信息" />
                                </Expander.Header>
                                <StackPanel Margin="0,6,0,0">
                                    <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                               Text="{Binding SelectedHistoryRunOriginalTitle, Mode=OneWay}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource SectionHintTextStyle}"
                                               Text="{Binding SelectedHistoryRunPreviewText, Mode=OneWay}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <TextBox Grid.Row="2"
                             Margin="0,6,0,0"
                             Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                             Text="{Binding SelectedHistoryRunDetailText, Mode=OneWay}" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="报告导出" />
                        <TextBlock Margin="0,3,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="导出当前结果并在此查看摘要" />
                    </StackPanel>

                    <Button Grid.Row="1"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding ExportCurrentReportCommand}"
                            Content="导出当前报告" />
                    <TextBox Grid.Row="2"
                             Margin="0,6,0,0"
                             Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                             Text="{Binding ReportArchiveSummary, Mode=OneWay}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
