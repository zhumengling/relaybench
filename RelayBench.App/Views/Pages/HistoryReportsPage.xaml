<UserControl x:Class="RelayBench.App.Views.Pages.HistoryReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Style="{StaticResource MotionPageRootStyle}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="HistoryRunListBoxStyle"
               TargetType="ListBox"
               BasedOn="{StaticResource {x:Type ListBox}}">
            <Style.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource WorkbenchScrollBarStyle}" />
                <Style TargetType="ScrollViewer" BasedOn="{StaticResource WorkbenchScrollViewerStyle}" />
            </Style.Resources>
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,0,12,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="HistoryRunListBoxItemStyle"
               TargetType="ListBoxItem"
               BasedOn="{StaticResource ListBoxItemStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Padding" Value="9,8" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource TabHoverBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#84ADFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EEF4FF" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryMetaStripBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource InsetPanelBorderStyle}">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#DCE6F8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </UserControl.Resources>

    <Grid MinHeight="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CommandBarBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel ClipToBounds="True">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="&#x5386;&#x53F2;&#x62A5;&#x544A;" />
                    <TextBlock Margin="0,2,0,0"
                               Style="{StaticResource SectionHintTextStyle}"
                               TextTrimming="CharacterEllipsis"
                               Text="&#x6309;&#x8FD0;&#x884C;&#x65F6;&#x95F4;&#x5012;&#x5E8F;&#x67E5;&#x770B;&#x8BCA;&#x65AD;&#x3001;&#x5BFC;&#x51FA;&#x548C;&#x590D;&#x76D8;&#x6458;&#x8981;" />
                </StackPanel>
                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        Command="{Binding ExportCurrentReportCommand}"
                        Style="{StaticResource WorkbenchIconButtonPrimaryStyle}"
                        Content="&#xE8E5;"
                        ToolTip="&#x5BFC;&#x51FA;&#x5F53;&#x524D;&#x62A5;&#x544A;" />
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,8,0,0"
              MinHeight="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="324" MinWidth="300" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" MinWidth="620" />
            </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource SectionPanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="&#x65F6;&#x95F4;&#x7EBF;" />
                    <TextBlock Margin="0,3,0,0"
                               Style="{StaticResource SectionHintTextStyle}"
                               Text="&#x6309;&#x8FD0;&#x884C;&#x65F6;&#x95F4;&#x5012;&#x5E8F;&#x663E;&#x793A;" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,6,0,0"
                        Style="{StaticResource HistoryMetaStripBorderStyle}">
                    <TextBlock Style="{StaticResource SectionHintTextStyle}"
                               Text="&#x9009;&#x4E2D;&#x4E00;&#x6761;&#x540E;&#xFF0C;&#x53F3;&#x4FA7;&#x9605;&#x8BFB;&#x5B8C;&#x6574;&#x62A5;&#x544A;&#x3002;" />
                </Border>

                <Border Grid.Row="2"
                        Margin="0,6,0,0"
                        Style="{StaticResource InsetPanelBorderStyle}">
                    <Grid>
                        <ListBox ItemsSource="{Binding HistoryRunItems}"
                                 SelectedItem="{Binding SelectedHistoryRunItem, Mode=TwoWay}"
                                 ItemContainerStyle="{StaticResource HistoryRunListBoxItemStyle}"
                                 Style="{StaticResource HistoryRunListBoxStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid>
                                            <Rectangle Width="1"
                                                       HorizontalAlignment="Center"
                                                       Fill="#D0D7E2" />
                                            <Border Width="18"
                                                    Height="18"
                                                    Margin="0,2,0,0"
                                                    VerticalAlignment="Top"
                                                    Background="#FFFFFF"
                                                    BorderBrush="{StaticResource AccentBrush}"
                                                    BorderThickness="2"
                                                    CornerRadius="9">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="8.6"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           Text="{Binding Rank}" />
                                            </Border>
                                        </Grid>

                                        <Grid Grid.Column="1">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding DisplayTitle}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding DisplayTitle}" />
                                            <StackPanel Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        HorizontalAlignment="Right">
                                                <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                                           TextAlignment="Right"
                                                           ToolTip="{Binding TimestampText}"
                                                           Text="{Binding DateText}" />
                                                <TextBlock Margin="0,1,0,0"
                                                           Style="{StaticResource SectionHintTextStyle}"
                                                           TextAlignment="Right"
                                                           ToolTip="{Binding TimestampText}"
                                                           Text="{Binding TimeText}" />
                                            </StackPanel>

                                            <WrapPanel Grid.Row="1"
                                                       Grid.ColumnSpan="2"
                                                       Margin="0,4,0,0">
                                                <Border Margin="0,0,6,0"
                                                        Padding="6,1"
                                                        Background="#F8FAFC"
                                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                    <TextBlock FontSize="10.4"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding ScopeTag}" />
                                                </Border>
                                                <Border Padding="6,1"
                                                        Background="#EEF4FF"
                                                        BorderBrush="#C7DAFF"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                    <TextBlock FontSize="10.4"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding CategoryTag}" />
                                                </Border>
                                            </WrapPanel>

                                            <TextBlock Grid.Row="2"
                                                       Grid.ColumnSpan="2"
                                                       Margin="0,4,0,0"
                                                       Style="{StaticResource SectionHintTextStyle}"
                                                       Text="{Binding PreviewText}"
                                                       MaxHeight="32"
                                                       ToolTip="{Binding PreviewText}"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Width="260"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasHistoryRunItems}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Image Height="128"
                                   Source="/Assets/Images/history-reports-empty.png"
                                   Stretch="Uniform" />
                            <TextBlock Margin="0,8,0,0"
                                       HorizontalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="暂无历史记录" />
                            <TextBlock Margin="0,4,0,0"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="完成一次诊断后，这里会显示报告和导出信息。"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.14*" />
                <RowDefinition Height="6" />
                <RowDefinition Height="0.86*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="&#x62A5;&#x544A;&#x9605;&#x8BFB;&#x5668;" />
                        <TextBlock Margin="0,3,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="&#x9ED8;&#x8BA4;&#x9009;&#x4E2D;&#x6700;&#x65B0;&#x8BB0;&#x5F55;" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,6,0,0"
                            Style="{StaticResource HistoryMetaStripBorderStyle}">
                        <StackPanel>
                            <TextBlock FontSize="11.8"
                                       FontWeight="SemiBold"
                                       Text="{Binding SelectedHistoryRunTitle, Mode=OneWay}"
                                       MaxHeight="38"
                                       ToolTip="{Binding SelectedHistoryRunTitle, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,3,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="{Binding SelectedHistoryRunMeta, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <Expander Margin="0,6,0,0"
                                      IsExpanded="False">
                                <Expander.Header>
                                    <TextBlock Style="{StaticResource SectionHintTextStyle}" Text="补充信息" />
                                </Expander.Header>
                                <StackPanel Margin="0,6,0,0">
                                    <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                               Text="{Binding SelectedHistoryRunOriginalTitle, Mode=OneWay}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource SectionHintTextStyle}"
                                               Text="{Binding SelectedHistoryRunPreviewText, Mode=OneWay}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <TabControl Grid.Row="2"
                                Margin="0,6,0,0">
                        <TabItem Header="&#x62A5;&#x544A;">
                            <TextBox Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                                     Text="{Binding SelectedHistoryRunDetailText, Mode=OneWay}" />
                        </TabItem>
                        <TabItem Header="&#x6458;&#x8981;">
                            <TextBox Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                                     Text="{Binding SelectedHistoryRunPreviewText, Mode=OneWay}" />
                        </TabItem>
                        <TabItem Header="&#x5143;&#x4FE1;&#x606F;">
                            <TextBox Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                                     Text="{Binding SelectedHistoryRunOriginalTitle, Mode=OneWay}" />
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="&#x62A5;&#x544A;&#x5BFC;&#x51FA;" />
                        <TextBlock Margin="0,3,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="&#x5BFC;&#x51FA;&#x5F53;&#x524D;&#x7ED3;&#x679C;&#x5E76;&#x5728;&#x6B64;&#x67E5;&#x770B;&#x5F52;&#x6863;&#x6458;&#x8981;" />
                    </StackPanel>

                    <Button Grid.Row="1"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding ExportCurrentReportCommand}"
                            Content="&#x5BFC;&#x51FA;&#x5F53;&#x524D;&#x62A5;&#x544A;" />
                    <TextBox Grid.Row="2"
                             Margin="0,6,0,0"
                             Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                             Text="{Binding ReportArchiveSummary, Mode=OneWay}" />
                </Grid>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</UserControl>
