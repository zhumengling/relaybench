<UserControl x:Class="RelayBench.App.Views.Pages.ModelChatPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RelayBench.App.Controls"
             xmlns:infra="clr-namespace:RelayBench.App.Infrastructure"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             Style="{StaticResource MotionPageRootStyle}"
             PreviewKeyDown="ModelChatPage_PreviewKeyDown"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="ChatRecordToolButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkbenchIconButtonStyle}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Margin" Value="0,0,3,0" />
        </Style>
        <Style x:Key="ChatSessionIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkbenchIconButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>
        <Style x:Key="ChatSessionDangerIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkbenchIconButtonDangerStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style x:Key="ChatMessageBubbleBorderStyle" TargetType="Border">
            <Setter Property="MaxWidth" Value="920" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
    </UserControl.Resources>

    <Grid MinHeight="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CommandBarBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource StatusPillBorderStyle}">
                        <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               Text="{Binding ChatModeSummary}" />
                    </Border>
                    <TextBlock Grid.Column="2"
                               Style="{StaticResource SectionHintTextStyle}"
                               Text="{Binding ChatSelectedModelsSummary}"
                               TextTrimming="CharacterEllipsis" />
                </Grid>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               MaxWidth="360"
                               Style="{StaticResource SectionHintTextStyle}"
                               Text="{Binding ChatStatusMessage}"
                               TextTrimming="CharacterEllipsis" />
                    <Button Style="{StaticResource ChatSessionIconButtonStyle}"
                            Command="{Binding ToggleChatSettingsPanelCommand}"
                            Content="&#xE713;"
                            ToolTip="&#x6253;&#x5F00;&#x53C2;&#x6570;" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,8,0,8" MinHeight="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="188" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Text="&#x8BB0;&#x5F55;" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ChatSessionIconButtonStyle}"
                                Command="{Binding NewChatSessionCommand}"
                                Content="&#xE710;"
                                ToolTip="&#x65B0;&#x5EFA;&#x4F1A;&#x8BDD;" />
                        <Button Grid.Column="2"
                                Style="{StaticResource ChatSessionDangerIconButtonStyle}"
                                Command="{Binding DeleteChatSessionCommand}"
                                Content="&#xE74D;"
                                ToolTip="&#x5220;&#x9664;&#x5F53;&#x524D;&#x4F1A;&#x8BDD;" />
                    </Grid>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding ChatSessions}"
                             SelectedItem="{Binding SelectedChatSession, Mode=TwoWay}"
                             Style="{StaticResource PresetCardListBoxStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6"
                                        Padding="8,7"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F8FAFC" />
                                            <Setter Property="BorderBrush" Value="#E4E7EC" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter Property="Background" Value="#F8FBFF" />
                                                    <Setter Property="BorderBrush" Value="#BFDBFE" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter Property="Background" Value="#EFF6FF" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid Visibility="{Binding IsNotRenaming, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock FontSize="11.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="#101828"
                                                           Text="{Binding Title}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Border Grid.Column="1"
                                                        Margin="6,0,0,0"
                                                        Padding="5,1"
                                                        Background="#EEF4FF"
                                                        BorderBrush="#B2CCFF"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        Visibility="{Binding IsManualTitle, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock FontSize="9.5"
                                                               FontWeight="SemiBold"
                                                               Foreground="#175CD3"
                                                               Text="&#x81EA;&#x5B9A;" />
                                                </Border>
                                            </Grid>
                                            <TextBlock Grid.Row="1"
                                                       Margin="0,3,0,0"
                                                       FontSize="10"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Text="{Binding Summary}" />
                                            <WrapPanel Grid.Row="2" Margin="0,6,0,0">
                                                <Button Style="{StaticResource ChatRecordToolButtonStyle}"
                                                        Command="{Binding DataContext.BeginRenameChatSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="&#xE70F;"
                                                        ToolTip="&#x91CD;&#x547D;&#x540D;" />
                                            </WrapPanel>
                                        </Grid>

                                        <Grid Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="6" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                     Text="{Binding DraftTitle, UpdateSourceTrigger=PropertyChanged}"
                                                     KeyDown="ChatSessionRenameTextBox_KeyDown" />
                                            <WrapPanel Grid.Row="2" HorizontalAlignment="Right">
                                                <Button Style="{StaticResource ChatRecordToolButtonStyle}"
                                                        Command="{Binding DataContext.CommitRenameChatSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="&#xE74E;"
                                                        ToolTip="&#x4FDD;&#x5B58;" />
                                                <Button Style="{StaticResource ChatRecordToolButtonStyle}"
                                                        Command="{Binding DataContext.CancelRenameChatSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="&#xE711;"
                                                        ToolTip="&#x53D6;&#x6D88;" />
                                            </WrapPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <ScrollViewer x:Name="ChatMessagesScrollViewer"
                                  Style="{StaticResource WorkbenchScrollViewerStyle}"
                                  ScrollChanged="ChatMessagesScrollViewer_ScrollChanged"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl Margin="0,0,18,0"
                                      ItemsSource="{Binding ChatMessages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Border Style="{StaticResource ChatMessageBubbleBorderStyle}"
                                            HorizontalAlignment="{Binding BubbleHorizontalAlignment}"
                                            Margin="{Binding BubbleOuterMargin}"
                                            Width="{Binding BubbleWidth}"
                                            Background="{Binding BubbleBackground}"
                                            BorderBrush="{Binding BubbleBorderBrush}"
                                            Visibility="{Binding IsStandardMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock FontSize="12"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               Foreground="#101828"
                                                               Text="{Binding DisplayRole}" />
                                                    <Button Grid.Column="1"
                                                            Margin="8,0,4,0"
                                                            Style="{StaticResource ChatRecordToolButtonStyle}"
                                                            Command="{Binding DataContext.EditChatMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Content="&#xE70F;"
                                                            ToolTip="&#x7F16;&#x8F91;&#x6D88;&#x606F;"
                                                            Visibility="{Binding IsUser, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                    <Button Grid.Column="2"
                                                            Style="{StaticResource ChatRecordToolButtonStyle}"
                                                            Command="{Binding DataContext.CopyChatMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Content="&#xE8C8;"
                                                            ToolTip="&#x590D;&#x5236;&#x6D88;&#x606F;" />
                                                    <Button Grid.Column="3"
                                                            Style="{StaticResource ChatRecordToolButtonStyle}"
                                                            Command="{Binding DataContext.RegenerateLastChatAnswerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            Content="&#xE72C;"
                                                            ToolTip="&#x91CD;&#x65B0;&#x751F;&#x6210;"
                                                            Visibility="{Binding IsAssistant, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </Grid>
                                                <TextBlock Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           FontSize="10.5"
                                                           Text="{Binding CreatedAtLabel}" />
                                            </Grid>

                                            <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding Attachments}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,6,6"
                                                                Padding="8,5"
                                                                Background="#EEF4FF"
                                                                BorderBrush="#B2CCFF"
                                                                BorderThickness="1"
                                                                CornerRadius="6">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock FontSize="10.5"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#175CD3"
                                                                           Text="{Binding KindLabel}" />
                                                                <TextBlock Margin="6,0,0,0"
                                                                           FontSize="10.5"
                                                                           Foreground="#344054"
                                                                           Text="{Binding FileName}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <controls:MarkdownViewer Margin="0,6,0,0"
                                                                     Markdown="{Binding Content}"
                                                                     Visibility="{Binding HasContent, Converter={StaticResource BoolToVisibilityConverter}}" />

                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="10.5"
                                                       Text="{Binding MetricsSummary}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="#B42318"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Error}"
                                                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                              Padding="12"
                                             Background="#F8FAFC"
                                            BorderBrush="#D0D5DD"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Visibility="{Binding IsMultiModelAnswer, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Foreground="#101828"
                                                           Text="&#x591A;&#x6A21;&#x578B;&#x56DE;&#x7B54;" />
                                                <Grid Grid.Column="1"
                                                      VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0"
                                                            Style="{StaticResource ChatRecordToolButtonStyle}"
                                                            Command="{Binding DataContext.CopyChatMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Content="&#xE8C8;"
                                                            ToolTip="&#x590D;&#x5236;&#x5168;&#x90E8;" />
                                                    <Button Grid.Column="1"
                                                            Style="{StaticResource ChatRecordToolButtonStyle}"
                                                            Command="{Binding DataContext.RegenerateLastChatAnswerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            Content="&#xE72C;"
                                                            ToolTip="&#x91CD;&#x65B0;&#x751F;&#x6210;" />
                                                    <TextBlock Grid.Column="2"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="10.5"
                                                               Text="{Binding CreatedAtLabel}" />
                                                </Grid>
                                            </Grid>

                                            <ScrollViewer Margin="0,8,0,0"
                                                          Style="{StaticResource WorkbenchScrollViewerStyle}"
                                                          HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding ModelAnswers}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Columns="{Binding AnswerColumnCount}" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border MinWidth="280"
                                                                    Margin="0,0,8,0"
                                                                    Padding="10"
                                                                    Background="White"
                                                                    BorderBrush="#E4E7EC"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8">
                                                                <StackPanel>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock FontSize="11.5"
                                                                                   FontWeight="SemiBold"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="#101828"
                                                                                   Text="{Binding Header}"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                        <Grid Grid.Column="1"
                                                                              VerticalAlignment="Center">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <Button Grid.Column="0"
                                                                                    Margin="8,0,4,0"
                                                                                    Style="{StaticResource ChatRecordToolButtonStyle}"
                                                                                    Command="{Binding DataContext.CopyChatModelAnswerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                    CommandParameter="{Binding}"
                                                                                    Content="&#xE8C8;"
                                                                                    ToolTip="&#x590D;&#x5236;&#x6A21;&#x578B;&#x56DE;&#x7B54;" />
                                                                            <Border Grid.Column="1"
                                                                                    Style="{StaticResource StatusPillBorderStyle}">
                                                                                <TextBlock FontSize="10.5"
                                                                                           VerticalAlignment="Center"
                                                                                           Foreground="{StaticResource AccentBrush}"
                                                                                           FontWeight="SemiBold"
                                                                                           Text="{Binding StatusText}" />
                                                                            </Border>
                                                                        </Grid>
                                                                    </Grid>

                                                                    <controls:MarkdownViewer Margin="0,8,0,0"
                                                                                             Markdown="{Binding Content}"
                                                                                             Visibility="{Binding HasContent, Converter={StaticResource BoolToVisibilityConverter}}" />

                                                                    <TextBlock Margin="0,8,0,0"
                                                                               Foreground="{StaticResource MutedBrush}"
                                                                               FontSize="10.5"
                                                                               Text="{Binding MetricsSummary}" />
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               Foreground="#B42318"
                                                                               FontSize="11"
                                                                               TextWrapping="Wrap"
                                                                               Text="{Binding Error}"
                                                                               Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button x:Name="BackToBottomButton"
                            Margin="0,0,12,12"
                            Style="{StaticResource WorkbenchIconButtonStyle}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Panel.ZIndex="2"
                            Click="BackToBottomButton_Click"
                            Content="&#xE70D;"
                            ToolTip="&#x56DE;&#x5230;&#x5E95;&#x90E8;"
                            Visibility="Collapsed" />
                </Grid>
            </Border>

        </Grid>

        <Border x:Name="ChatInputDropZone"
                Grid.Row="2"
                Style="{StaticResource CommandBarBorderStyle}"
                AllowDrop="True"
                DragEnter="ChatInputDropZone_DragEnter"
                DragOver="ChatInputDropZone_DragOver"
                DragLeave="ChatInputDropZone_DragLeave"
                Drop="ChatInputDropZone_Drop">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ItemsControl ItemsSource="{Binding PendingChatAttachments}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,8,8"
                                    Padding="8"
                                    Background="#F9FAFB"
                                    BorderBrush="#D0D5DD"
                                    BorderThickness="1"
                                    CornerRadius="7">
                                <Grid Width="180">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="#101828"
                                                   Text="{Binding FileName}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Margin="0,2,0,0"
                                                   FontSize="10"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Text="{Binding KindLabel}" />
                                        <TextBlock FontSize="10"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Text="{Binding SizeLabel}" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource ChatRecordToolButtonStyle}"
                                            Command="{Binding DataContext.RemoveChatAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="&#xE711;"
                                            ToolTip="&#x79FB;&#x9664;&#x9644;&#x4EF6;" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Grid.Row="1"
                      Margin="0,0,0,6"
                      Visibility="{Binding IsEditingChatMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Style="{StaticResource SectionHintTextStyle}"
                               Text="{Binding ChatEditStatusText}"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="1"
                            Margin="8,0,0,0"
                            Style="{StaticResource ChatRecordToolButtonStyle}"
                            Command="{Binding CancelChatEditCommand}"
                            Content="&#xE711;"
                            ToolTip="&#x53D6;&#x6D88;&#x7F16;&#x8F91;" />
                </Grid>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ChatInputTextBox"
                             MinHeight="74"
                             MaxHeight="150"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource CompactInputTextBoxStyle}"
                             Text="{Binding ChatInputText, UpdateSourceTrigger=PropertyChanged}" />

                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                        <WrapPanel HorizontalAlignment="Right">
                            <Button Style="{StaticResource WorkbenchComposerIconButtonStyle}"
                                    Command="{Binding AddChatImageAttachmentCommand}"
                                    Content="&#xEB9F;"
                                    ToolTip="&#x6DFB;&#x52A0;&#x56FE;&#x7247;" />
                            <Button Style="{StaticResource WorkbenchComposerIconButtonStyle}"
                                    Command="{Binding AddChatTextFileAttachmentCommand}"
                                    Content="&#xE723;"
                                    ToolTip="&#x6DFB;&#x52A0;&#x6587;&#x4EF6;" />
                            <Button Style="{StaticResource WorkbenchComposerIconButtonStyle}"
                                    Command="{Binding StopChatStreamingCommand}"
                                    Content="&#xE71A;"
                                    ToolTip="&#x505C;&#x6B62;&#x751F;&#x6210;" />
                            <Button Style="{StaticResource WorkbenchIconButtonPrimaryStyle}"
                                    Command="{Binding SendChatMessageCommand}"
                                    Content="&#xE724;"
                                    ToolTip="{Binding ChatSendButtonText}" />
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.RowSpan="3"
              Panel.ZIndex="30"
              Visibility="{Binding IsChatSettingsPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#220F172A">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding CloseChatSettingsPanelCommand}" />
                </Border.InputBindings>
            </Border>

            <Border Width="380"
                    Margin="0,8,8,8"
                    Padding="14"
                    Style="{StaticResource MotionDialogPanelStyle}"
                    Panel.ZIndex="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Background="{StaticResource PanelBrushStrong}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <ScrollViewer Style="{StaticResource WorkbenchScrollViewerStyle}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="&#x5BF9;&#x8BDD;&#x53C2;&#x6570;" />
                                <TextBlock Margin="0,3,0,0"
                                           Style="{StaticResource SectionHintTextStyle}"
                                           Text="{Binding ChatModeSummary}" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Style="{StaticResource ChatSessionIconButtonStyle}"
                                    Command="{Binding CloseChatSettingsPanelCommand}"
                                    Content="&#xE711;"
                                    ToolTip="&#x5173;&#x95ED;&#x53C2;&#x6570;" />
                        </Grid>

                        <Border Margin="0,12,0,0" Style="{StaticResource InsetPanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x8BF7;&#x6C42;&#x72B6;&#x6001;" />
                                <TextBlock Margin="0,4,0,0"
                                           Style="{StaticResource SectionHintTextStyle}"
                                           TextWrapping="Wrap"
                                           Text="{Binding ChatStatusMessage}" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource SectionHintTextStyle}"
                                           TextWrapping="Wrap"
                                           Text="{Binding ChatMetricsSummary}" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource SectionHintTextStyle}"
                                           TextWrapping="Wrap"
                                           Text="{Binding ChatReasoningEffortSummary}" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0" Style="{StaticResource InsetPanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x63A5;&#x53E3;&#x914D;&#x7F6E;" />
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="&#x63A5;&#x53E3;&#x5730;&#x5740;" />
                                <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                         Text="{Binding ProxyBaseUrl, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="API Key" />
                                <PasswordBox Style="{StaticResource CompactSecretInputPasswordBoxStyle}"
                                             infra:PasswordBoxAssistant.BoundPassword="{Binding ProxyApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="&#x5F53;&#x524D;&#x6A21;&#x578B;" />
                                <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                         Text="{Binding ProxyModel, UpdateSourceTrigger=PropertyChanged}" />

                                <Button Margin="0,10,0,0"
                                        Padding="10,5"
                                        HorizontalAlignment="Left"
                                        Command="{Binding FetchProxyModelsCommand}"
                                        Content="&#x62C9;&#x53D6;&#x6A21;&#x578B;" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,10,0,0" Style="{StaticResource InsetPanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x9884;&#x8BBE;" />
                                <ComboBox Margin="0,8,0,0"
                                          ItemsSource="{Binding ChatPresets}"
                                          SelectedItem="{Binding SelectedChatPreset, Mode=TwoWay}"
                                          Style="{StaticResource CompactComboBoxStyle}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock FontSize="11.1" FontWeight="SemiBold" Text="{Binding Name}" />
                                                <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="10.5" Foreground="{StaticResource MutedBrush}" Text="{Binding KindLabel}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <WrapPanel Margin="0,8,0,0">
                                    <Button Margin="0,0,6,0" Padding="10,5" Command="{Binding ApplyChatPresetCommand}" Content="&#x5E94;&#x7528;" />
                                    <Button Margin="0,0,6,0" Padding="10,5" Command="{Binding SaveChatPresetCommand}" Content="&#x4FDD;&#x5B58;&#x5F53;&#x524D;" />
                                    <Button Padding="10,5" Command="{Binding DeleteChatPresetCommand}" Content="&#x5220;&#x9664;" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,10,0,0" Style="{StaticResource InsetPanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x751F;&#x6210;&#x53C2;&#x6570;" />

                                <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldLabelTextStyle}" Text="System Prompt" />
                                <TextBox Height="92"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Style="{StaticResource CompactInputTextBoxStyle}"
                                         Text="{Binding ChatSystemPrompt, UpdateSourceTrigger=PropertyChanged}" />

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Temperature" />
                                        <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                 Text="{Binding ChatTemperatureText, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Max Tokens" />
                                        <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                 Text="{Binding ChatMaxTokensText, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x601D;&#x8003;&#x5F3A;&#x5EA6;" />
                                        <ComboBox ItemsSource="{Binding ChatReasoningEffortOptions}"
                                                  SelectedValuePath="Key"
                                                  TextSearch.TextPath="DisplayName"
                                                  SelectedValue="{Binding SelectedChatReasoningEffortKey, Mode=TwoWay}"
                                                  Style="{StaticResource CompactComboBoxStyle}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="11.1"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,10,0,0" Style="{StaticResource InsetPanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x591A;&#x6A21;&#x578B;&#x5BF9;&#x6BD4;" />
                                <TextBlock Margin="0,4,0,0"
                                           Style="{StaticResource SectionHintTextStyle}"
                                           TextWrapping="Wrap"
                                           Text="{Binding ChatSelectedModelsSummary}" />

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox ItemsSource="{Binding ProxyCatalogModels}"
                                              SelectedItem="{Binding ChatCandidateModel, Mode=TwoWay}"
                                              IsDropDownOpen="{Binding IsChatCandidateModelDropDownOpen, Mode=TwoWay}"
                                              Style="{StaticResource CompactComboBoxStyle}" />
                                    <WrapPanel Grid.Column="2">
                                        <Button Margin="0,0,6,0"
                                                Padding="10,5"
                                                Command="{Binding AddChatSelectedModelCommand}"
                                                Content="&#x52A0;&#x5165;" />
                                        <Button Padding="10,5"
                                                Command="{Binding ClearChatSelectedModelsCommand}"
                                                Content="&#x6E05;&#x7A7A;" />
                                    </WrapPanel>
                                </Grid>

                                <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding ChatSelectedModels}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,6,6"
                                                    Padding="7,3"
                                                    Background="#ECFDF3"
                                                    BorderBrush="#ABEFC6"
                                                    BorderThickness="1"
                                                    CornerRadius="6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontSize="10.5"
                                                               FontWeight="SemiBold"
                                                               Foreground="#067647"
                                                               Text="{Binding DisplayName}" />
                                                    <Button Margin="6,0,0,0"
                                                            Style="{StaticResource ChatRecordToolButtonStyle}"
                                                            Command="{Binding DataContext.RemoveChatSelectedModelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Content="&#xE711;"
                                                            ToolTip="&#x79FB;&#x9664;&#x5BF9;&#x6BD4;&#x6A21;&#x578B;" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,10,0,0" Style="{StaticResource InsetPanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x4F1A;&#x8BDD;&#x64CD;&#x4F5C;" />
                                <WrapPanel Margin="0,8,0,0">
                                    <Button Margin="0,0,6,0"
                                            Padding="10,5"
                                            Command="{Binding StopChatStreamingCommand}"
                                            Content="&#x505C;&#x6B62;&#x751F;&#x6210;" />
                                    <Button Margin="0,0,6,0"
                                            Padding="10,5"
                                            Command="{Binding ExportChatSessionMarkdownCommand}"
                                            Content="&#x5BFC;&#x51FA; MD" />
                                    <Button Margin="0,0,6,0"
                                            Padding="10,5"
                                            Command="{Binding ExportChatSessionTextCommand}"
                                            Content="&#x5BFC;&#x51FA; TXT" />
                                    <Button Padding="10,5"
                                            Command="{Binding ClearChatSessionCommand}"
                                            Content="&#x6E05;&#x7A7A;&#x4F1A;&#x8BDD;" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
