<UserControl x:Class="RelayBench.App.Views.Pages.ApplicationCenterPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Style="{StaticResource MotionPageRootStyle}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="ApplicationCenterActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkbenchIconButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,8,8,0" />
        </Style>

        <Style x:Key="ApplicationCenterIconActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkbenchIconButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="ApplicationCenterMotionInsetPanelStyle"
               TargetType="Border"
               BasedOn="{StaticResource MotionDialogPanelStyle}">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="{StaticResource PanelBrushStrong}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="ApplicationCenterMetaTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SectionHintTextStyle}">
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ApplicationCenterTagBorderStyle"
               TargetType="Border">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D0D5DD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>

        <Style x:Key="ApplicationCenterValueTagBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource ApplicationCenterTagBorderStyle}">
            <Setter Property="Background" Value="#FDFEFF" />
            <Setter Property="BorderBrush" Value="#E4E7EC" />
        </Style>

        <Style x:Key="ApplicationCenterStateBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource ApplicationCenterValueTagBorderStyle}">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style x:Key="ApplicationCenterTagTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SectionHintTextStyle}">
            <Setter Property="FontSize" Value="10.2" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid MinHeight="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CommandBarBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="应用接入" />
                    <TextBlock Margin="0,3,0,0"
                               Text="扫描本机支持应用并检查接入状态">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasClientApiStatusRows}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <Button Command="{Binding RunClientApiDiagnosticsCommand}"
                            Style="{StaticResource WorkbenchIconButtonPrimaryStyle}"
                            Content="&#xE768;"
                            ToolTip="&#x5F00;&#x59CB;&#x626B;&#x63CF;" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,8,0,0"
              MinHeight="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.08*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="0.92*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="应用列表" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="查看已发现应用、当前入口和还原操作">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasClientApiStatusRows}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="0,6,0,0">
                        <ScrollViewer Style="{StaticResource WorkbenchScrollViewerStyle}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ClientApiStatusRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="10"
                                                Background="#FFFFFF"
                                                BorderBrush="{StaticResource PanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <WrapPanel>
                                                        <Border Margin="0,0,8,0"
                                                                Padding="7,2"
                                                                Background="#F5F7FA"
                                                                BorderBrush="#D0D5DD"
                                                                BorderThickness="1"
                                                                CornerRadius="999">
                                                            <TextBlock FontSize="10"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource MutedBrush}"
                                                                       Text="{Binding Provider}" />
                                                        </Border>
                                                        <TextBlock VerticalAlignment="Center"
                                                                   FontSize="12.2"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   Text="{Binding Name}" />
                                                    </WrapPanel>
                                                    <TextBlock Margin="0,4,0,0"
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource TextBrush}"
                                                               Text="{Binding Summary}" />
                                                    <WrapPanel Margin="0,6,0,0">
                                                        <Border Style="{StaticResource ApplicationCenterTagBorderStyle}">
                                                            <TextBlock Style="{StaticResource ApplicationCenterTagTextStyle}"
                                                                       Text="&#x5F53;&#x524D;&#x5165;&#x53E3;" />
                                                        </Border>
                                                        <Border Style="{StaticResource ApplicationCenterValueTagBorderStyle}">
                                                            <TextBlock Style="{StaticResource ApplicationCenterTagTextStyle}"
                                                                       Foreground="{StaticResource TextBrush}"
                                                                       Text="{Binding EndpointText}" />
                                                        </Border>
                                                    </WrapPanel>
                                                    <Border Style="{StaticResource ApplicationCenterStateBorderStyle}"
                                                            Background="{Binding StatusBackground}"
                                                            BorderBrush="{Binding StatusForeground}">
                                                        <TextBlock Style="{StaticResource ApplicationCenterTagTextStyle}"
                                                                   Foreground="{Binding StatusForeground}"
                                                                   Text="{Binding StateText}"
                                                                   TextWrapping="Wrap" />
                                                    </Border>
                                                    <Expander Margin="0,4,0,0"
                                                              IsExpanded="False">
                                                        <Expander.Header>
                                                            <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                                                       Text="接入详情" />
                                                        </Expander.Header>
                                                        <StackPanel Margin="0,6,0,0">
                                                            <TextBlock Style="{StaticResource ApplicationCenterMetaTextStyle}"
                                                                       Text="{Binding AccessDetailText}" />
                                                            <TextBlock Style="{StaticResource ApplicationCenterMetaTextStyle}"
                                                                       Text="{Binding ConfigSourceText, StringFormat=配置来源：{0}}" />
                                                            <TextBlock Style="{StaticResource ApplicationCenterMetaTextStyle}"
                                                                       Text="{Binding RestoreHintText, StringFormat=还原说明：{0}}" />
                                                            <TextBlock Margin="0,4,0,0"
                                                                       FontFamily="Consolas"
                                                                       FontSize="10.2"
                                                                       Foreground="#667085"
                                                                       Text="{Binding EndpointMetaText}" />
                                                        </StackPanel>
                                                    </Expander>
                                                </StackPanel>

                                                <Border Grid.Column="1"
                                                        Margin="10,0,0,0"
                                                        Padding="10,4"
                                                        VerticalAlignment="Top"
                                                        CornerRadius="10"
                                                        Background="{Binding StatusBackground}">
                                                    <TextBlock FontSize="10.6"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding StatusForeground}"
                                                               Text="{Binding AvailabilityText}" />
                                                </Border>

                                                <StackPanel Grid.Row="1"
                                                            Grid.ColumnSpan="2"
                                                            Orientation="Horizontal">
                                                    <Button Command="{Binding OpenRawTraceCommand}"
                                                            Style="{StaticResource ApplicationCenterActionButtonStyle}"
                                                            Content="&#xE946;"
                                                            ToolTip="&#x539F;&#x59CB; Trace" />
                                                    <Button Command="{Binding RestoreDefaultConfigCommand}"
                                                            Style="{StaticResource ApplicationCenterActionButtonStyle}"
                                                            Visibility="{Binding HasRestoreDefaultConfigAction, Converter={StaticResource BoolToVisibilityConverter}}"
                                                            Content="&#xE777;"
                                                            ToolTip="&#x8FD8;&#x539F;&#x9ED8;&#x8BA4;" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="尚未扫描应用。点击“开始扫描”后显示结果。">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasClientApiStatusRows}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="当前接口" />
                            <TextBlock Margin="0,2,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="后续一键应用会使用这里的接口信息" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Margin="10,0,0,0"
                                Style="{StaticResource ApplicationCenterIconActionButtonStyle}"
                                VerticalAlignment="Top"
                                Command="{Binding OpenApplicationCenterProxyEndpointHistoryCommand}"
                                Content="&#xE81C;"
                                ToolTip="&#x5386;&#x53F2;&#x63A5;&#x53E3;" />
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,6,0,0"
                            Style="{StaticResource ApplicationCenterMotionInsetPanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x5F53;&#x524D; Base URL" />
                                <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                         IsReadOnly="True"
                                         Text="{Binding ApplicationCenterBaseUrl, Mode=OneWay}" />
                            </StackPanel>

                            <Grid Grid.Row="1"
                                  Margin="0,6,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x5F53;&#x524D;&#x6A21;&#x578B;" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Style="{StaticResource CompactInputTextBoxStyle}"
                                         IsReadOnly="True"
                                         Text="{Binding ApplicationCenterModel, Mode=OneWay}" />
                                <Button Grid.Row="1"
                                        Grid.Column="2"
                                        Style="{StaticResource ApplicationCenterIconActionButtonStyle}"
                                        Command="{Binding FetchApplicationCenterProxyModelsCommand}"
                                        Content="&#xE72C;"
                                        ToolTip="&#x62C9;&#x53D6;&#x6A21;&#x578B;" />
                            </Grid>

                            <StackPanel Grid.Row="2"
                                        Margin="0,6,0,0">
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="API Key" />
                                <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                         IsReadOnly="True"
                                         Text="{Binding ApplicationCenterProxyApiKeyPreview, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Style="{StaticResource ApplicationCenterMotionInsetPanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="应用到 Codex" />
                            <Button Grid.Column="1"
                                    Command="{Binding ApplyCurrentInterfaceToCodexAppsCommand}"
                                    Style="{StaticResource WorkbenchIconButtonPrimaryStyle}"
                                    Content="&#xE8FB;"
                                    ToolTip="&#x5E94;&#x7528;&#x5F53;&#x524D;&#x63A5;&#x53E3;" />

                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       TextWrapping="Wrap"
                                       Text="{Binding ApplicationCenterApplyTargetSummary, Mode=OneWay}" />

                            <Expander Grid.Row="2"
                                      Grid.ColumnSpan="2"
                                      Margin="0,8,0,0"
                                      IsExpanded="False">
                                <Expander.Header>
                                    <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                               Text="写入预览" />
                                </Expander.Header>
                                <TextBox Margin="0,6,0,0"
                                         MinHeight="146"
                                         Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                                         Text="{Binding ApplicationCenterApplyPreviewDetail, Mode=OneWay}" />
                            </Expander>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="5"
                          Margin="0,6,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="扫描结果" />

                        <TabControl Grid.Row="1"
                                    Margin="0,4,0,0">
                            <TabItem Header="&#x6982;&#x89C8;">
                                <TextBox Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                                         Text="{Binding ClientApiSummary, Mode=OneWay}" />
                            </TabItem>
                            <TabItem Header="&#x7EC6;&#x8282;">
                                <TextBox Style="{StaticResource ReadOnlyRawLogTextBoxStyle}"
                                         Text="{Binding ClientApiDetail, Mode=OneWay}" />
                            </TabItem>
                        </TabControl>

                        <Expander Grid.Row="2"
                                  Margin="0,8,0,0"
                                  IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                           Text="支持范围" />
                            </Expander.Header>
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="根据协议探测结果展示可应用软件；不确定兼容项会二次确认。" />
                        </Expander>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
