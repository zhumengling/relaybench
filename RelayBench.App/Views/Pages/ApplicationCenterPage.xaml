<UserControl x:Class="RelayBench.App.Views.Pages.ApplicationCenterPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Style="{StaticResource MotionPageRootStyle}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="ApplicationCenterActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkbenchIconButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,8,8,0" />
        </Style>

        <Style x:Key="ApplicationCenterIconActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkbenchIconButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="ApplicationCenterMotionInsetPanelStyle"
               TargetType="Border"
               BasedOn="{StaticResource MotionDialogPanelStyle}">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="{StaticResource PanelBrushStrong}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="ApplicationCenterMetaTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SectionHintTextStyle}">
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ApplicationCenterTagBorderStyle"
               TargetType="Border">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D0D5DD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>

        <Style x:Key="ApplicationCenterValueTagBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource ApplicationCenterTagBorderStyle}">
            <Setter Property="Background" Value="#FDFEFF" />
            <Setter Property="BorderBrush" Value="#E4E7EC" />
        </Style>

        <Style x:Key="ApplicationCenterStateBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource ApplicationCenterValueTagBorderStyle}">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style x:Key="ApplicationCenterTagTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SectionHintTextStyle}">
            <Setter Property="FontSize" Value="10.2" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid MinHeight="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CommandBarBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            ClipToBounds="True">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="应用接入" />
                    <TextBlock Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis"
                               Text="扫描本机支持应用并检查接入状态">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasClientApiStatusRows}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <Button Command="{Binding RunClientApiDiagnosticsCommand}"
                            Style="{StaticResource WorkbenchIconButtonPrimaryStyle}"
                            Content="&#xE768;"
                            ToolTip="&#x5F00;&#x59CB;&#x626B;&#x63CF;" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,8,0,0"
              MinHeight="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="380" MinWidth="340" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="应用列表" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="查看已发现应用、当前入口和还原操作">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasClientApiStatusRows}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="0,6,0,0">
                        <ItemsControl ItemsSource="{Binding ClientApiStatusRows}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,8,8"
                                            Padding="12,10"
                                            Background="#FBFDFF"
                                            BorderBrush="#D9E6F7"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="6" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Name}"
                                                           Text="{Binding Name}" />
                                                <TextBlock Margin="0,2,0,0"
                                                           FontSize="10.6"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Provider}"
                                                           Text="{Binding Provider}" />
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Padding="8,3"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Background="{Binding StatusBackground}"
                                                    BorderBrush="{Binding StatusForeground}"
                                                    BorderThickness="1"
                                                    CornerRadius="999">
                                                <TextBlock FontSize="10.6"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding StatusForeground}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding AvailabilityText}"
                                                           Text="{Binding AvailabilityText}" />
                                            </Border>

                                            <Border Grid.Row="2"
                                                    Grid.ColumnSpan="2"
                                                    Style="{StaticResource ApplicationCenterStateBorderStyle}">
                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                               Text="当前入口" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               FontFamily="Cascadia Mono, Consolas"
                                                               FontSize="11.2"
                                                               Foreground="{StaticResource TextBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding EndpointText}"
                                                               Text="{Binding EndpointText}" />
                                                </StackPanel>
                                            </Border>

                                            <StackPanel Grid.Row="4"
                                                        Grid.Column="0"
                                                        Margin="0,0,10,0">
                                                <TextBlock FontSize="12"
                                                           Foreground="{StaticResource TextBrush}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding StateText}"
                                                           Text="{Binding StateText}" />
                                                <TextBlock Margin="0,2,0,0"
                                                           Style="{StaticResource SectionHintTextStyle}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding AccessDetailText}"
                                                           Text="{Binding AccessDetailText}" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="4"
                                                        Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                                <Button Command="{Binding OpenRawTraceCommand}"
                                                        Style="{StaticResource ApplicationCenterActionButtonStyle}"
                                                        Margin="0,0,6,0"
                                                        Content="&#xE946;"
                                                        ToolTip="&#x539F;&#x59CB; Trace" />
                                                <Button Command="{Binding RestoreDefaultConfigCommand}"
                                                        Style="{StaticResource ApplicationCenterActionButtonStyle}"
                                                        Margin="0"
                                                        Visibility="{Binding HasRestoreDefaultConfigAction, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        Content="&#xE777;"
                                                        ToolTip="&#x8FD8;&#x539F;&#x9ED8;&#x8BA4;" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="尚未扫描应用。点击“开始扫描”后显示结果。">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasClientApiStatusRows}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="当前接口" />
                            <TextBlock Margin="0,2,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="后续一键应用会使用这里的接口信息" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Margin="10,0,0,0"
                                Style="{StaticResource ApplicationCenterIconActionButtonStyle}"
                                VerticalAlignment="Top"
                                Command="{Binding OpenApplicationCenterProxyEndpointHistoryCommand}"
                                Content="&#xE81C;"
                                ToolTip="&#x5386;&#x53F2;&#x63A5;&#x53E3;" />
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,6,0,0"
                            Style="{StaticResource ApplicationCenterMotionInsetPanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x5F53;&#x524D; Base URL" />
                                <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                         IsReadOnly="True"
                                         ToolTip="{Binding ApplicationCenterBaseUrl, Mode=OneWay}"
                                         Text="{Binding ApplicationCenterBaseUrl, Mode=OneWay}" />
                            </StackPanel>

                            <Grid Grid.Row="1"
                                  Margin="0,6,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x5F53;&#x524D;&#x6A21;&#x578B;" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Style="{StaticResource CompactInputTextBoxStyle}"
                                         IsReadOnly="True"
                                         ToolTip="{Binding ApplicationCenterModel, Mode=OneWay}"
                                         Text="{Binding ApplicationCenterModel, Mode=OneWay}" />
                                <Button Grid.Row="1"
                                        Grid.Column="2"
                                        Style="{StaticResource ApplicationCenterIconActionButtonStyle}"
                                        Command="{Binding FetchApplicationCenterProxyModelsCommand}"
                                        Content="&#xE72C;"
                                        ToolTip="&#x62C9;&#x53D6;&#x6A21;&#x578B;" />
                            </Grid>

                            <StackPanel Grid.Row="2"
                                        Margin="0,6,0,0">
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="API Key" />
                                <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                         IsReadOnly="True"
                                         Text="{Binding ApplicationCenterProxyApiKeyPreview, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Style="{StaticResource ApplicationCenterMotionInsetPanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="应用到 Codex" />
                            <Button Grid.Column="1"
                                    Command="{Binding ApplyCurrentInterfaceToCodexAppsCommand}"
                                    Style="{StaticResource WorkbenchIconButtonPrimaryStyle}"
                                    Content="&#xE8FB;"
                                    ToolTip="&#x5E94;&#x7528;&#x5F53;&#x524D;&#x63A5;&#x53E3;" />

                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       TextWrapping="Wrap"
                                       Text="{Binding ApplicationCenterApplyTargetSummary, Mode=OneWay}" />

                            <Expander Grid.Row="2"
                                      Grid.ColumnSpan="2"
                                      Margin="0,8,0,0"
                                      IsExpanded="False">
                                <Expander.Header>
                                    <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                               Text="写入预览" />
                                </Expander.Header>
                                <TextBox Margin="0,6,0,0"
                                         MinHeight="146"
                                         Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                                         Text="{Binding ApplicationCenterApplyPreviewDetail, Mode=OneWay}" />
                            </Expander>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="5"
                          Margin="0,6,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="扫描结果" />

                        <TabControl Grid.Row="1"
                                    Margin="0,4,0,0">
                            <TabItem Header="&#x6982;&#x89C8;">
                                <TextBox Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                                         Text="{Binding ClientApiSummary, Mode=OneWay}" />
                            </TabItem>
                            <TabItem Header="&#x7EC6;&#x8282;">
                                <TextBox Style="{StaticResource ReadOnlyRawLogTextBoxStyle}"
                                         Text="{Binding ClientApiDetail, Mode=OneWay}" />
                            </TabItem>
                        </TabControl>

                        <Expander Grid.Row="2"
                                  Margin="0,8,0,0"
                                  IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                           Text="支持范围" />
                            </Expander.Header>
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="根据协议探测结果展示可应用软件；不确定兼容项会二次确认。" />
                        </Expander>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
