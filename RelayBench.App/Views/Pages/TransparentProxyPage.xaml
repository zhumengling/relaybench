                                                                                Height="26"
                                                                                Command="{Binding DataContext.DeleteCodexOAuthCredentialCommand, ElementName=TransparentProxyPageRoot}"
                                                                                CommandParameter="{Binding}"
                                                                                Content="&#xE74D;"
                                                                                Style="{StaticResource GatewayIconButtonStyle}"
                                                                                ToolTip="删除账号" />
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                </ScrollViewer>
                                                <Grid Grid.Row="2"
                                                      Margin="0,6,0,0"
                                                      Visibility="{Binding IsCodexOAuthManualCallbackVisible, Converter={StaticResource BoolToVisibilityConverter}}">
