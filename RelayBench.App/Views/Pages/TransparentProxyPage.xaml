<UserControl x:Class="RelayBench.App.Views.Pages.TransparentProxyPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:infra="clr-namespace:RelayBench.App.Infrastructure"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Style="{StaticResource MotionPageRootStyle}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="GatewayStatusPillStyle" TargetType="Border">
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Background" Value="#F6F8FA" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>

        <Style x:Key="GatewayMetricTileStyle"
               TargetType="Border"
               BasedOn="{StaticResource InsetPanelBorderStyle}">
            <Setter Property="MinHeight" Value="50" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style x:Key="GatewayMetricValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="22" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="MaxHeight" Value="24" />
        </Style>

        <Style x:Key="GatewayIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkbenchIconButtonStyle}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="GatewayPrimaryIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkbenchIconButtonPrimaryStyle}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="GatewayBadgeBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="Height" Value="22" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style x:Key="GatewayMonoCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="FontSize" Value="11.6" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="MaxHeight" Value="18" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GatewayCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.2" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="MaxHeight" Value="18" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GatewayDataGridTextColumnElementStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="MaxHeight" Value="18" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
        </Style>

        <Style x:Key="GatewayMultilineRouteTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="168" />
            <Setter Property="Padding" Value="9,7" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="FontSize" Value="11.2" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="AcceptsTab" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="GatewayCompactDataGridHeaderStyle"
               TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="10.8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                ClipToBounds="True">
                            <TextBlock Margin="{TemplateBinding Padding}"
                                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                       VerticalAlignment="Center"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{TemplateBinding Content}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid MinHeight="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CommandBarBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            ClipToBounds="True">
                    <WrapPanel VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="透明代理"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Margin="8,1,0,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="本地入口调度器" />
                        <Border Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Style="{StaticResource GatewayStatusPillStyle}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding TransparentProxyRunStateBrush, Mode=OneWay}"
                                       Text="{Binding TransparentProxyRunStateText, Mode=OneWay}" />
                        </Border>
                    </WrapPanel>
                    <DockPanel Margin="0,4,0,0" LastChildFill="True">
                        <TextBlock DockPanel.Dock="Left"
                                   FontFamily="Cascadia Mono, Consolas"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedBrush}"
                                   MaxWidth="320"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding TransparentProxyLocalEndpoint, Mode=OneWay}"
                                   Text="{Binding TransparentProxyLocalEndpoint, Mode=OneWay}" />
                        <TextBlock Margin="12,0,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   MaxWidth="420"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding TransparentProxyStatusSummary, Mode=OneWay}"
                                   Text="{Binding TransparentProxyStatusSummary, Mode=OneWay}" />
                    </DockPanel>
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           MinWidth="294"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <Button Command="{Binding StartTransparentProxyCommand}"
                            Content="&#xE768;"
                            Style="{StaticResource GatewayPrimaryIconButtonStyle}"
                            ToolTip="启动透明代理" />
                    <Button Command="{Binding StopTransparentProxyCommand}"
                            Content="&#xE71A;"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="停止透明代理" />
                    <Button Command="{Binding CopyTransparentProxyEndpointCommand}"
                            Content="&#xE8C8;"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="复制本地入口" />
                    <Button Command="{Binding RefreshTransparentProxyRoutesCommand}"
                            Content="&#xE72C;"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="从当前接口和批量候选生成路由" />
                    <Button Command="{Binding ProbeTransparentProxyProtocolsCommand}"
                            Content="&#xE946;"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="拉取模型并探测 Responses / Anthropic / OpenAI Chat 协议" />
                    <Button Click="ToggleTokenMeterButton_OnClick"
                            Content="&#xE9D2;"
                            IsEnabled="{Binding IsTransparentProxyRunning, Mode=OneWay}"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="显示或隐藏 Token 悬浮窗"
                            ToolTipService.ShowOnDisabled="True" />
                    <Button Command="{Binding ClearTransparentProxyLogsCommand}"
                            Content="&#xE74D;"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="清空日志" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,8,0,0"
              MinHeight="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="392" MinWidth="372" MaxWidth="432" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionPanelBorderStyle}">
                <Grid MinHeight="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="入口设置" />
                        <TextBlock Margin="0,3,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="{Binding TransparentProxyHealthSummary, Mode=OneWay}" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,10,0,0"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource InsetPanelBorderStyle}">
                                <Grid>
                                     <Grid.RowDefinitions>
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="Auto" />
                                     </Grid.RowDefinitions>

                                     <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                Text="监听" />
                                     <Grid Grid.Row="1"
                                           Margin="0,7,0,0">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*" />
                                             <ColumnDefinition Width="8" />
                                             <ColumnDefinition Width="*" />
                                         </Grid.ColumnDefinitions>
                                         <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="端口" />
                                            <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                     Text="{Binding TransparentProxyPortText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                         </StackPanel>
                                         <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="并发上限" />
                                            <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                     Text="{Binding TransparentProxyMaxConcurrencyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                         </StackPanel>
                                     </Grid>
                                     <TextBox Grid.Row="2"
                                              Margin="0,7,0,0"
                                             FontFamily="Cascadia Mono, Consolas"
                                             IsReadOnly="True"
                                             Style="{StaticResource CompactInputTextBoxStyle}"
                                             ToolTip="{Binding TransparentProxyLocalEndpoint, Mode=OneWay}"
                                             Text="{Binding TransparentProxyLocalEndpoint, Mode=OneWay}" />
                                </Grid>
                            </Border>

                            <Border Margin="0,8,0,0"
                                    Style="{StaticResource InsetPanelBorderStyle}">
                                <Grid>
                                     <Grid.RowDefinitions>
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="Auto" />
                                     </Grid.RowDefinitions>

                                     <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                Text="保护" />
                                     <Grid Grid.Row="1"
                                           Margin="0,7,0,0">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*" />
                                             <ColumnDefinition Width="8" />
                                             <ColumnDefinition Width="*" />
                                         </Grid.ColumnDefinitions>
                                         <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="每分钟上限" />
                                            <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                     Text="{Binding TransparentProxyRateLimitPerMinuteText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                         </StackPanel>
                                         <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="缓存 TTL 秒" />
                                            <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                     Text="{Binding TransparentProxyCacheTtlSecondsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                     <UniformGrid Grid.Row="2"
                                                  Margin="0,8,0,0"
                                                 Columns="2">
                                        <CheckBox Content="启用 fallback"
                                                  IsChecked="{Binding TransparentProxyEnableFallback, Mode=TwoWay}" />
                                        <CheckBox Margin="0,5,0,0"
                                                  Content="启用短缓存"
                                                  IsChecked="{Binding TransparentProxyEnableCache, Mode=TwoWay}" />
                                        <CheckBox Margin="0,5,0,0"
                                                  Content="按路由模型改写请求"
                                                  IsChecked="{Binding TransparentProxyRewriteModel, Mode=TwoWay}" />
                                    </UniformGrid>
                                </Grid>
                            </Border>

                            <Expander Margin="0,8,0,0"
                                      Header="结构化路由"
                                      IsExpanded="True">
                                <Grid Margin="0,8,0,0" MinHeight="250">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <DockPanel LastChildFill="True">
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal">
                                            <Button Command="{Binding AddTransparentProxyRouteEditorItemCommand}"
                                                    Content="&#xE710;"
                                                    Style="{StaticResource GatewayIconButtonStyle}"
                                                    ToolTip="新增路由" />
                                            <Button Command="{Binding MoveTransparentProxyRouteEditorItemUpCommand}"
                                                    Content="&#xE74A;"
                                                    Style="{StaticResource GatewayIconButtonStyle}"
                                                    ToolTip="上移路由" />
                                            <Button Command="{Binding MoveTransparentProxyRouteEditorItemDownCommand}"
                                                    Content="&#xE74B;"
                                                    Style="{StaticResource GatewayIconButtonStyle}"
                                                    ToolTip="下移路由" />
                                            <Button Command="{Binding RemoveTransparentProxyRouteEditorItemCommand}"
                                                    Content="&#xE74D;"
                                                    Style="{StaticResource GatewayIconButtonStyle}"
                                                    ToolTip="删除路由" />
                                        </StackPanel>
                                        <TextBlock Margin="0,4,8,0"
                                                   Style="{StaticResource SectionHintTextStyle}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="启用行会进入自动选路；关闭的行会以 # 保留在高级文本中，不参与代理。"
                                                   Text="启用行参与选路，关闭行保留但不转发。" />
                                    </DockPanel>

                                    <DataGrid Grid.Row="1"
                                              Margin="0,8,0,0"
                                              MaxHeight="214"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              ColumnHeaderStyle="{StaticResource GatewayCompactDataGridHeaderStyle}"
                                              EnableColumnVirtualization="True"
                                              EnableRowVirtualization="True"
                                              GridLinesVisibility="Horizontal"
                                              HeadersVisibility="Column"
                                              ItemsSource="{Binding TransparentProxyRouteEditorItems}"
                                              RowHeight="42"
                                              SelectedItem="{Binding SelectedTransparentProxyRouteEditorItem, Mode=TwoWay}"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Width="48"
                                                                    MinWidth="48"
                                                                    Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    Header="启用" />
                                            <DataGridTextColumn Width="112"
                                                                MinWidth="96"
                                                                Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                                Header="名称" />
                                            <DataGridTextColumn Width="188"
                                                                MinWidth="168"
                                                                Binding="{Binding BaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                                Header="Base URL" />
                                            <DataGridTextColumn Width="120"
                                                                MinWidth="112"
                                                                Binding="{Binding Model, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                                Header="模型" />
                                            <DataGridTemplateColumn Width="136"
                                                                    MinWidth="126"
                                                                    Header="API Key">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                                   ToolTip="{Binding ApiKeyPreview}"
                                                                   Text="{Binding ApiKeyPreview}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <PasswordBox MinHeight="30"
                                                                     Padding="7,4"
                                                                     Style="{StaticResource CompactSecretInputPasswordBoxStyle}"
                                                                     infra:PasswordBoxAssistant.BoundPassword="{Binding ApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Expander Grid.Row="2"
                                              Margin="0,8,0,0"
                                              Header="高级：原始路由文本">
                                        <Grid Margin="0,8,0,0" MinHeight="160">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                                       TextWrapping="Wrap"
                                                       Text="每行格式：名称 | Base URL | 模型 | API Key。以 # 开头的行会保留但不启用。" />
                                            <TextBox Grid.Row="1"
                                                     Margin="0,6,0,0"
                                                     Style="{StaticResource GatewayMultilineRouteTextBoxStyle}"
                                                     Text="{Binding TransparentProxyRoutesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                    </Expander>
                                </Grid>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Column="2" MinHeight="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0"
                             Width="520"
                             HorizontalAlignment="Left"
                             Columns="3">
                    <Border Style="{StaticResource GatewayMetricTileStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="总请求" />
                            <TextBlock Style="{StaticResource GatewayMetricValueTextStyle}" Text="{Binding TransparentProxyTotalRequestsText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource GatewayMetricTileStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="成功率" />
                            <TextBlock Style="{StaticResource GatewayMetricValueTextStyle}" Text="{Binding TransparentProxySuccessRateText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource GatewayMetricTileStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="活跃" />
                            <TextBlock Style="{StaticResource GatewayMetricValueTextStyle}" Text="{Binding TransparentProxyActiveRequestsText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource GatewayMetricTileStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Fallback" />
                            <TextBlock Style="{StaticResource GatewayMetricValueTextStyle}" Text="{Binding TransparentProxyFallbackRequestsText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource GatewayMetricTileStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="缓存命中" />
                            <TextBlock Style="{StaticResource GatewayMetricValueTextStyle}" Text="{Binding TransparentProxyCacheHitsText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource GatewayMetricTileStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="P95" />
                            <TextBlock Style="{StaticResource GatewayMetricValueTextStyle}" Text="{Binding TransparentProxyP95LatencyText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="2" Style="{StaticResource SectionPanelBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                       Text="路由队列" />
                            <TextBlock Margin="0,3,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="{Binding TransparentProxyRoutingSummary, Mode=OneWay}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   MaxWidth="360"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   TextAlignment="Right"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding TransparentProxyProtocolSummary, Mode=OneWay}"
                                   Text="{Binding TransparentProxyProtocolSummary, Mode=OneWay}" />

                        <DataGrid Grid.Row="1"
                                  Grid.ColumnSpan="2"
                                  Margin="0,8,0,0"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding TransparentProxyRoutes}"
                                  ColumnHeaderStyle="{StaticResource GatewayCompactDataGridHeaderStyle}"
                                  RowHeight="38"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="52"
                                                    MinWidth="52"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding PriorityText}"
                                                    Header="#" />
                                <DataGridTemplateColumn Width="150" MinWidth="132" Header="名称">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayCellTextStyle}"
                                                       ToolTip="{Binding Name}"
                                                       Text="{Binding Name}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="248" MinWidth="220" Header="Base URL">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                       ToolTip="{Binding EndpointText}"
                                                       Text="{Binding EndpointText}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="132" MinWidth="118" Header="模型">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                       ToolTip="{Binding ModelText}"
                                                       Text="{Binding ModelText}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="104"
                                                    MinWidth="104"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding ProtocolText}"
                                                    Header="首选协议" />
                                <DataGridTextColumn Width="116"
                                                    MinWidth="116"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding ProtocolSupportText}"
                                                    Header="协议能力" />
                                <DataGridTemplateColumn Width="108" Header="健康">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource GatewayBadgeBorderStyle}"
                                                    Background="#F6F8FA"
                                                    BorderBrush="{Binding StatusBrush}"
                                                    ToolTip="{Binding StatusToolTip}">
                                                <TextBlock FontSize="10.8"
                                                           LineHeight="14"
                                                           MaxHeight="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding StatusBrush}"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding StatusText}" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="142"
                                                    MinWidth="132"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding StatsText}"
                                                    Header="统计" />
                                <DataGridTextColumn Width="82"
                                                    MinWidth="82"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding LatencyText}"
                                                    Header="延迟" />
                                <DataGridTextColumn Width="92"
                                                    MinWidth="92"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding ProtocolCheckedText}"
                                                    Header="探测" />
                                <DataGridTemplateColumn Width="86" Header="密钥">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                       ToolTip="{Binding ApiKeyPreview}"
                                                       Text="{Binding ApiKeyPreview}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource SectionPanelBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                       Text="脱敏日志" />
                            <TextBlock Margin="0,3,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="只记录路由、状态和耗时，不展示密钥正文。" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding ClearTransparentProxyLogsCommand}"
                                Content="&#xE74D;"
                                Style="{StaticResource GatewayIconButtonStyle}"
                                ToolTip="清空日志" />

                        <DataGrid Grid.Row="1"
                                  Grid.ColumnSpan="2"
                                  Margin="0,8,0,0"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding TransparentProxyLogs}"
                                  ColumnHeaderStyle="{StaticResource GatewayCompactDataGridHeaderStyle}"
                                  MinColumnWidth="112"
                                  RowHeight="42"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="158" MinWidth="158" Header="事件">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock FontFamily="Cascadia Mono, Consolas"
                                                           FontSize="11.4"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           LineHeight="14"
                                                           Text="{Binding TimeText}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <StackPanel Grid.Row="1"
                                                            Margin="0,2,0,0"
                                                            Orientation="Horizontal">
                                                    <Border Height="18"
                                                            MinWidth="42"
                                                            Padding="6,1"
                                                            BorderBrush="{Binding LevelBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="9">
                                                        <TextBlock FontSize="10.4"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding LevelBrush}"
                                                                   LineHeight="13"
                                                                   Text="{Binding Level}"
                                                                   TextAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </Border>
                                                    <TextBlock Margin="7,1,0,0"
                                                               FontFamily="Cascadia Mono, Consolas"
                                                               FontSize="10.6"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               LineHeight="13"
                                                               Text="{Binding Method}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="300" MinWidth="260" Header="路径">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                       ToolTip="{Binding Path}"
                                                       Text="{Binding Path}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="156" MinWidth="132" Header="路由">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayCellTextStyle}"
                                                       ToolTip="{Binding RouteName}"
                                                       Text="{Binding RouteName}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="126" MinWidth="118" Header="结果">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock FontFamily="Cascadia Mono, Consolas"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           LineHeight="15"
                                                           Text="{Binding StatusCode}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Margin="0,2,0,0"
                                                           FontFamily="Cascadia Mono, Consolas"
                                                           FontSize="10.8"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           LineHeight="13"
                                                           Text="{Binding ElapsedText}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="430" MinWidth="320" Header="消息">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayCellTextStyle}"
                                                       ToolTip="{Binding Message}"
                                                       Text="{Binding Message}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
