                                                                                Style="{StaticResource GatewayIconButtonStyle}"
                                                                                ToolTip="刷新令牌" />
                                                                        <Button Width="26"
                                                                                Height="26"
                                                                                Command="{Binding DataContext.DisableCodexOAuthCredentialCommand, ElementName=TransparentProxyPageRoot}"
                                                                                CommandParameter="{Binding}"
                                                                                Content="&#xE7BA;"
                                                                                Style="{StaticResource GatewayIconButtonStyle}"
                                                                                ToolTip="启用或停用" />
