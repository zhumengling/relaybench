<UserControl x:Class="RelayBench.App.Views.Pages.TransparentProxyPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="TransparentProxyPageRoot"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:infra="clr-namespace:RelayBench.App.Infrastructure"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             PreviewMouseDown="TransparentProxyPageRoot_OnPreviewMouseDown"
             Style="{StaticResource MotionPageRootStyle}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="GatewayStatusPillStyle" TargetType="Border">
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Background" Value="#F6F8FA" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>

        <Style x:Key="GatewayMetricTileStyle"
               TargetType="Border"
               BasedOn="{StaticResource InsetPanelBorderStyle}">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style x:Key="GatewayMetricLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource FieldLabelTextStyle}">
            <Setter Property="FontSize" Value="10.2" />
            <Setter Property="LineHeight" Value="13" />
            <Setter Property="MaxHeight" Value="15" />
            <Setter Property="Margin" Value="0,0,0,1" />
        </Style>

        <Style x:Key="GatewayMetricValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="FontSize" Value="12.8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="MaxHeight" Value="18" />
        </Style>

        <Style x:Key="GatewayIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkbenchIconButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="12.8" />
            <Setter Property="Margin" Value="0,0,5,0" />
        </Style>

        <Style x:Key="GatewayPrimaryIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkbenchIconButtonPrimaryStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,5,0" />
        </Style>

        <Style x:Key="GatewaySettingsToggleButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GatewayIconButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform Angle="0" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 To="180"
                                                 Duration="0:0:0.18">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 To="0"
                                                 Duration="0:0:0.16">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GatewaySettingsDrawerPanelStyle"
               TargetType="Border"
               BasedOn="{StaticResource SectionPanelBorderStyle}">
            <Setter Property="Width" Value="54" />
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="MaxWidth" Value="390" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTransparentProxySettingsDrawerOpen}" Value="True">
                    <Setter Property="Width" Value="360" />
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                 To="360"
                                                 Duration="0:0:0.20">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                 To="54"
                                                 Duration="0:0:0.18">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GatewayDrawerMenuButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="#EFF6FF" />
                    <Setter Property="BorderBrush" Value="#93C5FD" />
                    <Setter Property="Foreground" Value="#0F62FE" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GatewayDrawerMenuGlyphStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="20" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="GatewayDrawerMenuTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="4,0,2,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="GatewayAccordionPanelStyle"
               TargetType="Border"
               BasedOn="{StaticResource InsetPanelBorderStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="MaxHeight" Value="0" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="MaxHeight" Value="1200" />
                    <Setter Property="Margin" Value="0,0,0,8" />
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="IsHitTestVisible" Value="True" />
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                 To="1200"
                                                 Duration="0:0:0.18">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.14" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                 To="0"
                                                 Duration="0:0:0.16">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 Duration="0:0:0.10" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GatewayBadgeBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="Height" Value="22" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style x:Key="GatewayMonoCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="FontSize" Value="11.6" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="MaxHeight" Value="18" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GatewayCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.2" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="MaxHeight" Value="18" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GatewayDataGridTextColumnElementStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="MaxHeight" Value="18" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
        </Style>

        <Style x:Key="GatewayMultilineRouteTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="132" />
            <Setter Property="Padding" Value="9,7" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="FontSize" Value="11.2" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="AcceptsTab" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="GatewayCompactDataGridHeaderStyle"
               TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="10.8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                ClipToBounds="True">
                            <TextBlock Margin="{TemplateBinding Padding}"
                                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                       VerticalAlignment="Center"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{TemplateBinding Content}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch"
          ClipToBounds="True"
          MinHeight="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="8,6"
                Style="{StaticResource CommandBarBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            ClipToBounds="True">
                    <WrapPanel VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="透明代理"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Margin="8,1,0,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="本地入口调度器" />
                        <Border Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Style="{StaticResource GatewayStatusPillStyle}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding TransparentProxyRunStateBrush, Mode=OneWay}"
                                       Text="{Binding TransparentProxyRunStateText, Mode=OneWay}" />
                        </Border>
                    </WrapPanel>
                    <DockPanel Margin="0,4,0,0" LastChildFill="True">
                        <TextBlock DockPanel.Dock="Left"
                                   FontFamily="Cascadia Mono, Consolas"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedBrush}"
                                   MaxWidth="320"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding TransparentProxyLocalEndpoint, Mode=OneWay}"
                                   Text="{Binding TransparentProxyLocalEndpoint, Mode=OneWay}" />
                        <TextBlock Margin="12,0,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   MaxWidth="420"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding TransparentProxyStatusSummary, Mode=OneWay}"
                                   Text="{Binding TransparentProxyStatusSummary, Mode=OneWay}" />
                    </DockPanel>
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           MinWidth="260"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <Button Command="{Binding StartTransparentProxyCommand}"
                            Content="&#xE768;"
                            Style="{StaticResource GatewayPrimaryIconButtonStyle}"
                            ToolTip="启动透明代理" />
                    <Button Command="{Binding StopTransparentProxyCommand}"
                            Content="&#xE71A;"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="停止透明代理" />
                    <Button Command="{Binding CopyTransparentProxyEndpointCommand}"
                            Content="&#xE8C8;"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="复制本地入口" />
                    <Button Command="{Binding RefreshTransparentProxyRoutesCommand}"
                            Content="&#xE72C;"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="从当前接口和批量候选生成路由" />
                    <Button Command="{Binding ProbeTransparentProxyProtocolsCommand}"
                            Content="&#xE946;"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="拉取模型并探测 Responses / Anthropic / OpenAI Chat 协议" />
                    <Button Click="ToggleTokenMeterButton_OnClick"
                            Content="&#xE9D2;"
                            IsEnabled="{Binding IsTransparentProxyRunning, Mode=OneWay}"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="显示或隐藏 Token 悬浮窗"
                            ToolTipService.ShowOnDisabled="True" />
                    <Button Command="{Binding ClearTransparentProxyLogsCommand}"
                            Content="&#xE74D;"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="清空日志" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,8,0,0"
              MinHeight="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    x:Name="TransparentProxySettingsDrawerHost"
                    Style="{StaticResource GatewaySettingsDrawerPanelStyle}">
                <Grid MinHeight="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Button Margin="0,0,0,6"
                                Command="{Binding ToggleTransparentProxySettingsDrawerCommand}"
                                Content="&#xE713;"
                                Style="{StaticResource GatewaySettingsToggleButtonStyle}"
                                Tag="{Binding IsTransparentProxySettingsDrawerOpen}"
                                ToolTip="&#x5C55;&#x5F00;&#x6216;&#x6536;&#x8D77;&#x5165;&#x53E3;&#x8BBE;&#x7F6E;" />
                        <TextBlock Visibility="Collapsed" Text="入口设置">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SectionTitleTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTransparentProxySettingsDrawerOpen}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="0,3,0,0"
                                   Visibility="Collapsed"
                                   Text="{Binding TransparentProxyHealthSummary, Mode=OneWay}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTransparentProxySettingsDrawerOpen}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="0,6,0,0"
                          MinHeight="0"
                          Visibility="{Binding IsTransparentProxySettingsDrawerOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                            <Button Grid.Row="0"
                                    Command="{Binding ToggleTransparentProxyListenSettingsCommand}"
                                    Tag="{Binding IsTransparentProxyListenSettingsOpen}"
                                    Style="{StaticResource GatewayDrawerMenuButtonStyle}"
                                    ToolTip="展开或收起监听设置">
                                <DockPanel LastChildFill="False"
                                           VerticalAlignment="Center">
                                    <TextBlock DockPanel.Dock="Left"
                                               Width="20"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="13"
                                               LineHeight="16"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="&#xE968;" />
                                    <TextBlock VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               LineHeight="16"
                                               Text="监听设置" />
                                    <TextBlock DockPanel.Dock="Right"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="11"
                                               LineHeight="16"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="&#xE70D;" />
                                </DockPanel>
                            </Button>

                            <Border Grid.Row="1"
                                    Tag="{Binding IsTransparentProxyListenSettingsOpen}"
                                    Style="{StaticResource GatewayAccordionPanelStyle}">
                                <Grid>
                                     <Grid.RowDefinitions>
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="Auto" />
                                     </Grid.RowDefinitions>

                                     <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                Text="监听" />
                                     <Grid Grid.Row="1"
                                           Margin="0,5,0,0">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*" />
                                             <ColumnDefinition Width="8" />
                                             <ColumnDefinition Width="*" />
                                         </Grid.ColumnDefinitions>
                                         <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="端口" />
                                            <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                     Text="{Binding TransparentProxyPortText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                         </StackPanel>
                                         <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="并发上限" />
                                            <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                     Text="{Binding TransparentProxyMaxConcurrencyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                         </StackPanel>
                                     </Grid>
                                     <TextBox Grid.Row="2"
                                              Margin="0,5,0,0"
                                             FontFamily="Cascadia Mono, Consolas"
                                             IsReadOnly="True"
                                             Style="{StaticResource CompactInputTextBoxStyle}"
                                             ToolTip="{Binding TransparentProxyLocalEndpoint, Mode=OneWay}"
                                             Text="{Binding TransparentProxyLocalEndpoint, Mode=OneWay}" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Tag="{Binding IsTransparentProxyListenSettingsOpen}"
                                    Style="{StaticResource GatewayAccordionPanelStyle}">
                                <Grid>
                                     <Grid.RowDefinitions>
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="Auto" />
                                     </Grid.RowDefinitions>

                                     <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                Text="保护" />
                                     <Grid Grid.Row="1"
                                           Margin="0,5,0,0">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*" />
                                             <ColumnDefinition Width="8" />
                                             <ColumnDefinition Width="*" />
                                         </Grid.ColumnDefinitions>
                                         <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="每分钟上限" />
                                            <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                     Text="{Binding TransparentProxyRateLimitPerMinuteText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                         </StackPanel>
                                         <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="缓存 TTL 秒" />
                                            <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                     Text="{Binding TransparentProxyCacheTtlSecondsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                     <UniformGrid Grid.Row="2"
                                                   Margin="0,6,0,0"
                                                 Columns="2">
                                        <CheckBox Content="启用 fallback"
                                                  IsChecked="{Binding TransparentProxyEnableFallback, Mode=TwoWay}" />
                                        <CheckBox Margin="0,5,0,0"
                                                  Content="启用短缓存"
                                                  IsChecked="{Binding TransparentProxyEnableCache, Mode=TwoWay}" />
                                        <Button Margin="0,6,8,0"
                                                Command="{Binding ClearTransparentProxyCacheCommand}"
                                                Content="清空短缓存"
                                                MinWidth="0"
                                                ToolTip="立即清空本地响应短缓存，后续请求重新走上游" />
                                        <CheckBox Margin="0,5,0,0"
                                                  Content="按路由模型改写请求"
                                                  IsChecked="{Binding TransparentProxyRewriteModel, Mode=TwoWay}"
                                                  Visibility="Collapsed" />
                                    </UniformGrid>
                                </Grid>
                            </Border>

                            <Button Grid.Row="3"
                                    Command="{Binding ToggleTransparentProxyProviderSettingsCommand}"
                                    Tag="{Binding IsTransparentProxyProviderSettingsOpen}"
                                    Style="{StaticResource GatewayDrawerMenuButtonStyle}"
                                    ToolTip="展开或收起提供商">
                                <DockPanel LastChildFill="False"
                                           VerticalAlignment="Center">
                                    <TextBlock DockPanel.Dock="Left"
                                               Width="20"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="13"
                                               LineHeight="16"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="&#xE774;" />
                                    <TextBlock VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               LineHeight="16"
                                               Text="提供商" />
                                    <TextBlock DockPanel.Dock="Right"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="11"
                                               LineHeight="16"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="&#xE70D;" />
                                </DockPanel>
                            </Button>

                            <Border Grid.Row="4"
                                    VerticalAlignment="Stretch"
                                    Tag="{Binding IsTransparentProxyProviderSettingsOpen}"
                                    Style="{StaticResource GatewayAccordionPanelStyle}">
                                <Grid MinHeight="0"
                                      VerticalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="0" />
                                    </Grid.RowDefinitions>

                                    <DockPanel LastChildFill="True">
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal">
                                            <Button Command="{Binding AddTransparentProxyRouteEditorItemCommand}"
                                                    Content="&#xE710;"
                                                    Style="{StaticResource GatewayIconButtonStyle}"
                                                    ToolTip="新增路由" />
                                            <Button Command="{Binding MoveTransparentProxyRouteEditorItemUpCommand}"
                                                    Content="&#xE74A;"
                                                    Style="{StaticResource GatewayIconButtonStyle}"
                                                    ToolTip="上移路由" />
                                            <Button Command="{Binding MoveTransparentProxyRouteEditorItemDownCommand}"
                                                    Content="&#xE74B;"
                                                    Style="{StaticResource GatewayIconButtonStyle}"
                                                    ToolTip="下移路由" />
                                            <Button Command="{Binding RemoveTransparentProxyRouteEditorItemCommand}"
                                                    Content="&#xE74D;"
                                                    Style="{StaticResource GatewayIconButtonStyle}"
                                                    ToolTip="删除路由" />
                                        </StackPanel>
                                        <TextBlock Margin="0,4,8,0"
                                                   Style="{StaticResource SectionHintTextStyle}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="启用行会进入自动选路；关闭的行会以 # 保留在高级文本中，不参与代理。"
                                                   Text="启用行参与选路，关闭行保留但不转发。" />
                                    </DockPanel>

                                    <DataGrid Grid.Row="1"
                                              Margin="0,6,0,0"
                                              MinHeight="0"
                                              VerticalAlignment="Stretch"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              ColumnHeaderStyle="{StaticResource GatewayCompactDataGridHeaderStyle}"
                                              EnableColumnVirtualization="True"
                                              EnableRowVirtualization="True"
                                              GridLinesVisibility="Horizontal"
                                              HeadersVisibility="Column"
                                              ItemsSource="{Binding TransparentProxyRouteEditorItems}"
                                              MinColumnWidth="0"
                                              RowHeight="36"
                                              SelectedItem="{Binding SelectedTransparentProxyRouteEditorItem, Mode=TwoWay}"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Width="42"
                                                                    MinWidth="38"
                                                                    Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    Header="启用" />
                                            <DataGridTextColumn Width="76"
                                                                MinWidth="68"
                                                                Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                                Header="名称" />
                                            <DataGridTextColumn Width="1.3*"
                                                                MinWidth="92"
                                                                Binding="{Binding BaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                                Header="Base URL" />
                                            <DataGridTextColumn Width="82"
                                                                MinWidth="72"
                                                                Binding="{Binding ModelCountText, Mode=OneWay}"
                                                                ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                                Header="模型" />
                                            <DataGridTemplateColumn Width="0"
                                                                    Visibility="Collapsed"
                                                                    MinWidth="0"
                                                                    Header="API Key">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                                   ToolTip="{Binding ApiKeyPreview}"
                                                                   Text="{Binding ApiKeyPreview}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <PasswordBox MinHeight="30"
                                                                     Padding="7,4"
                                                                     Style="{StaticResource CompactSecretInputPasswordBoxStyle}"
                                                                     infra:PasswordBoxAssistant.BoundPassword="{Binding ApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="42" MinWidth="42" Header="">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Width="28"
                                                                Height="28"
                                                                Margin="0"
                                                                Command="{Binding DataContext.OpenTransparentProxyRouteSettingsCommand, ElementName=TransparentProxyPageRoot}"
                                                                CommandParameter="{Binding}"
                                                                Content="&#xE713;"
                                                                Style="{StaticResource GatewayIconButtonStyle}"
                                                                ToolTip="&#x8DEF;&#x7531;&#x8BBE;&#x7F6E;" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Expander Grid.Row="2"
                                              Visibility="Collapsed"
                                              Margin="0,6,0,0"
                                              Header="高级：原始路由文本">
                                        <Grid Margin="0,6,0,0" MinHeight="132">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                                       TextWrapping="Wrap"
                                                       Text="每行格式：名称 | Base URL | 模型 | API Key。以 # 开头的行会保留但不启用。" />
                                            <TextBox Grid.Row="1"
                                                     Margin="0,6,0,0"
                                                     Style="{StaticResource GatewayMultilineRouteTextBoxStyle}"
                                                     Text="{Binding TransparentProxyRoutesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                    </Expander>
                                </Grid>
                            </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="2" MinHeight="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition>
                        <RowDefinition.Style>
                            <Style TargetType="RowDefinition">
                                <Setter Property="Height" Value="3.2*" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTransparentProxyLogExpanded}" Value="True">
                                        <Setter Property="Height" Value="2.05*" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RowDefinition.Style>
                    </RowDefinition>
                    <RowDefinition Height="6" />
                    <RowDefinition>
                        <RowDefinition.Style>
                            <Style TargetType="RowDefinition">
                                <Setter Property="Height" Value="0.85*" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTransparentProxyLogExpanded}" Value="True">
                                        <Setter Property="Height" Value="2*" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RowDefinition.Style>
                    </RowDefinition>
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0"
                             Height="40"
                             HorizontalAlignment="Stretch"
                             Columns="6">
                    <Border Style="{StaticResource GatewayMetricTileStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource GatewayMetricLabelTextStyle}" Text="总请求" />
                            <TextBlock Style="{StaticResource GatewayMetricValueTextStyle}" Text="{Binding TransparentProxyTotalRequestsText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource GatewayMetricTileStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource GatewayMetricLabelTextStyle}" Text="成功率" />
                            <TextBlock Style="{StaticResource GatewayMetricValueTextStyle}" Text="{Binding TransparentProxySuccessRateText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource GatewayMetricTileStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource GatewayMetricLabelTextStyle}" Text="活跃" />
                            <TextBlock Style="{StaticResource GatewayMetricValueTextStyle}" Text="{Binding TransparentProxyActiveRequestsText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource GatewayMetricTileStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource GatewayMetricLabelTextStyle}" Text="Fallback" />
                            <TextBlock Style="{StaticResource GatewayMetricValueTextStyle}" Text="{Binding TransparentProxyFallbackRequestsText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource GatewayMetricTileStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource GatewayMetricLabelTextStyle}" Text="缓存命中" />
                            <TextBlock Style="{StaticResource GatewayMetricValueTextStyle}" Text="{Binding TransparentProxyCacheHitsText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource GatewayMetricTileStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource GatewayMetricLabelTextStyle}" Text="P95" />
                            <TextBlock Style="{StaticResource GatewayMetricValueTextStyle}" Text="{Binding TransparentProxyP95LatencyText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="2"
                        Padding="8"
                        Style="{StaticResource SectionPanelBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                       Text="路由队列" />
                            <TextBlock Margin="0,3,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="{Binding TransparentProxyRoutingSummary, Mode=OneWay}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   MaxWidth="360"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   TextAlignment="Right"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding TransparentProxyProtocolSummary, Mode=OneWay}"
                                   Text="{Binding TransparentProxyProtocolSummary, Mode=OneWay}" />

                        <DataGrid Grid.Row="1"
                                  Grid.ColumnSpan="2"
                                  Margin="0,8,0,0"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding TransparentProxyRoutes}"
                                  ColumnHeaderStyle="{StaticResource GatewayCompactDataGridHeaderStyle}"
                                  MinColumnWidth="0"
                                  RowHeight="36"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="32"
                                                    MinWidth="30"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding PriorityText}"
                                                    Header="#" />
                                <DataGridTemplateColumn Width="112" MinWidth="92" Header="名称">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayCellTextStyle}"
                                                       ToolTip="{Binding Name}"
                                                       Text="{Binding Name}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="2.4*" MinWidth="260" Header="Base URL">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                       ToolTip="{Binding EndpointText}"
                                                       Text="{Binding EndpointText}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="62" MinWidth="56" Header="模型">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                        ToolTip="{Binding ModelPoolToolTip}"
                                                        Text="{Binding ModelPoolText}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="0"
                                                    Visibility="Collapsed"
                                                    MinWidth="0"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding ProtocolText}"
                                                    Header="首选协议" />
                                <DataGridTextColumn Width="0"
                                                    Visibility="Collapsed"
                                                    MinWidth="0"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding ProtocolSupportText}"
                                                    Header="协议能力" />
                                <DataGridTemplateColumn Width="62" Header="健康">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource GatewayBadgeBorderStyle}"
                                                    Background="#F6F8FA"
                                                    BorderBrush="{Binding StatusBrush}"
                                                    ToolTip="{Binding StatusToolTip}">
                                                <TextBlock FontSize="10.8"
                                                           LineHeight="14"
                                                           MaxHeight="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding StatusBrush}"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding StatusText}" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="62"
                                                    MinWidth="52"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding StatsText}"
                                                    Header="统计" />
                                <DataGridTextColumn Width="46"
                                                    MinWidth="42"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding LatencyText}"
                                                    Header="延迟" />
                                <DataGridTextColumn Width="0"
                                                    Visibility="Collapsed"
                                                    MinWidth="0"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding ProtocolCheckedText}"
                                                    Header="探测" />
                                <DataGridTemplateColumn Width="0" Visibility="Collapsed" Header="密钥">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                       ToolTip="{Binding ApiKeyPreview}"
                                                       Text="{Binding ApiKeyPreview}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="4"
                        Padding="8"
                        Style="{StaticResource SectionPanelBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                            <Button Command="{Binding ToggleTransparentProxyLogExpandedCommand}"
                                    Content="{Binding TransparentProxyLogExpandIcon, Mode=OneWay}"
                                    Style="{StaticResource GatewayIconButtonStyle}"
                                    ToolTip="{Binding TransparentProxyLogExpandToolTip, Mode=OneWay}" />
                            <Button Command="{Binding ClearTransparentProxyLogsCommand}"
                                    Content="&#xE74D;"
                                    Style="{StaticResource GatewayIconButtonStyle}"
                                    ToolTip="清空日志" />
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  Grid.ColumnSpan="2"
                                  Margin="0,4,0,0"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding TransparentProxyLogs}"
                                  ColumnHeaderStyle="{StaticResource GatewayCompactDataGridHeaderStyle}"
                                  MinColumnWidth="0"
                                  RowHeight="36"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="118" MinWidth="104" Header="事件">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock FontFamily="Cascadia Mono, Consolas"
                                                           FontSize="11.4"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           LineHeight="14"
                                                           Text="{Binding TimeText}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <StackPanel Grid.Row="1"
                                                            Margin="0,2,0,0"
                                                            Orientation="Horizontal">
                                                    <Border Height="18"
                                                            MinWidth="42"
                                                            Padding="6,1"
                                                            BorderBrush="{Binding LevelBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="9">
                                                        <TextBlock FontSize="10.4"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding LevelBrush}"
                                                                   LineHeight="13"
                                                                   Text="{Binding Level}"
                                                                   TextAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </Border>
                                                    <TextBlock Margin="7,1,0,0"
                                                               FontFamily="Cascadia Mono, Consolas"
                                                               FontSize="10.6"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               LineHeight="13"
                                                               Text="{Binding Method}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="1.25*" MinWidth="120" Header="路径">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                       ToolTip="{Binding Path}"
                                                       Text="{Binding Path}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="1.05*" MinWidth="120" Header="模型">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                       ToolTip="{Binding ModelName}"
                                                       Text="{Binding ModelName}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="0.8*" MinWidth="88" Header="路由">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayCellTextStyle}"
                                                       ToolTip="{Binding RouteName}"
                                                       Text="{Binding RouteName}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="86" MinWidth="78" Header="结果">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock FontFamily="Cascadia Mono, Consolas"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           LineHeight="15"
                                                           Text="{Binding StatusCode}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Margin="0,2,0,0"
                                                           FontFamily="Cascadia Mono, Consolas"
                                                           FontSize="10.8"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           LineHeight="13"
                                                           Text="{Binding ElapsedText}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="1.55*" MinWidth="140" Header="消息">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayCellTextStyle}"
                                                       ToolTip="{Binding Message}"
                                                       Text="{Binding Message}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.RowSpan="2"
              Panel.ZIndex="40"
              Background="#66111827"
              Visibility="{Binding IsTransparentProxyRouteSettingsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Width="780"
                    MinHeight="540"
                    MaxWidth="{Binding ActualWidth, ElementName=TransparentProxyPageRoot}"
                    MaxHeight="620"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="16"
                    Padding="14"
                    Style="{StaticResource DashboardOverlayPanelStyle}"
                    infra:MotionAssist.LoadedOffsetY="10"
                    infra:MotionAssist.TransitionDurationMs="180"
                    infra:MotionAssist.UseVisibilityTransition="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleTextStyle}"
                                       Text="路由节点设置" />
                            <TextBlock Margin="0,4,0,0"
                                       MaxWidth="560"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="模型从上游 /v1/models 聚合，转发保持原始请求结构；前缀只用于显式选路。" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding CloseTransparentProxyRouteSettingsCommand}"
                                Content="&#xE711;"
                                Style="{StaticResource GatewayIconButtonStyle}"
                                ToolTip="关闭" />
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="0,12,0,12"
                          MinHeight="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.35*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="0.7*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="0.9*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                               Text="Provider name" />
                                    <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                             Text="{Binding TransparentProxyRouteSettingsItem.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                               Text="Priority" />
                                    <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                             Text="{Binding TransparentProxyRouteSettingsItem.PriorityText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                               Text="Prefix" />
                                    <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                             ToolTip="示例：openrouter；客户端可请求 openrouter/model-id 指定该节点。"
                                             Text="{Binding TransparentProxyRouteSettingsItem.Prefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="1"
                                        Margin="0,10,0,0">
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                           Text="Base URL" />
                                <TextBox FontFamily="Cascadia Mono, Consolas"
                                         Style="{StaticResource CompactInputTextBoxStyle}"
                                         Text="{Binding TransparentProxyRouteSettingsItem.BaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Margin="0,10,0,0">
                                <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                           Text="API Key" />
                                <PasswordBox Height="30"
                                             Style="{StaticResource CompactSecretInputPasswordBoxStyle}"
                                             infra:PasswordBoxAssistant.BoundPassword="{Binding TransparentProxyRouteSettingsItem.ApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,4,0,0"
                                           Style="{StaticResource SectionHintTextStyle}"
                                           Text="留空时继承客户端 Authorization；填写后对该节点覆盖为 Bearer token。" />
                            </StackPanel>

                            <Grid Grid.Row="3"
                                  Margin="0,10,0,0"
                                  MinHeight="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      MinHeight="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0"
                                               LastChildFill="True">
                                        <Button DockPanel.Dock="Right"
                                                Margin="6,0,0,0"
                                                Command="{Binding FetchTransparentProxyRouteEditorItemModelsCommand}"
                                                CommandParameter="{Binding TransparentProxyRouteSettingsItem}"
                                                Content="从 /models 获取"
                                                MinWidth="104"
                                                ToolTip="从该节点 /v1/models 拉取全部模型" />
                                        <Button DockPanel.Dock="Right"
                                                Command="{Binding AddTransparentProxyRouteModelMappingCommand}"
                                                CommandParameter="{Binding TransparentProxyRouteSettingsItem}"
                                                Content="添加模型"
                                                MinWidth="76"
                                                ToolTip="手动添加一个模型映射" />
                                        <TextBlock Margin="0,5,8,0"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="模型列表 name -> alias" />
                                    </DockPanel>
                                    <DataGrid Grid.Row="1"
                                              Margin="0,6,0,0"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              ColumnHeaderStyle="{StaticResource GatewayCompactDataGridHeaderStyle}"
                                              EnableColumnVirtualization="True"
                                              EnableRowVirtualization="True"
                                              GridLinesVisibility="Horizontal"
                                              HeadersVisibility="Column"
                                              IsReadOnly="False"
                                              ItemsSource="{Binding TransparentProxyRouteSettingsItem.ModelMappings}"
                                              MinColumnWidth="0"
                                              RowHeight="32"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Width="1.05*"
                                                                MinWidth="150"
                                                                Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                                Header="name / 上游模型" />
                                            <DataGridTextColumn Width="1.05*"
                                                                MinWidth="150"
                                                                Binding="{Binding Alias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                                Header="alias / 显示名称" />
                                            <DataGridTemplateColumn Width="36" MinWidth="34" Header="">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Width="28"
                                                                Height="28"
                                                                Margin="0"
                                                                Command="{Binding DataContext.RemoveTransparentProxyRouteModelMappingCommand, ElementName=TransparentProxyPageRoot}"
                                                                CommandParameter="{Binding}"
                                                                Content="&#xE711;"
                                                                Style="{StaticResource GatewayIconButtonStyle}"
                                                                ToolTip="删除模型映射" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock Grid.Row="2"
                                               Margin="0,4,0,0"
                                               Style="{StaticResource SectionHintTextStyle}"
                                               Text="{Binding TransparentProxyRouteSettingsItem.ModelPreviewText, Mode=OneWay}" />
                                </Grid>

                                <Grid Grid.Column="2"
                                      MinHeight="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                               Text="Custom headers" />
                                    <TextBox Grid.Row="1"
                                             Margin="0,6,0,0"
                                             MinHeight="0"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             FontFamily="Cascadia Mono, Consolas"
                                             FontSize="11.4"
                                             HorizontalScrollBarVisibility="Disabled"
                                             Padding="8,6"
                                             Style="{StaticResource {x:Type TextBox}}"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             ToolTip="每行一个 Header: value"
                                             Text="{Binding TransparentProxyRouteSettingsItem.HeadersText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </Grid>
                    </Grid>

                    <DockPanel Grid.Row="2" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="{Binding TransparentProxyRouteSettingsItem.ModelCountText, Mode=OneWay}" />
                        <Button DockPanel.Dock="Right"
                                Command="{Binding CloseTransparentProxyRouteSettingsCommand}"
                                Content="完成"
                                MinWidth="76" />
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
