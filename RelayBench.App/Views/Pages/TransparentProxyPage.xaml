                                      Margin="0,7,0,0"
                                      MaxHeight="88"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                        <ItemsControl Width="{Binding ActualWidth, ElementName=TransparentProxyModelPoolScroller}"
                                      ClipToBounds="True"
                                      ItemsSource="{Binding TransparentProxyModelPools}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource GatewayModelPoolChipStyle}"
                                            ToolTip="{Binding ToolTipText}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0"
                                                     Width="7"
                                                     Height="7"
                                                     Margin="0,0,7,0"
                                                     VerticalAlignment="Center"
                                                     Fill="{Binding HealthBrush}" />
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center">
                                                <TextBlock FontFamily="Cascadia Mono, Consolas"
                                                           FontSize="11.2"
                                                           FontWeight="SemiBold"
                                                           LineHeight="14"
                                                           MaxHeight="16"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding DisplayModelName}" />
                                                <TextBlock Margin="0,1,0,0"
                                                           FontSize="10.4"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           LineHeight="13"
                                                           MaxHeight="14"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding MemberCountText}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Right">
                                                <TextBlock FontSize="10.4"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding HealthBrush}"
                                                           LineHeight="13"
                                                           TextAlignment="Right"
                                                           Text="{Binding HealthText}" />
                                                <TextBlock Margin="0,1,0,0"
                                                           FontSize="10.2"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           LineHeight="12"
                                                           TextAlignment="Right"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding ProtocolSummary}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>

                        <DataGrid Grid.Row="2"
                                  Grid.ColumnSpan="2"
                                  Margin="0,4,0,0"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding TransparentProxyRoutes}"
                                  ColumnHeaderStyle="{StaticResource GatewayCompactDataGridHeaderStyle}"
                                  MinColumnWidth="0"
                                  RowHeight="36"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="32"
                                                    MinWidth="30"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding PriorityText}"
                                                    Header="#" />
                                <DataGridTemplateColumn Width="112" MinWidth="92" Header="名称">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayCellTextStyle}"
                                                       ToolTip="{Binding Name}"
                                                       Text="{Binding Name}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="2.4*" MinWidth="260" Header="接口地址">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                       ToolTip="{Binding EndpointText}"
                                                       Text="{Binding EndpointText}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="62" MinWidth="56" Header="模型">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                        ToolTip="{Binding ModelPoolToolTip}"
                                                        Text="{Binding ModelPoolText}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="0"
                                                    Visibility="Collapsed"
                                                    MinWidth="0"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding ProtocolText}"
                                                    Header="首选协议" />
                                <DataGridTextColumn Width="0"
                                                    Visibility="Collapsed"
                                                    MinWidth="0"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding ProtocolSupportText}"
                                                    Header="协议能力" />
                                <DataGridTemplateColumn Width="62" Header="健康">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource GatewayBadgeBorderStyle}"
                                                    Background="#F6F8FA"
                                                    BorderBrush="{Binding StatusBrush}"
                                                    ToolTip="{Binding StatusToolTip}">
                                                <TextBlock FontSize="10.8"
                                                           LineHeight="14"
                                                           MaxHeight="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding StatusBrush}"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding StatusText}" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="0"
                                                    Visibility="Collapsed"
                                                    MinWidth="0"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding StatsText}"
                                                    Header="统计" />
                                <DataGridTextColumn Width="0"
                                                    Visibility="Collapsed"
                                                    MinWidth="0"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding LatencyText}"
                                                    Header="延迟" />
                                <DataGridTextColumn Width="0"
                                                    Visibility="Collapsed"
                                                    MinWidth="0"
                                                    ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                    Binding="{Binding ProtocolCheckedText}"
                                                    Header="探测" />
                                <DataGridTemplateColumn Width="0" Visibility="Collapsed" Header="密钥">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                       ToolTip="{Binding ApiKeyPreview}"
                                                       Text="{Binding ApiKeyPreview}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="4"
                        Padding="8"
                        Style="{StaticResource SectionPanelBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Column="0"
                                   LastChildFill="True">
                            <TextBlock DockPanel.Dock="Left"
                                       Margin="0,4,10,0"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       Text="请求日志" />
                            <ComboBox DockPanel.Dock="Left"
                                      Width="122"
                                      Margin="0,0,6,0"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{Binding TransparentProxyLogSourceFilterOptions}"
                                      SelectedValuePath="Key"
                                      SelectedValue="{Binding TransparentProxyLogSourceFilterKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource CompactComboBoxStyle}"
                                      ToolTip="按入口来源筛选日志" />
                            <TextBox Width="220"
                                     HorizontalAlignment="Left"
                                     Style="{StaticResource CompactInputTextBoxStyle}"
                                     Text="{Binding TransparentProxyLogFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="按路由、模型、请求 ID、协议或消息过滤" />
                        </DockPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                            <Button Command="{Binding ToggleTransparentProxyLogExpandedCommand}"
                                    Content="{Binding TransparentProxyLogExpandIcon, Mode=OneWay}"
                                    Style="{StaticResource GatewayIconButtonStyle}"
                                    ToolTip="{Binding TransparentProxyLogExpandToolTip, Mode=OneWay}" />
                            <Button Command="{Binding ClearTransparentProxyLogsCommand}"
                                    Content="&#xE74D;"
                                    Style="{StaticResource GatewayIconButtonStyle}"
                                    ToolTip="清空日志" />
                            <Button Command="{Binding ExportTransparentProxyLogsCommand}"
                                    Content="&#xEDE1;"
                                    Style="{StaticResource GatewayIconButtonStyle}"
                                    ToolTip="导出日志" />
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  Grid.ColumnSpan="2"
                                  Margin="0,4,0,0"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding TransparentProxyLogs}"
                                  SelectedItem="{Binding SelectedTransparentProxyLog, Mode=TwoWay}"
                                  ColumnHeaderStyle="{StaticResource GatewayCompactDataGridHeaderStyle}"
                                  MinColumnWidth="0"
                                  RowHeight="36"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="138" MinWidth="118" Header="事件">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock FontFamily="Cascadia Mono, Consolas"
                                                           FontSize="11.4"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           LineHeight="14"
                                                           Text="{Binding TimeText}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <StackPanel Grid.Row="1"
                                                            Margin="0,2,0,0"
                                                            Orientation="Horizontal">
                                                    <Border Height="18"
                                                            MinWidth="42"
                                                            Padding="6,1"
                                                            BorderBrush="{Binding LevelBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="9">
                                                        <TextBlock FontSize="10.4"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding LevelBrush}"
                                                                   LineHeight="13"
                                                                   Text="{Binding Level}"
                                                                   TextAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </Border>
                                                     <TextBlock Margin="7,1,0,0"
                                                                FontFamily="Cascadia Mono, Consolas"
                                                                FontSize="10.6"
                                                                Foreground="{StaticResource MutedBrush}"
                                                                LineHeight="13"
                                                                Text="{Binding Method}"
                                                                TextTrimming="CharacterEllipsis" />
                                                     <TextBlock Margin="7,1,0,0"
                                                                MaxWidth="58"
                                                                FontSize="10.6"
                                                                Foreground="{StaticResource MutedBrush}"
                                                                LineHeight="13"
                                                                Text="{Binding SourceText}"
                                                                TextTrimming="CharacterEllipsis"
                                                                ToolTip="{Binding SourceApplication}" />
                                                 </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="1.25*" MinWidth="120" Header="路径">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                       ToolTip="{Binding Path}"
                                                       Text="{Binding Path}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="1.05*" MinWidth="120" Header="模型">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayMonoCellTextStyle}"
                                                       ToolTip="{Binding ModelName}"
                                                       Text="{Binding ModelName}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="0.8*" MinWidth="88" Header="路由">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayCellTextStyle}"
                                                       ToolTip="{Binding RouteName}"
                                                       Text="{Binding RouteName}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="86" MinWidth="78" Header="结果">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock FontFamily="Cascadia Mono, Consolas"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           LineHeight="15"
                                                           Text="{Binding StatusCode}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Margin="0,2,0,0"
                                                           FontFamily="Cascadia Mono, Consolas"
                                                           FontSize="10.8"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           LineHeight="13"
                                                           Text="{Binding ElapsedText}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="1.55*" MinWidth="140" Header="消息">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource GatewayCellTextStyle}"
                                                       ToolTip="{Binding Message}"
                                                       Text="{Binding Message}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Width="420"
                                Margin="0,4,0,0"
                                Padding="10"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                Panel.ZIndex="6"
                                Background="#FAFBFF"
                                BorderBrush="#C7D7FE"
                                BorderThickness="1"
                                CornerRadius="8"
                                infra:MotionAssist.LoadedOffsetY="0"
                                infra:MotionAssist.TransitionDurationMs="170"
                                infra:MotionAssist.UseVisibilityTransition="True"
                                Visibility="{Binding IsTransparentProxyLogDetailOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel LastChildFill="True">
                                    <Button DockPanel.Dock="Right"
                                            Command="{Binding CloseTransparentProxyLogDetailCommand}"
                                            Content="&#xE711;"
                                            Style="{StaticResource GatewayIconButtonStyle}"
                                            ToolTip="关闭详情" />
                                    <TextBlock Margin="0,5,8,0"
                                               Style="{StaticResource SectionTitleTextStyle}"
                                               Text="请求详情" />
                                </DockPanel>
                                <TextBox Grid.Row="1"
                                         Margin="0,8,0,0"
                                         FontFamily="Cascadia Mono, Consolas"
                                         FontSize="11.2"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Style="{StaticResource ReadOnlyOutputTextBoxStyle}"
                                         Text="{Binding SelectedTransparentProxyLog.DetailText, Mode=OneWay}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.RowSpan="2"
              Panel.ZIndex="40"
              Background="#66111827"
              Visibility="{Binding IsTransparentProxyRouteSettingsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Width="980"
                            MinHeight="620"
                            MaxWidth="{Binding ActualWidth, ElementName=TransparentProxyPageRoot}"
                            MaxHeight="{Binding ActualHeight, ElementName=TransparentProxyPageRoot}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="16"
                    Padding="14"
                    Style="{StaticResource DashboardOverlayPanelStyle}"
                    infra:MotionAssist.LoadedOffsetY="10"
                    infra:MotionAssist.TransitionDurationMs="180"
                    infra:MotionAssist.UseVisibilityTransition="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleTextStyle}"
                                       Text="路由节点设置" />
                            <TextBlock Margin="0,4,0,0"
                                       MaxWidth="560"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="模型从上游 /v1/models 聚合，转发保持原始请求结构；前缀只用于显式选路。" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding CloseTransparentProxyRouteSettingsCommand}"
                                Content="&#xE711;"
                                Style="{StaticResource GatewayIconButtonStyle}"
                                ToolTip="关闭" />
                    </Grid>

                    <TabControl Grid.Row="1"
                                Margin="0,10,0,10"
                                MinHeight="0"
                                Padding="7">
                        <TabItem Header="基础">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                            <Grid MinHeight="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.25*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="0.82*" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.ColumnSpan="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.4*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="0.65*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="0.9*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="提供商名称" />
                                        <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                 Text="{Binding TransparentProxyRouteSettingsItem.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="优先级" />
                                        <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                 Text="{Binding TransparentProxyRouteSettingsItem.PriorityText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="前缀" />
                                        <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                 ToolTip="示例：openrouter；客户端可请求 openrouter/model-id 指定该节点。"
                                                 Text="{Binding TransparentProxyRouteSettingsItem.Prefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="6"
                                              Margin="4,19,0,0"
                                              Content="启用"
                                              IsChecked="{Binding TransparentProxyRouteSettingsItem.IsEnabled, Mode=TwoWay}" />
                                </Grid>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                               Text="接口地址" />
                                    <TextBox FontFamily="Cascadia Mono, Consolas"
                                             Style="{StaticResource CompactInputTextBoxStyle}"
                                             Text="{Binding TransparentProxyRouteSettingsItem.BaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                               Text="出站代理" />
                                    <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                             ToolTip="留空继承系统代理；direct/none 直连；也可填写 http(s):// 或 socks5://"
                                             Text="{Binding TransparentProxyRouteSettingsItem.OutboundProxy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <Grid Grid.Row="4"
                                      Grid.ColumnSpan="3"
                                      MinHeight="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.05*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="1.15*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="认证方式" />
                                        <ComboBox Height="30"
                                                  Margin="0,0,0,8"
                                                  SelectedValue="{Binding TransparentProxyRouteSettingsItem.AuthMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Tag">
                                            <ComboBoxItem Content="API Key"
                                                          Tag="ApiKey" />
                                            <ComboBoxItem Content="Codex OAuth"
                                                          Tag="CodexOAuth" />
                                        </ComboBox>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Visibility="{Binding TransparentProxyRouteSettingsItem.IsCodexOAuthAuth, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   Text="Codex OAuth 账号" />
                                        <Grid Margin="0,0,0,8"
                                              Visibility="{Binding TransparentProxyRouteSettingsItem.IsCodexOAuthAuth, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Height="32"
                                                      ItemsSource="{Binding CodexOAuthCredentials}"
                                                      SelectedValue="{Binding TransparentProxyRouteSettingsItem.OAuthCredentialId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Id">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid MinWidth="220"
                                                              ToolTip="{Binding DetailText}">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock VerticalAlignment="Center"
                                                                       FontSize="11.2"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding DisplayName}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <Border Grid.Column="1"
                                                                    Margin="8,0,0,0"
                                                                    Padding="6,1"
                                                                    Height="20"
                                                                    VerticalAlignment="Center"
                                                                    Background="#F8FAFC"
                                                                    BorderBrush="#E2E8F0"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="6"
                                                                             Height="6"
                                                                             Margin="0,0,5,0"
                                                                             VerticalAlignment="Center"
                                                                             Fill="{Binding StateBrush}" />
                                                                    <TextBlock FontSize="10.2"
                                                                               Foreground="{StaticResource MutedBrush}"
                                                                               Text="{Binding StateText}" />
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <Button Grid.Column="2"
                                                    Width="32"
                                                    Height="32"
                                                    Command="{Binding StartCodexOAuthLoginCommand}"
                                                    Content="&#xE8D7;"
                                                    Style="{StaticResource GatewayIconButtonStyle}"
                                                    ToolTip="登录 Codex OAuth" />
                                        </Grid>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Visibility="{Binding TransparentProxyRouteSettingsItem.IsCodexOAuthAuth, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   Text="Codex Backend" />
                                        <TextBox Margin="0,0,0,8"
                                                 FontFamily="Cascadia Mono, Consolas"
                                                 Style="{StaticResource CompactInputTextBoxStyle}"
                                                 ToolTip="留空使用 https://chatgpt.com/backend-api/codex"
                                                 Text="{Binding TransparentProxyRouteSettingsItem.CodexBackendBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Visibility="{Binding TransparentProxyRouteSettingsItem.IsCodexOAuthAuth, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Visibility="{Binding TransparentProxyRouteSettingsItem.IsApiKeyAuth, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   Text="接口密钥" />
                                        <PasswordBox Height="30"
                                                     Style="{StaticResource CompactSecretInputPasswordBoxStyle}"
                                                     infra:PasswordBoxAssistant.BoundPassword="{Binding TransparentProxyRouteSettingsItem.ApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Visibility="{Binding TransparentProxyRouteSettingsItem.IsApiKeyAuth, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock Margin="0,5,0,0"
                                                   Style="{StaticResource SectionHintTextStyle}"
                                                   Visibility="{Binding TransparentProxyRouteSettingsItem.IsApiKeyAuth, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   Text="留空继承客户端 Authorization；填写后仅覆盖该节点。" />
                                    </StackPanel>

                                    <Grid Grid.Column="2"
                                          Grid.RowSpan="2"
                                          MinHeight="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="自定义请求头" />
                                        <TextBox Grid.Row="1"
                                                 Margin="0,6,0,0"
                                                 MinHeight="0"
                                                 AcceptsReturn="True"
                                                 AcceptsTab="True"
                                                 FontFamily="Cascadia Mono, Consolas"
                                                 FontSize="11.4"
                                                 HorizontalScrollBarVisibility="Disabled"
                                                 Padding="8,6"
                                                 Style="{StaticResource {x:Type TextBox}}"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 ToolTip="每行一个 Header: value"
                                                 Text="{Binding TransparentProxyRouteSettingsItem.HeadersText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <StackPanel Grid.Row="1"
                                                Grid.Column="0"
                                                Margin="0,16,0,0">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="排除模型" />
                                        <TextBox Margin="0,5,0,0"
                                                 FontFamily="Cascadia Mono, Consolas"
                                                 Style="{StaticResource CompactInputTextBoxStyle}"
                                                 ToolTip="用英文逗号分隔通配符，例如 gpt-4o-mini*,claude-*"
                                                 Text="{Binding TransparentProxyRouteSettingsItem.ExcludedModelsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="模型">
                            <Grid MinHeight="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <DockPanel LastChildFill="True">
                                    <Button DockPanel.Dock="Right"
                                            Margin="6,0,0,0"
                                            Command="{Binding FetchTransparentProxyRouteEditorItemModelsCommand}"
                                            CommandParameter="{Binding TransparentProxyRouteSettingsItem}"
                                            Content="从 /models 获取"
                                            MinWidth="110"
                                            ToolTip="从该节点 /v1/models 拉取全部模型" />
                                    <Button DockPanel.Dock="Right"
                                            Command="{Binding AddTransparentProxyRouteModelMappingCommand}"
                                            CommandParameter="{Binding TransparentProxyRouteSettingsItem}"
                                            Content="添加模型"
                                            MinWidth="82"
                                            ToolTip="手动添加一个模型映射" />
                                    <TextBlock Margin="0,5,8,0"
                                               Style="{StaticResource FieldLabelTextStyle}"
                                               Text="模型映射表" />
                                </DockPanel>
                                <DataGrid Grid.Row="1"
                                          Margin="0,7,0,0"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          ColumnHeaderStyle="{StaticResource GatewayCompactDataGridHeaderStyle}"
                                          EnableColumnVirtualization="True"
                                          EnableRowVirtualization="True"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          IsReadOnly="False"
                                          ItemsSource="{Binding TransparentProxyRouteSettingsItem.ModelMappings}"
                                          MinColumnWidth="0"
                                          RowHeight="32"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="1.15*"
                                                            MinWidth="180"
                                                            Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                            Header="上游模型名称" />
                                        <DataGridTextColumn Width="1.15*"
                                                            MinWidth="180"
                                                            Binding="{Binding Alias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            ElementStyle="{StaticResource GatewayDataGridTextColumnElementStyle}"
                                                            Header="对外显示名称 / Alias" />
                                        <DataGridTemplateColumn Width="42" MinWidth="38" Header="">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Width="28"
                                                            Height="28"
                                                            Margin="0"
                                                            Command="{Binding DataContext.RemoveTransparentProxyRouteModelMappingCommand, ElementName=TransparentProxyPageRoot}"
                                                            CommandParameter="{Binding}"
                                                            Content="&#xE711;"
                                                            Style="{StaticResource GatewayIconButtonStyle}"
                                                            ToolTip="删除模型映射" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock Grid.Row="2"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource SectionHintTextStyle}"
                                           Text="{Binding TransparentProxyRouteSettingsItem.ModelPreviewText, Mode=OneWay}" />
                            </Grid>
                        </TabItem>

                        <TabItem Header="协议">
                            <Grid MinHeight="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Padding="10"
                                        Background="#F8FAFC"
                                        BorderBrush="#DCE6F8"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                                   Text="自动协议顺序" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Style="{StaticResource SectionHintTextStyle}"
                                                   Text="默认按 Responses → Anthropic Messages → OpenAI Chat 探测和回退；已探测失败的协议不会优先选中。" />
                                    </StackPanel>
                                </Border>
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Padding="10"
                                            Style="{StaticResource DialogMetaStripBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="探测状态" />
                                            <TextBlock Margin="0,4,0,0"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource SectionHintTextStyle}"
                                                       Text="{Binding TransparentProxyProtocolSummary}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2"
                                            Padding="10"
                                            Style="{StaticResource DialogMetaStripBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="转发策略" />
                                            <TextBlock Margin="0,4,0,0"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource SectionHintTextStyle}"
                                                       Text="OpenAI 兼容和 Responses API 均拉取全部模型；请求不指定节点时进入同模型池调度。" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="缓存">
                            <Grid MinHeight="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="170" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              Margin="0,18,0,0"
                                              Content="启用响应缓存"
                                              IsChecked="{Binding TransparentProxyEnableCache, Mode=TwoWay}" />
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="缓存 TTL 秒" />
                                        <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                 Text="{Binding TransparentProxyCacheTtlSecondsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="会话粘滞 TTL 秒" />
                                        <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                 Text="{Binding TransparentProxySessionAffinityTtlSecondsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                                <Border Grid.Row="2"
                                        Padding="10"
                                        Background="#F8FAFC"
                                        BorderBrush="#DCE6F8"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="缓存说明" />
                                        <TextBlock Margin="0,4,0,0"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource SectionHintTextStyle}"
                                                   Text="{Binding TransparentProxyCacheEfficiencyToolTip}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="熔断">
                            <Grid MinHeight="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="重试次数" />
                                        <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                 ToolTip="留空继承全局；0-5"
                                                 Text="{Binding TransparentProxyRouteSettingsItem.RequestRetryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="重试等待" />
                                        <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                 ToolTip="留空继承全局最大重试等待秒数"
                                                 Text="{Binding TransparentProxyRouteSettingsItem.MaxRetryIntervalSecondsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="模型冷却秒" />
                                        <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                 ToolTip="留空继承全局模型冷却秒数"
                                                 Text="{Binding TransparentProxyRouteSettingsItem.ModelCooldownSecondsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <Button Grid.Column="6"
                                            Margin="0,18,0,0"
                                            Command="{Binding ResetTransparentProxyRouteCircuitCommand}"
                                            CommandParameter="{Binding TransparentProxyRouteSettingsItem}"
                                            Content="重置熔断"
                                            MinWidth="104"
                                            ToolTip="重置该路由节点的熔断状态" />
                                </Grid>
                                <Border Grid.Row="2"
                                        Padding="10"
                                        Background="#F8FAFC"
                                        BorderBrush="#DCE6F8"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="当前规则" />
                                        <TextBlock Margin="0,4,0,0"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource SectionHintTextStyle}"
                                                   Text="429、quota、timeout、5xx、model_not_found 会进入不同冷却；流式首包发出后只记录失败，不再切换节点。" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Payload">
                            <Grid MinHeight="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource FieldLabelTextStyle}"
                                               Text="请求体规则" />
                                    <TextBlock Grid.Column="2"
                                               HorizontalAlignment="Right"
                                               Style="{StaticResource SectionHintTextStyle}"
                                               Foreground="{Binding TransparentProxyRouteSettingsItem.PayloadRuleStateBrush, Mode=OneWay}"
                                               TextAlignment="Right"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding TransparentProxyRouteSettingsItem.PayloadRuleSummary, Mode=OneWay}"
                                               Text="{Binding TransparentProxyRouteSettingsItem.PayloadRuleSummary, Mode=OneWay}" />
                                </Grid>
                                <TextBox Grid.Row="1"
                                         Margin="0,6,0,0"
                                         MinHeight="0"
                                         AcceptsReturn="True"
                                         AcceptsTab="True"
                                         FontFamily="Cascadia Mono, Consolas"
                                         FontSize="11.2"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Padding="8,6"
                                         Style="{StaticResource {x:Type TextBox}}"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         ToolTip="规则类型：默认(default)、覆盖(override)、过滤(filter)；可按模型、协议、路径匹配"
                                         Text="{Binding TransparentProxyRouteSettingsItem.PayloadRulesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <DockPanel Grid.Row="2" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="{Binding TransparentProxyRouteSettingsItem.ModelCountText, Mode=OneWay}" />
                        <Button DockPanel.Dock="Left"
                                Margin="12,0,0,0"
                                Command="{Binding ResetTransparentProxyRouteCircuitCommand}"
                                CommandParameter="{Binding TransparentProxyRouteSettingsItem}"
                                Content="重置熔断"
                                MinWidth="104"
                                ToolTip="重置该路由节点的熔断状态" />
                        <Button DockPanel.Dock="Right"
                                Command="{Binding CloseTransparentProxyRouteSettingsCommand}"
                                Content="完成"
                                MinWidth="76" />
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
