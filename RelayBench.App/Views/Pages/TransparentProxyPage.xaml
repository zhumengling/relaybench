<UserControl x:Class="RelayBench.App.Views.Pages.TransparentProxyPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="TransparentProxyPageRoot"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:infra="clr-namespace:RelayBench.App.Infrastructure"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             PreviewMouseDown="TransparentProxyPageRoot_OnPreviewMouseDown"
             PreviewKeyDown="TransparentProxyPageRoot_OnPreviewKeyDown"
             Focusable="True"
             Style="{StaticResource MotionPageRootStyle}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="GatewayStatusPillStyle" TargetType="Border">
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Background" Value="#F6F8FA" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>

        <Style x:Key="GatewayMetricTileStyle"
               TargetType="Border"
               BasedOn="{StaticResource InsetPanelBorderStyle}">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style x:Key="GatewayMetricLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource FieldLabelTextStyle}">
            <Setter Property="FontSize" Value="10.2" />
            <Setter Property="LineHeight" Value="13" />
            <Setter Property="MaxHeight" Value="15" />
            <Setter Property="Margin" Value="0,0,0,1" />
        </Style>

        <Style x:Key="GatewayMetricValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="FontSize" Value="12.8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="MaxHeight" Value="18" />
        </Style>

        <Style x:Key="GatewayIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkbenchIconButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="12.8" />
            <Setter Property="Margin" Value="0,0,5,0" />
        </Style>

        <Style x:Key="GatewayCopyBadgeButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GatewayIconButtonStyle}">
            <Setter Property="Width" Value="38" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="GatewayPrimaryIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkbenchIconButtonPrimaryStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,5,0" />
        </Style>

        <Style x:Key="GatewaySettingsToggleButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GatewayIconButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform Angle="0" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 To="180"
                                                 Duration="0:0:0.18">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 To="0"
                                                 Duration="0:0:0.16">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GatewaySettingsDrawerPanelStyle"
               TargetType="Border"
               BasedOn="{StaticResource SectionPanelBorderStyle}">
            <Setter Property="Width" Value="54" />
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="MaxWidth" Value="390" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTransparentProxySettingsDrawerOpen}" Value="True">
                    <Setter Property="Width" Value="360" />
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                 To="360"
                                                 Duration="0:0:0.20">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                 To="54"
                                                 Duration="0:0:0.18">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GatewayDrawerMenuButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="#EFF6FF" />
                    <Setter Property="BorderBrush" Value="#93C5FD" />
                    <Setter Property="Foreground" Value="#0F62FE" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GatewayDrawerMenuGlyphStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="20" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="GatewayDrawerMenuTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="4,0,2,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="GatewayAccordionChevronStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource GatewayDrawerMenuGlyphStyle}">
            <Setter Property="Width" Value="18" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Text" Value="&#xE70D;" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform Angle="0" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Foreground" Value="#0F62FE" />
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 To="90"
                                                 Duration="0:0:0.18">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 To="0"
                                                 Duration="0:0:0.16">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GatewayAccordionPanelStyle"
               TargetType="Border"
               BasedOn="{StaticResource InsetPanelBorderStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="MaxHeight" Value="0" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="MaxHeight" Value="1200" />
                    <Setter Property="Margin" Value="0,0,0,8" />
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="IsHitTestVisible" Value="True" />
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                 To="1200"
                                                 Duration="0:0:0.18">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.14" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                 To="0"
                                                 Duration="0:0:0.16">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 Duration="0:0:0.10" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GatewayBadgeBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="Height" Value="22" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style x:Key="GatewayModelPoolChipStyle" TargetType="Border">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MaxWidth" Value="220" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Background" Value="#FBFCFE" />
            <Setter Property="BorderBrush" Value="#E0E7F2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style x:Key="GatewayMonoCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="FontSize" Value="11.6" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="MaxHeight" Value="18" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GatewayCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.2" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="MaxHeight" Value="18" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GatewayDataGridTextColumnElementStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="MaxHeight" Value="18" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
        </Style>

        <Style x:Key="GatewayMultilineRouteTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="132" />
            <Setter Property="Padding" Value="9,7" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="FontSize" Value="11.2" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="AcceptsTab" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="GatewayCompactDataGridHeaderStyle"
               TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="10.8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                ClipToBounds="True">
                            <TextBlock Margin="{TemplateBinding Padding}"
                                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                       VerticalAlignment="Center"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{TemplateBinding Content}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch"
          ClipToBounds="True"
          MinHeight="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="8,6"
                Style="{StaticResource CommandBarBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            ClipToBounds="True">
                    <WrapPanel VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="本地统一出口"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Margin="8,1,0,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   Text="默认启动 · 应用接管可选" />
                        <Border Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Style="{StaticResource GatewayStatusPillStyle}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding TransparentProxyRunStateBrush, Mode=OneWay}"
                                       Text="{Binding TransparentProxyRunStateText, Mode=OneWay}" />
                        </Border>
                    </WrapPanel>
                    <DockPanel Margin="0,4,0,0" LastChildFill="True">
                        <TextBlock DockPanel.Dock="Left"
                                   FontFamily="Cascadia Mono, Consolas"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedBrush}"
                                   MaxWidth="320"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding TransparentProxyLocalEndpoint, Mode=OneWay}"
                                   Text="{Binding TransparentProxyLocalEndpoint, Mode=OneWay}" />
                        <TextBlock Margin="12,0,0,0"
                                   Style="{StaticResource SectionHintTextStyle}"
                                   MaxWidth="420"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding TransparentProxyStatusSummary, Mode=OneWay}"
                                   Text="{Binding TransparentProxyStatusSummary, Mode=OneWay}" />
                    </DockPanel>
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           MinWidth="260"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <Button Command="{Binding StartTransparentProxyCommand}"
                            Content="&#xE768;"
                            Style="{StaticResource GatewayPrimaryIconButtonStyle}"
                            ToolTip="启动本地统一出口" />
                    <Button Command="{Binding StopTransparentProxyCommand}"
                            Content="&#xE71A;"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="停止本地统一出口" />
                    <Button Command="{Binding GenerateTransparentProxyCandidateRoutesCommand}"
                            AutomationProperties.Name="生成候选路由"
                            Content="&#xE72C;"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="按顺序执行：从当前接口和批量候选生成路由、拉取模型并探测协议、测试本地统一出口端点" />
                    <Button Click="ToggleTokenMeterButton_OnClick"
                            Content="&#xE9D2;"
                            IsEnabled="{Binding IsTransparentProxyRunning, Mode=OneWay}"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="显示或隐藏 Token 悬浮窗"
                            ToolTipService.ShowOnDisabled="True" />
                    <Button Command="{Binding ClearTransparentProxyLogsCommand}"
                            Content="&#xE74D;"
                            Style="{StaticResource GatewayIconButtonStyle}"
                            ToolTip="清空日志" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,8,0,0"
              MinHeight="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    x:Name="TransparentProxySettingsDrawerHost"
                    Style="{StaticResource GatewaySettingsDrawerPanelStyle}">
                <Grid MinHeight="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Button Margin="0,0,0,6"
                                Command="{Binding ToggleTransparentProxySettingsDrawerCommand}"
                                Content="&#xE713;"
                                Style="{StaticResource GatewaySettingsToggleButtonStyle}"
                                Tag="{Binding IsTransparentProxySettingsDrawerOpen}"
                                ToolTip="&#x5C55;&#x5F00;&#x6216;&#x6536;&#x8D77;&#x5165;&#x53E3;&#x8BBE;&#x7F6E;" />
                        <TextBlock Visibility="Collapsed" Text="入口设置">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SectionTitleTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTransparentProxySettingsDrawerOpen}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,6,0,0"
                                  MinHeight="0"
                                  CanContentScroll="False"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsTransparentProxySettingsDrawerOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Button Grid.Row="0"
                                    Command="{Binding ToggleTransparentProxyListenSettingsCommand}"
                                    Tag="{Binding IsTransparentProxyListenSettingsOpen}"
                                    Style="{StaticResource GatewayDrawerMenuButtonStyle}"
                                    ToolTip="展开或收起监听设置">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource GatewayDrawerMenuGlyphStyle}"
                                               Text="&#xE968;" />
                                    <TextBlock Grid.Column="1"
                                               Style="{StaticResource GatewayDrawerMenuTextStyle}"
                                               Text="监听设置" />
                                    <TextBlock Grid.Column="2"
                                               Tag="{Binding IsTransparentProxyListenSettingsOpen}"
                                               Style="{StaticResource GatewayAccordionChevronStyle}" />
                                </Grid>
                            </Button>

                            <Border Grid.Row="1"
                                    Tag="{Binding IsTransparentProxyListenSettingsOpen}"
                                    Style="{StaticResource GatewayAccordionPanelStyle}">
                                <Grid>
                                     <Grid.RowDefinitions>
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="Auto" />
                                          <RowDefinition Height="Auto" />
                                          <RowDefinition Height="Auto" />
                                          <RowDefinition Height="Auto" />
                                          <RowDefinition Height="Auto" />
                                          <RowDefinition Height="Auto" />
                                      </Grid.RowDefinitions>

                                     <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                Text="监听" />
                                     <Grid Grid.Row="1"
                                           Margin="0,5,0,0">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*" />
                                             <ColumnDefinition Width="8" />
                                             <ColumnDefinition Width="*" />
                                         </Grid.ColumnDefinitions>
                                         <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="端口" />
                                            <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                     Text="{Binding TransparentProxyPortText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                         </StackPanel>
                                         <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="并发上限" />
                                            <TextBox Style="{StaticResource CompactInputTextBoxStyle}"
                                                     Text="{Binding TransparentProxyMaxConcurrencyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                         </StackPanel>
                                     </Grid>
                                     <StackPanel Grid.Row="2"
                                                 Margin="0,5,0,0">
                                         <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                    Text="调度策略" />
                                         <ComboBox Style="{StaticResource CompactComboBoxStyle}"
                                                   ItemsSource="{Binding TransparentProxyRouteStrategyOptions}"
                                                   DisplayMemberPath="DisplayName"
                                                   SelectedValuePath="Key"
                                                   SelectedValue="{Binding TransparentProxyRouteStrategyKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                     </StackPanel>
                                     <TextBox Grid.Row="3"
                                              Margin="0,5,0,0"
                                             FontFamily="Cascadia Mono, Consolas"
                                             IsReadOnly="True"
                                             Style="{StaticResource CompactInputTextBoxStyle}"
                                             ToolTip="{Binding TransparentProxyLocalEndpoint, Mode=OneWay}"
                                             Text="{Binding TransparentProxyLocalEndpoint, Mode=OneWay}" />
                                     <TextBox Grid.Row="4"
                                              Margin="0,5,0,0"
                                              FontFamily="Cascadia Mono, Consolas"
                                              IsReadOnly="True"
                                              Style="{StaticResource CompactInputTextBoxStyle}"
                                              ToolTip="{Binding TransparentProxyResponsesEndpoint, Mode=OneWay}"
                                              Text="{Binding TransparentProxyResponsesEndpoint, Mode=OneWay}" />
                                      <TextBox Grid.Row="5"
                                               Margin="0,5,0,0"
