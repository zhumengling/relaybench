<UserControl x:Class="RelayBench.App.Views.Pages.NetworkReviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:infra="clr-namespace:RelayBench.App.Infrastructure"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="NetworkReviewSubmenuItemStyle"
               TargetType="ListBoxItem"
               BasedOn="{StaticResource PresetCardListBoxItemStyle}">
            <Setter Property="Width" Value="132" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>

        <Style x:Key="ReviewPaneBorderStyle"
               TargetType="Border">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="ReviewDividerBorderStyle"
               TargetType="Border">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,1,0,0" />
        </Style>

        <Style x:Key="ReviewPaneTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource ReadOnlyOutputTextBoxStyle}">
            <Setter Property="MinHeight" Value="118" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ReviewPaneConsoleTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource ReadOnlyConsoleTextBoxStyle}">
            <Setter Property="MinHeight" Value="118" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ReviewPaneRawTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource ReadOnlyRawLogTextBoxStyle}">
            <Setter Property="MinHeight" Value="118" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ReviewFlatTabControlStyle"
               TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0"
                                      Margin="0,0,0,6"
                                      IsItemsHost="True"
                                      Background="Transparent" />
                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReviewFlatTabItemStyle"
               TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="FontSize" Value="10.4" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Margin="0,0,4,0"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource InputHoverBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#D0D5DD" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#EEF4FF" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReviewResultListBoxStyle"
               TargetType="ListBox"
               BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style x:Key="ReviewResultListBoxItemStyle"
               TargetType="ListBoxItem"
               BasedOn="{StaticResource ListBoxItemStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0,6,0,6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                BorderBrush="#EAECF0"
                                BorderThickness="0,0,0,1">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F8FAFC" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EEF4FF" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OfficialApiOverviewBorderStyle"
               TargetType="Border">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#EAECF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="OfficialApiTraceButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="IpRiskSummaryBadgeBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource SectionPanelBorderStyle}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="MinWidth" Value="202" />
        </Style>

        <Style x:Key="IpRiskIndicatorBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource InsetPanelBorderStyle}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="MinHeight" Value="88" />
        </Style>

        <Style x:Key="IpRiskStatusPillBorderStyle"
               TargetType="Border">
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="IpRiskMatrixHeaderTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource FieldLabelTextStyle}">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="IpRiskMetaStripBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource InsetPanelBorderStyle}">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#DCE6F8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="IpRiskAssessmentPanelBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource SectionPanelBorderStyle}">
            <Setter Property="Background" Value="#F8FBFF" />
            <Setter Property="BorderBrush" Value="#C7DAFF" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <Grid Margin="0,0,2,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="工具" />
                    <ListBox Grid.Row="1"
                             Margin="0,6,0,0"
                             ItemsSource="{Binding NetworkReviewToolOptions}"
                             SelectedValuePath="Key"
                             SelectedValue="{Binding SelectedNetworkReviewToolKey, Mode=TwoWay}"
                             Style="{StaticResource PresetCardListBoxStyle}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <StaticResource ResourceKey="NetworkReviewSubmenuItemStyle" />
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,4,0,0"
                    Style="{StaticResource SectionPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                       Text="{Binding SelectedNetworkReviewToolDisplayName}" />
                            <TextBlock Margin="0,3,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="{Binding SelectedNetworkReviewToolDescription}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Padding="8,2"
                                Background="#EEF4FF"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <TextBlock FontWeight="SemiBold"
                                       Text="{Binding SelectedNetworkReviewToolGroupName}" />
                        </Border>

                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,8,0,8"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="0,0,0,1" />

                    <Grid Grid.Row="2">
                        <Grid Visibility="{Binding IsNetworkReviewBasicNetworkSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                           Text="先看本机网络、DNS 和公网出口" />
                                <Button Grid.Column="1"
                                        MinWidth="128"
                                        Command="{Binding RunNetworkCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Content="&#x5F00;&#x59CB;&#x68C0;&#x6D4B;" />
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource ReviewPaneBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x57FA;&#x7840;&#x7F51;&#x7EDC;&#x6458;&#x8981;" />
                                        <TextBox Grid.Row="1"
                                                 Style="{StaticResource ReviewPaneTextBoxStyle}"
                                                 Text="{Binding NetworkSummary, Mode=OneWay}" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Style="{StaticResource ReviewPaneBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x6D3B;&#x52A8;&#x7F51;&#x5361;" />
                                            <TextBox Grid.Row="1"
                                                     Style="{StaticResource ReviewPaneTextBoxStyle}"
                                                     Text="{Binding AdapterSummary, Mode=OneWay}" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="2" Style="{StaticResource ReviewPaneBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Ping &#x8FD4;&#x56DE;" />
                                            <TextBox Grid.Row="1"
                                                     Style="{StaticResource ReviewPaneConsoleTextBoxStyle}"
                                                     Text="{Binding PingSummary, Mode=OneWay}" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                        <Grid Visibility="{Binding IsNetworkReviewOfficialApiSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="看网页入口和 API 目录是否可达">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasOfficialApiStatusRows}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Grid.Column="1"
                                        MinWidth="128"
                                        Command="{Binding RunWebApiTraceCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Content="&#x5F00;&#x59CB;&#x68C0;&#x6D4B;" />
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Style="{StaticResource OfficialApiOverviewBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="网页 API 概览" />
                                            <TextBlock Margin="0,4,0,0"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextBrush}"
                                                       Text="{Binding UnlockCatalogSummary, Mode=OneWay}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Top"
                                                   Style="{StaticResource SectionHintTextStyle}"
                                                   Text="右侧可看原始 Trace" />
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2"
                                        Style="{StaticResource ReviewPaneBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="网页入口 / API 列表" />
                                            <TextBlock Grid.Column="1"
                                                       Style="{StaticResource SectionHintTextStyle}"
                                                       Text="点击按钮看原始 Trace" />
                                        </Grid>

                                        <Grid Grid.Row="1"
                                              Margin="0,6,0,0">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Background="Transparent"
                                                          infra:ScrollViewerWheelHelper.EnableNestedWheelRouting="True">
                                                <ItemsControl ItemsSource="{Binding OfficialApiStatusRows}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="0,8"
                                                                    BorderBrush="#EAECF0"
                                                                    BorderThickness="0,0,0,1">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>

                                                                    <StackPanel Grid.Column="0">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Border Padding="7,2"
                                                                                    Margin="0,0,8,0"
                                                                                    Background="#F5F7FA"
                                                                                    BorderBrush="#D0D5DD"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="999">
                                                                                <TextBlock FontSize="10"
                                                                                           FontWeight="SemiBold"
                                                                                           Foreground="{StaticResource MutedBrush}"
                                                                                           Text="{Binding Provider}" />
                                                                            </Border>
                                                                            <TextBlock VerticalAlignment="Center"
                                                                                       FontSize="11.4"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="{StaticResource TextBrush}"
                                                                                       Text="{Binding Name}" />
                                                                        </StackPanel>

                                                                        <TextBlock Margin="0,4,0,0"
                                                                                   TextWrapping="Wrap"
                                                                                   Foreground="{StaticResource MutedBrush}"
                                                                                   Text="{Binding Summary}" />

                                                                        <TextBlock Margin="0,3,0,0"
                                                                                   FontFamily="Consolas"
                                                                                   FontSize="10.2"
                                                                                   Foreground="#667085"
                                                                                   Text="{Binding EndpointMetaText}" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Column="1"
                                                                                Margin="12,0,0,0"
                                                                                HorizontalAlignment="Right">
                                                                        <Border Padding="8,3"
                                                                                Background="{Binding StatusBackground}"
                                                                                CornerRadius="999">
                                                                            <TextBlock FontWeight="SemiBold"
                                                                                       Foreground="{Binding StatusForeground}"
                                                                                       Text="{Binding AvailabilityText}" />
                                                                        </Border>
                                                                        <Button Command="{Binding OpenRawTraceCommand}"
                                                                                Style="{StaticResource OfficialApiTraceButtonStyle}"
                                                                                Content="&#x539F;&#x59CB; Trace" />
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>

                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Text="点击“开始检测”后显示结果。">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHintTextStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasOfficialApiStatusRows}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid Visibility="{Binding IsNetworkReviewSpeedTestSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Text="&#x6D4B;&#x901F;&#x65B9;&#x6848;" />
                                <ComboBox Grid.Column="1"
                                          Margin="8,0,0,0"
                                          ItemsSource="{Binding SpeedTestProfiles}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Key"
                                          SelectedValue="{Binding SelectedSpeedTestProfileKey, Mode=TwoWay}"
                                          Style="{StaticResource CompactComboBoxStyle}" />
                                <Button Grid.Column="3"
                                        MinWidth="128"
                                        Margin="0"
                                        Command="{Binding RunSpeedTestCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Content="&#x5F00;&#x59CB;&#x6D4B;&#x901F;" />
                            </Grid>

                            <TextBlock Grid.Row="1"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="{Binding SelectedSpeedTestProfileDescription}" />

                            <Grid Grid.Row="3">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource ReviewPaneBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x6D4B;&#x901F;&#x603B;&#x89C8;" />
                                        <TextBox Grid.Row="1"
                                                 Style="{StaticResource ReviewPaneTextBoxStyle}"
                                                 Text="{Binding SpeedTestSummary, Mode=OneWay}" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource ReviewPaneBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x5EF6;&#x8FDF; / &#x6296;&#x52A8;&#x91C7;&#x6837;" />
                                            <TextBox Grid.Row="1"
                                                     Style="{StaticResource ReviewPaneConsoleTextBoxStyle}"
                                                     Text="{Binding SpeedTestLatencyDetail, Mode=OneWay}" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource ReviewPaneBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x4F20;&#x8F93;&#x6D4B;&#x91CF;" />
                                            <TextBox Grid.Row="1"
                                                     Style="{StaticResource ReviewPaneConsoleTextBoxStyle}"
                                                     Text="{Binding SpeedTestTransferDetail, Mode=OneWay}" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Border Grid.Row="4" Style="{StaticResource ReviewPaneBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x4E22;&#x5305;&#x8BC4;&#x4F30;" />
                                        <TextBox Grid.Row="1"
                                                 Style="{StaticResource ReviewPaneTextBoxStyle}"
                                                 Text="{Binding SpeedTestPacketLossDetail, Mode=OneWay}" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid Visibility="{Binding IsNetworkReviewRouteSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
