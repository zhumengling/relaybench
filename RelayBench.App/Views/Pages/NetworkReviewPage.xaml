                                                        CornerRadius="999">
                                                    <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               Text="&#x7ED3;&#x8BBA;" />
                                                </Border>
                                            </Grid>
                                            <TextBox Grid.Row="1"
                                                     Style="{StaticResource ReviewPaneTextBoxStyle}"
                                                     MinHeight="220"
                                                     Text="{Binding IpRiskAssessmentSummary, Mode=OneWay}" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Style="{StaticResource SectionPanelBorderStyle}">
                                        <Expander IsExpanded="False">
                                            <Expander.Header>
                                                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="原始明细" />
                                            </Expander.Header>
                                            <StackPanel Margin="0,6,0,0">
                                                <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                                           Text="保留各来源摘要、详情和错误" />
                                                <TextBox Margin="0,6,0,0"
                                                         Style="{StaticResource ReviewPaneTextBoxStyle}"
                                                         MinHeight="220"
                                                         Text="{Binding IpRiskSourceDetailSummary, Mode=OneWay}" />
                                            </StackPanel>
                                        </Expander>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <Grid Visibility="{Binding IsNetworkReviewStunSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Style="{StaticResource SectionHintTextStyle}"
                                       Text="先确认公网映射；支持 RFC 5780 时可继续细分 NAT" />

                            <Grid Grid.Row="1" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Text="&#x534F;&#x8BAE;" />
                                <ComboBox Grid.Column="1"
                                          Margin="8,0,0,0"
                                          ItemsSource="{Binding StunTransportOptions}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Key"
                                          SelectedValue="{Binding SelectedStunTransportKey, Mode=TwoWay}"
                                          Style="{StaticResource CompactComboBoxStyle}" />
                                <TextBlock Grid.Column="3"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Text="STUN &#x670D;&#x52A1;&#x5668;" />
                                <ComboBox Grid.Column="4"
                                          Margin="8,0,0,0"
                                          ItemsSource="{Binding VisibleStunServerOptions}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Key"
                                          SelectedValue="{Binding StunServer, Mode=TwoWay}"
                                          Style="{StaticResource CompactComboBoxStyle}" />
                                <Button Grid.Column="6"
                                        MinWidth="128"
                                        Command="{Binding RunStunCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Content="&#x5F00;&#x59CB;&#x68C0;&#x6D4B;" />
                            </Grid>

                            <Border Grid.Row="3" Style="{StaticResource ReviewPaneBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="NAT / STUN &#x603B;&#x89C8;" />
                                    <TextBox Grid.Row="1"
                                             Style="{StaticResource ReviewPaneTextBoxStyle}"
                                             MinHeight="96"
                                             Text="{Binding StunSummary, Mode=OneWay}" />
                                </Grid>
                            </Border>

                            <TabControl Grid.Row="5"
                                        ItemContainerStyle="{StaticResource ReviewFlatTabItemStyle}"
                                        Style="{StaticResource ReviewFlatTabControlStyle}">
                                <TabItem Header="&#x8986;&#x76D6;&#x5224;&#x5B9A;">
                                    <TextBox Style="{StaticResource ReviewPaneTextBoxStyle}"
                                             MinHeight="300"
                                             Text="{Binding StunCoverageSummary, Mode=OneWay}" />
                                </TabItem>
                                <TabItem Header="&#x6D4B;&#x8BD5;&#x8FC7;&#x7A0B;">
                                    <TextBox Style="{StaticResource ReviewPaneTextBoxStyle}"
                                             MinHeight="300"
                                             Text="{Binding StunTestSummary, Mode=OneWay}" />
                                </TabItem>
                                <TabItem Header="&#x5C5E;&#x6027;&#x8BE6;&#x60C5;">
                                    <TextBox Style="{StaticResource ReviewPaneTextBoxStyle}"
                                             MinHeight="300"
                                             Text="{Binding StunAttributeSummary, Mode=OneWay}" />
                                </TabItem>
                            </TabControl>
                        </Grid>

                        <Grid Visibility="{Binding IsNetworkReviewPortScanSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Text="&#x76EE;&#x6807;" />
                                <TextBox Grid.Column="1"
                                         Margin="8,0,0,0"
                                         Style="{StaticResource CompactInputTextBoxStyle}"
                                         Text="{Binding PortScanTarget, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="3"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Text="&#x6A21;&#x677F;" />
                                <ComboBox Grid.Column="4"
                                          Margin="8,0,0,0"
                                          ItemsSource="{Binding PortScanProfiles}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Key"
                                          SelectedValue="{Binding SelectedPortScanProfileKey, Mode=TwoWay}"
                                          Style="{StaticResource CompactComboBoxStyle}" />
                                <Button Grid.Column="6"
                                        MinWidth="110"
                                        Margin="8,0,0,0"
                                        Command="{Binding RunPortScanCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Content="&#x5F00;&#x59CB;&#x626B;&#x63CF;" />
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Text="&#x81EA;&#x5B9A;&#x4E49;&#x7AEF;&#x53E3;" />
                                <TextBox Grid.Column="1"
                                         Style="{StaticResource CompactInputTextBoxStyle}"
                                         Text="{Binding PortScanCustomPortsText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="3"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Text="&#x641C;&#x7D22;" />
                                <TextBox Grid.Column="4"
                                         Style="{StaticResource CompactInputTextBoxStyle}"
                                         Text="{Binding PortScanSearchText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="6"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Text="&#x534F;&#x8BAE;" />
                                <ComboBox Grid.Column="7"
                                          ItemsSource="{Binding PortScanProtocolFilterOptions}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Key"
                                          SelectedValue="{Binding SelectedPortScanProtocolFilterKey, Mode=TwoWay}"
                                          Style="{StaticResource CompactComboBoxStyle}" />
                            </Grid>

                            <TextBlock Grid.Row="2"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="{Binding SelectedPortScanProfileDescription}" />

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.95*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="1.05*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource ReviewPaneBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x626B;&#x63CF;&#x603B;&#x89C8;" />
                                        <TextBlock Grid.Row="1"
                                                   Margin="0,6,0,0"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Text="{Binding PortScanProgressSummary, Mode=OneWay}" />
                                        <TextBox Grid.Row="2"
                                                 Style="{StaticResource ReviewPaneTextBoxStyle}"
                                                 MinHeight="210"
                                                 Text="{Binding PortScanSummary, Mode=OneWay}" />
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource ReviewPaneBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="&#x5F00;&#x653E;&#x7AEF;&#x70B9;&#x5217;&#x8868;" />
                                        <TextBlock Grid.Row="1"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource SectionHintTextStyle}"
                                                   Text="{Binding PortScanFilterSummary, Mode=OneWay}" />
                                        <ListBox Grid.Row="2"
                                                 ItemsSource="{Binding FilteredPortScanFindings}"
                                                 ItemContainerStyle="{StaticResource ReviewResultListBoxItemStyle}"
                                                 Style="{StaticResource ReviewResultListBoxStyle}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <DockPanel LastChildFill="False">
                                                            <TextBlock FontWeight="SemiBold"
                                                                       Text="{Binding Endpoint}" />
                                                            <TextBlock DockPanel.Dock="Right"
                                                                       Foreground="{StaticResource AccentBrush}"
                                                                       Text="{Binding LatencyText}" />
                                                        </DockPanel>
                                                        <TextBlock Margin="0,2,0,0"
                                                                   Style="{StaticResource SectionHintTextStyle}"
                                                                   Text="{Binding ServiceHint}" />
                                                        <TextBlock Margin="0,1,0,0"
                                                                   Style="{StaticResource SectionHintTextStyle}"
                                                                   TextWrapping="Wrap"
                                                                   Text="{Binding ApplicationSummary}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Grid>

                            <TabControl Grid.Row="6"
                                        ItemContainerStyle="{StaticResource ReviewFlatTabItemStyle}"
                                        Style="{StaticResource ReviewFlatTabControlStyle}">
                                <TabItem Header="&#x8BE6;&#x7EC6;&#x6458;&#x8981;">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                                   Text="{Binding PortScanExportSummary, Mode=OneWay}" />
                                        <TextBox Grid.Row="1"
                                                 Style="{StaticResource ReviewPaneTextBoxStyle}"
                                                 MinHeight="190"
                                                 Text="{Binding PortScanDetail, Mode=OneWay}" />
                                    </Grid>
                                </TabItem>
                                <TabItem Header="&#x539F;&#x59CB;&#x65E5;&#x5FD7;">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <WrapPanel>
                                            <Button MinWidth="116"
                                                    Command="{Binding ExportPortScanCsvCommand}"
                                                    Content="&#x5BFC;&#x51FA; CSV" />
                                            <Button MinWidth="124"
                                                    Command="{Binding ExportPortScanExcelCommand}"
                                                    Content="&#x5BFC;&#x51FA; Excel" />
                                        </WrapPanel>
                                        <TextBox Grid.Row="1"
                                                 Style="{StaticResource ReviewPaneRawTextBoxStyle}"
                                                 MinHeight="190"
                                                 Text="{Binding PortScanRawOutput, Mode=OneWay}" />
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
