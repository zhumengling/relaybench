<?xml version="1.0" encoding="utf-8" ?>
<local:PageBase
    x:Class="RelayBench.WinUI.Pages.DataSafetyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RelayBench.WinUI.Pages"
    xmlns:vm="using:RelayBench.WinUI.ViewModels"
    Background="Transparent">

    <local:PageBase.Resources>
        <ResourceDictionary>
        <ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary x:Key="Light">
                <SolidColorBrush x:Key="SafetyAccentChipBackgroundBrush" Color="#EEF5FF" />
                <SolidColorBrush x:Key="SafetyAccentChipBorderBrush" Color="#C7DAF8" />
                <SolidColorBrush x:Key="SafetyAccentChipForegroundBrush" Color="#2563EB" />
                <SolidColorBrush x:Key="SafetyHealthyChipBackgroundBrush" Color="#ECFDF3" />
                <SolidColorBrush x:Key="SafetyHealthyChipBorderBrush" Color="#BBF7D0" />
                <SolidColorBrush x:Key="SafetyHealthyChipForegroundBrush" Color="#0B7A46" />
                <SolidColorBrush x:Key="SafetyDangerChipBackgroundBrush" Color="#FEF2F2" />
                <SolidColorBrush x:Key="SafetyDangerChipBorderBrush" Color="#FCA5A5" />
                <SolidColorBrush x:Key="SafetyDangerChipForegroundBrush" Color="#A6192E" />
                <SolidColorBrush x:Key="SafetyMutedChipBackgroundBrush" Color="#F8FAFC" />
                <SolidColorBrush x:Key="SafetyMutedChipBorderBrush" Color="#CBD5E1" />
                <SolidColorBrush x:Key="SafetyMutedChipForegroundBrush" Color="#475569" />
                <SolidColorBrush x:Key="SafetyTrackBrush" Color="#CBD5E1" />
            </ResourceDictionary>
            <ResourceDictionary x:Key="Dark">
                <SolidColorBrush x:Key="SafetyAccentChipBackgroundBrush" Color="#102A4A" />
                <SolidColorBrush x:Key="SafetyAccentChipBorderBrush" Color="#34506E" />
                <SolidColorBrush x:Key="SafetyAccentChipForegroundBrush" Color="#7CCBFF" />
                <SolidColorBrush x:Key="SafetyHealthyChipBackgroundBrush" Color="#143827" />
                <SolidColorBrush x:Key="SafetyHealthyChipBorderBrush" Color="#287348" />
                <SolidColorBrush x:Key="SafetyHealthyChipForegroundBrush" Color="#8FF2B6" />
                <SolidColorBrush x:Key="SafetyDangerChipBackgroundBrush" Color="#4A1218" />
                <SolidColorBrush x:Key="SafetyDangerChipBorderBrush" Color="#7F1D1D" />
                <SolidColorBrush x:Key="SafetyDangerChipForegroundBrush" Color="#FDA4AF" />
                <SolidColorBrush x:Key="SafetyMutedChipBackgroundBrush" Color="#111827" />
                <SolidColorBrush x:Key="SafetyMutedChipBorderBrush" Color="#334155" />
                <SolidColorBrush x:Key="SafetyMutedChipForegroundBrush" Color="#94A3B8" />
                <SolidColorBrush x:Key="SafetyTrackBrush" Color="#233044" />
            </ResourceDictionary>
            <ResourceDictionary x:Key="HighContrast">
                <SolidColorBrush x:Key="SafetyAccentChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SafetyAccentChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SafetyAccentChipForegroundBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                <SolidColorBrush x:Key="SafetyHealthyChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SafetyHealthyChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SafetyHealthyChipForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SafetyDangerChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SafetyDangerChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SafetyDangerChipForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SafetyMutedChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SafetyMutedChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SafetyMutedChipForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SafetyTrackBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            </ResourceDictionary>
        </ResourceDictionary.ThemeDictionaries>

        <Style x:Key="SafetyCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="SafetySubtleCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style x:Key="SafetyCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="SafetyTiny" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="SafetyToolbarButton" TargetType="Button" BasedOn="{StaticResource AppToolbarButton}" />
        <Style x:Key="SafetyCompactToggleSwitch" TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="OnContent" Value="" />
            <Setter Property="OffContent" Value="" />
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock
                            MaxWidth="132"
                            Text="{Binding}"
                            TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </local:PageBase.Resources>

    <Grid Padding="18,12,18,16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ScrollViewer
            HorizontalScrollBarVisibility="Auto"
            HorizontalScrollMode="Enabled"
            VerticalScrollBarVisibility="Disabled"
            VerticalScrollMode="Disabled">
        <Border Style="{StaticResource SafetyCard}" Padding="12,9" MinWidth="1120">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="2.1*" />
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1.55*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Style="{StaticResource SafetyCaption}" Text="&#x63A5;&#x53E3;&#x5730;&#x5740;" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <Grid Grid.Column="1" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="86" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox MinWidth="86" SelectedIndex="{x:Bind ViewModel.ProtocolIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="https" />
                        <ComboBoxItem Content="http" />
                    </ComboBox>
                    <TextBox Grid.Column="1" Text="{x:Bind ViewModel.BaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="relay.example.com/v1" />
                </Grid>

                <PasswordBox Grid.Column="2" Password="{x:Bind ViewModel.ApiKey, Mode=TwoWay}" PlaceholderText="&#x63A5;&#x53E3;&#x5BC6;&#x94A5;" />

                <Grid Grid.Column="3" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox IsEditable="True" ItemsSource="{x:Bind ViewModel.AvailableModels, Mode=OneWay}" Text="{x:Bind ViewModel.Model, Mode=TwoWay}" PlaceholderText="&#x9009;&#x62E9;&#x6A21;&#x578B;" />
                    <Button Grid.Column="1" Style="{StaticResource SafetyToolbarButton}" Command="{x:Bind ViewModel.FetchModelsCommand}" AutomationProperties.Name="拉取数据安全模型" ToolTipService.ToolTip="&#x4ECE;&#x5F53;&#x524D;&#x63A5;&#x53E3;&#x62C9;&#x53D6;&#x6A21;&#x578B;">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE896;" />
                            <TextBlock FontSize="12" Text="&#x62C9;&#x53D6;" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Button Grid.Column="4" Style="{StaticResource SafetyToolbarButton}" Click="OnOpenEndpointHistoryDialogClick" AutomationProperties.Name="打开数据安全接口历史" ToolTipService.ToolTip="&#x67E5;&#x770B;&#x5386;&#x53F2;&#x7AEF;&#x70B9;">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE81C;" />
                        <TextBlock FontSize="12" Text="&#x5386;&#x53F2;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="5" Style="{StaticResource SafetyToolbarButton}" Command="{x:Bind ViewModel.RefreshProtocolCacheCommand}" AutomationProperties.Name="刷新数据安全协议缓存" ToolTipService.ToolTip="&#x5237;&#x65B0;&#x5F53;&#x524D;&#x6A21;&#x578B;&#x7684;&#x534F;&#x8BAE;&#x7F13;&#x5B58;&#x89C6;&#x56FE;">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE72C;" />
                        <TextBlock FontSize="12" Text="&#x534F;&#x8BAE;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="6" Style="{StaticResource AppAccentToolbarButton}" Command="{x:Bind ViewModel.StartTestCommand}" AutomationProperties.Name="启动数据安全测试">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE768;" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Text="&#x5F00;&#x59CB;&#x6D4B;&#x8BD5;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="7" Style="{StaticResource SafetyToolbarButton}" Click="OnConfirmStopTestClick" IsEnabled="{x:Bind ViewModel.CanStopTest, Mode=OneWay}" AutomationProperties.Name="停止数据安全测试" ToolTipService.ToolTip="&#x505C;&#x6B62;&#x5F53;&#x524D;&#x6570;&#x636E;&#x5B89;&#x5168;&#x6D4B;&#x8BD5;">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource SafetyDangerChipForegroundBrush}" Glyph="&#xE71A;" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource SafetyDangerChipForegroundBrush}" Text="&#x505C;&#x6B62;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        </ScrollViewer>

        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Auto"
            HorizontalScrollMode="Enabled"
            VerticalScrollBarVisibility="Disabled"
            VerticalScrollMode="Disabled">
            <Grid ColumnSpacing="12" MinWidth="1160" Tag="ResponsiveStack">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="292" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="326" />
            </Grid.ColumnDefinitions>

            <ScrollViewer HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <Border Style="{StaticResource SafetyCard}" Padding="12,11">
                        <StackPanel Spacing="9">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2" MinWidth="0">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="&#x6D4B;&#x8BD5;&#x5957;&#x4EF6;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Style="{StaticResource SafetyCaption}" Text="{x:Bind ViewModel.SuiteEnablementSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Border Grid.Column="1" Padding="7,3" CornerRadius="10" Background="{ThemeResource SafetyAccentChipBackgroundBrush}" BorderBrush="{ThemeResource SafetyAccentChipBorderBrush}" BorderThickness="1" VerticalAlignment="Top">
                                    <TextBlock FontSize="10" Foreground="{ThemeResource SafetyAccentChipForegroundBrush}" Text="&#x53EF;&#x5C55;&#x5F00;" TextTrimming="CharacterEllipsis" />
                                </Border>
                            </Grid>

                            <TextBlock FontSize="11" Foreground="{ThemeResource SafetyDangerChipForegroundBrush}" Text="{x:Bind ViewModel.ValidationError, Mode=OneWay}" Visibility="{x:Bind ViewModel.HasValidationError, Mode=OneWay}" TextWrapping="Wrap" MaxLines="2" />

                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Padding="8,5" Command="{x:Bind ViewModel.EnableAllSuitesCommand}">
                                    <TextBlock FontSize="11" Text="&#x5168;&#x9009;" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </Button>
                                <Button Grid.Column="1" Padding="8,5" Command="{x:Bind ViewModel.DisableAllSuitesCommand}">
                                    <TextBlock FontSize="11" Text="&#x6E05;&#x7A7A;" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </Button>
                                <Button Grid.Column="2" Padding="8,5" Command="{x:Bind ViewModel.ExpandAllSuitesCommand}">
                                    <TextBlock FontSize="11" Text="&#x5C55;&#x5F00;" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </Button>
                                <Button Grid.Column="3" Padding="8,5" Command="{x:Bind ViewModel.CollapseAllSuitesCommand}">
                                    <TextBlock FontSize="11" Text="&#x6536;&#x8D77;" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </Button>
                            </Grid>

                            <ListView ItemsSource="{x:Bind ViewModel.TestSuites}" CanReorderItems="True" AllowDrop="True" SelectionMode="None" MaxHeight="492">
                                <ListView.Transitions>
                                    <TransitionCollection>
                                        <EntranceThemeTransition FromVerticalOffset="12" IsStaggeringEnabled="True" />
                                        <RepositionThemeTransition />
                                    </TransitionCollection>
                                </ListView.Transitions>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinHeight" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TestSuiteItem">
                                        <Expander Margin="0,0,0,7" IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}">
                                            <Expander.Header>
                                                <Grid ColumnSpacing="9" RowSpacing="8" Padding="2,4,0,4" MinHeight="68" ToolTipService.ToolTip="{x:Bind Description}">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="43" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="56" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Width="34" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Border Padding="0,2" CornerRadius="9" Background="{ThemeResource SafetyDangerChipBackgroundBrush}" BorderBrush="{ThemeResource SafetyDangerChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind HighRiskVisibility}">
                                                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource SafetyDangerChipForegroundBrush}" Text="{x:Bind RiskLevelShortText}" TextAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                        </Border>
                                                        <Border Padding="0,2" CornerRadius="9" Background="{ThemeResource SafetyAccentChipBackgroundBrush}" BorderBrush="{ThemeResource SafetyAccentChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind MediumRiskVisibility}">
                                                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource SafetyAccentChipForegroundBrush}" Text="{x:Bind RiskLevelShortText}" TextAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                        </Border>
                                                        <Border Padding="0,2" CornerRadius="9" Background="{ThemeResource SafetyHealthyChipBackgroundBrush}" BorderBrush="{ThemeResource SafetyHealthyChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind LowRiskVisibility}">
                                                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource SafetyHealthyChipForegroundBrush}" Text="{x:Bind RiskLevelShortText}" TextAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold" Text="{x:Bind DisplayName}" TextTrimming="CharacterEllipsis" MaxLines="1" VerticalAlignment="Center" />
                                                    <ToggleSwitch Grid.Column="2" Width="50" MinWidth="50" HorizontalAlignment="Center" VerticalAlignment="Center" IsOn="{x:Bind IsEnabled, Mode=TwoWay}" OnContent="" OffContent="" />
                                                    <TextBlock Grid.Row="1" FontSize="10" Foreground="{ThemeResource SafetyAccentChipForegroundBrush}" Text="{x:Bind CompactCaseSummary}" TextAlignment="Center" TextTrimming="CharacterEllipsis" MaxLines="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <Grid Grid.Row="1" Grid.Column="1" Width="96" Height="5" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                        <Rectangle RadiusX="2.5" RadiusY="2.5" Fill="{ThemeResource SafetyTrackBrush}" />
                                                        <Rectangle RadiusX="2.5" RadiusY="2.5" Width="{x:Bind EnabledRatioWidth, Mode=OneWay}" Fill="{ThemeResource SafetyDangerChipForegroundBrush}" Visibility="{x:Bind HighRiskVisibility}" HorizontalAlignment="Left" />
                                                        <Rectangle RadiusX="2.5" RadiusY="2.5" Width="{x:Bind EnabledRatioWidth, Mode=OneWay}" Fill="{ThemeResource SafetyAccentChipForegroundBrush}" Visibility="{x:Bind MediumRiskVisibility}" HorizontalAlignment="Left" />
                                                        <Rectangle RadiusX="2.5" RadiusY="2.5" Width="{x:Bind EnabledRatioWidth, Mode=OneWay}" Fill="{ThemeResource SafetyHealthyChipForegroundBrush}" Visibility="{x:Bind LowRiskVisibility}" HorizontalAlignment="Left" />
                                                    </Grid>
                                                    <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource SafetyTiny}" Text="{x:Bind EnabledRatioText}" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </Expander.Header>
                                            <ItemsRepeater ItemsSource="{x:Bind Cases, Mode=OneWay}">
                                                <ItemsRepeater.Layout>
                                                    <StackLayout Orientation="Vertical" Spacing="5" />
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:TestCaseItem">
                                                        <Border Padding="8,6" CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                                            <Grid ColumnSpacing="7">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox IsChecked="{x:Bind IsEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                                                                <StackPanel Grid.Column="1" Spacing="1">
                                                                    <TextBlock FontSize="11" FontWeight="SemiBold" Text="{x:Bind DisplayName}" TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Style="{StaticResource SafetyTiny}" Text="{x:Bind Description}" TextWrapping="Wrap" MaxLines="2" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </Expander>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SafetyCard}" Padding="12,11">
                        <StackPanel Spacing="9">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="&#x6D4B;&#x8BD5;&#x914D;&#x7F6E;" TextTrimming="CharacterEllipsis" />
                            <Border Style="{StaticResource SafetySubtleCard}" Padding="9,8">
                                <Grid ColumnSpacing="8" Tag="ResponsiveStack">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2" MinWidth="0">
                                        <TextBlock Style="{StaticResource SafetyCaption}" Text="&#x5165;&#x53E3;&#x6765;&#x6E90;" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind ViewModel.EndpointSourceText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Style="{StaticResource SafetyTiny}" Text="{x:Bind ViewModel.TransparentProxyContextText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Padding="8,5" Command="{x:Bind ViewModel.UseTransparentProxyCommand}" AutomationProperties.Name="使用透明代理模型池" ToolTipService.ToolTip="&#x4F7F;&#x7528;&#x672C;&#x5730;&#x900F;&#x660E;&#x4EE3;&#x7406;&#x6A21;&#x578B;&#x6C60;">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE968;" />
                                            <TextBlock FontSize="11" Text="&#x63A5;&#x5165;&#x4EE3;&#x7406;" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="92" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource SafetyCaption}" Text="&#x5E76;&#x53D1;&#x7EBF;&#x7A0B;" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <NumberBox Grid.Column="1" Value="{x:Bind ViewModel.Concurrency, Mode=TwoWay}" Minimum="1" Maximum="32" SpinButtonPlacementMode="Compact" />
                                <TextBlock Grid.Row="1" Style="{StaticResource SafetyCaption}" Text="&#x573A;&#x666F;&#x8D85;&#x65F6;&#xFF08;&#x79D2;&#xFF09;" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <NumberBox Grid.Row="1" Grid.Column="1" Value="{x:Bind ViewModel.Timeout, Mode=TwoWay}" Minimum="5" Maximum="300" SpinButtonPlacementMode="Compact" />
                            </Grid>

                            <Grid ColumnSpacing="8" RowSpacing="7">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ToggleSwitch Style="{StaticResource SafetyCompactToggleSwitch}" Header="&#x5E76;&#x884C;&#x5957;&#x4EF6;" IsOn="{x:Bind ViewModel.AllowParallelSuites, Mode=TwoWay}" />
                                <ToggleSwitch Grid.Column="1" Style="{StaticResource SafetyCompactToggleSwitch}" Header="&#x539F;&#x59CB;&#x8BB0;&#x5F55;" IsOn="{x:Bind ViewModel.IncludeRawExchange, Mode=TwoWay}" />
                                <ToggleSwitch Grid.Row="1" Style="{StaticResource SafetyCompactToggleSwitch}" Header="TLS &#x9519;&#x8BEF;" IsOn="{x:Bind ViewModel.IgnoreTlsErrors, Mode=TwoWay}" />
                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                    <TextBlock Style="{StaticResource SafetyCaption}" Text="&#x534F;&#x8BAE;&#x8DEF;&#x5F84;" TextTrimming="CharacterEllipsis" />
                                    <ComboBox SelectedIndex="{x:Bind ViewModel.PreferredWireApiIndex, Mode=TwoWay}">
                                        <ComboBoxItem Content="&#x81EA;&#x52A8;&#x63A2;&#x6D4B;" />
                                        <ComboBoxItem Content="&#x804A;&#x5929;&#x8865;&#x5168;" />
                                        <ComboBoxItem Content="&#x54CD;&#x5E94;&#x63A5;&#x53E3;" />
                                        <ComboBoxItem Content="Anthropic &#x6D88;&#x606F;" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="1" HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <Border Style="{StaticResource SafetyCard}" Padding="14,12">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="10" Tag="ResponsiveStack">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2" MinWidth="0">
                                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="&#x6570;&#x636E;&#x5B89;&#x5168;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Style="{StaticResource SafetyCaption}" Text="&#x9010;&#x573A;&#x666F;&#x5B9E;&#x65F6;&#x8BC4;&#x4F30;&#x6A21;&#x578B;&#x670D;&#x52A1;&#x7684;&#x63D0;&#x793A;&#x6CE8;&#x5165;&#x3001;&#x9690;&#x79C1;&#x6CC4;&#x9732;&#x3001;&#x5DE5;&#x5177;&#x8D8A;&#x6743;&#x548C; RAG &#x6C61;&#x67D3;&#x98CE;&#x9669;" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
