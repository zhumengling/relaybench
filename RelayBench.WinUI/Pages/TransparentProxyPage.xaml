                                            </Border>
                                            <TextBlock Grid.Column="3" FontSize="10" Text="{x:Bind Path}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="4" FontSize="10" Text="{x:Bind RouteName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="5" FontSize="10" Text="{x:Bind ModelName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                            <Border Grid.Column="6" Padding="5,1" CornerRadius="8" HorizontalAlignment="Left" VerticalAlignment="Center" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                    ToolTipService.ToolTip="{x:Bind SignalTooltip}">
                                                <TextBlock FontSize="10" Text="{x:Bind SignalDisplay}" TextTrimming="CharacterEllipsis" />
                                            </Border>
                                            <TextBlock Grid.Column="7" FontSize="10" Text="{x:Bind TokenDisplay}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                       ToolTipService.ToolTip="{x:Bind TokenTooltip}" />
                                            <TextBlock Grid.Column="8" FontSize="10" Text="{x:Bind TraceShortDisplay}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                       ToolTipService.ToolTip="{x:Bind TraceIdDisplay}" />
                                            <TextBlock Grid.Column="9" FontSize="10" Text="{x:Bind LatencyDisplay}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- Log detail panel - shows full request/response on selection -->
                            <Border Grid.Row="4" Padding="12,10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0"
                                    Visibility="{x:Bind ViewModel.LogViewer.IsDetailVisible, Mode=OneWay}">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="&#x8BF7;&#x6C42;&#x8BE6;&#x60C5;" TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="1" Padding="6,4" Command="{x:Bind ViewModel.CloseTransparentProxyLogDetailCommand}" AutomationProperties.Name="关闭透明代理请求详情" ToolTipService.ToolTip="关闭请求详情">
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="10" Glyph="&#xE711;" />
                                        </Button>
                                    </Grid>
                                    <ScrollViewer Grid.Row="1" MaxHeight="180" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
                                        <TextBlock FontFamily="Cascadia Mono, Consolas, Courier New" FontSize="11" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                                                   Text="{x:Bind ViewModel.LogViewer.SelectedEntryDetailText, Mode=OneWay}" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="ProxyChartsScroll" Grid.Column="2" HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <Border Style="{StaticResource ProxyCard}" Padding="12,10">
                        <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Text="Token &#x901F;&#x5EA6;&#xFF08;&#x5B9E;&#x65F6;&#xFF09;" TextTrimming="CharacterEllipsis" />
                                <Button Grid.Column="1" Padding="8,4" Click="OnOpenProxyTrendDialogClick" AutomationProperties.Name="打开透明代理趋势详情" ToolTipService.ToolTip="&#x6253;&#x5F00;&#x8D8B;&#x52BF;&#x8BE6;&#x60C5;">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE9D2;" />
                                </Button>
                                <ComboBox Grid.Column="2" SelectedIndex="0" Width="82" Margin="6,0,0,0">
                                    <ComboBoxItem Content="1 &#x5206;&#x949F;" />
                                    <ComboBoxItem Content="5 &#x5206;&#x949F;" />
                                </ComboBox>
                            </Grid>
                            <Border Style="{StaticResource ProxyChartSurface}">
                                <lvc:CartesianChart x:Name="ThroughputTrendChart" Height="160" Background="Transparent" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ProxyCard}" Padding="12,10">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x5EF6;&#x8FDF;&#x8D8B;&#x52BF;" TextTrimming="CharacterEllipsis" />
                            <Border Style="{StaticResource ProxyChartSurface}">
                                <lvc:CartesianChart x:Name="LatencyTrendChart" Height="140" Background="Transparent" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ProxyCard}" Padding="14,12">
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x7F13;&#x5B58;&#x547D;&#x4E2D;&#x7387;" TextTrimming="CharacterEllipsis" />
                            <Grid Height="126">
                                <Ellipse Width="118" Height="118" Stroke="{ThemeResource CardStrokeColorDefaultBrush}" StrokeThickness="12" Fill="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Ellipse x:Name="CacheHitRing" Width="118" Height="118" Stroke="{ThemeResource ProxyAccentChipForegroundBrush}" StrokeThickness="12" StrokeDashArray="0,30.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform Angle="-90" />
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock FontSize="26" FontWeight="SemiBold" Text="{x:Bind ViewModel.CacheHitRate, Mode=OneWay}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" />
                                    <TextBlock Style="{StaticResource ProxyTiny}" Text="{x:Bind ViewModel.CacheHitRateChange, Mode=OneWay}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource ProxyCaption}" Text="&#x547D;&#x4E2D;" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" FontSize="12" Text="{x:Bind ViewModel.CachedTokens, Mode=OneWay}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid ColumnSpacing="8" RowSpacing="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource ProxyCaption}" Text="响应" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" FontSize="11" Text="{x:Bind ViewModel.ResponseCacheSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="1" Style="{StaticResource ProxyCaption}" Text="会话" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="1" Grid.Column="1" FontSize="11" Text="{x:Bind ViewModel.PromptSessionCacheSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="2" Style="{StaticResource ProxyCaption}" Text="压力" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="2" Grid.Column="1" FontSize="11" Text="{x:Bind ViewModel.CachePressureSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ProxyCard}" Padding="14,12">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind ViewModel.PolicyOverviewTitle, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.PolicyStatusItems, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical" Spacing="6" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TransparentProxyPolicyStatusItem">
                                        <Border Padding="9,7" CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                                ToolTipService.ToolTip="{x:Bind Detail}">
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="1">
                                                    <TextBlock FontSize="11" FontWeight="SemiBold" Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Style="{StaticResource ProxyTiny}" Text="{x:Bind Detail}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Spacing="3" HorizontalAlignment="Right">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind Value}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />
                                                    <Grid HorizontalAlignment="Right" MaxWidth="88">
                                                        <Border Background="{ThemeResource ProxyPolicyAccentChipBackgroundBrush}" BorderBrush="{ThemeResource ProxyPolicyAccentChipBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2" Visibility="{x:Bind AccentToneVisibility, Mode=OneWay}">
                                                            <TextBlock FontSize="10" Foreground="{ThemeResource ProxyPolicyAccentChipForegroundBrush}" Text="{x:Bind BadgeText}" TextTrimming="CharacterEllipsis" />
                                                        </Border>
                                                        <Border Background="{ThemeResource ProxyPolicyHealthyChipBackgroundBrush}" BorderBrush="{ThemeResource ProxyPolicyHealthyChipBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2" Visibility="{x:Bind HealthyToneVisibility, Mode=OneWay}">
                                                            <TextBlock FontSize="10" Foreground="{ThemeResource ProxyPolicyHealthyChipForegroundBrush}" Text="{x:Bind BadgeText}" TextTrimming="CharacterEllipsis" />
                                                        </Border>
                                                        <Border Background="{ThemeResource ProxyPolicyWarningChipBackgroundBrush}" BorderBrush="{ThemeResource ProxyPolicyWarningChipBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2" Visibility="{x:Bind WarningToneVisibility, Mode=OneWay}">
                                                            <TextBlock FontSize="10" Foreground="{ThemeResource ProxyPolicyWarningChipForegroundBrush}" Text="{x:Bind BadgeText}" TextTrimming="CharacterEllipsis" />
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ProxyCard}" Padding="14,12">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x6700;&#x8FD1;&#x5F02;&#x5E38;" TextTrimming="CharacterEllipsis" />
                            <Border Style="{StaticResource ProxySubtleCard}" Padding="10,8" Visibility="{x:Bind ViewModel.RecentActivityEmptyVisibility, Mode=OneWay}">
                                <StackPanel Spacing="3">
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="0 &#x6761;&#x5F02;&#x5E38;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Style="{StaticResource ProxyTiny}" Text="&#x8FD0;&#x884C;&#x65F6;&#x6309;&#x65E5;&#x5FD7;&#x5E93;&#x548C;&#x5B9E;&#x65F6;&#x72B6;&#x6001;&#x5C55;&#x793A;&#xFF0C;&#x4E0D;&#x586B;&#x5145;&#x793A;&#x4F8B;&#x4E8B;&#x4EF6;" TextWrapping="Wrap" MaxLines="2" />
                                </StackPanel>
                            </Border>
                            <ListView ItemsSource="{x:Bind ViewModel.RecentActivityEvents, Mode=OneWay}" SelectionMode="None" IsItemClickEnabled="False" MaxHeight="170" Padding="0" Visibility="{x:Bind ViewModel.RecentActivityListVisibility, Mode=OneWay}">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinHeight" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TransparentProxyActivityEvent">
                                        <Grid Padding="0,5" ColumnSpacing="7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="42" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Style="{StaticResource ProxyTiny}" Text="{x:Bind TimeText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="1" Style="{StaticResource ProxyWarningChip}" Padding="5,1" VerticalAlignment="Center">
                                                <TextBlock FontSize="9" Foreground="{ThemeResource ProxyWarningChipForegroundBrush}" Text="{x:Bind BadgeText}" TextTrimming="CharacterEllipsis" />
                                            </Border>
                                            <StackPanel Grid.Column="2" Spacing="1">
                                                <TextBlock FontSize="10" Text="{x:Bind Detail}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Style="{StaticResource ProxyTiny}" Text="{x:Bind Source}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="3" Style="{StaticResource ProxyTiny}" Text="{x:Bind StatusText}" HorizontalAlignment="Right" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ProxyCard}" Padding="14,12">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind ViewModel.ModelPoolTitle, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            <ListView ItemsSource="{x:Bind ViewModel.ModelPool}" SelectionMode="None" IsItemClickEnabled="False" MaxHeight="180">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinHeight" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ModelPoolEntry">
                                        <Grid Padding="8,6" ColumnSpacing="8" ToolTipService.ToolTip="{x:Bind DetailToolTip, Mode=OneWay}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontSize="11" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                                 <TextBlock Style="{StaticResource ProxyTiny}" Text="{x:Bind ProtocolSummary}" TextTrimming="CharacterEllipsis" />
                                                 <TextBlock Style="{StaticResource ProxyTiny}" Text="{x:Bind UsageDisplay}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Style="{StaticResource ProxyHealthyChip}" Padding="6,2" VerticalAlignment="Center">
                                                <TextBlock Style="{StaticResource ProxyHealthyChipText}" Text="{x:Bind HealthDisplay}" TextTrimming="CharacterEllipsis" />
                                            </Border>
                                            <TextBlock Grid.Column="2" FontSize="11" Text="{x:Bind LatencyDisplay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        </ScrollViewer>
    </Grid>
</local:PageBase>


