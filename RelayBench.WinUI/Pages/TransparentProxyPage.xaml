<?xml version="1.0" encoding="utf-8" ?>
<local:PageBase
    x:Class="RelayBench.WinUI.Pages.TransparentProxyPage"
    x:Name="TransparentProxyRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RelayBench.WinUI.Pages"
    xmlns:vm="using:RelayBench.WinUI.ViewModels"
    xmlns:storage="using:RelayBench.WinUI.Storage"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    Background="Transparent">

    <local:PageBase.Resources>
        <ResourceDictionary>
        <ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary x:Key="Light">
                <SolidColorBrush x:Key="ProxyHeaderIconBackgroundBrush" Color="#EEF5FF" />
                <SolidColorBrush x:Key="ProxyHeaderIconBorderBrush" Color="#C7DAF8" />
                <SolidColorBrush x:Key="ProxyHeaderIconForegroundBrush" Color="#2563EB" />
                <SolidColorBrush x:Key="ProxyAccentChipBackgroundBrush" Color="#EEF5FF" />
                <SolidColorBrush x:Key="ProxyAccentChipBorderBrush" Color="#C7DAF8" />
                <SolidColorBrush x:Key="ProxyAccentChipForegroundBrush" Color="#2563EB" />
                <SolidColorBrush x:Key="ProxyHealthyChipBackgroundBrush" Color="#ECFDF3" />
                <SolidColorBrush x:Key="ProxyHealthyChipBorderBrush" Color="#BBF7D0" />
                <SolidColorBrush x:Key="ProxyHealthyChipForegroundBrush" Color="#08763A" />
                <SolidColorBrush x:Key="ProxyWarningChipBackgroundBrush" Color="#FFF7E6" />
                <SolidColorBrush x:Key="ProxyWarningChipBorderBrush" Color="#F2C46D" />
                <SolidColorBrush x:Key="ProxyWarningChipForegroundBrush" Color="#8A4B00" />
                <SolidColorBrush x:Key="ProxyDangerChipForegroundBrush" Color="#B42318" />
                <SolidColorBrush x:Key="ProxyGatewayPanelBackgroundBrush" Color="#E6F8FBFF" />
                <SolidColorBrush x:Key="ProxyChartSurfaceBackgroundBrush" Color="#F2F8FAFC" />
                <SolidColorBrush x:Key="ProxyChartSurfaceBorderBrush" Color="#CBD5E1" />
            </ResourceDictionary>
            <ResourceDictionary x:Key="Dark">
                <SolidColorBrush x:Key="ProxyHeaderIconBackgroundBrush" Color="#14213F" />
                <SolidColorBrush x:Key="ProxyHeaderIconBorderBrush" Color="#2F6FED" />
                <SolidColorBrush x:Key="ProxyHeaderIconForegroundBrush" Color="#7CCBFF" />
                <SolidColorBrush x:Key="ProxyAccentChipBackgroundBrush" Color="#102A4A" />
                <SolidColorBrush x:Key="ProxyAccentChipBorderBrush" Color="#34506E" />
                <SolidColorBrush x:Key="ProxyAccentChipForegroundBrush" Color="#7CCBFF" />
                <SolidColorBrush x:Key="ProxyHealthyChipBackgroundBrush" Color="#143827" />
                <SolidColorBrush x:Key="ProxyHealthyChipBorderBrush" Color="#2D8D62" />
                <SolidColorBrush x:Key="ProxyHealthyChipForegroundBrush" Color="#8FF2B6" />
                <SolidColorBrush x:Key="ProxyWarningChipBackgroundBrush" Color="#4A3210" />
                <SolidColorBrush x:Key="ProxyWarningChipBorderBrush" Color="#8A5A14" />
                <SolidColorBrush x:Key="ProxyWarningChipForegroundBrush" Color="#FFC36D" />
                <SolidColorBrush x:Key="ProxyDangerChipForegroundBrush" Color="#FDA4AF" />
                <SolidColorBrush x:Key="ProxyGatewayPanelBackgroundBrush" Color="#C6101724" />
                <SolidColorBrush x:Key="ProxyChartSurfaceBackgroundBrush" Color="#B30A111C" />
                <SolidColorBrush x:Key="ProxyChartSurfaceBorderBrush" Color="#33496A" />
            </ResourceDictionary>
            <ResourceDictionary x:Key="HighContrast">
                <SolidColorBrush x:Key="ProxyHeaderIconBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="ProxyHeaderIconBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="ProxyHeaderIconForegroundBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                <SolidColorBrush x:Key="ProxyAccentChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="ProxyAccentChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="ProxyAccentChipForegroundBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                <SolidColorBrush x:Key="ProxyHealthyChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="ProxyHealthyChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="ProxyHealthyChipForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="ProxyWarningChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="ProxyWarningChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="ProxyWarningChipForegroundBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                <SolidColorBrush x:Key="ProxyDangerChipForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="ProxyGatewayPanelBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="ProxyChartSurfaceBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="ProxyChartSurfaceBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            </ResourceDictionary>
        </ResourceDictionary.ThemeDictionaries>
        <Style x:Key="ProxyCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="ProxySubtleCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style x:Key="ProxyCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ProxyTiny" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ProxyToolbarButton" TargetType="Button" BasedOn="{StaticResource AppToolbarButton}" />
        <Style x:Key="ProxyCompactToggleSwitch" TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="OnContent" Value="" />
            <Setter Property="OffContent" Value="" />
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock
                            MaxWidth="214"
                            Text="{Binding}"
                            TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ProxyChartSurface" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource ProxyChartSurfaceBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ProxyChartSurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style x:Key="ProxyAccentChip" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource ProxyAccentChipBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ProxyAccentChipBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="ProxyHealthyChip" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource ProxyHealthyChipBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ProxyHealthyChipBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="ProxyWarningChip" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource ProxyWarningChipBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ProxyWarningChipBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="ProxyAccentChipText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{ThemeResource ProxyAccentChipForegroundBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ProxyHealthyChipText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{ThemeResource ProxyHealthyChipForegroundBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ProxyWarningChipText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{ThemeResource ProxyWarningChipForegroundBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        </ResourceDictionary>
    </local:PageBase.Resources>

    <Grid Padding="20,14,20,18" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="14" RowSpacing="8" Tag="ResponsiveStack">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid MinWidth="0" ColumnSpacing="12" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource AppHeaderIcon}" Background="{ThemeResource ProxyHeaderIconBackgroundBrush}" BorderBrush="{ThemeResource ProxyHeaderIconBorderBrush}">
                    <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="24" Foreground="{ThemeResource ProxyHeaderIconForegroundBrush}" Glyph="&#xEC27;" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="2" MinWidth="0">
                    <TextBlock FontSize="23" FontWeight="SemiBold" Text="&#x900F;&#x660E;&#x4EE3;&#x7406;" TextTrimming="CharacterEllipsis" />
                    <TextBlock Style="{StaticResource ProxyCaption}" Text="&#x672C;&#x5730; AI &#x7F51;&#x5173; &#x00B7; &#x7EDF;&#x4E00;&#x8DEF;&#x7531;&#x4E0E;&#x5B89;&#x5168;&#x7BA1;&#x63A7;" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Border Grid.Column="2" Style="{StaticResource AppStatusPill}" Background="{ThemeResource ProxyHealthyChipBackgroundBrush}" BorderBrush="{ThemeResource ProxyHealthyChipBorderBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="8" Height="8" Fill="{ThemeResource ProxyHealthyChipForegroundBrush}" VerticalAlignment="Center" />
                        <TextBlock FontSize="11" Foreground="{ThemeResource ProxyHealthyChipForegroundBrush}" MaxWidth="160" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Grid>
            <ScrollViewer Grid.Column="1"
                          MaxWidth="620"
                          HorizontalAlignment="Right"
                          HorizontalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          VerticalScrollMode="Disabled"
                          ZoomMode="Disabled">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border Padding="10,6" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="8" Height="8" Fill="{ThemeResource ProxyAccentChipForegroundBrush}" VerticalAlignment="Center" />
                        <StackPanel>
                            <TextBlock Style="{StaticResource ProxyTiny}" Text="&#x5B9E;&#x65F6; Token" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="13" FontWeight="SemiBold" MaxWidth="92" Text="{x:Bind ViewModel.TokenSpeed, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Button Style="{StaticResource ProxyToolbarButton}" KeyDown="FlyoutButton_KeyDown" AutomationProperties.Name="打开透明代理更多菜单" ToolTipService.ToolTip="&#x66F4;&#x591A;&#x900F;&#x660E;&#x4EE3;&#x7406;&#x64CD;&#x4F5C;">
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                            <MenuFlyoutItem Text="&#x590D;&#x5236;&#x672C;&#x5730;&#x5165;&#x53E3;" AccessKey="C" Command="{x:Bind ViewModel.CopyTransparentProxyEndpointCommand}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8C8;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="AI &#x63D0;&#x4F9B;&#x5546;&#x7BA1;&#x7406;" AccessKey="A" Click="OnOpenOAuthDialogClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE77B;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE712;" />
                        <TextBlock FontSize="12" Text="&#x66F4;&#x591A;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource AppAccentToolbarButton}" Command="{x:Bind ViewModel.StartTransparentProxyCommand}" AutomationProperties.Name="启动透明代理监听器" ToolTipService.ToolTip="启动本地透明代理监听器">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE768;" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Text="&#x542F;&#x52A8;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ProxyToolbarButton}" Command="{x:Bind ViewModel.StopTransparentProxyCommand}" AutomationProperties.Name="停止透明代理监听器" ToolTipService.ToolTip="停止本地透明代理监听器">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource ProxyDangerChipForegroundBrush}" Glyph="&#xE71A;" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource ProxyDangerChipForegroundBrush}" Text="&#x505C;&#x6B62;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
            </StackPanel>
            </ScrollViewer>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      VerticalScrollMode="Disabled"
                      ZoomMode="Disabled">
        <Grid MinWidth="0" ColumnSpacing="8" Tag="ResponsiveStack">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource ProxyCard}" Padding="12,9">
                <StackPanel Spacing="3">
                    <TextBlock Style="{StaticResource ProxyCaption}" Text="&#x603B;&#x8BF7;&#x6C42;" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Bind ViewModel.TotalRequests, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="10" Foreground="{ThemeResource ProxyHealthyChipForegroundBrush}" Text="{x:Bind ViewModel.TotalRequestsChange, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource ProxyCard}" Padding="12,9">
                <StackPanel Spacing="3">
                    <TextBlock Style="{StaticResource ProxyCaption}" Text="&#x6210;&#x529F;&#x7387;" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Bind ViewModel.SuccessRate, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="10" Foreground="{ThemeResource ProxyHealthyChipForegroundBrush}" Text="{x:Bind ViewModel.SuccessRateChange, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource ProxyCard}" Padding="12,9">
                <StackPanel Spacing="3">
                    <TextBlock Style="{StaticResource ProxyCaption}" Text="&#x7F13;&#x5B58;&#x7387;" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Bind ViewModel.CacheHitRate, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="10" Foreground="{ThemeResource ProxyHealthyChipForegroundBrush}" Text="{x:Bind ViewModel.CacheHitRateChange, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource ProxyCard}" Padding="12,9">
                <StackPanel Spacing="3">
                    <TextBlock Style="{StaticResource ProxyCaption}" Text="&#x603B; Token" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Bind ViewModel.TotalTokens, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="10" Foreground="{ThemeResource ProxyHealthyChipForegroundBrush}" Text="{x:Bind ViewModel.TotalTokensChange, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource ProxyCard}" Padding="12,9">
                <StackPanel Spacing="3">
                    <TextBlock Style="{StaticResource ProxyCaption}" Text="&#x7F13;&#x5B58; Token" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Bind ViewModel.CachedTokens, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="10" Foreground="{ThemeResource ProxyHealthyChipForegroundBrush}" Text="{x:Bind ViewModel.CachedTokensChange, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
            <Border Grid.Column="5" Style="{StaticResource ProxyCard}" Padding="12,9">
                <StackPanel Spacing="3">
                    <TextBlock Style="{StaticResource ProxyCaption}" Text="&#x8F93;&#x5165; / &#x8F93;&#x51FA;" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Bind ViewModel.IoTokens, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="10" Foreground="{ThemeResource ProxyHealthyChipForegroundBrush}" Text="{x:Bind ViewModel.IoTokensChange, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
            <Border Grid.Column="6" Style="{StaticResource ProxyCard}" Padding="12,9">
                <StackPanel Spacing="3">
                    <TextBlock Style="{StaticResource ProxyCaption}" Text="&#x6D3B;&#x8DC3;&#x8FDE;&#x63A5;" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Bind ViewModel.ActiveConnections, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Style="{StaticResource ProxyTiny}" Text="&#x7A33;&#x5B9A;" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </Grid>
        </ScrollViewer>

        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      VerticalScrollMode="Disabled"
                      ZoomMode="Disabled">
            <Grid MinWidth="0" ColumnSpacing="12" Tag="ResponsiveStack">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ProxySettingsColumn" Width="0" />
                <ColumnDefinition x:Name="ProxyCenterColumn" Width="*" />
                <ColumnDefinition x:Name="ProxyChartsColumn" Width="320" />
            </Grid.ColumnDefinitions>

            <ScrollViewer x:Name="ProxySettingsScroll" HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <Border Style="{StaticResource ProxyCard}" Padding="14,12">
                        <StackPanel Spacing="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x4EE3;&#x7406;&#x8BBE;&#x7F6E;" TextTrimming="CharacterEllipsis" />
                                <Button Grid.Column="1" Padding="6,3" Background="Transparent" BorderThickness="0" Command="{x:Bind ViewModel.ToggleTransparentProxySettingsDrawerCommand}" AutomationProperties.Name="展开或收起透明代理设置抽屉" ToolTipService.ToolTip="&#x5C55;&#x5F00;/&#x6536;&#x8D77;&#x4EE3;&#x7406;&#x8BBE;&#x7F6E;">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE70D;" />
                                </Button>
                            </Grid>
                            <Grid ColumnSpacing="6" Visibility="{x:Bind ViewModel.TransparentProxySettingsDrawerVisibility, Mode=OneWay}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Padding="8,5" Command="{x:Bind ViewModel.ToggleTransparentProxyListenSettingsCommand}" AutomationProperties.Name="打开透明代理监听与缓存设置" ToolTipService.ToolTip="&#x76D1;&#x542C;&#x4E0E;&#x7F13;&#x5B58;&#x8BBE;&#x7F6E;">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE71D;" />
                                </Button>
                                <Button Grid.Column="1" Padding="8,5" Command="{x:Bind ViewModel.ToggleTransparentProxyProviderSettingsCommand}" AutomationProperties.Name="打开透明代理提供方与路由设置" ToolTipService.ToolTip="提供方 / 路由">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8D4;" />
                                </Button>
                                <Button Grid.Column="2" Padding="8,5" Click="OnOpenOAuthDialogClick" AutomationProperties.Name="打开透明代理 AI 提供商管理窗口" ToolTipService.ToolTip="AI 提供商管理">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE77B;" />
                                </Button>
                            </Grid>
                            <Border Style="{StaticResource ProxySubtleCard}" Padding="10,9" Visibility="{x:Bind ViewModel.TransparentProxyListenSettingsVisibility, Mode=OneWay}">
                                <StackPanel Spacing="4">
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="&#x76D1;&#x542C;&#x8BBE;&#x7F6E;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="{x:Bind ViewModel.ListenAddress, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Style="{StaticResource ProxyCaption}" Text="HTTP(S) / HTTP2" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ProxySubtleCard}" Padding="10,9" Visibility="{x:Bind ViewModel.TransparentProxyProviderSettingsVisibility, Mode=OneWay}">
                                <StackPanel Spacing="7">
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="&#x63D0;&#x4F9B;&#x5546;&#x4E0E;&#x8DEF;&#x7531;" TextTrimming="CharacterEllipsis" />
                                    <ComboBox ItemsSource="{x:Bind ViewModel.RouteStrategyDisplayOptions}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Key"
                                              SelectedValue="{x:Bind ViewModel.SelectedRouteStrategy, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"
                                              AutomationProperties.Name="透明代理路由策略"
                                              ToolTipService.ToolTip="选择透明代理如何选择上游路由" />
                                    <Button Padding="8,6" Click="OnAddRouteClick" AutomationProperties.Name="添加透明代理路由" ToolTipService.ToolTip="添加一条透明代理路由">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE710;" />
                                            <TextBlock FontSize="11" Text="&#x6DFB;&#x52A0;&#x8DEF;&#x7531;" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ProxySubtleCard}" Padding="10,9" Visibility="{x:Bind ViewModel.TransparentProxyProviderSettingsVisibility, Mode=OneWay}">
                                <StackPanel Spacing="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="&#x6A21;&#x578B;&#x91CD;&#x5199;" TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="1" Padding="4,2" Background="Transparent" BorderThickness="0" Command="{x:Bind ViewModel.AddModelRewriteRuleCommand}" AutomationProperties.Name="添加模型重写规则" ToolTipService.ToolTip="添加一条模型重写规则">
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Glyph="&#xE710;" />
                                        </Button>
                                    </Grid>
                                    <ListView ItemsSource="{x:Bind ViewModel.ModelRewriteRules}" SelectionMode="None" IsItemClickEnabled="False" MaxHeight="140" Padding="0">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="MinHeight" Value="0" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ModelRewriteRule">
