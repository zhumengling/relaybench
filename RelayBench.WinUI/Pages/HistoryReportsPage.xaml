                                <TextBlock Grid.Row="3" Grid.Column="1" FontSize="11" Text="{x:Bind ViewModel.SelectedReportProxyModeSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HistoryCard}" Padding="14,12">
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x6A21;&#x578B;&#x4E0E;&#x534F;&#x8BAE;" TextTrimming="CharacterEllipsis" />
                            <Grid ColumnSpacing="10" RowSpacing="7">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource HistoryCaption}" Text="&#x6A21;&#x578B;" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" FontSize="11" Text="{x:Bind ViewModel.SelectedReportModelSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="1" Style="{StaticResource HistoryCaption}" Text="&#x8F93;&#x5165; Tokens" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="1" Grid.Column="1" FontSize="11" Text="{x:Bind ViewModel.SelectedReportInputTokensSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="2" Style="{StaticResource HistoryCaption}" Text="&#x8F93;&#x51FA; Tokens" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="2" Grid.Column="1" FontSize="11" Text="{x:Bind ViewModel.SelectedReportOutputTokensSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="3" Style="{StaticResource HistoryCaption}" Text="&#x7F13;&#x5B58; Tokens" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="3" Grid.Column="1" FontSize="11" Text="{x:Bind ViewModel.SelectedReportPromptCacheTokensSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="4" Style="{StaticResource HistoryCaption}" Text="&#x7F13;&#x5B58;&#x547D;&#x4E2D;" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="4" Grid.Column="1" FontSize="11" Text="{x:Bind ViewModel.SelectedReportCacheHitRateSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="5" Style="{StaticResource HistoryCaption}" Text="&#x8F93;&#x51FA;&#x53E3;&#x5F84;" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="5" Grid.Column="1" FontSize="11" Text="{x:Bind ViewModel.SelectedReportOutputTokenSourceSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="6" Style="{StaticResource HistoryCaption}" Text="&#x534F;&#x8BAE;&#x652F;&#x6301;" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Row="6" Grid.Column="1" FontSize="11" Text="{x:Bind ViewModel.SelectedReportProtocolSupportSummary, Mode=OneWay}" TextWrapping="Wrap" MaxLines="3" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HistoryCard}" Padding="14,12">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedReportAttachmentTitle, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Attachments, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical" Spacing="6" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:HistoryAttachmentItem">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8A5;" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" FontSize="11" Text="{x:Bind FileName}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2" Style="{StaticResource HistoryTiny}" Text="{x:Bind Size}" TextTrimming="CharacterEllipsis" />
                                            <FontIcon Grid.Column="3" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE896;" Opacity="0.55" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HistoryCard}" Padding="14,12">
                        <StackPanel Spacing="9">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x62A5;&#x544A;&#x5F52;&#x6863;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Style="{StaticResource HistoryTiny}" Text="zip / bundle / report" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Button Grid.Column="1" Padding="7,5" Background="Transparent" BorderThickness="0" Command="{x:Bind ViewModel.RefreshReportArchiveCommand}" AutomationProperties.Name="刷新报告归档" ToolTipService.ToolTip="&#x5237;&#x65B0;&#x5F52;&#x6863;">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE72C;" />
                                </Button>
                                <Button Grid.Column="2" Padding="7,5" Background="Transparent" BorderThickness="0" Click="OnOpenReportArchiveClick" AutomationProperties.Name="打开报告归档弹窗" ToolTipService.ToolTip="&#x6253;&#x5F00;&#x5F52;&#x6863;&#x5F39;&#x7A97;">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8A7;" />
                                </Button>
                            </Grid>
                            <TextBlock FontFamily="Cascadia Mono, Consolas"
                                       FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind ViewModel.ReportArchiveSummary, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords"
                                       MaxLines="6" />
                            <Button Padding="9,7" HorizontalAlignment="Stretch" Click="OnOpenReportArchiveClick"
                                    AutomationProperties.Name="打开最近报告归档"
                                    ToolTipService.ToolTip="打开最近报告归档">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8A7;" />
                                    <TextBlock FontSize="12" Text="&#x67E5;&#x770B;&#x6700;&#x8FD1;&#x5F52;&#x6863;" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HistoryCard}" Padding="14,12">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x5FEB;&#x6377;&#x64CD;&#x4F5C;" TextTrimming="CharacterEllipsis" />
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Padding="9,7" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.PrepareRerunCommand}" ToolTipService.ToolTip="&#x751F;&#x6210;&#x91CD;&#x8FD0;&#x5305;">
                                    <TextBlock FontSize="12" Text="&#x91CD;&#x65B0;&#x8FD0;&#x884C;" TextTrimming="CharacterEllipsis" />
                                </Button>
                                <Button Grid.Column="1" Padding="9,7" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.CompareSelectedReportCommand}" ToolTipService.ToolTip="&#x751F;&#x6210;&#x5BF9;&#x6BD4;&#x62A5;&#x544A;">
                                    <TextBlock FontSize="12" Text="&#x5BF9;&#x6BD4;&#x62A5;&#x544A;" TextTrimming="CharacterEllipsis" />
                                </Button>
                                <Button Grid.Row="1" Padding="9,7" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.CopyReportLinkCommand}" ToolTipService.ToolTip="&#x590D;&#x5236;&#x62A5;&#x544A;&#x94FE;&#x63A5;">
                                    <TextBlock FontSize="12" Text="&#x590D;&#x5236;&#x94FE;&#x63A5;" TextTrimming="CharacterEllipsis" />
                                </Button>
                                <Button Grid.Row="1" Grid.Column="1" Padding="9,7" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.DeleteReportCommand}"
                                        ToolTipService.ToolTip="删除所选报告">
                                    <TextBlock FontSize="12" Foreground="{ThemeResource HistoryDangerChipForegroundBrush}" MaxWidth="92" Text="&#x5220;&#x9664;&#x62A5;&#x544A;" TextTrimming="CharacterEllipsis" />
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        </ScrollViewer>
    </Grid>
</local:PageBase>

