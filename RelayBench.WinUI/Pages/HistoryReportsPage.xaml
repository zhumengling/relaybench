<?xml version="1.0" encoding="utf-8" ?>
<local:PageBase
    x:Class="RelayBench.WinUI.Pages.HistoryReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:RelayBench.WinUI.Converters"
    xmlns:local="using:RelayBench.WinUI.Pages"
    xmlns:vm="using:RelayBench.WinUI.ViewModels"
    Background="Transparent">

    <local:PageBase.Resources>
        <Style x:Key="HistoryCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="HistorySubtleCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style x:Key="HistoryCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="HistoryTiny" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="HistoryToolbarButton" TargetType="Button" BasedOn="{StaticResource AppToolbarButton}" />
        <converters:ImagePathToBitmapImageConverter x:Key="ImagePathToBitmapImageConverter" />
    </local:PageBase.Resources>

    <Grid Padding="20,14,20,18" RowSpacing="10">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="12" IsStaggeringEnabled="True" />
                <RepositionThemeTransition />
            </TransitionCollection>
        </Grid.ChildrenTransitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HistoryCard}" Padding="12,10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          VerticalScrollMode="Disabled"
                          ZoomMode="Disabled">
            <Grid MinWidth="0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="1.7*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox PlaceholderText="&#x641C;&#x7D22;&#x62A5;&#x544A;&#xFF08;ID&#x3001;&#x540D;&#x79F0;&#x3001;&#x63A5;&#x53E3;&#x3001;&#x5907;&#x6CE8;&#xFF09;" Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Padding="10,7" />
                <TextBlock Grid.Column="1" Style="{StaticResource HistoryCaption}" Text="&#x7C7B;&#x578B;:" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <ComboBox Grid.Column="2" SelectedIndex="{x:Bind ViewModel.SelectedTypeIndex, Mode=TwoWay}" Width="112">
                    <ComboBoxItem Content="&#x5168;&#x90E8;&#x7C7B;&#x578B;" />
                    <ComboBoxItem Content="&#x5355;&#x7AD9;&#x6D4B;&#x8BD5;" />
                    <ComboBoxItem Content="&#x6279;&#x91CF;&#x8BC4;&#x6D4B;" />
                    <ComboBoxItem Content="&#x7F51;&#x7EDC;&#x590D;&#x6838;" />
                    <ComboBoxItem Content="&#x6570;&#x636E;&#x5B89;&#x5168;" />
                    <ComboBoxItem Content="&#x900F;&#x660E;&#x4EE3;&#x7406;" />
                    <ComboBoxItem Content="&#x5927;&#x6A21;&#x578B;&#x5BF9;&#x8BDD;" />
                    <ComboBoxItem Content="&#x5E94;&#x7528;&#x63A5;&#x5165;" />
                </ComboBox>
                <Grid Grid.Column="3" ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox PlaceholderText="yyyy-MM-dd" Text="{x:Bind ViewModel.StartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Padding="10,7" />
                    <TextBlock Grid.Column="1" Text="&#x2192;" FontSize="12" Opacity="0.55" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <TextBox Grid.Column="2" PlaceholderText="yyyy-MM-dd" Text="{x:Bind ViewModel.EndDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Padding="10,7" />
                </Grid>
                <Button Grid.Column="4" Style="{StaticResource HistoryToolbarButton}"
                        AutomationProperties.Name="刷新历史报告"
                        Command="{x:Bind ViewModel.RefreshCommand}"
                        ToolTipService.ToolTip="刷新历史报告">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE72C;" />
                </Button>
                <Button Grid.Column="5" Style="{StaticResource HistoryToolbarButton}" Command="{x:Bind ViewModel.ExportCurrentReportCommand}"
                        AutomationProperties.Name="导出所选历史报告"
                        ToolTipService.ToolTip="导出所选报告">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE74E;" />
                        <TextBlock FontSize="12" Text="&#x5BFC;&#x51FA;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="6" Style="{StaticResource HistoryToolbarButton}" Command="{x:Bind ViewModel.ExportReportsCommand}" AutomationProperties.Name="打包历史报告附件" ToolTipService.ToolTip="&#x5BFC;&#x51FA;&#x5F53;&#x524D;&#x9009;&#x4E2D;&#x6216;&#x5168;&#x90E8;&#x62A5;&#x544A;">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE8A7;" />
                        <TextBlock FontSize="12" Text="&#x6253;&#x5305;&#x9644;&#x4EF6;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="7" Style="{StaticResource HistoryToolbarButton}" Click="OnOpenReportArchiveClick" AutomationProperties.Name="打开报告归档" ToolTipService.ToolTip="&#x67E5;&#x770B;&#x6700;&#x8FD1;&#x5BFC;&#x51FA;&#x7684; zip / bundle / report &#x5F52;&#x6863;">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE8A7;" />
                </Button>
            </Grid>
            </ScrollViewer>
        </Border>

        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Auto"
            HorizontalScrollMode="Enabled"
            VerticalScrollBarVisibility="Disabled"
            VerticalScrollMode="Disabled">
            <Grid MinWidth="1120" ColumnSpacing="12" Tag="ResponsiveStack">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource HistoryCard}" Padding="0">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Padding="14,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel MinWidth="0">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="&#x5386;&#x53F2;&#x62A5;&#x544A;" TextTrimming="CharacterEllipsis" />
                            <TextBlock Style="{StaticResource HistoryCaption}" Text="{x:Bind ViewModel.TotalReports, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="1" Padding="7,5" Background="Transparent" BorderThickness="0" Command="{x:Bind ViewModel.RefreshCommand}" AutomationProperties.Name="刷新历史报告列表" ToolTipService.ToolTip="&#x5237;&#x65B0;&#x5217;&#x8868;">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE71C;" />
                        </Button>
                        <Button Grid.Column="2" Padding="7,5" Background="Transparent" BorderThickness="0" Command="{x:Bind ViewModel.ExportReportsCommand}" AutomationProperties.Name="打包全部历史报告" ToolTipService.ToolTip="&#x6253;&#x5305;&#x5168;&#x90E8;&#x62A5;&#x544A;">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8CB;" />
                        </Button>
                    </Grid>
                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Reports, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedReport, Mode=TwoWay}" SelectionMode="Single" Padding="8">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:HistoryReportItem">
                                <Grid ColumnSpacing="8" Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid>
                                        <Rectangle Width="2" Fill="{ThemeResource HistoryAccentChipBorderBrush}" HorizontalAlignment="Center" />
                                        <Ellipse Width="8" Height="8" Fill="{ThemeResource HistoryAccentChipForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                    <Border Grid.Column="1" Padding="11,9" CornerRadius="7" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="3" MinWidth="0">
                                                    <Grid ColumnSpacing="8" MinWidth="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind Time}" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="1" Style="{StaticResource HistoryTiny}" MaxWidth="92" Text="{x:Bind Type}" TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                    <TextBlock FontSize="11" Text="{x:Bind Detail}" TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Style="{StaticResource HistoryTiny}" MaxWidth="90" Text="{x:Bind Duration}" TextTrimming="CharacterEllipsis" />
                                                    <Grid>
                                                        <Border Padding="6,2" CornerRadius="9" Background="{ThemeResource HistoryHealthyChipBackgroundBrush}" BorderBrush="{ThemeResource HistoryHealthyChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind SuccessVisibility}">
                                                            <TextBlock FontSize="10" Foreground="{ThemeResource HistoryHealthyChipForegroundBrush}" Text="&#x6210;&#x529F;" TextTrimming="CharacterEllipsis" />
                                                        </Border>
                                                        <Border Padding="6,2" CornerRadius="9" Background="{ThemeResource HistoryWarningChipBackgroundBrush}" BorderBrush="{ThemeResource HistoryWarningChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind ReviewVisibility}">
                                                            <TextBlock FontSize="10" Foreground="{ThemeResource HistoryWarningChipForegroundBrush}" Text="&#x590D;&#x6838;" TextTrimming="CharacterEllipsis" />
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind Score}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Style="{StaticResource HistoryTiny}" Text="&#x8BC4;&#x5206;" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1" HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid ColumnSpacing="8" VerticalAlignment="Center" MinWidth="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="17" FontWeight="SemiBold" MaxWidth="220" Text="{x:Bind ViewModel.SelectedReport.Type, Mode=OneWay, FallbackValue='--'}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" Style="{StaticResource HistoryCaption}" Text="/" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" Style="{StaticResource HistoryCaption}" MaxWidth="220" Text="{x:Bind ViewModel.SelectedReport.Id, Mode=OneWay, FallbackValue='--'}" TextTrimming="CharacterEllipsis" />
                            <Grid Grid.Column="3">
                                <Border Padding="7,2" CornerRadius="10" Background="{ThemeResource HistoryHealthyChipBackgroundBrush}" BorderBrush="{ThemeResource HistoryHealthyChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind ViewModel.SelectedReportSuccessVisibility, Mode=OneWay}">
                                    <TextBlock FontSize="10" Foreground="{ThemeResource HistoryHealthyChipForegroundBrush}" Text="&#x6210;&#x529F;" TextTrimming="CharacterEllipsis" />
                                </Border>
                                <Border Padding="7,2" CornerRadius="10" Background="{ThemeResource HistoryWarningChipBackgroundBrush}" BorderBrush="{ThemeResource HistoryWarningChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind ViewModel.SelectedReportReviewVisibility, Mode=OneWay}">
                                    <TextBlock FontSize="10" Foreground="{ThemeResource HistoryWarningChipForegroundBrush}" Text="{x:Bind ViewModel.SelectedReportStatusText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                </Border>
                            </Grid>
                        </Grid>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Padding="8,5" Background="Transparent" BorderThickness="0" Command="{x:Bind ViewModel.ExportCurrentReportCommand}" AutomationProperties.Name="导出当前报告详情" ToolTipService.ToolTip="&#x5BFC;&#x51FA;&#x5F53;&#x524D;&#x62A5;&#x544A;">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE734;" />
                            </Button>
                            <Button Padding="8,5" Background="Transparent" BorderThickness="0" Command="{x:Bind ViewModel.CopyReportLinkCommand}" AutomationProperties.Name="复制所选报告链接" ToolTipService.ToolTip="&#x590D;&#x5236;&#x62A5;&#x544A;&#x94FE;&#x63A5;">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE712;" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer
                        HorizontalScrollBarVisibility="Auto"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollBarVisibility="Disabled"
                        VerticalScrollMode="Disabled">
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.MetricTiles, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="8" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:HistoryMetricTile">
                                <Border Width="152" Style="{StaticResource HistoryCard}" Padding="12,10">
                                    <StackPanel Spacing="4">
                                        <TextBlock Style="{StaticResource HistoryCaption}" Text="{x:Bind Label}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind Value}" TextTrimming="CharacterEllipsis" />
                                        <Grid>
                                            <TextBlock FontSize="11" Foreground="{ThemeResource HistoryAccentChipForegroundBrush}" Text="{x:Bind Delta}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind AccentToneVisibility}" />
                                            <TextBlock FontSize="11" Foreground="{ThemeResource HistoryHealthyChipForegroundBrush}" Text="{x:Bind Delta}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind HealthyToneVisibility}" />
                                            <TextBlock FontSize="11" Foreground="{ThemeResource HistoryWarningChipForegroundBrush}" Text="{x:Bind Delta}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind WarningToneVisibility}" />
                                            <TextBlock FontSize="11" Foreground="{ThemeResource HistoryDangerChipForegroundBrush}" Text="{x:Bind Delta}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind DangerToneVisibility}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    </ScrollViewer>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.35*" />
                            <ColumnDefinition Width="0.9*" />
                            <ColumnDefinition Width="1.25*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource HistoryCard}" Padding="12,10">
                            <StackPanel Spacing="9">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x5EF6;&#x8FDF;&#x6458;&#x8981;" TextTrimming="CharacterEllipsis" />
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource HistoryCaption}" Text="P50" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" FontSize="18" FontWeight="SemiBold" Text="{x:Bind ViewModel.HistoryP50Summary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                    <Grid Grid.Row="1" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource HistoryCaption}" Text="P95" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" FontSize="14" FontWeight="SemiBold" Text="{x:Bind ViewModel.HistoryP95Summary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                    <Grid Grid.Row="2" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource HistoryCaption}" Text="P99" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" FontSize="14" FontWeight="SemiBold" Text="{x:Bind ViewModel.HistoryP99Summary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Grid>
                                <TextBlock Style="{StaticResource HistoryTiny}" Text="&#x6765;&#x81EA;&#x5F53;&#x524D;&#x7B5B;&#x9009;&#x7ED3;&#x679C;&#x7684;&#x771F;&#x5B9E; payload &#x805A;&#x5408;&#xFF0C;&#x7F3A;&#x5931;&#x6309; 0 &#x663E;&#x793A;" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource HistoryCard}" Padding="12,10">
                            <StackPanel Spacing="9">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x8BF7;&#x6C42;&#x4E0E;&#x7A33;&#x5B9A;" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind ViewModel.HistoryTotalRequestsSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="12" Text="{x:Bind ViewModel.HistorySuccessRequestsSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="12" Text="{x:Bind ViewModel.HistoryErrorRateSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                                <TextBlock FontSize="11" Text="{x:Bind ViewModel.HistoryTimeoutSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="11" Text="{x:Bind ViewModel.HistoryRateLimitSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="11" Text="{x:Bind ViewModel.HistoryServerErrorSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource HistoryCard}" Padding="12,10">
                            <StackPanel Spacing="9">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x541E;&#x5410;&#x4E0E; Token" TextTrimming="CharacterEllipsis" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Padding="10,8" CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <StackPanel Spacing="3">
                                            <TextBlock Style="{StaticResource HistoryTiny}" Text="&#x8F93;&#x5165;&#x541E;&#x5410;" TextTrimming="CharacterEllipsis" />
                                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind ViewModel.HistoryInputThroughputSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Padding="10,8" CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <StackPanel Spacing="3">
                                            <TextBlock Style="{StaticResource HistoryTiny}" Text="&#x8F93;&#x51FA;&#x541E;&#x5410;" TextTrimming="CharacterEllipsis" />
                                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind ViewModel.HistoryOutputThroughputSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <TextBlock FontSize="12" Text="{x:Bind ViewModel.HistoryTotalInputSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="12" Text="{x:Bind ViewModel.HistoryTotalOutputSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Style="{StaticResource HistoryTiny}" Text="&#x53EA;&#x5C55;&#x793A;&#x5386;&#x53F2;&#x4E2D;&#x771F;&#x5B9E;&#x5199;&#x5165;&#x7684;&#x6307;&#x6807;" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="1.05*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource HistoryCard}" Padding="12,10">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x534F;&#x8BAE;&#x63A2;&#x6D4B;&#x7ED3;&#x679C;" TextTrimming="CharacterEllipsis" />
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.ProtocolResults, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Horizontal" Spacing="8" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:HistoryProtocolResult">
                                            <Border Width="158" Padding="12,10" CornerRadius="7" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                                <StackPanel Spacing="6">
                                                    <Grid ColumnSpacing="6" MinWidth="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                                        <Grid Grid.Column="1">
                                                            <Border Grid.Column="1" Padding="6,2" CornerRadius="9" Background="{ThemeResource HistoryAccentChipBackgroundBrush}" BorderBrush="{ThemeResource HistoryAccentChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind AccentToneVisibility}">
                                                                <TextBlock FontSize="10" Foreground="{ThemeResource HistoryAccentChipForegroundBrush}" Text="{x:Bind State}" TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                            <Border Padding="6,2" CornerRadius="9" Background="{ThemeResource HistoryHealthyChipBackgroundBrush}" BorderBrush="{ThemeResource HistoryHealthyChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind HealthyToneVisibility}">
                                                                <TextBlock FontSize="10" Foreground="{ThemeResource HistoryHealthyChipForegroundBrush}" Text="{x:Bind State}" TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                            <Border Padding="6,2" CornerRadius="9" Background="{ThemeResource HistoryWarningChipBackgroundBrush}" BorderBrush="{ThemeResource HistoryWarningChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind WarningToneVisibility}">
                                                                <TextBlock FontSize="10" Foreground="{ThemeResource HistoryWarningChipForegroundBrush}" Text="{x:Bind State}" TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                            <Border Padding="6,2" CornerRadius="9" Background="{ThemeResource HistoryDangerChipBackgroundBrush}" BorderBrush="{ThemeResource HistoryDangerChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind DangerToneVisibility}">
                                                                <TextBlock FontSize="10" Foreground="{ThemeResource HistoryDangerChipForegroundBrush}" Text="{x:Bind State}" TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                        </Grid>
                                                    </Grid>
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
