<?xml version="1.0" encoding="utf-8"?>
<local:PageBase
    x:Class="RelayBench.WinUI.Pages.ModelChatPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RelayBench.WinUI.Pages"
    xmlns:controls="using:RelayBench.WinUI.Pages.Controls"
    xmlns:vm="using:RelayBench.WinUI.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    Loaded="OnPageLoaded"
    Unloaded="OnPageUnloaded">

    <local:PageBase.Resources>
        <Style x:Key="ConversationGlassCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="CaptionText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ReasoningEffortToggle" TargetType="ToggleButton" BasedOn="{StaticResource AppModeToggle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Storyboard x:Name="StreamingPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation
                Storyboard.TargetName="StreamingGlow"
                Storyboard.TargetProperty="Opacity"
                From="0.03"
                To="0.14"
                Duration="0:0:0.8" />
        </Storyboard>
    </local:PageBase.Resources>

    <Grid Padding="16,12,16,12" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="ChatToolbarGrid" ColumnSpacing="10" RowSpacing="8" VerticalAlignment="Center">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="ChatToolbarStates">
                    <VisualState x:Name="ChatToolbarWide">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="761" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="ChatToolbarEndpointGrid.(Grid.Row)" Value="0" />
                            <Setter Target="ChatToolbarEndpointGrid.(Grid.Column)" Value="1" />
                            <Setter Target="ChatToolbarEndpointGrid.(Grid.ColumnSpan)" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="ChatToolbarCompact">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="ChatToolbarEndpointGrid.(Grid.Row)" Value="1" />
                            <Setter Target="ChatToolbarEndpointGrid.(Grid.Column)" Value="0" />
                            <Setter Target="ChatToolbarEndpointGrid.(Grid.ColumnSpan)" Value="5" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Style="{StaticResource AppAccentToolbarButton}" Command="{x:Bind ViewModel.NewChatSessionCommand}" AutomationProperties.Name="新建对话会话" ToolTipService.ToolTip="&#x65B0;&#x4F1A;&#x8BDD;">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE710;" />
                    <TextBlock FontWeight="SemiBold" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" MaxWidth="74" Text="&#x65B0;&#x4F1A;&#x8BDD;" TextTrimming="CharacterEllipsis" />
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE70D;" />
                </StackPanel>
            </Button>
            <Grid x:Name="ChatToolbarEndpointGrid" Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    MinWidth="0"
                    Text="{x:Bind ViewModel.BaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="&#x63A5;&#x53E3;&#x5730;&#x5740;"
                    AutomationProperties.Name="对话接口地址" />
                <PasswordBox
                    Grid.Column="1"
                    MinWidth="0"
                    Password="{x:Bind ViewModel.ApiKey, Mode=TwoWay}"
                    PlaceholderText="API &#x5BC6;&#x94A5;"
                    AutomationProperties.Name="对话 API 密钥" />
                <ComboBox
                    Grid.Column="2"
                    MinWidth="0"
                    IsEditable="True"
                    ItemsSource="{x:Bind ViewModel.AvailableModels, Mode=OneWay}"
                    Text="{x:Bind ViewModel.Model, Mode=TwoWay}"
                    PlaceholderText="&#x6A21;&#x578B;"
                    AutomationProperties.Name="对话模型" />
                <Button Grid.Column="3" Style="{StaticResource AppIconButton}" Command="{x:Bind ViewModel.FetchModelsCommand}" AutomationProperties.Name="拉取对话模型" ToolTipService.ToolTip="&#x62C9;&#x53D6;&#x6A21;&#x578B;">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE896;" />
                </Button>
            </Grid>
            <Button Grid.Column="2" Style="{StaticResource AppToolbarButton}" Command="{x:Bind ViewModel.ClearChatSessionCommand}" AutomationProperties.Name="清空当前对话会话" ToolTipService.ToolTip="&#x6E05;&#x7A7A;&#x5F53;&#x524D;&#x4F1A;&#x8BDD;">
                <StackPanel Orientation="Horizontal" Spacing="7">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE74D;" />
                    <TextBlock Text="&#x6E05;&#x7A7A;" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Button>
            <Button Grid.Column="3" Style="{StaticResource AppToolbarButton}" Command="{x:Bind ViewModel.StopChatStreamingCommand}" AutomationProperties.Name="停止对话生成" ToolTipService.ToolTip="&#x505C;&#x6B62;&#x751F;&#x6210;">
                <StackPanel Orientation="Horizontal" Spacing="7">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource ChatDangerChipForegroundBrush}" Glyph="&#xE711;" />
                    <TextBlock Foreground="{ThemeResource ChatDangerChipForegroundBrush}" MaxWidth="86" Text="&#x505C;&#x6B62;&#x751F;&#x6210;" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Button>
            <Button Grid.Column="4" Style="{StaticResource AppIconButton}" Command="{x:Bind ViewModel.ToggleChatSettingsPanelCommand}" AutomationProperties.Name="打开对话设置" ToolTipService.ToolTip="&#x5BF9;&#x8BDD;&#x8BBE;&#x7F6E;">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14" Glyph="&#xE713;" />
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto">
            <Grid x:Name="Chat工作区Grid" ColumnSpacing="10" MinWidth="820" Tag="ResponsiveStack">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ChatSessionColumn" Width="286" />
                <ColumnDefinition x:Name="ChatConversationColumn" Width="*" />
                <ColumnDefinition x:Name="ChatSettingsColumn" Width="0" MinWidth="0" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ChatSessionPanel" Style="{StaticResource ConversationGlassCard}" Padding="12">
                <controls:ConversationSessionList
                    x:Name="SessionList"
                    Sessions="{x:Bind ViewModel.Sessions, Mode=OneWay}"
                    SelectedSession="{x:Bind ViewModel.CurrentSession, Mode=TwoWay}"
                    SessionCreated="OnSessionCreated"
                    SessionSelected="OnSessionSelected"
                    SessionDeleted="OnSessionDeleted"
                    SessionRenamed="OnSessionRenamed" />
                <!-- Session action automation names are implemented inside ConversationSessionList:
                     AutomationProperties.Name="重命名对话会话"
                     AutomationProperties.Name="删除对话会话"
                     AutomationProperties.Name="管理对话会话" -->
            </Border>

            <Grid Grid.Column="1" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled">
                <Grid ColumnSpacing="8" MinWidth="0" Tag="ResponsiveStack">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource ConversationGlassCard}" Padding="14,10">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="30" Height="30" CornerRadius="15" Background="{ThemeResource ChatVioletChipBackgroundBrush}" BorderBrush="{ThemeResource ChatVioletChipBorderBrush}" BorderThickness="1">
                                <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="15" Foreground="{ThemeResource ChatVioletChipForegroundBrush}" Glyph="&#xE895;" />
                            </Border>
                                <StackPanel Grid.Column="1" Spacing="2" MinWidth="0">
                                    <TextBlock Style="{StaticResource CaptionText}" Text="&#x8F93;&#x5165; Token" TextTrimming="CharacterEllipsis" />
                                    <Grid ColumnSpacing="8" MinWidth="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind ViewModel.InputTokensDisplay, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" FontSize="11" Foreground="{ThemeResource ChatHealthyChipForegroundBrush}" MaxWidth="72" Text="{x:Bind ViewModel.InputTokenTrend, Mode=OneWay}" TextTrimming="CharacterEllipsis" VerticalAlignment="Bottom" />
                                    </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource ConversationGlassCard}" Padding="14,10">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="30" Height="30" CornerRadius="15" Background="{ThemeResource ChatWarningChipBackgroundBrush}" BorderBrush="{ThemeResource ChatWarningChipBorderBrush}" BorderThickness="1">
                                <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="15" Foreground="{ThemeResource ChatWarningChipForegroundBrush}" Glyph="&#xE8AB;" />
                            </Border>
                                <StackPanel Grid.Column="1" Spacing="2" MinWidth="0">
                                    <TextBlock Style="{StaticResource CaptionText}" Text="&#x8F93;&#x51FA; Token" TextTrimming="CharacterEllipsis" />
                                    <Grid ColumnSpacing="8" MinWidth="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind ViewModel.OutputTokensDisplay, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" FontSize="11" Foreground="{ThemeResource ChatHealthyChipForegroundBrush}" MaxWidth="72" Text="{x:Bind ViewModel.OutputTokenTrend, Mode=OneWay}" TextTrimming="CharacterEllipsis" VerticalAlignment="Bottom" />
                                    </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource ConversationGlassCard}" Padding="14,10">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="30" Height="30" CornerRadius="15" Background="{ThemeResource ChatAccentChipBackgroundBrush}" BorderBrush="{ThemeResource ChatAccentChipBorderBrush}" BorderThickness="1">
                                <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="15" Foreground="{ThemeResource ChatAccentChipForegroundBrush}" Glyph="&#xE8F1;" />
                            </Border>
                                <StackPanel Grid.Column="1" Spacing="2" MinWidth="0">
                                    <TextBlock Style="{StaticResource CaptionText}" Text="&#x7F13;&#x5B58; Token" TextTrimming="CharacterEllipsis" />
                                    <Grid ColumnSpacing="8" MinWidth="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind ViewModel.CachedTokensDisplay, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" FontSize="11" Foreground="{ThemeResource ChatHealthyChipForegroundBrush}" MaxWidth="72" Text="{x:Bind ViewModel.CachedTokenTrend, Mode=OneWay}" TextTrimming="CharacterEllipsis" VerticalAlignment="Bottom" />
                                    </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource ConversationGlassCard}" Padding="14,10">
                        <Grid>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource CaptionText}" Text="&#x6D41;&#x5F0F;&#x901F;&#x5EA6;" TextTrimming="CharacterEllipsis" />
                                <Grid ColumnSpacing="4" MinWidth="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind ViewModel.TokensPerSecond, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" FontSize="11" Text="tok/s" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis" />
                                </Grid>
                                <Border Height="2" Margin="0,4,18,0" Background="{ThemeResource ChatHealthyChipForegroundBrush}" CornerRadius="1" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource ConversationGlassCard}" Padding="14,10">
                        <StackPanel Spacing="2">
                            <TextBlock Style="{StaticResource CaptionText}" Text="&#x547D;&#x4E2D;&#x7F13;&#x5B58;" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind ViewModel.CacheHitRate, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock FontSize="11" Foreground="{ThemeResource ChatHealthyChipForegroundBrush}" MaxWidth="86" Text="{x:Bind ViewModel.CacheHitTrend, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <Border Width="28" Height="2" Background="{ThemeResource ChatHealthyChipForegroundBrush}" CornerRadius="1" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
                </ScrollViewer>

                <Border Grid.Row="1" Style="{StaticResource ConversationGlassCard}" Padding="0">
                    <Grid>
                        <Border x:Name="StreamingGlow" Background="{ThemeResource ChatAccentChipForegroundBrush}" CornerRadius="8" Opacity="0" />
                        <ScrollViewer x:Name="ChatMessagesScrollViewer"
                                      MinHeight="180"
                                      Padding="22,18"
                                      VerticalScrollBarVisibility="Auto"
                                      ViewChanged="ChatMessagesScrollViewer_ViewChanged">
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="14" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ChatMessageItem">
                                        <Grid>
                                            <Border
                                                MaxWidth="760"
                                                HorizontalAlignment="Right"
                                                Background="{ThemeResource ChatAccentChipBackgroundBrush}"
                                                BorderBrush="{ThemeResource ChatAccentChipBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="16,12"
                                                Visibility="{x:Bind IsUser, Mode=OneWay}">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock FontSize="13" Text="{x:Bind Content, Mode=OneWay}" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                                                        <TextBlock Grid.Column="1" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" MaxWidth="160" Text="{x:Bind Metrics, Mode=OneWay}" TextTrimming="CharacterEllipsis" VerticalAlignment="Bottom" />
                                                        <Button Grid.Column="2" Padding="4" Background="Transparent" BorderThickness="0"
                                                                Command="{Binding ViewModel.EditChatMessageCommand, ElementName=RootPage}" CommandParameter="{x:Bind}"
                                                                AutomationProperties.Name="编辑对话消息"
                                                                ToolTipService.ToolTip="&#x7F16;&#x8F91;&#x6D88;&#x606F;">
                                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Glyph="&#xE70F;" />
                                                        </Button>
                                                        <Button Grid.Column="3" Padding="4" Background="Transparent" BorderThickness="0"
                                                                Command="{Binding ViewModel.CopyChatMessageCommand, ElementName=RootPage}" CommandParameter="{x:Bind}"
                                                                AutomationProperties.Name="复制对话消息"
                                                                ToolTipService.ToolTip="&#x590D;&#x5236;&#x6D88;&#x606F;">
                                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Glyph="&#xE8C8;" />
                                                        </Button>
                                                    </Grid>
                                                    <ItemsRepeater ItemsSource="{x:Bind AttachmentItems, Mode=OneWay}" Visibility="{x:Bind HasAttachments, Mode=OneWay}">
                                                        <ItemsRepeater.Layout>
                                                            <StackLayout Orientation="Horizontal" Spacing="6" />
                                                        </ItemsRepeater.Layout>
                                                        <ItemsRepeater.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:ChatAttachmentItem">
                                                                <Border Background="{ThemeResource ChatAccentChipBackgroundBrush}" BorderBrush="{ThemeResource ChatAccentChipBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8,5">
                                                                    <Grid ColumnSpacing="6">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8B7;" />
                                                                        <StackPanel Grid.Column="1" Spacing="1">
                                                                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="{x:Bind FileName, Mode=OneWay}" TextTrimming="CharacterEllipsis" MaxWidth="180" />
                                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                                <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" MaxWidth="72" Text="{x:Bind TypeLabel, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                                                <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" MaxWidth="72" Text="{x:Bind SizeDisplay, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsRepeater.ItemTemplate>
                                                    </ItemsRepeater>
                                                </StackPanel>
                                            </Border>

                                            <Grid ColumnSpacing="10" Visibility="{x:Bind IsAssistant, Mode=OneWay}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="42" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="34" Height="34" CornerRadius="8" Background="{ThemeResource ChatVioletChipBackgroundBrush}" BorderBrush="{ThemeResource ChatVioletChipBorderBrush}" BorderThickness="1" VerticalAlignment="Top">
                                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="{ThemeResource ChatVioletChipForegroundBrush}" Text="AI" TextTrimming="CharacterEllipsis" />
                                                </Border>
                                                <Border Grid.Column="1" MaxWidth="760" HorizontalAlignment="Left" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,13">
                                                    <StackPanel Spacing="12">
                                                        <Grid ColumnSpacing="8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock FontSize="12" FontWeight="SemiBold" MaxWidth="170" Text="{Binding ViewModel.Model, ElementName=RootPage}" TextTrimming="CharacterEllipsis" />
                                                            <Border Grid.Column="1" Background="{ThemeResource ChatWarningChipBackgroundBrush}" BorderBrush="{ThemeResource ChatWarningChipBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="7,2">
                                                                <TextBlock FontSize="11" Foreground="{ThemeResource ChatWarningChipForegroundBrush}" Text="&#x5B9E;&#x65F6;" TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                            <Border Grid.Column="2" Background="{ThemeResource ChatAccentChipBackgroundBrush}" BorderBrush="{ThemeResource ChatAccentChipBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="7,2">
                                                                <TextBlock FontSize="11" Foreground="{ThemeResource ChatAccentChipForegroundBrush}" MaxWidth="110" Text="{Binding ViewModel.EndpointProtocol, ElementName=RootPage}" TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                            <Border Grid.Column="3" Width="6" Height="6" CornerRadius="3" Background="{ThemeResource ChatHealthyChipForegroundBrush}" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="4" FontSize="11" Text="{x:Bind Metrics, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                            <Button Grid.Column="5" Padding="4" Background="Transparent" BorderThickness="0"
                                                                    Command="{Binding ViewModel.CopyChatMessageCommand, ElementName=RootPage}" CommandParameter="{x:Bind}"
                                                                    AutomationProperties.Name="复制对话回答"
                                                                    ToolTipService.ToolTip="&#x590D;&#x5236;&#x56DE;&#x7B54;">
                                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Glyph="&#xE8C8;" />
                                                            </Button>
                                                            <Button Grid.Column="6" Padding="4" Background="Transparent" BorderThickness="0"
                                                                    Command="{Binding ViewModel.RegenerateLastChatAnswerCommand, ElementName=RootPage}"
                                                                    AutomationProperties.Name="继续生成上一条对话响应"
                                                                    ToolTipService.ToolTip="继续生成">
                                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Glyph="&#xE72C;" />
                                                            </Button>
                                                        </Grid>
                                                        <TextBlock FontSize="13" Text="{x:Bind Content, Mode=OneWay}" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                                                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x5B9E;&#x73B0;&#x4EE3;&#x7801;" Visibility="{x:Bind HasCodeBlock, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                        <Border Background="{ThemeResource DialogTerminalBackgroundBrush}" BorderBrush="{ThemeResource DialogTerminalBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="0" Visibility="{x:Bind HasCodeBlock, Mode=OneWay}">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>
                                                                <Grid Padding="12,8">
                                                                    <TextBlock FontSize="12" Text="go" TextTrimming="CharacterEllipsis" />
                                                                    <Button HorizontalAlignment="Right" Padding="8,4"
                                                                            Command="{Binding ViewModel.CopyChatCodeBlockCommand, ElementName=RootPage}" CommandParameter="{x:Bind}"
                                                                            AutomationProperties.Name="复制对话代码块"
                                                                            ToolTipService.ToolTip="&#x590D;&#x5236;&#x4EE3;&#x7801;">
                                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8C8;" />
                                                                            <TextBlock FontSize="11" Text="&#x590D;&#x5236;&#x4EE3;&#x7801;" TextTrimming="CharacterEllipsis" />
                                                                        </StackPanel>
                                                                    </Button>
                                                                </Grid>
                                                                <TextBlock Grid.Row="1" Padding="14,4,14,14" FontFamily="Consolas" FontSize="12" Text="{x:Bind CodeBlock, Mode=OneWay}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                                            </Grid>
                                                        </Border>
                                                        <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" MaxWidth="540" Text="{x:Bind Metrics, Mode=OneWay}" Visibility="{x:Bind HasMetrics, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>
                        <Button x:Name="BackToBottomButton"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,24,20"
                                Padding="10,7"
                                Background="{ThemeResource RxAcrylicOverlayBrush}"
