<?xml version="1.0" encoding="utf-8" ?>
<local:PageBase
    x:Class="RelayBench.WinUI.Pages.ApplicationCenterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RelayBench.WinUI.Pages"
    xmlns:vm="using:RelayBench.WinUI.ViewModels"
    x:Name="PageRoot"
    Background="Transparent"
    Loaded="OnPageLoaded"
    Unloaded="OnPageUnloaded">

    <local:PageBase.Resources>
        <Style x:Key="AccessCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="AccessSubtleCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style x:Key="AccessCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="AccessTiny" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ToolIconButton" TargetType="Button" BasedOn="{StaticResource AppToolbarButton}" />
        <Style x:Key="AccessCompactCheckBox" TargetType="CheckBox" BasedOn="{StaticResource AppCompactCheckBox}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock
                            MaxWidth="86"
                            Text="{Binding}"
                            TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </local:PageBase.Resources>

    <Grid Padding="20,14,20,18" RowSpacing="10">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="12" IsStaggeringEnabled="True" />
                <RepositionThemeTransition />
            </TransitionCollection>
        </Grid.ChildrenTransitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="14" RowSpacing="8" Tag="ResponsiveStack">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid MinWidth="0" ColumnSpacing="12" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource AppHeaderIcon}" Background="{ThemeResource AccessHeaderIconBackgroundBrush}" BorderBrush="{ThemeResource AccessHeaderIconBorderBrush}">
                    <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="24" Foreground="{ThemeResource AccessHeaderIconForegroundBrush}" Glyph="&#xE8A7;" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="2" MinWidth="0">
                    <TextBlock FontSize="23" FontWeight="SemiBold" Text="&#x5E94;&#x7528;&#x63A5;&#x5165;" TextTrimming="CharacterEllipsis" />
                    <TextBlock Style="{StaticResource AccessCaption}" Text="&#x5C06; RelayBench &#x63A5;&#x53E3;&#x5B89;&#x5168;&#x63A5;&#x5165;&#x5404;&#x7C7B;&#x5E94;&#x7528;&#x4E0E;&#x5DE5;&#x5177;" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Border Grid.Column="2" Style="{StaticResource AppStatusPill}" Background="{ThemeResource AccessHealthyChipBackgroundBrush}" BorderBrush="{ThemeResource AccessHealthyChipBorderBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="8" Height="8" Fill="{ThemeResource AccessHealthyChipForegroundBrush}" VerticalAlignment="Center" />
                        <TextBlock FontSize="11" Foreground="{ThemeResource AccessHealthyChipForegroundBrush}" MaxWidth="160" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        MinWidth="0">
                <Button Style="{StaticResource ToolIconButton}"
                        Command="{x:Bind ViewModel.ProbeProtocolCommand}"
                        AutomationProperties.Name="强制探测当前接口协议"
                        ToolTipService.ToolTip="强制探测当前接口协议">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource AccessAccentChipForegroundBrush}" Glyph="&#xE9D9;" />
                        <TextBlock FontSize="12" MaxWidth="72" Text="&#x5F3A;&#x5236;&#x63A2;&#x6D4B;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolIconButton}"
                        Command="{x:Bind ViewModel.RunClientApiDiagnosticsCommand}"
                        AutomationProperties.Name="运行客户端 API 诊断"
                        ToolTipService.ToolTip="运行本地客户端 API 诊断">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource AccessAccentChipForegroundBrush}" Glyph="&#xE7C3;" />
                        <TextBlock FontSize="12" MaxWidth="86" Text="&#x5BA2;&#x6237;&#x7AEF;&#x8BCA;&#x65AD;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolIconButton}" Command="{x:Bind ViewModel.ApplyCurrentInterfaceToCodexAppsCommand}" AutomationProperties.Name="将当前接口应用到 Codex 应用" ToolTipService.ToolTip="&#x5C06;&#x5F53;&#x524D;&#x63A5;&#x53E3;&#x5199;&#x5165; Codex" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource AccessAccentChipForegroundBrush}" Glyph="&#xE8F1;" />
                        <TextBlock FontSize="12" MaxWidth="58" Text="Codex" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource AppAccentToolbarButton}"
                        Command="{x:Bind ViewModel.ApplyToSelectedCommand}"
                        AutomationProperties.Name="将当前接口应用到所选应用"
                        ToolTipService.ToolTip="将当前接口应用到所选应用">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE8FB;" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" MaxWidth="126" Text="{x:Bind ViewModel.ApplySelectedButtonText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolIconButton}" Click="OnOpenClientApplyTargetDialogClick" AutomationProperties.Name="打开应用接入目标选择" ToolTipService.ToolTip="&#x6253;&#x5F00;&#x63A5;&#x5165;&#x76EE;&#x6807;&#x9009;&#x62E9;" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource AccessAccentChipForegroundBrush}" Glyph="&#xE8FD;" />
                        <TextBlock FontSize="12" Text="&#x76EE;&#x6807;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource AccessCard}" Padding="16,12">
            <ScrollViewer
                HorizontalScrollBarVisibility="Auto"
                HorizontalScrollMode="Enabled"
                VerticalScrollBarVisibility="Disabled"
                VerticalScrollMode="Disabled">
            <StackPanel Spacing="10" MinWidth="0">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource AccessCaption}" Text="&#x63A5;&#x53E3;&#x5730;&#x5740;" TextTrimming="CharacterEllipsis" />
                    <TextBox
                        Text="{x:Bind ViewModel.BaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="http://127.0.0.1:8080"
                        HorizontalAlignment="Stretch" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Style="{StaticResource AccessCaption}" Text="API &#x5BC6;&#x94A5;" TextTrimming="CharacterEllipsis" />
                    <PasswordBox Password="{x:Bind ViewModel.ApiKey, Mode=TwoWay}"
                                 AutomationProperties.Name="应用接入 API 密钥"
                                 ToolTipService.ToolTip="输入要写入所选客户端配置的 API 密钥" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Style="{StaticResource AccessCaption}" Text="&#x6A21;&#x578B;" TextTrimming="CharacterEllipsis" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox
                            IsEditable="True"
                            Text="{x:Bind ViewModel.Model, Mode=TwoWay}"
                            ItemsSource="{x:Bind ViewModel.AvailableModels, Mode=OneWay}"
                            PlaceholderText="claude-3-5-sonnet"
                            HorizontalAlignment="Stretch" />
                        <Button
                            Grid.Column="1"
                            Style="{StaticResource AppIconButton}"
                            Command="{x:Bind ViewModel.FetchApplicationCenterProxyModelsCommand}"
                            AutomationProperties.Name="拉取应用中心代理模型"
                            ToolTipService.ToolTip="&#x62C9;&#x53D6;&#x6A21;&#x578B;">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE896;" />
                        </Button>
                    </Grid>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom" Margin="2,0,0,4">
                    <Button
                        Style="{StaticResource AppIconButton}"
                        Click="OnUseTransparentProxyClick"
                        AutomationProperties.Name="使用透明代理当前入口"
                        ToolTipService.ToolTip="&#x4F7F;&#x7528;&#x900F;&#x660E;&#x4EE3;&#x7406;&#x5F53;&#x524D;&#x672C;&#x5730;&#x5165;&#x53E3;"
                        Visibility="Collapsed">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8A7;" />
                    </Button>
                    <Button
                        Style="{StaticResource AppIconButton}"
                        Click="OnOpenEndpointHistoryDialogClick"
                        AutomationProperties.Name="打开历史接口"
                        ToolTipService.ToolTip="&#x5386;&#x53F2;&#x63A5;&#x53E3;">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE81C;" />
                    </Button>
                    <ProgressRing Width="24" Height="24" IsActive="{x:Bind ViewModel.IsEndpointBusy, Mode=OneWay}" />
                </StackPanel>
            </Grid>
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.45*" />
                </Grid.ColumnDefinitions>
                <Border Padding="10,6" CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <StackPanel Spacing="1">
                        <TextBlock Style="{StaticResource AccessTiny}" Text="&#x76EE;&#x6807;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind ViewModel.TargetOverviewText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="10,6" CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <StackPanel Spacing="1">
                        <TextBlock Style="{StaticResource AccessTiny}" Text="&#x5DF2;&#x53D1;&#x73B0;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind ViewModel.InstalledTargetOverviewText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Padding="10,6" CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <StackPanel Spacing="1">
                        <TextBlock Style="{StaticResource AccessTiny}" Text="&#x5DF2;&#x9009;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedTargetOverviewText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Padding="10,6" CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <StackPanel Spacing="1">
                        <TextBlock Style="{StaticResource AccessTiny}" Text="&#x5907;&#x4EFD;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind ViewModel.BackupOverviewText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Padding="10,6" CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <StackPanel Spacing="1">
                        <TextBlock Style="{StaticResource AccessTiny}" Text="&#x534F;&#x8BAE;&#x590D;&#x6838;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind ViewModel.ProtocolCoverageText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="5" Padding="10,6" CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <StackPanel Spacing="1">
                        <TextBlock Style="{StaticResource AccessTiny}" Text="&#x5165;&#x53E3;&#x63A5;&#x7BA1;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind ViewModel.EndpointTakeoverText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Grid>
            </StackPanel>
            </ScrollViewer>
        </Border>

        <ScrollViewer
            Grid.Row="2"
            HorizontalScrollBarVisibility="Auto"
            HorizontalScrollMode="Enabled"
            VerticalScrollBarVisibility="Disabled"
            VerticalScrollMode="Disabled">
        <Grid RowSpacing="12" MinWidth="1180" Tag="ResponsiveStack">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.02*" />
                <RowDefinition Height="0.98*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource AccessCard}" Padding="0">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Padding="14,10" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="1.55*" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="1.7*" />
                            <ColumnDefinition Width="118" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource AccessCaption}" FontWeight="SemiBold" Text="&#x9009;&#x62E9;" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" Style="{StaticResource AccessCaption}" FontWeight="SemiBold" Text="&#x5E94;&#x7528; / &#x5BA2;&#x6237;&#x7AEF;" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="2" Style="{StaticResource AccessCaption}" FontWeight="SemiBold" Text="&#x5B89;&#x88C5;&#x72B6;&#x6001;" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="3" Style="{StaticResource AccessCaption}" FontWeight="SemiBold" Text="&#x5F53;&#x524D;&#x914D;&#x7F6E;" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="4" Style="{StaticResource AccessCaption}" FontWeight="SemiBold" Text="&#x53EF;&#x7528;&#x534F;&#x8BAE;" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="5" Style="{StaticResource AccessCaption}" FontWeight="SemiBold" Text="&#x5199;&#x5165;&#x8DEF;&#x5F84;" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="6" Style="{StaticResource AccessCaption}" FontWeight="SemiBold" Text="&#x64CD;&#x4F5C;" TextTrimming="CharacterEllipsis" />
                    </Grid>

                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Targets, Mode=OneWay}" SelectionMode="None" Padding="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:AppTargetItem">
                                <Grid Padding="14,10" ColumnSpacing="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="1.55*" />
                                        <ColumnDefinition Width="0.8*" />
                                        <ColumnDefinition Width="1.1*" />
                                        <ColumnDefinition Width="0.8*" />
                                        <ColumnDefinition Width="1.7*" />
                                        <ColumnDefinition Width="154" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                              MinWidth="0"
                                              Padding="0"
                                              VerticalAlignment="Center"
                                              AutomationProperties.Name="{x:Bind Name}"
                                              ToolTipService.ToolTip="{x:Bind Description}" />
                                    <Grid Grid.Column="1" ColumnSpacing="10" VerticalAlignment="Center" MinWidth="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Width="34" Height="34">
                                            <Border CornerRadius="8" Background="{ThemeResource AccessAccentChipBackgroundBrush}" BorderBrush="{ThemeResource AccessAccentChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind IconAccentToneVisibility}" />
                                            <Border CornerRadius="8" Background="{ThemeResource AccessHealthyChipBackgroundBrush}" BorderBrush="{ThemeResource AccessHealthyChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind IconHealthyToneVisibility}" />
                                            <Border CornerRadius="8" Background="{ThemeResource AccessWarningChipBackgroundBrush}" BorderBrush="{ThemeResource AccessWarningChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind IconWarningToneVisibility}" />
                                            <Border CornerRadius="8" Background="{ThemeResource AccessDangerChipBackgroundBrush}" BorderBrush="{ThemeResource AccessDangerChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind IconDangerToneVisibility}" />
                                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="17" Foreground="{ThemeResource AccessAccentChipForegroundBrush}" Glyph="{x:Bind IconGlyph}" />
                                        </Grid>
                                        <StackPanel Grid.Column="1" Spacing="1" MinWidth="0">
                                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Style="{StaticResource AccessTiny}" Text="{x:Bind Description}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="12" Foreground="{ThemeResource AccessHealthyChipForegroundBrush}" FontWeight="SemiBold" Text="{x:Bind InstalledText}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Style="{StaticResource AccessTiny}" Text="{x:Bind SelectabilityText}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="12" Text="{x:Bind CurrentConfig}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Style="{StaticResource AccessTiny}" Text="{x:Bind Endpoint}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Border Grid.Column="4" Padding="8,3" CornerRadius="10" Background="{ThemeResource AccessAccentChipBackgroundBrush}" BorderBrush="{ThemeResource AccessAccentChipBorderBrush}" BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource AccessAccentChipForegroundBrush}" Text="{x:Bind Protocol}" TextTrimming="CharacterEllipsis" />
                                    </Border>
                                    <TextBlock Grid.Column="5" FontSize="11" VerticalAlignment="Center" Text="{x:Bind ConfigFile}" TextTrimming="CharacterEllipsis" />
                                    <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <Button Style="{StaticResource AppRowIconButton}" AutomationProperties.Name="写入应用目标配置" ToolTipService.ToolTip="&#x5199;&#x5165;&#x914D;&#x7F6E;" Click="OnApplyTargetClick">
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8FB;" />
                                        </Button>
                                        <Button Style="{StaticResource AppRowIconButton}" AutomationProperties.Name="还原应用目标配置" ToolTipService.ToolTip="&#x8FD8;&#x539F;&#x914D;&#x7F6E;" Click="OnRestoreTargetClick">
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE777;" />
                                        </Button>
                                        <Button Style="{StaticResource AppRowIconButton}" KeyDown="FlyoutButton_KeyDown" AutomationProperties.Name="打开应用目标操作" ToolTipService.ToolTip="&#x66F4;&#x591A;&#x63A5;&#x5165;&#x64CD;&#x4F5C;">
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE712;" />
                                            <Button.Flyout>
                                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                    <MenuFlyoutItem Text="聊天记录导出" AccessKey="H" Click="OnExportChatHistoryClick" Tag="{Binding}">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE896;" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutItem Text="聊天记录导入" AccessKey="I" Click="OnImportChatHistoryClick">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8B5;" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutItem Text="还原所选配置" AccessKey="R" Click="OnRestoreSelectedMenuClick">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE777;" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutSubItem Text="&#x8BCA;&#x65AD;" AccessKey="D">
                                                        <MenuFlyoutSubItem.Icon>
                                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE9D9;" />
                                                        </MenuFlyoutSubItem.Icon>
                                                        <MenuFlyoutItem Text="&#x5F3A;&#x5236;&#x534F;&#x8BAE;&#x63A2;&#x6D4B;" AccessKey="P" Click="OnProbeProtocolMenuClick" Tag="{Binding}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE9D9;" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem Text="&#x5BA2;&#x6237;&#x7AEF; API &#x8BCA;&#x65AD;" AccessKey="A" Click="OnRunClientApiDiagnosticsMenuClick" Tag="{Binding}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE7C3;" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem Text="&#x540C;&#x6B65;&#x900F;&#x660E;&#x4EE3;&#x7406;&#x5165;&#x53E3;" AccessKey="T" Click="OnUseTransparentProxyMenuClick" Tag="{Binding}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEC27;" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem Text="&#x590D;&#x5236;&#x8BCA;&#x65AD;&#x6458;&#x8981;" AccessKey="C" Click="OnCopyTargetDiagnosticsClick" Tag="{Binding}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8C8;" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                    </MenuFlyoutSubItem>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

                <Grid Grid.Row="1" ColumnSpacing="12" Tag="ResponsiveStack">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="0.72*" />
                    <ColumnDefinition Width="1.28*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource AccessCard}" Padding="14,12">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="14" FontWeight="SemiBold" Text="&#x534F;&#x8BAE;&#x63A2;&#x6D4B;&#x7ED3;&#x679C;" TextTrimming="CharacterEllipsis" />
                                <TextBlock Style="{StaticResource AccessCaption}" Text="{x:Bind ViewModel.ProbeResult, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Style="{StaticResource AccessCaption}" Text="{x:Bind ViewModel.LastWriteTime, Mode=OneWay}" VerticalAlignment="Top" TextTrimming="CharacterEllipsis" />
                        </Grid>

                        <ItemsRepeater Grid.Row="1" ItemsSource="{x:Bind ViewModel.ProtocolProbeRows, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="0" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:ProtocolProbeItem">
                                    <Grid Padding="0,7" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.3*" />
                                            <ColumnDefinition Width="0.85*" />
                                            <ColumnDefinition Width="0.75*" />
                                            <ColumnDefinition Width="1.35*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontSize="12" Text="{x:Bind Protocol}" TextTrimming="CharacterEllipsis" />
                                        <Grid Grid.Column="1">
                                            <TextBlock FontSize="12" Foreground="{ThemeResource AccessAccentChipForegroundBrush}" Text="{x:Bind Result}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind ResultAccentToneVisibility}" />
                                            <TextBlock FontSize="12" Foreground="{ThemeResource AccessHealthyChipForegroundBrush}" Text="{x:Bind Result}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind ResultHealthyToneVisibility}" />
                                            <TextBlock FontSize="12" Foreground="{ThemeResource AccessWarningChipForegroundBrush}" Text="{x:Bind Result}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind ResultWarningToneVisibility}" />
                                            <TextBlock FontSize="12" Foreground="{ThemeResource AccessDangerChipForegroundBrush}" Text="{x:Bind Result}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind ResultDangerToneVisibility}" />
                                        </Grid>
                                        <TextBlock Grid.Column="2" FontSize="12" Text="{x:Bind Latency}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3" Style="{StaticResource AccessTiny}" Text="{x:Bind Request}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <Border Grid.Row="2" Style="{StaticResource AccessSubtleCard}" Padding="12,10">
                            <StackPanel Spacing="6">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="&#x7EFC;&#x5408;&#x5224;&#x5B9A;" TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="9" Height="9" Fill="{ThemeResource AccessHealthyChipForegroundBrush}" VerticalAlignment="Center" />
                                    <TextBlock FontSize="12" MaxWidth="260" Text="&#x5F53;&#x524D;&#x63A5;&#x53E3;&#x9002;&#x5408; Codex&#xFF08;Responses &#x539F;&#x751F;&#xFF09;" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Style="{StaticResource AccessCaption}" Text="Codex &#x5C06;&#x76F4;&#x63A5;&#x901A;&#x8FC7; Responses &#x534F;&#x8BAE;&#x8BBF;&#x95EE;&#xFF0C;&#x65E0;&#x9700;&#x8F6C;&#x6362;&#xFF0C;&#x83B7;&#x5F97;&#x6700;&#x4F73;&#x517C;&#x5BB9;&#x6027;&#x4E0E;&#x6027;&#x80FD;&#x3002;" TextWrapping="Wrap" MaxLines="2" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AccessCard}" Padding="14,12">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel MinWidth="0">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="&#x5199;&#x5165;&#x8FFD;&#x8E2A;" TextTrimming="CharacterEllipsis" />
                            <TextBlock Style="{StaticResource AccessCaption}" Text="{x:Bind ViewModel.SelectedTargetName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <ItemsRepeater Grid.Row="1" ItemsSource="{x:Bind ViewModel.WriteTraceSteps, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="8" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:WriteTraceItem">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="18" Height="18" CornerRadius="9" Background="{ThemeResource AccessAccentChipBackgroundBrush}" BorderBrush="{ThemeResource AccessAccentChipBorderBrush}" BorderThickness="1">
                                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource AccessAccentChipForegroundBrush}" Text="{x:Bind Step}" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="1" MinWidth="0">
                                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Style="{StaticResource AccessTiny}" Text="{x:Bind Detail}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Padding="7,2" CornerRadius="9" Background="{ThemeResource AccessTraceChipBackgroundBrush}" BorderBrush="{ThemeResource AccessTraceChipBorderBrush}" BorderThickness="1" VerticalAlignment="Top">
                                            <Grid>
                                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource AccessAccentChipForegroundBrush}" Text="{x:Bind State}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind AccentToneVisibility}" />
                                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource AccessHealthyChipForegroundBrush}" Text="{x:Bind State}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind HealthyToneVisibility}" />
                                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource AccessWarningChipForegroundBrush}" Text="{x:Bind State}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind WarningToneVisibility}" />
                                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource AccessDangerChipForegroundBrush}" Text="{x:Bind State}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind DangerToneVisibility}" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                        <TextBlock Grid.Row="2" Style="{StaticResource AccessTiny}" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" TextWrapping="Wrap" MaxLines="2" />
                    </Grid>
                </Border>

                <Grid Grid.Column="2" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource AccessCard}" Padding="14,12">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="14" FontWeight="SemiBold" Text="Codex &#x914D;&#x7F6E;&#x6A21;&#x677F; (config.toml)" TextTrimming="CharacterEllipsis" />
                                <CheckBox Grid.Column="1" Style="{StaticResource AccessCompactCheckBox}" Content="&#x4F7F;&#x7528;&#x6A21;&#x677F;" FontSize="11" IsChecked="True" Margin="0,0,10,0" />
                                <Button Grid.Column="2" Padding="9,5"
                                        Command="{x:Bind ViewModel.OpenCodexHistoryMergeReviewCommand}"
                                        AutomationProperties.Name="复核 Codex 历史合并"
                                        ToolTipService.ToolTip="修改本地 Codex 记录前复核 Codex 历史合并选项"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE81C;" />
                                        <TextBlock FontSize="11" MaxWidth="58" Text="历史" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="3" Padding="9,5"
                                        Command="{x:Bind ViewModel.OpenCodexConfigTemplateDialogCommand}"
                                        AutomationProperties.Name="编辑 Codex 配置模板"
                                        ToolTipService.ToolTip="打开高级 Codex 配置模板编辑器">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE70F;" />
                                        <TextBlock FontSize="11" Text="&#x9AD8;&#x7EA7;&#x7F16;&#x8F91;" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Grid Grid.Row="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Padding="10,7" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.05*" />
                                        <ColumnDefinition Width="1.45*" />
                                        <ColumnDefinition Width="1.15*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource AccessCaption}" FontWeight="SemiBold" Text="&#x53C2;&#x6570;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource AccessCaption}" FontWeight="SemiBold" Text="&#x5F53;&#x524D;&#x503C;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource AccessCaption}" FontWeight="SemiBold" Text="&#x8BF4;&#x660E;" TextTrimming="CharacterEllipsis" />
                                </Grid>
                                <ItemsRepeater Grid.Row="1" ItemsSource="{x:Bind ViewModel.TemplateRows, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Vertical" Spacing="0" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ConfigTemplateRow">
                                            <Grid Padding="10,8" ColumnSpacing="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.05*" />
                                                    <ColumnDefinition Width="1.45*" />
                                                    <ColumnDefinition Width="1.15*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock FontSize="11" Text="{x:Bind Parameter}" TextTrimming="CharacterEllipsis" />
                                                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="4" Padding="7,3">
                                                    <TextBlock FontSize="11" Text="{x:Bind Value}" TextTrimming="CharacterEllipsis" />
                                                </Border>
                                                <TextBlock Grid.Column="2" Style="{StaticResource AccessTiny}" Text="{x:Bind Description}" TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource AccessCard}" Padding="14,12">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel MinWidth="0">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="&#x5BA2;&#x6237;&#x7AEF; API &#x8BCA;&#x65AD;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Style="{StaticResource AccessCaption}" Text="{x:Bind ViewModel.ClientApiCheckedAtText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource ToolIconButton}" Command="{x:Bind ViewModel.RunClientApiDiagnosticsCommand}" AutomationProperties.Name="扫描本地客户端 API 接入" ToolTipService.ToolTip="&#x626B;&#x63CF;&#x672C;&#x673A;&#x5BA2;&#x6237;&#x7AEF; API &#x63A5;&#x5165;&#x72B6;&#x6001;">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE9D9;" />
                                        <TextBlock FontSize="11" Text="&#x626B;&#x63CF;" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2" Style="{StaticResource ToolIconButton}" Click="OnOpenEndpointHistoryDialogClick" AutomationProperties.Name="打开接口历史" ToolTipService.ToolTip="&#x6253;&#x5F00;&#x63A5;&#x53E3;&#x5386;&#x53F2;">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE81C;" />
                                        <TextBlock FontSize="11" Text="&#x5386;&#x53F2;" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBlock Grid.Row="1" Style="{StaticResource AccessCaption}" Text="{x:Bind ViewModel.ClientApiSummary, Mode=OneWay}" TextWrapping="Wrap" MaxLines="3" />

                            <ListView Grid.Row="2"
                                      ItemsSource="{x:Bind ViewModel.ClientApiStatusRows, Mode=OneWay}"
                                      SelectionMode="None"
                                      Padding="0"
                                      Margin="0,4,0,0"
                                      MaxHeight="172"
                                      MinWidth="0"
                                      HorizontalAlignment="Stretch"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.HorizontalScrollMode="Disabled">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinHeight" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ClientApiStatusRow">
                                        <Grid Padding="0,7" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" ColumnSpacing="8" MinWidth="0" HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.15*" />
                                                <ColumnDefinition Width="0.82*" />
                                                <ColumnDefinition Width="1.35*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="1" VerticalAlignment="Center" MinWidth="0">
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Style="{StaticResource AccessTiny}" Text="{x:Bind Provider}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Grid Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Border Padding="8,3" CornerRadius="10" Background="{ThemeResource AccessAccentChipBackgroundBrush}" BorderBrush="{ThemeResource AccessAccentChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind StatusAccentToneVisibility}">
                                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource AccessAccentChipForegroundBrush}" Text="{x:Bind AvailabilityText}" TextTrimming="CharacterEllipsis" />
                                                </Border>
                                                <Border Padding="8,3" CornerRadius="10" Background="{ThemeResource AccessHealthyChipBackgroundBrush}" BorderBrush="{ThemeResource AccessHealthyChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind StatusHealthyToneVisibility}">
                                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource AccessHealthyChipForegroundBrush}" Text="{x:Bind AvailabilityText}" TextTrimming="CharacterEllipsis" />
                                                </Border>
                                                <Border Padding="8,3" CornerRadius="10" Background="{ThemeResource AccessWarningChipBackgroundBrush}" BorderBrush="{ThemeResource AccessWarningChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind StatusWarningToneVisibility}">
                                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource AccessWarningChipForegroundBrush}" Text="{x:Bind AvailabilityText}" TextTrimming="CharacterEllipsis" />
                                                </Border>
                                                <Border Padding="8,3" CornerRadius="10" Background="{ThemeResource AccessDangerChipBackgroundBrush}" BorderBrush="{ThemeResource AccessDangerChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind StatusDangerToneVisibility}">
                                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource AccessDangerChipForegroundBrush}" Text="{x:Bind AvailabilityText}" TextTrimming="CharacterEllipsis" />
                                                </Border>
                                            </Grid>
                                            <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center" MinWidth="0" MaxWidth="320">
                                                <TextBlock FontSize="11" FontWeight="SemiBold" Text="{x:Bind BriefResultText}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Style="{StaticResource AccessTiny}" Text="{x:Bind BriefDetailText}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Button Grid.Column="3" Style="{StaticResource AppRowIconButton}" Click="OnOpenClientApiDetailClick" AutomationProperties.Name="打开客户端 API 诊断详细信息" ToolTipService.ToolTip="查看客户端 API 诊断详细信息">
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE946;" />
                                            </Button>
                                            <Button Grid.Column="4" Style="{StaticResource AppRowIconButton}" Click="OnRestoreClientApiClick" IsEnabled="{x:Bind RestoreSupported}" AutomationProperties.Name="还原客户端 API 配置" ToolTipService.ToolTip="{x:Bind RestoreHint}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE777;" />
                                                    <TextBlock FontSize="11" Text="&#x8FD8;&#x539F;" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <TextBlock Grid.Row="3" Style="{StaticResource AccessTiny}" Text="每行仅显示精简诊断结果，完整路径、备注和证据请点右侧详细信息。" TextWrapping="Wrap" MaxLines="2" />
                        </Grid>
                    </Border>

                </Grid>
            </Grid>
        </Grid>
        </ScrollViewer>
    </Grid>
</local:PageBase>




