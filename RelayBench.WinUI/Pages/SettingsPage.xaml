<?xml version="1.0" encoding="utf-8" ?>
<local:PageBase
    x:Class="RelayBench.WinUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RelayBench.WinUI.Pages"
    Background="Transparent">

    <local:PageBase.Resources>
        <ResourceDictionary>
        <ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary x:Key="Light">
                <SolidColorBrush x:Key="SettingsCodePanelBackgroundBrush" Color="#F8FAFC" />
                <SolidColorBrush x:Key="SettingsCodePanelBorderBrush" Color="#CBD5E1" />
                <SolidColorBrush x:Key="SettingsCodePanelForegroundBrush" Color="#166534" />
                <SolidColorBrush x:Key="SettingsHeaderIconBackgroundBrush" Color="#EEF5FF" />
                <SolidColorBrush x:Key="SettingsHeaderIconBorderBrush" Color="#C7DAF8" />
                <SolidColorBrush x:Key="SettingsHeaderIconForegroundBrush" Color="#2563EB" />
                <SolidColorBrush x:Key="SettingsAccentChipBackgroundBrush" Color="#EEF5FF" />
                <SolidColorBrush x:Key="SettingsAccentChipBorderBrush" Color="#C7DAF8" />
                <SolidColorBrush x:Key="SettingsAccentChipForegroundBrush" Color="#2563EB" />
                <SolidColorBrush x:Key="SettingsHealthyChipBackgroundBrush" Color="#ECFDF3" />
                <SolidColorBrush x:Key="SettingsHealthyChipBorderBrush" Color="#BBF7D0" />
                <SolidColorBrush x:Key="SettingsHealthyChipForegroundBrush" Color="#0B7A46" />
                <SolidColorBrush x:Key="SettingsDangerChipBackgroundBrush" Color="#FEF2F2" />
                <SolidColorBrush x:Key="SettingsDangerChipBorderBrush" Color="#FCA5A5" />
                <SolidColorBrush x:Key="SettingsDangerChipForegroundBrush" Color="#A6192E" />
            </ResourceDictionary>
            <ResourceDictionary x:Key="Dark">
                <SolidColorBrush x:Key="SettingsCodePanelBackgroundBrush" Color="#0B1220" />
                <SolidColorBrush x:Key="SettingsCodePanelBorderBrush" Color="#172033" />
                <SolidColorBrush x:Key="SettingsCodePanelForegroundBrush" Color="#C8F7C5" />
                <SolidColorBrush x:Key="SettingsHeaderIconBackgroundBrush" Color="#14213F" />
                <SolidColorBrush x:Key="SettingsHeaderIconBorderBrush" Color="#2F6FED" />
                <SolidColorBrush x:Key="SettingsHeaderIconForegroundBrush" Color="#7CCBFF" />
                <SolidColorBrush x:Key="SettingsAccentChipBackgroundBrush" Color="#102A4A" />
                <SolidColorBrush x:Key="SettingsAccentChipBorderBrush" Color="#34506E" />
                <SolidColorBrush x:Key="SettingsAccentChipForegroundBrush" Color="#7CCBFF" />
                <SolidColorBrush x:Key="SettingsHealthyChipBackgroundBrush" Color="#143827" />
                <SolidColorBrush x:Key="SettingsHealthyChipBorderBrush" Color="#287348" />
                <SolidColorBrush x:Key="SettingsHealthyChipForegroundBrush" Color="#8FF2B6" />
                <SolidColorBrush x:Key="SettingsDangerChipBackgroundBrush" Color="#4A1218" />
                <SolidColorBrush x:Key="SettingsDangerChipBorderBrush" Color="#7F1D1D" />
                <SolidColorBrush x:Key="SettingsDangerChipForegroundBrush" Color="#FDA4AF" />
            </ResourceDictionary>
            <ResourceDictionary x:Key="HighContrast">
                <SolidColorBrush x:Key="SettingsCodePanelBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SettingsCodePanelBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SettingsCodePanelForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SettingsHeaderIconBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SettingsHeaderIconBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SettingsHeaderIconForegroundBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                <SolidColorBrush x:Key="SettingsAccentChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SettingsAccentChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SettingsAccentChipForegroundBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                <SolidColorBrush x:Key="SettingsHealthyChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SettingsHealthyChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SettingsHealthyChipForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SettingsDangerChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SettingsDangerChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SettingsDangerChipForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            </ResourceDictionary>
        </ResourceDictionary.ThemeDictionaries>
        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="SettingsSubtleCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style x:Key="SettingsActionBand" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
        </Style>
        <Style x:Key="SettingsCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="SettingsTiny" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="SettingsSectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="SettingsCompactToggleSwitch" TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="OnContent" Value="" />
            <Setter Property="OffContent" Value="" />
        </Style>
        </ResourceDictionary>
    </local:PageBase.Resources>

    <Grid Padding="20,14,20,18" RowSpacing="10">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="12" IsStaggeringEnabled="True" />
                <RepositionThemeTransition />
            </TransitionCollection>
        </Grid.ChildrenTransitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SettingsActionBand}">
            <Grid ColumnSpacing="12" RowSpacing="8" Tag="ResponsiveStack">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource AppHeaderIcon}" Background="{ThemeResource SettingsHeaderIconBackgroundBrush}" BorderBrush="{ThemeResource SettingsHeaderIconBorderBrush}">
                    <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="22" Foreground="{ThemeResource SettingsHeaderIconForegroundBrush}" Glyph="&#xE713;" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center" MinWidth="0">
                    <Grid ColumnSpacing="8" MinWidth="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="&#x8BBE;&#x7F6E;" TextTrimming="CharacterEllipsis" />
                        <Border Grid.Column="1" Style="{StaticResource AppStatusPill}" Padding="8,3" Background="{ThemeResource SettingsHealthyChipBackgroundBrush}" BorderBrush="{ThemeResource SettingsHealthyChipBorderBrush}">
                            <TextBlock FontSize="11" Foreground="{ThemeResource SettingsHealthyChipForegroundBrush}" MaxWidth="130" Text="{x:Bind ViewModel.ThemeName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </Border>
                    </Grid>
                    <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x5916;&#x89C2;&#x3001;&#x4EE3;&#x7406;&#x3001;&#x6027;&#x80FD;&#x4E0E;&#x6570;&#x636E;&#x4FDD;&#x7559;" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Button Grid.Column="2" Style="{StaticResource AppToolbarButton}" Command="{x:Bind ViewModel.ResetSettingsCommand}" Background="{ThemeResource SettingsDangerChipBackgroundBrush}" BorderBrush="{ThemeResource SettingsDangerChipBorderBrush}" AutomationProperties.Name="閲嶇疆璁剧疆">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource SettingsDangerChipForegroundBrush}" Glyph="&#xE777;" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource SettingsDangerChipForegroundBrush}" Text="&#x91CD;&#x7F6E;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Style="{StaticResource AppIconButton}" KeyDown="FlyoutButton_KeyDown" AutomationProperties.Name="鎵撳紑璁剧疆鎿嶄綔" ToolTipService.ToolTip="&#x66F4;&#x591A;&#x8BBE;&#x7F6E;&#x64CD;&#x4F5C;">
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                            <MenuFlyoutSubItem Text="&#x914D;&#x7F6E;" AccessKey="C">
                                <MenuFlyoutSubItem.Icon>
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE713;" />
                                </MenuFlyoutSubItem.Icon>
                                <MenuFlyoutItem Text="&#x4FDD;&#x5B58;&#x5F53;&#x524D;&#x8BBE;&#x7F6E;" AccessKey="S" Command="{x:Bind ViewModel.SaveSettingsCommand}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE74E;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="&#x6062;&#x590D;&#x9ED8;&#x8BA4;" AccessKey="R" Command="{x:Bind ViewModel.ResetSettingsCommand}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE777;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyoutSubItem>
                            <MenuFlyoutSubItem Text="&#x5FEB;&#x901F;&#x68C0;&#x67E5;" AccessKey="Q">
                                <MenuFlyoutSubItem.Icon>
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE946;" />
                                </MenuFlyoutSubItem.Icon>
                                <MenuFlyoutItem Text="{x:Bind ViewModel.ProxyEndpointText, Mode=OneWay}" AccessKey="P" IsEnabled="False">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEC27;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="{x:Bind ViewModel.PerformanceSummaryText, Mode=OneWay}" AccessKey="M" IsEnabled="False">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE916;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyoutSubItem>
                        </MenuFlyout>
                    </Button.Flyout>
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE712;" />
                </Button>
                <Button Grid.Column="4" Style="{StaticResource AppAccentToolbarButton}" Command="{x:Bind ViewModel.SaveSettingsCommand}" AutomationProperties.Name="淇濆瓨璁剧疆">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE74E;" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Text="&#x4FDD;&#x5B58;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      VerticalScrollMode="Disabled"
                      ZoomMode="Disabled">
        <Grid MinWidth="0" ColumnSpacing="10" Tag="ResponsiveStack">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource SettingsCard}" Padding="14,12">
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x4E3B;&#x9898;" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="{x:Bind ViewModel.ThemeName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Style="{StaticResource SettingsTiny}" Text="WinUI &#x4E3B;&#x9898;" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource SettingsCard}" Padding="14,12" Background="{ThemeResource SettingsAccentChipBackgroundBrush}" BorderBrush="{ThemeResource SettingsAccentChipBorderBrush}">
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x4EE3;&#x7406;&#x5165;&#x53E3;" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{ThemeResource SettingsAccentChipForegroundBrush}" Text="{x:Bind ViewModel.ProxyEndpointText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Style="{StaticResource SettingsTiny}" Text="{x:Bind ViewModel.SystemProxyText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource SettingsCard}" Padding="14,12">
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x6027;&#x80FD;&#x53C2;&#x6570;" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind ViewModel.PerformanceSummaryText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Style="{StaticResource SettingsTiny}" Text="&#x5E76;&#x53D1; / &#x8D85;&#x65F6; / TTL" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource SettingsCard}" Padding="14,12">
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x5907;&#x4EFD;" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{ThemeResource SettingsHealthyChipForegroundBrush}" Text="{x:Bind ViewModel.BackupText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Style="{StaticResource SettingsTiny}" Text="{x:Bind ViewModel.AutoStartText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </Grid>
        </ScrollViewer>

        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      VerticalScrollMode="Disabled"
                      ZoomMode="Disabled">
            <Grid ColumnSpacing="12" MinWidth="0" Tag="ResponsiveStack">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <ScrollViewer HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <Border Style="{StaticResource SettingsCard}" Padding="14,12">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SettingsSectionTitle}" Text="&#x5916;&#x89C2;" TextTrimming="CharacterEllipsis" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x4E3B;&#x9898;" TextTrimming="CharacterEllipsis" />
                                    <ComboBox HorizontalAlignment="Stretch" SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}">
                                        <ComboBoxItem Content="&#x6D45;&#x8272;" />
                                        <ComboBoxItem Content="&#x6DF1;&#x8272;" />
                                        <ComboBoxItem Content="&#x8DDF;&#x968F;&#x7CFB;&#x7EDF;" />
                                    </ComboBox>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource SettingsSubtleCard}" Padding="12,10">
                                    <StackPanel Spacing="3">
                                        <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x5F53;&#x524D;&#x4E3B;&#x9898;" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind ViewModel.ThemeName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}" Padding="14,12">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SettingsSectionTitle}" Text="&#x4EE3;&#x7406;" TextTrimming="CharacterEllipsis" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="170" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x76D1;&#x542C;&#x5730;&#x5740;" TextTrimming="CharacterEllipsis" />
                                    <TextBox Text="{x:Bind ViewModel.ListenAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x7AEF;&#x53E3;" TextTrimming="CharacterEllipsis" />
                                    <NumberBox Value="{x:Bind ViewModel.ListenPort, Mode=TwoWay}" Minimum="1" Maximum="65535" SpinButtonPlacementMode="Compact" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x81EA;&#x52A8;&#x542F;&#x52A8;" TextTrimming="CharacterEllipsis" />
                                    <ToggleSwitch Style="{StaticResource SettingsCompactToggleSwitch}" IsOn="{x:Bind ViewModel.AutoStart, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="4">
                                    <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x7CFB;&#x7EDF;&#x4EE3;&#x7406;" TextTrimming="CharacterEllipsis" />
                                    <ToggleSwitch Style="{StaticResource SettingsCompactToggleSwitch}" IsOn="{x:Bind ViewModel.SystemProxy, Mode=TwoWay}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}" Padding="14,12">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SettingsSectionTitle}" Text="&#x6027;&#x80FD;" TextTrimming="CharacterEllipsis" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x6700;&#x5927;&#x5E76;&#x53D1;" TextTrimming="CharacterEllipsis" />
                                    <NumberBox Value="{x:Bind ViewModel.MaxConcurrency, Mode=TwoWay}" Minimum="1" Maximum="256" SpinButtonPlacementMode="Compact" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x8BF7;&#x6C42;&#x8D85;&#x65F6; (s)" TextTrimming="CharacterEllipsis" />
                                    <NumberBox Value="{x:Bind ViewModel.RequestTimeout, Mode=TwoWay}" Minimum="1" Maximum="300" SpinButtonPlacementMode="Compact" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x7F13;&#x5B58; TTL (s)" TextTrimming="CharacterEllipsis" />
                                    <NumberBox Value="{x:Bind ViewModel.CacheTtl, Mode=TwoWay}" Minimum="0" Maximum="86400" SpinButtonPlacementMode="Compact" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}" Padding="14,12">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SettingsSectionTitle}" Text="&#x6570;&#x636E;" TextTrimming="CharacterEllipsis" />
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x6570;&#x636E;&#x76EE;&#x5F55;" TextTrimming="CharacterEllipsis" />
                                <TextBox Text="{x:Bind ViewModel.DataDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x81EA;&#x52A8;&#x5907;&#x4EFD;" TextTrimming="CharacterEllipsis" />
                                    <ToggleSwitch Style="{StaticResource SettingsCompactToggleSwitch}" IsOn="{x:Bind ViewModel.AutoBackup, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x4FDD;&#x7559;&#x5929;&#x6570;" TextTrimming="CharacterEllipsis" />
                                    <NumberBox Value="{x:Bind ViewModel.RetentionDays, Mode=TwoWay}" Minimum="1" Maximum="365" SpinButtonPlacementMode="Compact" />
                                </StackPanel>
                                <Border Grid.Column="2" Style="{StaticResource SettingsSubtleCard}" Padding="12,10">
                                    <StackPanel Spacing="3">
                                        <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x4FDD;&#x7559;&#x7B56;&#x7565;" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind ViewModel.BackupText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Column="1" Spacing="10">
                <Border Style="{StaticResource SettingsCard}" Padding="14,12">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource SettingsSectionTitle}" Text="&#x8FD0;&#x884C;&#x72B6;&#x6001;" TextTrimming="CharacterEllipsis" />
                        <Grid RowSpacing="8" ColumnSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="108" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SettingsCaption}" Text="&#x4E3B;&#x9898;" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Text="{x:Bind ViewModel.ThemeName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="1" Style="{StaticResource SettingsCaption}" Text="&#x4EE3;&#x7406;" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="1" Grid.Column="1" FontSize="12" Text="{x:Bind ViewModel.ProxyEndpointText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="2" Style="{StaticResource SettingsCaption}" Text="&#x7CFB;&#x7EDF;&#x4EE3;&#x7406;" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="2" Grid.Column="1" FontSize="12" Text="{x:Bind ViewModel.SystemProxyText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="3" Style="{StaticResource SettingsCaption}" Text="&#x5907;&#x4EFD;" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="3" Grid.Column="1" FontSize="12" Text="{x:Bind ViewModel.BackupText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}" Padding="14,12">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource SettingsSectionTitle}" Text="&#x914D;&#x7F6E;&#x6458;&#x8981;" TextTrimming="CharacterEllipsis" />
                        <Border Padding="12,10" CornerRadius="7" Background="{ThemeResource SettingsCodePanelBackgroundBrush}" BorderBrush="{ThemeResource SettingsCodePanelBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="5">
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource SettingsCodePanelForegroundBrush}" Text="{x:Bind ViewModel.ProxyEndpointText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource SettingsCodePanelForegroundBrush}" Text="{x:Bind ViewModel.PerformanceSummaryText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource SettingsCodePanelForegroundBrush}" Text="{x:Bind ViewModel.DataDirectory, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <InfoBar
                    IsOpen="{x:Bind ViewModel.IsErrorVisible, Mode=OneWay}"
                    Severity="Error"
                    Title="&#x5199;&#x5165;&#x5931;&#x8D25;"
                    Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    IsClosable="True" />

                <Border Style="{StaticResource SettingsCard}" Padding="14,12">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource SettingsSectionTitle}" Text="&#x4FDD;&#x5B58;&#x72B6;&#x6001;" TextTrimming="CharacterEllipsis" />
                        <Border Padding="10,8" CornerRadius="7" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <TextBlock FontSize="12" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" TextWrapping="Wrap" MaxLines="2" />
                        </Border>
                        <Button Style="{StaticResource AppAccentToolbarButton}" Command="{x:Bind ViewModel.SaveSettingsCommand}" HorizontalAlignment="Stretch" AutomationProperties.Name="淇濆瓨褰撳墠璁剧疆">
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE74E;" />
                                <TextBlock FontSize="12" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Text="&#x4FDD;&#x5B58;&#x8BBE;&#x7F6E;" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
        </ScrollViewer>
    </Grid>
</local:PageBase>


