                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource ReviewAccentChipForegroundBrush}" Glyph="&#xE72C;" />
                        <TextBlock FontSize="12" Text="&#x5237;&#x65B0;&#x5FEB;&#x7167;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="12,0,0,0">
