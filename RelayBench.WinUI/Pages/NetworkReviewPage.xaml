                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="106" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Style="{StaticResource ReviewCaption}" Text="目标" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" FontSize="12" Text="{x:Bind ViewModel.PortScanTarget, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="1" Style="{StaticResource ReviewCaption}" Text="配置档" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" FontSize="12" Text="{x:Bind ViewModel.PortScanSelectedProfileIndex, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="2" Style="{StaticResource ReviewCaption}" Text="自定义" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" FontSize="12" Text="{x:Bind ViewModel.PortScanCustomPorts, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource ReviewCard}" Padding="14,12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Style="{StaticResource ReviewSectionTitle}" Text="&#x590D;&#x6838;&#x5EFA;&#x8BAE;" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="13" Text="&#x82E5;&#x547D;&#x4E2D;&#x975E; HTTPS / HTTP &#x7AEF;&#x53E3;&#xFF0C;&#x5EFA;&#x8BAE;&#x7ACB;&#x5373;&#x68C0;&#x67E5;&#x8DEF;&#x7531;&#x89C4;&#x5219;&#x548C;&#x4EE3;&#x7406;&#x51FA;&#x53E3;&#x7B56;&#x7565;&#x3002;" TextWrapping="Wrap" MaxLines="3" />
                                        <Button Padding="10,7" Command="{x:Bind ViewModel.RunIpRiskReviewCommand}" HorizontalAlignment="Stretch"
                                                AutomationProperties.Name="打开当前出口 IP 风险复核"
                                                ToolTipService.ToolTip="打开当前出口 IP 风险复核">
                                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource ReviewAccentChipForegroundBrush}" Glyph="&#xE9D9;" />
                                                <TextBlock Text="&#x8F6C;&#x5230;&#x98CE;&#x9669;&#x590D;&#x6838;" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                                <!-- Batch Scan & Export -->
                                <Border Style="{StaticResource ReviewCard}" Padding="14,12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Style="{StaticResource ReviewSectionTitle}" Text="&#x6279;&#x91CF;&#x626B;&#x63CF;" TextTrimming="CharacterEllipsis" />
                                        <TextBox PlaceholderText="&#x6BCF;&#x884C;&#x4E00;&#x4E2A;&#x76EE;&#x6807;&#xFF08;&#x57DF;&#x540D;&#x6216; IP&#xFF09;" Text="{x:Bind ViewModel.PortScanBatchTargets, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" MaxHeight="120" FontSize="12" />
                                        <Button Padding="10,7" Command="{x:Bind ViewModel.RunPortScanBatchCommand}" HorizontalAlignment="Stretch"
                                                AutomationProperties.Name="运行批量端口扫描"
                                                ToolTipService.ToolTip="运行批量端口扫描">
                                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Foreground="{ThemeResource ReviewAccentChipForegroundBrush}" Glyph="&#xE768;" />
                                                <TextBlock FontSize="12" Text="&#x6267;&#x884C;&#x6279;&#x91CF;&#x626B;&#x63CF;" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Button>
                                        <ProgressRing Width="20" Height="20" IsActive="{x:Bind ViewModel.IsPortScanBatchRunning, Mode=OneWay}" HorizontalAlignment="Left" />
                                        <TextBlock Style="{StaticResource ReviewTiny}" Text="{x:Bind ViewModel.PortScanBatchSummary, Mode=OneWay}" TextWrapping="Wrap" MaxLines="2" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Padding="8,6" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.ExportPortScanCsvCommand}"
                                                    ToolTipService.ToolTip="导出端口扫描 CSV">
                                                <TextBlock FontSize="12" Text="&#x5BFC;&#x51FA; CSV" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            </Button>
                                            <Button Grid.Column="1" Padding="8,6" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.ExportPortScanExcelCommand}"
                                                    ToolTipService.ToolTip="导出端口扫描 Excel">
                                                <TextBlock FontSize="12" Text="&#x5BFC;&#x51FA; Excel" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            </Button>
                                        </Grid>
                                        <TextBlock Style="{StaticResource ReviewTiny}" Foreground="{ThemeResource ReviewAccentChipForegroundBrush}" Text="{x:Bind ViewModel.PortScanExportStatus, Mode=OneWay}" TextWrapping="Wrap" MaxLines="2" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </PivotItem>

            <PivotItem>
                <PivotItem.Header>
                    <TextBlock MinWidth="104" Text="&#x98CE;&#x9669;&#x590D;&#x6838;" TextWrapping="NoWrap" />
                </PivotItem.Header>
                <ScrollViewer Padding="8,8,8,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Disabled">
                    <Grid RowSpacing="10" MinWidth="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource ReviewActionBand}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="IP &#x98CE;&#x9669;&#x590D;&#x6838;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Style="{StaticResource ReviewCaption}" Text="&#x805A;&#x5408;&#x591A;&#x4E2A;&#x60C5;&#x62A5;&#x6E90;&#xFF0C;&#x8BC6;&#x522B;&#x6570;&#x636E;&#x4E2D;&#x5FC3;&#x3001;&#x4EE3;&#x7406;&#x3001;VPN&#x3001;Tor &#x548C;&#x6EE5;&#x7528;&#x98CE;&#x9669;" TextTrimming="CharacterEllipsis" />
                                    <TextBox Margin="0,6,0,0"
                                             PlaceholderText="&#x53EF;&#x9009;&#xFF1A;&#x6307;&#x5B9A;&#x8981;&#x590D;&#x6838;&#x7684; IP&#xFF0C;&#x7559;&#x7A7A;&#x5219;&#x4F7F;&#x7528;&#x5F53;&#x524D;&#x51FA;&#x53E3;"
                                             Text="{x:Bind ViewModel.IpRiskTargetAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource AppAccentToolbarButton}" Command="{x:Bind ViewModel.RunIpRiskReviewCommand}"
                                        AutomationProperties.Name="运行 IP 风险复核"
                                        ToolTipService.ToolTip="运行 IP 风险复核">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE9D9;" />
                                        <TextBlock Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Text="&#x8BC4;&#x4F30;" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                                <ProgressRing Grid.Column="2" Width="28" Height="28" VerticalAlignment="Center" IsActive="{x:Bind ViewModel.IsIpRiskRunning, Mode=OneWay}" />
                            </Grid>
                        </Border>

                        <TextBlock Grid.Row="1" Foreground="{ThemeResource ReviewDangerChipForegroundBrush}" Text="{x:Bind ViewModel.IpRiskError, Mode=OneWay}" TextWrapping="Wrap" MaxLines="2" Visibility="{x:Bind ViewModel.HasIpRiskError, Mode=OneWay}" />

                        <Grid Grid.Row="2" ColumnSpacing="10" Tag="ResponsiveStack">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource ReviewCard}" Padding="16,14">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="64" Height="64" CornerRadius="32" BorderBrush="{ThemeResource ReviewIpRiskRingStrokeBrush}" BorderThickness="6" Background="{ThemeResource ReviewIpRiskRingBackgroundBrush}">
                                        <TextBlock FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Bind ViewModel.IpRiskScore, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource ReviewCaption}" Text="&#x98CE;&#x9669;&#x5206;" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{ThemeResource ReviewHealthyChipForegroundBrush}" Text="{x:Bind ViewModel.IpRiskScoreLabel, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Style="{StaticResource ReviewTiny}" Text="{x:Bind ViewModel.LastRiskReviewText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource ReviewCard}" Padding="16,14">
                                <StackPanel Spacing="4">
                                    <TextBlock Style="{StaticResource ReviewCaption}" Text="&#x7ED3;&#x8BBA;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="{x:Bind ViewModel.IpRiskVerdict, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Style="{StaticResource ReviewTiny}" Text="{x:Bind ViewModel.IpRiskPublicIp, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource ReviewCard}" Padding="16,14">
                                <StackPanel Spacing="4">
                                    <TextBlock Style="{StaticResource ReviewCaption}" Text="&#x5730;&#x57DF;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="{x:Bind ViewModel.IpRiskCountry, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Style="{StaticResource ReviewTiny}" Text="{x:Bind ViewModel.PublicIpCountry, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Style="{StaticResource ReviewCard}" Padding="16,14">
                                <StackPanel Spacing="4">
                                    <TextBlock Style="{StaticResource ReviewCaption}" Text="&#x7EC4;&#x7EC7;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="{x:Bind ViewModel.IpRiskOrganization, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Style="{StaticResource ReviewTiny}" Text="{x:Bind ViewModel.PublicIpAsn, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="3" ColumnSpacing="10" Tag="ResponsiveStack">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.45*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource ReviewCard}" Padding="14,12">
                                <Grid RowSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Style="{StaticResource ReviewSectionTitle}" Text="&#x60C5;&#x62A5;&#x6E90;&#x660E;&#x7EC6;" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Style="{StaticResource ReviewCaption}" Text="{x:Bind ViewModel.IpRiskSummary, Mode=OneWay}" TextWrapping="Wrap" MaxLines="3" />
                                    </StackPanel>
                                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.IpRiskSources, Mode=OneWay}" SelectionMode="None" MaxHeight="440" ItemContainerStyle="{StaticResource ReviewListItemCompact}">
                                        <ListView.Header>
                                            <Grid ColumnSpacing="8" Padding="8,0,8,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="96" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource ReviewTableHeader}" Text="来源" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Style="{StaticResource ReviewTableHeader}" Text="判定" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2" Style="{StaticResource ReviewTableHeader}" Text="评分" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="3" Style="{StaticResource ReviewTableHeader}" Text="ASN" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="4" Style="{StaticResource ReviewTableHeader}" Text="摘要" TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </ListView.Header>
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="models:ExitIpRiskSourceResult">
                                                <Grid ColumnSpacing="8" Padding="8,7">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150" />
                                                        <ColumnDefinition Width="96" />
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{x:Bind Verdict}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="2" Text="{x:Bind RiskScore}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="3" Text="{x:Bind Asn}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="4" Text="{x:Bind Summary}" TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="10">
                                <Border Style="{StaticResource ReviewCard}" Padding="14,12">
                                    <StackPanel Spacing="10">
                                        <TextBlock Style="{StaticResource ReviewSectionTitle}" Text="&#x98CE;&#x9669;&#x4FE1;&#x53F7;" TextTrimming="CharacterEllipsis" />
                                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.IpRiskSignals, Mode=OneWay}">
                                            <ItemsRepeater.Layout>
                                                <StackLayout Spacing="7" />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="x:String">
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="18" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Foreground="{ThemeResource ReviewWarningChipForegroundBrush}" Glyph="&#xE7BA;" />
                                                        <TextBlock Grid.Column="1" FontSize="12" Text="{x:Bind}" TextWrapping="Wrap" MaxLines="2" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource ReviewCard}" Padding="14,12">
                                    <StackPanel Spacing="10">
                                        <TextBlock Style="{StaticResource ReviewSectionTitle}" Text="&#x6B63;&#x9762;&#x4FE1;&#x53F7;" TextTrimming="CharacterEllipsis" />
                                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.IpRiskPositiveSignals, Mode=OneWay}">
                                            <ItemsRepeater.Layout>
                                                <StackLayout Spacing="7" />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="x:String">
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="18" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Foreground="{ThemeResource ReviewHealthyChipForegroundBrush}" Glyph="&#xE73E;" />
                                                        <TextBlock Grid.Column="1" FontSize="12" Text="{x:Bind}" TextWrapping="Wrap" MaxLines="2" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource ReviewCard}" Padding="14,12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Style="{StaticResource ReviewSectionTitle}" Text="&#x5FEB;&#x901F;&#x64CD;&#x4F5C;" TextTrimming="CharacterEllipsis" />
                                        <Button Padding="10,7" Command="{x:Bind ViewModel.RunWebApiTraceCommand}" HorizontalAlignment="Stretch"
                                                AutomationProperties.Name="重新验证出口 IP"
                                                ToolTipService.ToolTip="重新验证出口 IP">
                                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource ReviewAccentChipForegroundBrush}" Glyph="&#xE774;" />
                                                <TextBlock Text="&#x91CD;&#x65B0;&#x6838;&#x5BF9;&#x51FA;&#x53E3;" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Button>
                                        <Button Padding="10,7" Command="{x:Bind ViewModel.ExportNetworkSnapshotCommand}" HorizontalAlignment="Stretch"
                                                AutomationProperties.Name="导出当前网络复核报告"
                                                ToolTipService.ToolTip="导出当前网络复核报告">
                                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource ReviewAccentChipForegroundBrush}" Glyph="&#xE896;" />
                                                <TextBlock Text="&#x5BFC;&#x51FA;&#x62A5;&#x544A;" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </PivotItem>
        </Pivot>
    </Grid>
</local:PageBase>



