<?xml version="1.0" encoding="utf-8" ?>
<local:PageBase
    x:Class="RelayBench.WinUI.Pages.BatchComparisonPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RelayBench.WinUI.Pages"
    xmlns:vm="using:RelayBench.WinUI.ViewModels"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:converters="using:RelayBench.WinUI.Converters"
    Background="Transparent">

    <local:PageBase.Resources>
        <ResourceDictionary>
        <ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary x:Key="Light">
                <SolidColorBrush x:Key="BatchHeaderIconBackgroundBrush" Color="#EEF5FF" />
                <SolidColorBrush x:Key="BatchHeaderIconBorderBrush" Color="#C7DAF8" />
                <SolidColorBrush x:Key="BatchHeaderIconForegroundBrush" Color="#2563EB" />
                <SolidColorBrush x:Key="BatchAccentChipBackgroundBrush" Color="#EEF5FF" />
                <SolidColorBrush x:Key="BatchAccentChipBorderBrush" Color="#C7DAF8" />
                <SolidColorBrush x:Key="BatchAccentChipForegroundBrush" Color="#2563EB" />
                <SolidColorBrush x:Key="BatchHealthyChipBackgroundBrush" Color="#ECFDF3" />
                <SolidColorBrush x:Key="BatchHealthyChipBorderBrush" Color="#BBF7D0" />
                <SolidColorBrush x:Key="BatchHealthyChipForegroundBrush" Color="#0B7A46" />
                <SolidColorBrush x:Key="BatchWarningChipBackgroundBrush" Color="#FFF7E6" />
                <SolidColorBrush x:Key="BatchWarningChipBorderBrush" Color="#F2C46D" />
                <SolidColorBrush x:Key="BatchWarningChipForegroundBrush" Color="#8A4B00" />
                <SolidColorBrush x:Key="BatchDangerChipBackgroundBrush" Color="#FEF2F2" />
                <SolidColorBrush x:Key="BatchDangerChipBorderBrush" Color="#FCA5A5" />
                <SolidColorBrush x:Key="BatchDangerChipForegroundBrush" Color="#B42318" />
                <SolidColorBrush x:Key="BatchMutedChipBackgroundBrush" Color="#F8FAFC" />
                <SolidColorBrush x:Key="BatchMutedChipBorderBrush" Color="#CBD5E1" />
                <SolidColorBrush x:Key="BatchMutedChipForegroundBrush" Color="#475569" />
                <SolidColorBrush x:Key="BatchChartGridBrush" Color="#CBD5E1" />
                <SolidColorBrush x:Key="BatchCompositeSuccessLineBrush" Color="#0B7A46" />
                <SolidColorBrush x:Key="BatchCompositeThroughputLineBrush" Color="#0E7490" />
                <SolidColorBrush x:Key="BatchHeatmapEmptyBrush" Color="#E2E8F0" />
                <SolidColorBrush x:Key="BatchHeatmapHealthyBrush" Color="#18A058" />
                <SolidColorBrush x:Key="BatchHeatmapWarningBrush" Color="#D97706" />
                <SolidColorBrush x:Key="BatchHeatmapDangerBrush" Color="#DC2626" />
            </ResourceDictionary>
            <ResourceDictionary x:Key="Dark">
                <SolidColorBrush x:Key="BatchHeaderIconBackgroundBrush" Color="#14213F" />
                <SolidColorBrush x:Key="BatchHeaderIconBorderBrush" Color="#2F6FED" />
                <SolidColorBrush x:Key="BatchHeaderIconForegroundBrush" Color="#7CCBFF" />
                <SolidColorBrush x:Key="BatchAccentChipBackgroundBrush" Color="#102A4A" />
                <SolidColorBrush x:Key="BatchAccentChipBorderBrush" Color="#34506E" />
                <SolidColorBrush x:Key="BatchAccentChipForegroundBrush" Color="#7CCBFF" />
                <SolidColorBrush x:Key="BatchHealthyChipBackgroundBrush" Color="#143827" />
                <SolidColorBrush x:Key="BatchHealthyChipBorderBrush" Color="#2D8D62" />
                <SolidColorBrush x:Key="BatchHealthyChipForegroundBrush" Color="#8FF2B6" />
                <SolidColorBrush x:Key="BatchWarningChipBackgroundBrush" Color="#4A3210" />
                <SolidColorBrush x:Key="BatchWarningChipBorderBrush" Color="#8A5A14" />
                <SolidColorBrush x:Key="BatchWarningChipForegroundBrush" Color="#FFC36D" />
                <SolidColorBrush x:Key="BatchDangerChipBackgroundBrush" Color="#4A1218" />
                <SolidColorBrush x:Key="BatchDangerChipBorderBrush" Color="#8A2632" />
                <SolidColorBrush x:Key="BatchDangerChipForegroundBrush" Color="#FDA4AF" />
                <SolidColorBrush x:Key="BatchMutedChipBackgroundBrush" Color="#111827" />
                <SolidColorBrush x:Key="BatchMutedChipBorderBrush" Color="#334155" />
                <SolidColorBrush x:Key="BatchMutedChipForegroundBrush" Color="#CBD5E1" />
                <SolidColorBrush x:Key="BatchChartGridBrush" Color="#263247" />
                <SolidColorBrush x:Key="BatchCompositeSuccessLineBrush" Color="#8FF2B6" />
                <SolidColorBrush x:Key="BatchCompositeThroughputLineBrush" Color="#7DE3DE" />
                <SolidColorBrush x:Key="BatchHeatmapEmptyBrush" Color="#263247" />
                <SolidColorBrush x:Key="BatchHeatmapHealthyBrush" Color="#8FF2B6" />
                <SolidColorBrush x:Key="BatchHeatmapWarningBrush" Color="#FFC36D" />
                <SolidColorBrush x:Key="BatchHeatmapDangerBrush" Color="#FDA4AF" />
            </ResourceDictionary>
            <ResourceDictionary x:Key="HighContrast">
                <SolidColorBrush x:Key="BatchHeaderIconBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="BatchHeaderIconBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="BatchHeaderIconForegroundBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                <SolidColorBrush x:Key="BatchAccentChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="BatchAccentChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="BatchAccentChipForegroundBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                <SolidColorBrush x:Key="BatchHealthyChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="BatchHealthyChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="BatchHealthyChipForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="BatchWarningChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="BatchWarningChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="BatchWarningChipForegroundBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                <SolidColorBrush x:Key="BatchDangerChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="BatchDangerChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="BatchDangerChipForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="BatchMutedChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="BatchMutedChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="BatchMutedChipForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="BatchChartGridBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="BatchCompositeSuccessLineBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="BatchCompositeThroughputLineBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                <SolidColorBrush x:Key="BatchHeatmapEmptyBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="BatchHeatmapHealthyBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="BatchHeatmapWarningBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                <SolidColorBrush x:Key="BatchHeatmapDangerBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            </ResourceDictionary>
        </ResourceDictionary.ThemeDictionaries>

        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />

        <Style x:Key="BatchCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="BatchSubtleCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
        </Style>

        <Style x:Key="BatchHeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="BatchCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="BatchTiny" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="BatchToolbarButton" TargetType="Button" BasedOn="{StaticResource AppToolbarButton}" />

        <Style x:Key="BatchIconButton" TargetType="Button" BasedOn="{StaticResource AppRowIconButton}" />

        <Style x:Key="BatchModeToggle" TargetType="ToggleButton" BasedOn="{StaticResource AppModeToggle}" />

        <Style x:Key="BatchModeRadio" TargetType="RadioButton" BasedOn="{StaticResource AppModeRadio}" />

        <Style x:Key="BatchCellTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        </ResourceDictionary>
    </local:PageBase.Resources>

    <Grid Padding="10,8,10,10" RowSpacing="8">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="12" IsStaggeringEnabled="True" />
                <RepositionThemeTransition />
            </TransitionCollection>
        </Grid.ChildrenTransitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource BatchCard}" Padding="12,8">
            <Grid ColumnSpacing="10" RowSpacing="8" Tag="ResponsiveStack">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid MinWidth="0" ColumnSpacing="10" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource AppHeaderIcon}" Background="{ThemeResource BatchHeaderIconBackgroundBrush}" BorderBrush="{ThemeResource BatchHeaderIconBorderBrush}">
                        <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="20" Foreground="{ThemeResource BatchHeaderIconForegroundBrush}" Glyph="&#xE9D5;" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" MinWidth="0">
                        <Grid ColumnSpacing="8" MinWidth="0" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="&#x6279;&#x91CF;&#x8BC4;&#x6D4B;" TextTrimming="CharacterEllipsis" />
                            <Border Grid.Column="1" Style="{StaticResource AppStatusPill}" Padding="8,3" Background="{ThemeResource BatchAccentChipBackgroundBrush}" BorderBrush="{ThemeResource BatchAccentChipBorderBrush}">
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource BatchAccentChipForegroundBrush}" MaxWidth="120" Text="{x:Bind ViewModel.ProgressDisplay, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource AppStatusPill}" Padding="8,3" Background="{ThemeResource BatchHealthyChipBackgroundBrush}" BorderBrush="{ThemeResource BatchHealthyChipBorderBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="7" Height="7" Fill="{ThemeResource BatchHealthyChipForegroundBrush}" VerticalAlignment="Center" />
                                    <TextBlock FontSize="11" Foreground="{ThemeResource BatchHealthyChipForegroundBrush}" MaxWidth="130" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <TextBlock Style="{StaticResource BatchCaption}" Text="&#x6807;&#x51C6;&#x5316;&#x57FA;&#x51C6;&#x3001;&#x534F;&#x8BAE;&#x3001;&#x541E;&#x5410;&#x548C;&#x7A33;&#x5B9A;&#x6027;&#x7EFC;&#x5408;&#x8BC4;&#x4F30;" TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                            <Border Padding="8,4" CornerRadius="12" Background="{ThemeResource BatchMutedChipBackgroundBrush}" BorderBrush="{ThemeResource BatchMutedChipBorderBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Style="{StaticResource BatchTiny}" Text="&#x5206;&#x7EC4;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource BatchMutedChipForegroundBrush}" MaxWidth="48" Text="{x:Bind SiteEditor.GroupCount, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <Border Padding="8,4" CornerRadius="12" Background="{ThemeResource BatchMutedChipBackgroundBrush}" BorderBrush="{ThemeResource BatchMutedChipBorderBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Style="{StaticResource BatchTiny}" Text="&#x53EF;&#x8FD0;&#x884C;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource BatchMutedChipForegroundBrush}" MaxWidth="48" Text="{x:Bind SiteEditor.ReadyIncludedCount, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <Border Padding="8,4" CornerRadius="12" Background="{ThemeResource BatchWarningChipBackgroundBrush}" BorderBrush="{ThemeResource BatchWarningChipBorderBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock FontSize="10" Foreground="{ThemeResource BatchWarningChipForegroundBrush}" Text="&#x7F3A; Key" TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource BatchWarningChipForegroundBrush}" MaxWidth="48" Text="{x:Bind SiteEditor.MissingKeyCount, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Column="1"
                              MaxWidth="640"
                              HorizontalAlignment="Right"
                              HorizontalScrollBarVisibility="Auto"
                              HorizontalScrollMode="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              VerticalScrollMode="Disabled"
                              ZoomMode="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Border Padding="3" CornerRadius="9" Background="{ThemeResource BatchMutedChipBackgroundBrush}" BorderBrush="{ThemeResource BatchMutedChipBorderBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <RadioButton GroupName="BatchRunMode"
                                         Style="{StaticResource BatchModeRadio}"
                                         IsChecked="{x:Bind ViewModel.IsQuickRunMode, Mode=OneWay}"
                                         IsEnabled="{x:Bind ViewModel.CanChangeRunMode, Mode=OneWay}"
                                         Command="{x:Bind ViewModel.UseQuickRunModeCommand}"
                                         AutomationProperties.Name="使用快速批量测试模式">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE945;" />
                                    <TextBlock Text="&#x5FEB;&#x901F;&#x6D4B;&#x8BD5;" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="BatchRunMode"
                                         Style="{StaticResource BatchModeRadio}"
                                         IsChecked="{x:Bind ViewModel.IsDeepRunMode, Mode=OneWay}"
                                         IsEnabled="{x:Bind ViewModel.CanChangeRunMode, Mode=OneWay}"
                                         Command="{x:Bind ViewModel.UseDeepRunModeCommand}"
                                         AutomationProperties.Name="使用深度批量测试模式">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE9D9;" />
                                    <TextBlock Text="&#x6DF1;&#x5EA6;&#x6D4B;&#x8BD5;" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource BatchToolbarButton}" Command="{x:Bind ViewModel.OpenProxyBatchEditorCommand}" AutomationProperties.Name="打开批量入口组编辑器" ToolTipService.ToolTip="&#x6253;&#x5F00;&#x6279;&#x91CF;&#x7AD9;&#x70B9;&#x7F16;&#x8F91;&#x5668;">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource BatchAccentChipForegroundBrush}" Glyph="&#xE8B5;" />
                            <TextBlock FontSize="12" Foreground="{ThemeResource BatchAccentChipForegroundBrush}" Text="&#x5165;&#x53E3;&#x7EC4;&#x7EF4;&#x62A4;" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource AppAccentToolbarButton}" Command="{x:Bind ViewModel.RunProxyBatchCommand}" AutomationProperties.Name="运行批量对比" ToolTipService.ToolTip="&#x8FD0;&#x884C;&#x6279;&#x91CF;&#x6BD4;&#x8F83;">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE768;" />
                            <TextBlock FontSize="12" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" MaxWidth="126" Text="{x:Bind ViewModel.StartBatchButtonText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource BatchToolbarButton}" Command="{x:Bind ViewModel.StopBatchCommand}" AutomationProperties.Name="停止批量对比" ToolTipService.ToolTip="&#x505C;&#x6B62;&#x5F53;&#x524D;&#x6279;&#x91CF;&#x4EFB;&#x52A1;">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource BatchDangerChipForegroundBrush}" Glyph="&#xE71A;" />
                            <TextBlock FontSize="12" Foreground="{ThemeResource BatchDangerChipForegroundBrush}" Text="&#x505C;&#x6B62;" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      VerticalScrollMode="Disabled"
                      ZoomMode="Disabled">
            <Grid MinWidth="1180" ColumnSpacing="10" Tag="ResponsiveStack">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="305" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="8">
                    <Grid ColumnSpacing="8" Tag="ResponsiveStack">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.78*" />
                            <ColumnDefinition Width="1.22*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource BatchCard}" Padding="0">
                            <Grid RowSpacing="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid Padding="14,11" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Style="{StaticResource BatchHeaderText}" Text="&#x5165;&#x53E3;&#x7EC4;&#x5217;&#x8868;" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Style="{StaticResource BatchCaption}" Text="{x:Bind SiteEditor.EditorSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="1" Padding="10,6" Background="{ThemeResource BatchMutedChipBackgroundBrush}" ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="66" />
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="82" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource BatchCaption}" Text="&#x7AD9;&#x70B9;&#x7EC4;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource BatchCaption}" Text="&#x53EF;&#x6D4B;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource BatchCaption}" Text="&#x72B6;&#x6001;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3" Style="{StaticResource BatchCaption}" Text="&#x6A21;&#x578B;" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="4" Style="{StaticResource BatchCaption}" Text="&#x534F;&#x8BAE;" TextTrimming="CharacterEllipsis" />
                                </Grid>
                                <ItemsRepeater Grid.Row="2" ItemsSource="{x:Bind SiteEditor.SiteGroups, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Vertical" Spacing="0" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:BatchSiteGroupSummary">
                                            <Grid Padding="9,7,10,7" ColumnSpacing="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource BatchMutedChipBorderBrush}" BorderThickness="0,0,0,1" IsTabStop="True" KeyDown="SiteGroup_KeyDown" Tapped="SiteGroup_Tapped" AutomationProperties.Name="{x:Bind Name, Mode=OneWay}" AutomationProperties.LocalizedControlType="站点组行" AutomationProperties.HelpText="{x:Bind Tooltip, Mode=OneWay}" ToolTipService.ToolTip="{x:Bind Tooltip, Mode=OneWay}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="4" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="66" />
                                                    <ColumnDefinition Width="92" />
                                                    <ColumnDefinition Width="82" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.ColumnSpan="6" Background="{ThemeResource BatchAccentChipBackgroundBrush}" BorderBrush="{ThemeResource BatchAccentChipBorderBrush}" BorderThickness="1" Opacity="0.64" Visibility="{x:Bind SelectedVisibility, Mode=OneWay}" />
                                                <Border Grid.ColumnSpan="6" Background="{ThemeResource BatchMutedChipBackgroundBrush}" BorderBrush="{ThemeResource BatchMutedChipBorderBrush}" BorderThickness="1" Opacity="0.44" Visibility="{x:Bind PlaceholderVisibility, Mode=OneWay}" />
                                                <Border Width="3" CornerRadius="2" Background="{ThemeResource BatchAccentChipForegroundBrush}" Opacity="{x:Bind SelectionMarkerOpacity, Mode=OneWay}" />
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <Grid ColumnSpacing="6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid>
                                                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource BatchAccentChipForegroundBrush}" Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind SelectedVisibility, Mode=OneWay}" />
                                                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind NormalVisibility, Mode=OneWay}" />
                                                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind PlaceholderVisibility, Mode=OneWay}" />
                                                        </Grid>
                                                        <Grid Grid.Column="1">
                                                            <Border Padding="7,2" CornerRadius="10" Background="{ThemeResource BatchAccentChipBackgroundBrush}" BorderBrush="{ThemeResource BatchAccentChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind SelectedVisibility, Mode=OneWay}">
                                                                <TextBlock FontSize="10" Foreground="{ThemeResource BatchAccentChipForegroundBrush}" Text="{x:Bind SelectionStateText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                            <Border Padding="7,2" CornerRadius="10" Background="{ThemeResource BatchMutedChipBackgroundBrush}" BorderBrush="{ThemeResource BatchMutedChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind PlaceholderVisibility, Mode=OneWay}">
                                                                <TextBlock FontSize="10" Foreground="{ThemeResource BatchMutedChipForegroundBrush}" Text="{x:Bind SelectionStateText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                            <Border Padding="7,2" CornerRadius="10" Background="{ThemeResource BatchAccentChipBackgroundBrush}" BorderBrush="{ThemeResource BatchAccentChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind NormalVisibility, Mode=OneWay}">
                                                                <TextBlock FontSize="10" Foreground="{ThemeResource BatchAccentChipForegroundBrush}" Text="{x:Bind SelectionStateText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                        </Grid>
                                                    </Grid>
                                                    <TextBlock Style="{StaticResource BatchTiny}" Text="{x:Bind FirstEndpoint, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <Border Grid.Column="2" Padding="7,3" CornerRadius="10" Background="{ThemeResource BatchHealthyChipBackgroundBrush}" BorderBrush="{ThemeResource BatchHealthyChipBorderBrush}" BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                    <TextBlock FontSize="10" Foreground="{ThemeResource BatchHealthyChipForegroundBrush}" Text="{x:Bind Detail, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                </Border>
                                                <StackPanel Grid.Column="3" Spacing="3" VerticalAlignment="Center">
                                                    <TextBlock FontSize="10" Foreground="{ThemeResource BatchAccentChipForegroundBrush}" Text="{x:Bind EnabledText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
