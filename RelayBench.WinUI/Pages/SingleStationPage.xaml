<?xml version="1.0" encoding="utf-8" ?>
<local:PageBase
    x:Class="RelayBench.WinUI.Pages.SingleStationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RelayBench.WinUI.Pages"
    xmlns:vm="using:RelayBench.WinUI.ViewModels"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    Background="Transparent">

    <local:PageBase.Resources>
        <ResourceDictionary>
        <ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary x:Key="Light">
                <SolidColorBrush x:Key="SingleHeaderIconBackgroundBrush" Color="#EAF5FF" />
                <SolidColorBrush x:Key="SingleHeaderIconBorderBrush" Color="#BFD7F2" />
                <SolidColorBrush x:Key="SingleAccentChipBackgroundBrush" Color="#E7F2FF" />
                <SolidColorBrush x:Key="SingleAccentChipBorderBrush" Color="#B7D2F0" />
                <SolidColorBrush x:Key="SingleAccentChipForegroundBrush" Color="#2563EB" />
                <SolidColorBrush x:Key="SingleHealthyChipBackgroundBrush" Color="#E8F8EF" />
                <SolidColorBrush x:Key="SingleHealthyChipBorderBrush" Color="#B7E4C7" />
                <SolidColorBrush x:Key="SingleHealthyChipForegroundBrush" Color="#0B7A46" />
                <SolidColorBrush x:Key="SingleWarningChipBackgroundBrush" Color="#FFF7E0" />
                <SolidColorBrush x:Key="SingleWarningChipBorderBrush" Color="#F2C46D" />
                <SolidColorBrush x:Key="SingleWarningChipForegroundBrush" Color="#8A4B00" />
                <SolidColorBrush x:Key="SingleDangerChipBackgroundBrush" Color="#FFF0F1" />
                <SolidColorBrush x:Key="SingleDangerChipBorderBrush" Color="#F5A6AD" />
                <SolidColorBrush x:Key="SingleDangerChipForegroundBrush" Color="#A6192E" />
                <SolidColorBrush x:Key="SingleVioletChipBackgroundBrush" Color="#F3EEFF" />
                <SolidColorBrush x:Key="SingleVioletChipBorderBrush" Color="#D8B4FE" />
                <SolidColorBrush x:Key="SingleVioletChipForegroundBrush" Color="#6D28D9" />
                <SolidColorBrush x:Key="SingleMutedChipBackgroundBrush" Color="#F7FAFD" />
                <SolidColorBrush x:Key="SingleMutedChipBorderBrush" Color="#C7D3E0" />
                <SolidColorBrush x:Key="SingleMutedChipForegroundBrush" Color="#475569" />
                <SolidColorBrush x:Key="SingleTrackBrush" Color="#CCD6E2" />
            </ResourceDictionary>
            <ResourceDictionary x:Key="Dark">
                <SolidColorBrush x:Key="SingleHeaderIconBackgroundBrush" Color="#14213F" />
                <SolidColorBrush x:Key="SingleHeaderIconBorderBrush" Color="#2F6FED" />
                <SolidColorBrush x:Key="SingleAccentChipBackgroundBrush" Color="#102A4A" />
                <SolidColorBrush x:Key="SingleAccentChipBorderBrush" Color="#34506E" />
                <SolidColorBrush x:Key="SingleAccentChipForegroundBrush" Color="#7CCBFF" />
                <SolidColorBrush x:Key="SingleHealthyChipBackgroundBrush" Color="#143827" />
                <SolidColorBrush x:Key="SingleHealthyChipBorderBrush" Color="#2D8D62" />
                <SolidColorBrush x:Key="SingleHealthyChipForegroundBrush" Color="#8FF2B6" />
                <SolidColorBrush x:Key="SingleWarningChipBackgroundBrush" Color="#4A3210" />
                <SolidColorBrush x:Key="SingleWarningChipBorderBrush" Color="#8A5A14" />
                <SolidColorBrush x:Key="SingleWarningChipForegroundBrush" Color="#FFC36D" />
                <SolidColorBrush x:Key="SingleDangerChipBackgroundBrush" Color="#4A1218" />
                <SolidColorBrush x:Key="SingleDangerChipBorderBrush" Color="#8A2632" />
                <SolidColorBrush x:Key="SingleDangerChipForegroundBrush" Color="#FDA4AF" />
                <SolidColorBrush x:Key="SingleVioletChipBackgroundBrush" Color="#201B4A" />
                <SolidColorBrush x:Key="SingleVioletChipBorderBrush" Color="#5746A6" />
                <SolidColorBrush x:Key="SingleVioletChipForegroundBrush" Color="#C4B5FD" />
                <SolidColorBrush x:Key="SingleMutedChipBackgroundBrush" Color="#111827" />
                <SolidColorBrush x:Key="SingleMutedChipBorderBrush" Color="#334155" />
                <SolidColorBrush x:Key="SingleMutedChipForegroundBrush" Color="#CBD5E1" />
                <SolidColorBrush x:Key="SingleTrackBrush" Color="#233044" />
            </ResourceDictionary>
            <ResourceDictionary x:Key="HighContrast">
                <SolidColorBrush x:Key="SingleHeaderIconBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SingleHeaderIconBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SingleAccentChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SingleAccentChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SingleAccentChipForegroundBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                <SolidColorBrush x:Key="SingleHealthyChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SingleHealthyChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SingleHealthyChipForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SingleWarningChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SingleWarningChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SingleWarningChipForegroundBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                <SolidColorBrush x:Key="SingleDangerChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SingleDangerChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SingleDangerChipForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SingleVioletChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SingleVioletChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SingleVioletChipForegroundBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                <SolidColorBrush x:Key="SingleMutedChipBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                <SolidColorBrush x:Key="SingleMutedChipBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SingleMutedChipForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                <SolidColorBrush x:Key="SingleTrackBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            </ResourceDictionary>
        </ResourceDictionary.ThemeDictionaries>

        <Style x:Key="SingleStationCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="MutedCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="SingleCompactToggleSwitch" TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="OnContent" Value="" />
            <Setter Property="OffContent" Value="" />
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock
                            MaxWidth="220"
                            Text="{Binding}"
                            TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SingleCompactCheckBox" TargetType="CheckBox">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock
                            MaxWidth="150"
                            Text="{Binding}"
                            TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SingleToolbarButton" TargetType="Button" BasedOn="{StaticResource AppToolbarButton}" />
        <Storyboard x:Name="TestingPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation
                Storyboard.TargetName="TestingGlow"
                Storyboard.TargetProperty="Opacity"
                From="0.04"
                To="0.18"
                Duration="0:0:0.9" />
        </Storyboard>
        </ResourceDictionary>
    </local:PageBase.Resources>

    <Grid x:Name="SingleStationRootGrid" Padding="12,8,12,14" RowSpacing="10" ColumnSpacing="10" Tag="ResponsiveStack">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="SidePanelColumn" Width="294" />
        </Grid.ColumnDefinitions>

        <Border Grid.ColumnSpan="2" Style="{StaticResource SingleStationCard}" Padding="14,10">
            <Grid>
            <ScrollViewer x:Name="TopCommandScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          VerticalScrollMode="Disabled"
                          ZoomMode="Disabled">
            <Grid MinWidth="1280" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="78" />
                    <ColumnDefinition Width="1.45*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="&#x63A5;&#x53E3;&#x5730;&#x5740;" TextTrimming="CharacterEllipsis" />
                <ComboBox Grid.Column="1" SelectedIndex="{x:Bind ViewModel.ProtocolIndex, Mode=TwoWay}" VerticalAlignment="Center" MinWidth="90">
                    <ComboBoxItem Content="https" />
                    <ComboBoxItem Content="http" />
                </ComboBox>
                <TextBox
                    Grid.Column="2"
                    MinWidth="230"
                    Text="{x:Bind ViewModel.BaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="relay.example.com/v1"
                    VerticalAlignment="Center" />

                <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold" Text="API &#x5BC6;&#x94A5;" TextTrimming="CharacterEllipsis" />
                <PasswordBox
                    Grid.Column="4"
                    MinWidth="180"
                    Password="{x:Bind ViewModel.ApiKey, Mode=TwoWay}"
                    PlaceholderText="sk-..."
                    VerticalAlignment="Center" />

                <TextBlock Grid.Column="5" VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold" Text="&#x6A21;&#x578B;" TextTrimming="CharacterEllipsis" />
                <ComboBox
                    x:Name="ModelComboBox"
                    Grid.Column="6"
                    MinWidth="180"
                    IsEditable="True"
                    Text="{x:Bind ViewModel.Model, Mode=TwoWay}"
                    ItemsSource="{x:Bind ViewModel.AvailableModels, Mode=OneWay}"
                    PlaceholderText="claude-3-5-sonnet"
                    VerticalAlignment="Center" />

                <!-- Mode selector: RadioButtons styled as segmented control -->
                <Border Grid.Column="8" VerticalAlignment="Center" Background="{ThemeResource ControlFillColorSecondaryBrush}" CornerRadius="6" Padding="3">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <RadioButton
                            x:Name="QuickModeRadio"
                            IsChecked="{x:Bind ViewModel.IsQuickMode, Mode=TwoWay}"
                            MinWidth="0" Padding="10,5"
                            Style="{StaticResource DefaultRadioButtonStyle}"
                            ToolTipService.ToolTip="&#x5FEB;&#x901F;&#xFF1A;&#x57FA;&#x7840;&#x8FDE;&#x901A;&#x6027;&#x4E0E;&#x541E;&#x5410;&#x6D4B;&#x8BD5;">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="&#x5FEB;&#x901F;" TextTrimming="CharacterEllipsis" />
                        </RadioButton>
                        <RadioButton
                            x:Name="StabilityModeRadio"
                            IsChecked="{x:Bind ViewModel.IsStabilityMode, Mode=TwoWay}"
                            MinWidth="0" Padding="10,5"
                            Style="{StaticResource DefaultRadioButtonStyle}"
                            ToolTipService.ToolTip="&#x7A33;&#x5B9A;&#x6027;&#xFF1A;&#x591A;&#x8F6E;&#x5EF6;&#x8FDF;&#x4E0E;&#x6210;&#x529F;&#x7387;&#x5206;&#x6790;">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="&#x7A33;&#x5B9A;&#x6027;" TextTrimming="CharacterEllipsis" />
                        </RadioButton>
                        <RadioButton
                            x:Name="DeepModeRadio"
                            IsChecked="{x:Bind ViewModel.IsDeepMode, Mode=TwoWay}"
                            MinWidth="0" Padding="10,5"
                            Style="{StaticResource DefaultRadioButtonStyle}"
                            ToolTipService.ToolTip="&#x6DF1;&#x5EA6;&#xFF1A;&#x534F;&#x8BAE;&#x3001;&#x80FD;&#x529B;&#x4E0E;&#x8FB9;&#x754C;&#x573A;&#x666F;&#x6D4B;&#x8BD5;">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="&#x6DF1;&#x5EA6;" TextTrimming="CharacterEllipsis" />
                        </RadioButton>
                        <RadioButton
                            x:Name="ConcurrencyModeRadio"
                            IsChecked="{x:Bind ViewModel.IsConcurrencyMode, Mode=TwoWay}"
                            MinWidth="0" Padding="10,5"
                            Style="{StaticResource DefaultRadioButtonStyle}"
                            ToolTipService.ToolTip="&#x5E76;&#x53D1;&#xFF1A;&#x538B;&#x529B;&#x4E0B;&#x7684;&#x541E;&#x5410;&#x4E0E;&#x9519;&#x8BEF;&#x7387;">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="&#x5E76;&#x53D1;" TextTrimming="CharacterEllipsis" />
                        </RadioButton>
                    </StackPanel>
                </Border>

                <Button Grid.Column="9" Style="{StaticResource SingleToolbarButton}" Command="{x:Bind ViewModel.OpenProxyEndpointHistoryCommand}" AutomationProperties.Name="鎵撳紑鍗曠珯鎺ュ彛鍘嗗彶" ToolTipService.ToolTip="&#x67E5;&#x770B;&#x5386;&#x53F2;&#x7AEF;&#x70B9;" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE81C;" />
                        <TextBlock FontSize="12" Text="&#x5386;&#x53F2;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="7" Style="{StaticResource SingleToolbarButton}" Command="{x:Bind ViewModel.FetchProxyModelsCommand}" AutomationProperties.Name="鎷夊彇鍗曠珯浠ｇ悊妯″瀷" ToolTipService.ToolTip="&#x62C9;&#x53D6;&#x6A21;&#x578B;&#x5217;&#x8868;" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE896;" />
                        <TextBlock FontSize="12" Text="&#x62C9;&#x53D6;&#x6A21;&#x578B;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="10" Style="{StaticResource AppAccentToolbarButton}" Command="{x:Bind ViewModel.RunSelectedSingleStationModeCommand}" AutomationProperties.Name="杩愯鍗曠珯娴嬭瘯" ToolTipService.ToolTip="&#x5F00;&#x59CB;&#x6D4B;&#x8BD5;" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE768;" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Text="&#x5F00;&#x59CB;&#x6D4B;&#x8BD5;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="11" Style="{StaticResource SingleToolbarButton}" Command="{x:Bind ViewModel.StopCurrentProxyTestCommand}" AutomationProperties.Name="鍋滄鍗曠珯娴嬭瘯" ToolTipService.ToolTip="&#x505C;&#x6B62;&#x5F53;&#x524D;&#x6D4B;&#x8BD5;" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource SingleDangerChipForegroundBrush}" Glyph="&#xE71A;" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource SingleDangerChipForegroundBrush}" MaxWidth="56" Text="&#x505C;&#x6B62;" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
            </Grid>
            </ScrollViewer>
            <Grid x:Name="CompactCommandGrid" RowSpacing="8" ColumnSpacing="8" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="86" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="CompactCommandModelColumn" Width="170" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox SelectedIndex="{x:Bind ViewModel.ProtocolIndex, Mode=TwoWay}" VerticalAlignment="Center">
                    <ComboBoxItem Content="https" />
                    <ComboBoxItem Content="http" />
                </ComboBox>
                <TextBox
                    Grid.Column="1"
                    MinWidth="0"
                    Text="{x:Bind ViewModel.BaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="relay.example.com/v1"
                    VerticalAlignment="Center" />
                <Button Grid.Column="3" Style="{StaticResource AppAccentIconButton}" Command="{x:Bind ViewModel.RunSelectedSingleStationModeCommand}" AutomationProperties.Name="杩愯绱у噾鍗曠珯娴嬭瘯" ToolTipService.ToolTip="&#x5F00;&#x59CB;&#x6D4B;&#x8BD5;" VerticalAlignment="Center">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE768;" />
                </Button>
                <PasswordBox
                    x:Name="CompactApiPasswordBox"
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    MinWidth="0"
                    Password="{x:Bind ViewModel.ApiKey, Mode=TwoWay}"
                    PlaceholderText="API &#x5BC6;&#x94A5;" />
                <ComboBox
                    x:Name="CompactModelComboBox"
                    Grid.Row="1"
                    Grid.Column="2"
                    MinWidth="0"
                    IsEditable="True"
                    Text="{x:Bind ViewModel.Model, Mode=TwoWay}"
                    ItemsSource="{x:Bind ViewModel.AvailableModels, Mode=OneWay}"
                    PlaceholderText="&#x6A21;&#x578B;" />
                <Button x:Name="CompactFetchModelsButton" Grid.Row="1" Grid.Column="3" Style="{StaticResource AppIconButton}" Command="{x:Bind ViewModel.FetchProxyModelsCommand}" AutomationProperties.Name="鎷夊彇绱у噾鍗曠珯浠ｇ悊妯″瀷" ToolTipService.ToolTip="&#x62C9;&#x53D6;&#x6A21;&#x578B;&#x5217;&#x8868;">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE896;" />
                </Button>
            </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource SingleStationCard}" Padding="18,14">
            <Grid>
            <ScrollViewer x:Name="StatusSummaryScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          VerticalScrollMode="Disabled"
                          ZoomMode="Disabled">
            <Grid MinWidth="1120">
                <Border x:Name="TestingGlow" Background="{ThemeResource SingleAccentChipForegroundBrush}" CornerRadius="8" Opacity="0" />
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid ColumnSpacing="12" VerticalAlignment="Center" MinWidth="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="52" Height="52" CornerRadius="26" Background="{ThemeResource SingleHeaderIconBackgroundBrush}" BorderBrush="{ThemeResource SingleHeaderIconBorderBrush}" BorderThickness="1">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                FontSize="24"
                                Foreground="{ThemeResource SingleAccentChipForegroundBrush}"
                                Glyph="&#xE83D;" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center" MinWidth="0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource SingleAccentChipForegroundBrush}" MaxWidth="200" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <ProgressRing Width="16" Height="16" IsActive="{x:Bind ViewModel.IsTesting, Mode=OneWay}" Visibility="{x:Bind ViewModel.IsTesting, Mode=OneWay}" />
                            </StackPanel>
                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.EntryNodeDisplay, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Column="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,0,0" Padding="18,0,0,0">
                    <StackPanel Spacing="3" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource MutedCaption}" Text="&#x603B;&#x8017;&#x65F6;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="17" FontWeight="SemiBold" Text="{x:Bind ViewModel.TotalTime, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    </Border>
                    <Border Grid.Column="2" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,0,0" Padding="18,0,0,0">
                    <StackPanel Spacing="3" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource MutedCaption}" Text="&#x8BF7;&#x6C42;&#x5927;&#x5C0F;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="17" FontWeight="SemiBold" Text="{x:Bind ViewModel.QuickRequestSize, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    </Border>
                    <Border Grid.Column="3" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,0,0" Padding="18,0,0,0">
                    <StackPanel Spacing="3" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource MutedCaption}" Text="&#x54CD;&#x5E94;&#x5927;&#x5C0F;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="17" FontWeight="SemiBold" Text="{x:Bind ViewModel.QuickResponseSize, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    </Border>
                    <Border Grid.Column="4" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,0,0" Padding="18,0,0,0">
                    <StackPanel Spacing="3" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource MutedCaption}" Text="TTFT" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="17" FontWeight="SemiBold" Text="{x:Bind ViewModel.StreamTtft, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    </Border>
                    <Border Grid.Column="5" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,0,0" Padding="18,0,0,0">
                    <StackPanel Spacing="3" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource MutedCaption}" Text="&#x72B6;&#x6001;&#x7801;" TextTrimming="CharacterEllipsis" />
                        <Grid HorizontalAlignment="Left">
                            <Border Background="{ThemeResource SingleHealthyChipBackgroundBrush}" BorderBrush="{ThemeResource SingleHealthyChipBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2" Visibility="{x:Bind ViewModel.StatusBadgeSuccessVisibility, Mode=OneWay}">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource SingleHealthyChipForegroundBrush}" Text="{x:Bind ViewModel.StatusBadgeText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </Border>
                            <Border Background="{ThemeResource SingleDangerChipBackgroundBrush}" BorderBrush="{ThemeResource SingleDangerChipBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2" Visibility="{x:Bind ViewModel.StatusBadgeErrorVisibility, Mode=OneWay}">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource SingleDangerChipForegroundBrush}" Text="{x:Bind ViewModel.StatusBadgeText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </Border>
                        </Grid>
                    </StackPanel>
                    </Border>
                    <Border Grid.Column="6" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,0,0" Padding="18,0,0,0">
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource MutedCaption}" Text="&#x6210;&#x529F;&#x7387;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource SingleHealthyChipForegroundBrush}" Text="{x:Bind ViewModel.QuickSuccessRate, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.SuccessRateDetail, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    </Border>
                    <Border Grid.Column="7" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,0,0" Padding="18,0,0,0">
                    <StackPanel Spacing="3" VerticalAlignment="Center">
