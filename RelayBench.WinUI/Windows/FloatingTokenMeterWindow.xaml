<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="RelayBench.WinUI.Desktop.FloatingTokenMeterWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="RelayBench Token 计">
    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootSurface" Background="Transparent">
        <Border x:Name="RootChrome"
                Width="196"
                Height="68"
                Padding="12,9"
                AutomationProperties.HelpText="双击或按 Enter/空格打开 RelayBench。拖动可移动位置。右键或菜单键打开窗口和 Token 计操作。"
                AutomationProperties.LocalizedControlType="浮动 Token 计"
                AutomationProperties.Name="RelayBench Token 计"
                Opacity="0"
                BorderBrush="{ThemeResource TrayMenuBorderBrush}"
                BorderThickness="1"
                Background="{ThemeResource TrayMenuBackgroundBrush}"
                CornerRadius="14"
                DoubleTapped="RootChrome_DoubleTapped"
                IsTabStop="True"
                KeyDown="RootChrome_KeyDown"
                Loaded="RootChrome_Loaded"
                PointerCanceled="RootChrome_PointerCanceled"
                PointerEntered="RootChrome_PointerEntered"
                PointerExited="RootChrome_PointerExited"
                PointerMoved="RootChrome_PointerMoved"
                PointerPressed="RootChrome_PointerPressed"
                PointerReleased="RootChrome_PointerReleased"
                ToolTipService.ToolTip="{x:Bind ViewModel.TokenMeterMetricsSummary, Mode=OneWay}">
            <Border.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="6" />
                </TransitionCollection>
            </Border.Transitions>
            <Border.RenderTransform>
                <CompositeTransform x:Name="RootTransform"
                                    ScaleX="0.985"
                                    ScaleY="0.985"
                                    TranslateY="6" />
            </Border.RenderTransform>
            <Border.ContextFlyout>
                <MenuFlyout Placement="Left">
                    <MenuFlyoutSubItem Text="窗口" AccessKey="W">
                        <MenuFlyoutSubItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8A7;" />
                        </MenuFlyoutSubItem.Icon>
                        <MenuFlyoutItem Text="打开 RelayBench" AccessKey="O" Click="OpenMainWindowMenuItem_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8A7;" />
                            </MenuFlyoutItem.Icon>
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Key="O" Modifiers="Control" />
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <ToggleMenuFlyoutItem x:Name="LockPositionMenuItem"
                                              AccessKey="L"
                                              Text="锁定位置"
                                              Click="LockPositionMenuItem_Click">
                            <ToggleMenuFlyoutItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72E;" />
                            </ToggleMenuFlyoutItem.Icon>
                            <ToggleMenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Key="L" Modifiers="Control" />
                            </ToggleMenuFlyoutItem.KeyboardAccelerators>
                        </ToggleMenuFlyoutItem>
                        <ToggleMenuFlyoutItem x:Name="MousePassThroughMenuItem"
                                              AccessKey="M"
                                              Text="鼠标穿透"
                                              Click="MousePassThroughMenuItem_Click">
                            <ToggleMenuFlyoutItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8F0;" />
                            </ToggleMenuFlyoutItem.Icon>
                            <ToggleMenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Key="M" Modifiers="Control" />
                            </ToggleMenuFlyoutItem.KeyboardAccelerators>
                        </ToggleMenuFlyoutItem>
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSubItem Text="Token 计" AccessKey="T">
                        <MenuFlyoutSubItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE9D2;" />
                        </MenuFlyoutSubItem.Icon>
                        <MenuFlyoutItem Text="重置阶段计数" AccessKey="R" Click="ResetCounterMenuItem_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE777;" />
                            </MenuFlyoutItem.Icon>
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Key="R" Modifiers="Control" />
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="复制状态摘要" AccessKey="C" Click="CopySummaryMenuItem_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8C8;" />
                            </MenuFlyoutItem.Icon>
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Key="C" Modifiers="Control" />
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="隐藏计数器" AccessKey="H" Click="HideMenuItem_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE711;" />
                        </MenuFlyoutItem.Icon>
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="H" Modifiers="Control" />
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </Border.ContextFlyout>

            <Grid>
                <Border x:Name="InteractionOverlay"
                        Margin="-12,-9"
                        Opacity="0"
                        IsHitTestVisible="False"
                        Background="{ThemeResource TrayMenuButtonBackgroundPointerOverBrush}"
                        BorderBrush="{ThemeResource TrayMenuButtonBorderPointerOverBrush}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Border.OpacityTransition>
                        <ScalarTransition Duration="0:0:0.14" />
                    </Border.OpacityTransition>
                </Border>
                <Border x:Name="PressedInteractionOverlay"
                        Margin="-12,-9"
                        Opacity="0"
                        IsHitTestVisible="False"
                        Background="{ThemeResource TrayMenuButtonBackgroundPressedBrush}"
                        BorderBrush="{ThemeResource TrayMenuButtonBorderPressedBrush}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Border.OpacityTransition>
                        <ScalarTransition Duration="0:0:0.10" />
                    </Border.OpacityTransition>
                </Border>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Width="15" Height="44" VerticalAlignment="Center">
                        <Ellipse Width="15"
                                 Height="15"
                                 Fill="{ThemeResource TrayMenuIdleStatusBrush}"
                                 Opacity="0.18"
                                 Visibility="{x:Bind ViewModel.TokenMeterWaitToneVisibility, Mode=OneWay}" />
                        <Ellipse Width="15"
                                 Height="15"
                                 Fill="{ThemeResource TrayMenuAccentTextBrush}"
                                 Opacity="0.18"
                                 Visibility="{x:Bind ViewModel.TokenMeterIdleToneVisibility, Mode=OneWay}" />
                        <Ellipse Width="15"
                                 Height="15"
                                 Fill="{ThemeResource TrayMenuLiveStatusBrush}"
                                 Opacity="0.18"
                                 Visibility="{x:Bind ViewModel.TokenMeterLiveToneVisibility, Mode=OneWay}" />
                        <Ellipse Width="7"
                                 Height="7"
                                 Fill="{ThemeResource TrayMenuIdleStatusBrush}"
                                 Visibility="{x:Bind ViewModel.TokenMeterWaitToneVisibility, Mode=OneWay}" />
                        <Ellipse Width="7"
                                 Height="7"
                                 Fill="{ThemeResource TrayMenuAccentTextBrush}"
                                 Visibility="{x:Bind ViewModel.TokenMeterIdleToneVisibility, Mode=OneWay}" />
                        <Ellipse Width="7"
                                 Height="7"
                                 Fill="{ThemeResource TrayMenuLiveStatusBrush}"
                                 Visibility="{x:Bind ViewModel.TokenMeterLiveToneVisibility, Mode=OneWay}" />
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1" MinWidth="0">
                        <TextBlock Text="{x:Bind ViewModel.TokenMeterPrimaryText, Mode=OneWay}"
                               TextTrimming="CharacterEllipsis"
                                   FontFamily="Cascadia Mono, Consolas"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TrayMenuPrimaryTextBrush}" />
                        <TextBlock FontFamily="Segoe UI, Microsoft YaHei UI"
                                   FontSize="10.5"
                                   Foreground="{ThemeResource TrayMenuSecondaryTextBrush}"
                                   Text="{x:Bind ViewModel.TokenMeterSecondaryText, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Border Grid.Column="2"
                            MaxWidth="54"
                            Padding="6,2"
                            VerticalAlignment="Center"
                            Background="{ThemeResource TrayMenuPillBackgroundBrush}"
                            BorderBrush="{ThemeResource TrayMenuIconBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <TextBlock FontSize="9.5"
                                       FontWeight="SemiBold"
                                       Text="{x:Bind ViewModel.TokenMeterModeText, Mode=OneWay}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{x:Bind ViewModel.TokenMeterWaitToneVisibility, Mode=OneWay}"
                                       Foreground="{ThemeResource TrayMenuIdleStatusBrush}" />
                            <TextBlock FontSize="9.5"
                                       FontWeight="SemiBold"
                                       Text="{x:Bind ViewModel.TokenMeterModeText, Mode=OneWay}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{x:Bind ViewModel.TokenMeterIdleToneVisibility, Mode=OneWay}"
                                       Foreground="{ThemeResource TrayMenuAccentTextBrush}" />
                            <TextBlock FontSize="9.5"
                                       FontWeight="SemiBold"
                                       Text="{x:Bind ViewModel.TokenMeterModeText, Mode=OneWay}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{x:Bind ViewModel.TokenMeterLiveToneVisibility, Mode=OneWay}"
                                       Foreground="{ThemeResource TrayMenuLiveStatusBrush}" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
