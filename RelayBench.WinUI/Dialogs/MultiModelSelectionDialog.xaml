<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="RelayBench.WinUI.Dialogs.MultiModelSelectionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dialogs="using:RelayBench.WinUI.Dialogs"
    Title="&#x591A;&#x6A21;&#x578B;&#x6D4B;&#x901F;"
    PrimaryButtonText="&#x786E;&#x5B9A;"
    SecondaryButtonText="&#x6E05;&#x7A7A;"
    CloseButtonText="&#x53D6;&#x6D88;"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryButtonClick"
    SecondaryButtonClick="OnSecondaryButtonClick">

    <ScrollViewer MaxHeight="620"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Border MinWidth="0"
                MaxWidth="820"
                Padding="16"
                CornerRadius="10"
                Background="{ThemeResource RxAcrylicOverlayBrush}"
                BorderBrush="{ThemeResource ContentDialogBorderBrush}"
                BorderThickness="1">
            <StackPanel Spacing="14">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="10" IsStaggeringEnabled="True" />
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="42" Height="42" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1" CornerRadius="12">
                        <FontIcon HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  FontSize="20"
                                  Foreground="{ThemeResource DialogAccentChipForegroundBrush}"
                                  Glyph="&#xE762;" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" MinWidth="0">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="&#x6DF1;&#x5EA6;&#x591A;&#x6A21;&#x578B;&#x6D4B;&#x901F;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind SummaryText, Mode=OneWay}" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" MaxLines="2" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Padding="9,5" Click="OnSelectAllClick" AutomationProperties.Name="全选模型" ToolTipService.ToolTip="&#x5168;&#x9009;">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8FB;" />
                        </Button>
                        <Button Padding="9,5" Click="OnInvertClick" AutomationProperties.Name="反选模型" ToolTipService.ToolTip="&#x53CD;&#x9009;">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8AB;" />
                        </Button>
                        <Button Padding="9,5" Click="OnClearClick" AutomationProperties.Name="清空模型选择" ToolTipService.ToolTip="&#x6E05;&#x7A7A;">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE711;" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x5019;&#x9009;" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{x:Bind CandidateCountText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x5DF2;&#x9009;" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{x:Bind SelectedCountText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x5F53;&#x524D;" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="{x:Bind CurrentModelText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <ListView ItemsSource="{x:Bind Items, Mode=OneWay}" SelectionMode="None" MaxHeight="360">
                        <ListView.Transitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromVerticalOffset="10" IsStaggeringEnabled="True" />
                                <RepositionThemeTransition />
                            </TransitionCollection>
                        </ListView.Transitions>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="dialogs:MultiModelSelectionItem">
                                <Grid Padding="12,9" ColumnSpacing="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox MinWidth="0"
                                              Padding="0"
                                              VerticalAlignment="Center"
                                              IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                              Checked="OnModelCheckChanged"
                                              Unchecked="OnModelCheckChanged"
                                              AutomationProperties.Name="{x:Bind Model}"
                                              ToolTipService.ToolTip="{x:Bind DetailText}" />
                                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind Model}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind DetailText}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Grid Grid.Column="2" VerticalAlignment="Center">
                                        <Border Padding="8,3" CornerRadius="10" Background="{ThemeResource DialogSuccessChipBackgroundBrush}" BorderBrush="{ThemeResource DialogSuccessChipBorderBrush}" BorderThickness="1" MaxWidth="130" Visibility="{x:Bind CurrentModelVisibility}">
                                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource DialogSuccessChipForegroundBrush}" Text="{x:Bind BadgeText}" TextTrimming="CharacterEllipsis" />
                                        </Border>
                                        <Border Padding="8,3" CornerRadius="10" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1" MaxWidth="130" Visibility="{x:Bind CandidateVisibility}">
                                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Text="{x:Bind BadgeText}" TextTrimming="CharacterEllipsis" />
                                        </Border>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="15" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Glyph="&#xE946;" />
                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind HintText, Mode=OneWay}" TextWrapping="Wrap" MaxLines="3" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </ScrollViewer>
</ContentDialog>
