<ContentDialog
    x:Class="RelayBench.WinUI.Dialogs.BatchTopCandidateApplyDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RelayBench.WinUI.ViewModels"
    Title="接入 Top 候选到应用"
    PrimaryButtonText="应用所选"
    CloseButtonText="关闭"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryButtonClick">

    <ScrollViewer MaxHeight="640"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Border MinWidth="0"
                MaxWidth="920"
                Padding="16"
                CornerRadius="10"
                Background="{ThemeResource RxAcrylicOverlayBrush}"
                BorderBrush="{ThemeResource ContentDialogBorderBrush}"
                BorderThickness="1">
            <Grid ColumnSpacing="14">
                <Grid.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="10" IsStaggeringEnabled="True" />
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </Grid.ChildrenTransitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.18*" />
                    <ColumnDefinition Width="0.82*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="10">
                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="批量排行候选" TextTrimming="CharacterEllipsis" />
                    <ListView x:Name="CandidateList"
                              ItemsSource="{x:Bind ViewModel.Candidates, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedCandidate, Mode=TwoWay}"
                              SelectionMode="Single"
                              MaxHeight="420">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:BatchTopCandidateApplicationCandidate">
                                <Grid Padding="10,8" ColumnSpacing="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="17" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Text="{x:Bind Rank}" TextTrimming="CharacterEllipsis" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" MinWidth="0">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind SiteName}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind BaseUrl}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind DetailText}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="2" MinWidth="94">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind ScoreText}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="10.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Model}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" MaxWidth="150" />
                                        <TextBlock FontSize="10.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ProtocolSummary}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" MaxWidth="150" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="12">
                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="接入目标" TextTrimming="CharacterEllipsis" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Targets, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="8" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:BatchApplicationTargetChoice">
                                <Border Padding="12,10" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" AutomationProperties.Name="{x:Bind Name}" ToolTipService.ToolTip="{x:Bind DetailText}">
                                        <StackPanel Spacing="2">
                                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ProtocolText}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock FontSize="10.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind DetailText}" TextWrapping="Wrap" MaxLines="2" />
                                        </StackPanel>
                                    </CheckBox>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <Border Padding="12,10" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="执行状态" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" TextWrapping="Wrap" MaxLines="6" />
                            <ProgressRing Width="24" Height="24" IsActive="{x:Bind ViewModel.IsApplying, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </ScrollViewer>
</ContentDialog>
