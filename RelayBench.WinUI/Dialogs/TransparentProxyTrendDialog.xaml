<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="RelayBench.WinUI.Dialogs.TransparentProxyTrendDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:vm="using:RelayBench.WinUI.ViewModels"
    Title="代理趋势"
    CloseButtonText="&#x5173;&#x95ED;"
    DefaultButton="Close">

    <ScrollViewer MaxHeight="640"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Border Padding="16"
                CornerRadius="10"
                Background="{ThemeResource RxAcrylicOverlayBrush}"
                BorderBrush="{ThemeResource ContentDialogBorderBrush}"
                BorderThickness="1">
            <StackPanel Spacing="14" MinWidth="0" MaxWidth="980">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="10" IsStaggeringEnabled="True" />
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="42" Height="42" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1" CornerRadius="12">
                        <FontIcon HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  FontSize="20"
                                  Foreground="{ThemeResource DialogAccentChipForegroundBrush}"
                                  Glyph="&#xE9D2;" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" MinWidth="0">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="&#x900F;&#x660E;&#x4EE3;&#x7406;&#x8D8B;&#x52BF;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Snapshot.SummaryText, Mode=OneWay}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" />
                    </StackPanel>
                    <Border Grid.Column="2" MaxWidth="180" Padding="8,4" VerticalAlignment="Center" Background="{ThemeResource DialogSuccessChipBackgroundBrush}" BorderBrush="{ThemeResource DialogSuccessChipBorderBrush}" BorderThickness="1" CornerRadius="10">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource DialogSuccessChipForegroundBrush}" Text="{x:Bind Snapshot.CurrentTokenSpeedText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </Border>
                </Grid>

                <Grid ColumnSpacing="10" RowSpacing="10" Tag="ResponsiveStack">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="P50 平均" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{x:Bind Snapshot.AverageP50LatencyText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="P95 峰值" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{x:Bind Snapshot.PeakP95LatencyText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Token 峰值" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{x:Bind Snapshot.PeakThroughputText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="成功率" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{x:Bind Snapshot.SuccessRateText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="缓存" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{x:Bind Snapshot.CacheHitRateText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="10" Tag="ResponsiveStack">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="14" FontWeight="SemiBold" Text="Token &#x901F;&#x5EA6;" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Snapshot.ThroughputSampleCount, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                            <lvc:CartesianChart Grid.Row="1" x:Name="ThroughputChart" Height="230" />
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="14" FontWeight="SemiBold" Text="&#x5EF6;&#x8FDF;&#x8D8B;&#x52BF;" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Snapshot.LatencySampleCount, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                            <lvc:CartesianChart Grid.Row="1" x:Name="LatencyChart" Height="230" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="10" Tag="ResponsiveStack">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="0.85*" />
                    </Grid.ColumnDefinitions>
                    <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="&#x8DEF;&#x7531;&#x5065;&#x5EB7;" TextTrimming="CharacterEllipsis" />
                            <ListView Grid.Row="1" ItemsSource="{x:Bind Snapshot.RouteRows, Mode=OneWay}" SelectionMode="None" MaxHeight="250">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RouteQueueEntry">
                                        <Grid ColumnSpacing="8" Padding="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="82" />
                                                <ColumnDefinition Width="82" />
                                                <ColumnDefinition Width="82" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="1">
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind RouteName}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Protocol}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" FontSize="11" Text="{x:Bind LatencyDisplay}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right" />
                                            <TextBlock Grid.Column="2" FontSize="11" Text="{x:Bind HealthDisplay}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right" />
                                            <TextBlock Grid.Column="3" FontSize="11" Text="{x:Bind TokenSpeedDisplay}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="&#x8FD1;&#x671F;&#x4E8B;&#x4EF6;" TextTrimming="CharacterEllipsis" />
                            <ListView Grid.Row="1" ItemsSource="{x:Bind Snapshot.ActivityRows, Mode=OneWay}" SelectionMode="None" MaxHeight="250">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TransparentProxyActivityEvent">
                                        <Grid ColumnSpacing="8" Padding="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind TimeText}" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="1" Padding="5,1" CornerRadius="8" Background="{ThemeResource DialogWarningChipBackgroundBrush}" BorderBrush="{ThemeResource DialogWarningChipBorderBrush}" BorderThickness="1">
                                                <TextBlock FontSize="9" Foreground="{ThemeResource DialogWarningChipForegroundBrush}" Text="{x:Bind BadgeText}" TextTrimming="CharacterEllipsis" />
                                            </Border>
                                            <TextBlock Grid.Column="2" FontSize="11" Text="{x:Bind Detail}" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>
    </ScrollViewer>
</ContentDialog>
