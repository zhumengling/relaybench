<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="RelayBench.WinUI.Dialogs.BatchSiteEditorDialog"
    x:Name="DialogRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RelayBench.WinUI.ViewModels">

    <Border BorderBrush="{ThemeResource ContentDialogBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18,14,18,16" Background="{ThemeResource RxAcrylicOverlayBrush}">
    <Border.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition FromVerticalOffset="10" />
            <RepositionThemeTransition />
        </TransitionCollection>
    </Border.Transitions>
    <Grid x:Name="DialogSurface" MinWidth="0" MaxWidth="1180" MaxHeight="740" RowSpacing="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.Resources>
        <Style x:Key="DialogCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="DialogSubtleCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
        </Style>

        <Style x:Key="DialogHeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="DialogCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="DialogTiny" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="DialogToolbarButton" TargetType="Button" BasedOn="{StaticResource AppToolbarButton}" />

        <Style x:Key="DialogCellTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="DialogCellPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="PasswordRevealMode" Value="Hidden" />
        </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12" Tag="ResponsiveStack">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="3" MinWidth="0">
                <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="&#x5165;&#x53E3;&#x7EC4;&#x7EF4;&#x62A4;" TextTrimming="CharacterEllipsis" />
                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="&#x6279;&#x91CF;&#x5165;&#x53E3;&#x7684;&#x5F55;&#x5165;&#x3001;&#x5206;&#x7EC4;&#x548C;&#x6A21;&#x578B;&#x7EF4;&#x62A4;" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                <TextBlock Style="{StaticResource DialogCaption}" Text="{x:Bind SiteEditor.EditorSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <StackPanel Grid.Column="1" MaxWidth="320" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                <Border Padding="8,4" CornerRadius="12" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1">
                    <TextBlock FontSize="11" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" MaxWidth="142" Text="{x:Bind SiteEditor.EditorHealthSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                </Border>
                <Border Padding="8,4" CornerRadius="12" Background="{ThemeResource DialogSuccessChipBackgroundBrush}" BorderBrush="{ThemeResource DialogSuccessChipBorderBrush}" BorderThickness="1">
                    <TextBlock FontSize="11" Foreground="{ThemeResource DialogSuccessChipForegroundBrush}" MaxWidth="142" Text="{x:Bind SiteEditor.DraftSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12" RowSpacing="12" Tag="ResponsiveStack">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.9*" />
                    <RowDefinition Height="1.1*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource DialogCard}" Padding="0">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Padding="11,9" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource DialogHeaderText}" Text="&#x5DF2;&#x5F55;&#x5165;&#x5165;&#x53E3;&#x7EC4;" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" Style="{StaticResource DialogCaption}" Text="{x:Bind SiteEditor.TotalSiteCount, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsRepeater ItemsSource="{x:Bind SiteEditor.SiteGroups, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical" Spacing="6" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:BatchSiteGroupSummary">
                                        <Grid Margin="8,0" IsTabStop="True" KeyDown="SiteGroup_KeyDown" Tapped="SiteGroup_Tapped" AutomationProperties.Name="{x:Bind Name, Mode=OneWay}" AutomationProperties.LocalizedControlType="站点组行" AutomationProperties.HelpText="{x:Bind Tooltip, Mode=OneWay}" ToolTipService.ToolTip="{x:Bind Tooltip, Mode=OneWay}">
                                            <Border CornerRadius="7" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Visibility="{x:Bind NormalVisibility, Mode=OneWay}" />
                                            <Border CornerRadius="7" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind SelectedVisibility, Mode=OneWay}" />
                                            <Border CornerRadius="7" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource DialogWarningChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind PlaceholderVisibility, Mode=OneWay}" />
                                            <Grid Padding="9,8" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="4" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="3" CornerRadius="2" Background="{ThemeResource DialogAccentChipForegroundBrush}" Opacity="{x:Bind SelectionMarkerOpacity, Mode=OneWay}" />
                                            <StackPanel Grid.Column="1" Spacing="6">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid>
                                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind NormalVisibility, Mode=OneWay}" />
                                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind SelectedVisibility, Mode=OneWay}" />
                                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" Visibility="{x:Bind PlaceholderVisibility, Mode=OneWay}" />
                                                    </Grid>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                                        <TextBlock FontSize="11" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" MaxWidth="70" Text="{x:Bind CountText, Mode=OneWay}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                        <Grid>
                                                            <Border Padding="7,2" CornerRadius="10" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind NormalVisibility, Mode=OneWay}">
                                                                <TextBlock FontSize="10" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" MaxWidth="72" Text="{x:Bind SelectionStateText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                            <Border Padding="7,2" CornerRadius="10" Background="{ThemeResource DialogSuccessChipBackgroundBrush}" BorderBrush="{ThemeResource DialogSuccessChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind SelectedVisibility, Mode=OneWay}">
                                                                <TextBlock FontSize="10" Foreground="{ThemeResource DialogSuccessChipForegroundBrush}" MaxWidth="72" Text="{x:Bind SelectionStateText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                            <Border Padding="7,2" CornerRadius="10" Background="{ThemeResource DialogWarningChipBackgroundBrush}" BorderBrush="{ThemeResource DialogWarningChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind PlaceholderVisibility, Mode=OneWay}">
                                                                <TextBlock FontSize="10" Foreground="{ThemeResource DialogWarningChipForegroundBrush}" MaxWidth="72" Text="{x:Bind SelectionStateText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock Style="{StaticResource DialogCaption}" Text="{x:Bind FirstEndpoint, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                <Grid ColumnSpacing="6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                <Border Padding="6,3" CornerRadius="9" Background="{ThemeResource DialogSuccessChipBackgroundBrush}" BorderBrush="{ThemeResource DialogSuccessChipBorderBrush}" BorderThickness="1"><TextBlock FontSize="10" Foreground="{ThemeResource DialogSuccessChipForegroundBrush}" Text="{x:Bind Detail, Mode=OneWay}" TextTrimming="CharacterEllipsis" /></Border>
                                                <Border Grid.Column="1" Padding="6,3" CornerRadius="9" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1"><TextBlock FontSize="10" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Text="{x:Bind EnabledText, Mode=OneWay}" TextTrimming="CharacterEllipsis" /></Border>
                                                <Border Grid.Column="2" Padding="6,3" CornerRadius="9" Background="{ThemeResource DialogWarningChipBackgroundBrush}" BorderBrush="{ThemeResource DialogWarningChipBorderBrush}" BorderThickness="1"><TextBlock FontSize="10" Foreground="{ThemeResource DialogWarningChipForegroundBrush}" Text="{x:Bind MissingText, Mode=OneWay}" TextTrimming="CharacterEllipsis" /></Border>
                                                </Grid>
                                                <TextBlock Style="{StaticResource DialogTiny}" Text="{x:Bind ModelText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource DialogCard}" Padding="0">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Padding="11,9" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource DialogHeaderText}" Text="&#x5165;&#x53E3;&#x660E;&#x7EC6;" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" Style="{StaticResource DialogCaption}" Text="{x:Bind ViewModel.SelectionSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <ItemsRepeater ItemsSource="{x:Bind SiteEditor.Sites, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical" Spacing="0" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:BatchSiteEntry">
                                        <Grid MinWidth="460" Padding="9,7" ColumnSpacing="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" IsTabStop="True" KeyDown="ExistingSiteRow_KeyDown" Tapped="ExistingSiteRow_Tapped" AutomationProperties.Name="{x:Bind DisplayName, Mode=OneWay}" AutomationProperties.LocalizedControlType="已保存入口行" AutomationProperties.HelpText="{x:Bind EndpointDisplay, Mode=OneWay}" ToolTipService.ToolTip="{x:Bind EndpointDisplay, Mode=OneWay}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="64" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox IsChecked="{x:Bind IsIncluded, Mode=TwoWay}" MinWidth="0" Padding="0" VerticalAlignment="Center"
                                                      AutomationProperties.Name="{x:Bind DisplayName, Mode=OneWay}"
                                                      ToolTipService.ToolTip="{x:Bind EndpointDisplay, Mode=OneWay}" />
                                            <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Text="{x:Bind DisplayName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2" Style="{StaticResource DialogCaption}" Text="{x:Bind EndpointDisplay, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="3" Padding="6,3" CornerRadius="9" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <TextBlock FontSize="10" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Text="{x:Bind EntryStatusText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Style="{StaticResource DialogCard}" Padding="0">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Padding="12,10" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Style="{StaticResource DialogHeaderText}" FontSize="15" Text="&#x5F53;&#x524D;&#x7AD9;&#x70B9;&#x5F55;&#x5165;" TextTrimming="CharacterEllipsis" />
                            <TextBlock Style="{StaticResource DialogCaption}" Text="{x:Bind SiteEditor.DraftStatusText, Mode=OneWay}" TextWrapping="Wrap" MaxLines="2" />
                        </StackPanel>
                        <ScrollViewer Grid.Column="1"
                                      MaxWidth="360"
                                      HorizontalScrollBarVisibility="Auto"
                                      HorizontalScrollMode="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      VerticalScrollMode="Disabled"
                                      ZoomMode="Disabled">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Button Style="{StaticResource DialogToolbarButton}"
                                        Click="OnBringCurrentEndpointClick"
                                        AutomationProperties.Name="带入当前入口到批量编辑器"
                                        ToolTipService.ToolTip="带入当前入口到批量编辑器">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Glyph="&#xE8B5;" />
                                        <TextBlock FontSize="11" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" MaxWidth="96" Text="&#x5E26;&#x5165;&#x4E3B;&#x9875;" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource DialogToolbarButton}"
                                        Command="{x:Bind SiteEditor.PasteProxyBatchTemplateRowsCommand}"
                                        AutomationProperties.Name="从剪贴板粘贴入口行"
                                        ToolTipService.ToolTip="从剪贴板粘贴入口行">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Glyph="&#xE77F;" />
                                        <TextBlock FontSize="11" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" MaxWidth="118" Text="&#x4ECE;&#x526A;&#x8D34;&#x677F;&#x7C98;&#x8D34;" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource DialogToolbarButton}"
                                        Command="{x:Bind SiteEditor.AddProxyBatchTemplateRowCommand}"
                                        AutomationProperties.Name="新增入口行"
                                        ToolTipService.ToolTip="新增入口行">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Glyph="&#xE710;" />
                                        <TextBlock FontSize="11" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" MaxWidth="88" Text="&#x65B0;&#x589E;&#x4E00;&#x884C;" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Border Grid.Row="1" Margin="12,0,12,10" Padding="10,8" CornerRadius="7" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="12" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Text="&#x652F;&#x6301;&#x5355;&#x4E2A; URL / Key / &#x6A21;&#x578B;&#xFF0C;&#x4E5F;&#x652F;&#x6301; URL|Key|&#x6A21;&#x578B;&#x3001;&#x540D;&#x79F0;|URL|Key|&#x6A21;&#x578B;&#x3002;&#x7C98;&#x8D34;&#x5355;&#x4E2A;&#x503C;&#x65F6;&#x4F1A;&#x81EA;&#x52A8;&#x8865;&#x5230;&#x7F3A;&#x5C11;&#x7684;&#x5217;&#xFF0C;&#x65B0;&#x884C;&#x4F1A;&#x6CBF;&#x7528;&#x4E0A;&#x4E00;&#x884C;&#x3002;" TextWrapping="Wrap" MaxLines="3" />
                            <Border Grid.Column="1" Padding="8,3" CornerRadius="12" Background="{ThemeResource DialogSuccessChipBackgroundBrush}" BorderBrush="{ThemeResource DialogSuccessChipBorderBrush}" BorderThickness="1" VerticalAlignment="Center">
                                <TextBlock FontSize="11" Foreground="{ThemeResource DialogSuccessChipForegroundBrush}" Text="&#x667A;&#x80FD;&#x8BC6;&#x522B;&#x5DF2;&#x5F00;&#x542F;" TextTrimming="CharacterEllipsis" />
                            </Border>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="2"
                                  Margin="12,0,12,0"
                                  HorizontalScrollBarVisibility="Auto"
                                  HorizontalScrollMode="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  VerticalScrollMode="Disabled">
                    <Grid MinWidth="760">
                        <Grid RowSpacing="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Padding="10,8" ColumnSpacing="6" Background="{ThemeResource DialogTerminalBackgroundBrush}" BorderBrush="{ThemeResource DialogTerminalBorderBrush}" BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="92" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="1.25*" />
                                    <ColumnDefinition Width="1.35*" />
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="30" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource DialogCaption}" Text="&#x6D4B;&#x8BD5;" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Style="{StaticResource DialogCaption}" Text="&#x540D;&#x79F0;" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2" Style="{StaticResource DialogCaption}" Text="URL" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="3" Style="{StaticResource DialogCaption}" Text="密钥" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="4" Style="{StaticResource DialogCaption}" Text="&#x6A21;&#x578B;" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="5" Style="{StaticResource DialogCaption}" Text="" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="6" Style="{StaticResource DialogCaption}" Text="&#x72B6;&#x6001;" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="7" Style="{StaticResource DialogCaption}" Text="" TextTrimming="CharacterEllipsis" />
                            </Grid>

                            <ScrollViewer Grid.Row="1" HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                <ItemsRepeater HorizontalAlignment="Stretch" ItemsSource="{x:Bind SiteEditor.DraftRows, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Vertical" Spacing="0" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:BatchSiteDraftRow">
                                            <Grid Padding="10,7" ColumnSpacing="6" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" IsTabStop="True" KeyDown="DraftRow_KeyDown" Tapped="DraftRow_Tapped" Tag="{x:Bind}" HorizontalAlignment="Stretch" AutomationProperties.Name="{x:Bind DisplayName, Mode=OneWay}" AutomationProperties.LocalizedControlType="草稿入口行" AutomationProperties.HelpText="{x:Bind StatusText, Mode=OneWay}" ToolTipService.ToolTip="{x:Bind StatusText, Mode=OneWay}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34" />
                                                    <ColumnDefinition Width="92" />
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="1.25*" />
                                                    <ColumnDefinition Width="1.35*" />
                                                    <ColumnDefinition Width="64" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="30" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{x:Bind IsIncluded, Mode=TwoWay}" MinWidth="0" Padding="0" VerticalAlignment="Center"
                                                          AutomationProperties.Name="{x:Bind DisplayName, Mode=OneWay}"
                                                          ToolTipService.ToolTip="{x:Bind StatusText, Mode=OneWay}" />
                                                <TextBox Grid.Column="1" Style="{StaticResource DialogCellTextBox}" Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="&#x540D;&#x79F0;" />
                                                <TextBox Grid.Column="2" Style="{StaticResource DialogCellTextBox}" Text="{x:Bind BaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="https://..." />
                                                <PasswordBox Grid.Column="3" Style="{StaticResource DialogCellPasswordBox}" Password="{x:Bind ApiKey, Mode=TwoWay}" PlaceholderText="密钥" ToolTipService.ToolTip="{x:Bind KeyPreview, Mode=OneWay}" />
                                                <ComboBox Grid.Column="4" MinWidth="0" IsEditable="True" ItemsSource="{x:Bind AvailableModels, Mode=OneWay}" Text="{x:Bind Model, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Tag="{x:Bind}" SelectionChanged="OnDraftModelSelectionChanged" LostFocus="OnDraftModelComboLostFocus" DropDownClosed="OnDraftModelDropDownClosed" PlaceholderText="&#x6A21;&#x578B;&#x6216;&#x4ECE;&#x7F13;&#x5B58;&#x9009;&#x62E9;" ToolTipService.ToolTip="{x:Bind ModelCatalogSummary, Mode=OneWay}" />
                                                <Button Grid.Column="5" Padding="7,4" MinWidth="58" MinHeight="28" CornerRadius="7" Click="OnFetchDraftRowModelsClick" Tag="{x:Bind}" AutomationProperties.Name="拉取草稿行模型" ToolTipService.ToolTip="&#x6309;&#x672C;&#x884C; URL + Key &#x62C9;&#x53D6;&#x6A21;&#x578B;&#xFF0C;Key &#x4E3A;&#x7A7A;&#x65F6;&#x6CBF;&#x7528;&#x4E0A;&#x4E00;&#x884C;&#x3002;">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Glyph="&#xE896;" />
                                                        <TextBlock FontSize="11" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Text="&#x62C9;&#x53D6;" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Button>
                                                <StackPanel Grid.Column="6" Spacing="2" VerticalAlignment="Center">
                                                    <Border Padding="7,3" CornerRadius="10" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1" HorizontalAlignment="Left">
                                                        <TextBlock FontSize="10" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" MaxWidth="84" Text="{x:Bind StatusText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                    </Border>
                                                    <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" MaxWidth="128" Text="{x:Bind ModelCatalogSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <Button Grid.Column="7" Padding="6,4" MinWidth="28" MinHeight="26" CornerRadius="7" Click="OnDeleteDraftRowClick" Tag="{x:Bind}" AutomationProperties.Name="删除草稿行" ToolTipService.ToolTip="&#x5220;&#x9664;&#x8BE5;&#x884C;">
                                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Foreground="{ThemeResource DialogDangerChipForegroundBrush}" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                    </ScrollViewer>

                    <Grid Grid.Row="3" Padding="12,10,12,12" ColumnSpacing="8" RowSpacing="8" Tag="ResponsiveStack">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource DialogCaption}" Text="{x:Bind SiteEditor.SelectedSiteSummary, Mode=OneWay}" TextWrapping="Wrap" MaxLines="2" VerticalAlignment="Center" />
                        <ScrollViewer Grid.Column="1"
                                      MaxWidth="560"
                                      HorizontalScrollBarVisibility="Auto"
                                      HorizontalScrollMode="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      VerticalScrollMode="Disabled"
                                      ZoomMode="Disabled">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Style="{StaticResource DialogToolbarButton}"
                                        Command="{x:Bind SiteEditor.ToggleProxyBatchTemplateRowsTestInclusionCommand}"
                                        AutomationProperties.Name="切换所有入口行是否加入测试计划"
                                        ToolTipService.ToolTip="切换所有入口行是否加入测试计划">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8FD;" />
                                        <TextBlock FontSize="11" MaxWidth="112" Text="&#x5168;&#x90E8;&#x52A0;&#x5165;/&#x8DF3;&#x8FC7;" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource DialogToolbarButton}"
                                        Command="{x:Bind SiteEditor.ClearProxyBatchTemplateEmptyRowsCommand}"
                                        AutomationProperties.Name="移除空白入口行"
                                        ToolTipService.ToolTip="移除空白入口行">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE74D;" />
                                        <TextBlock FontSize="11" MaxWidth="92" Text="&#x6E05;&#x7406;&#x7A7A;&#x767D;&#x884C;" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource DialogToolbarButton}"
                                        Command="{x:Bind SiteEditor.ResetProxyBatchEditorFormCommand}"
                                        AutomationProperties.Name="清空批量入口草稿"
                                        ToolTipService.ToolTip="清空批量入口草稿">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE72C;" />
                                        <TextBlock FontSize="11" MaxWidth="84" Text="&#x6E05;&#x7A7A;&#x8349;&#x7A3F;" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource DialogToolbarButton}"
                                        Command="{x:Bind SiteEditor.DeleteProxyBatchEditorItemCommand}"
                                        AutomationProperties.Name="删除选中的站点组"
                                        ToolTipService.ToolTip="删除选中的站点组">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Foreground="{ThemeResource DialogDangerChipForegroundBrush}" Glyph="&#xE74D;" />
                                        <TextBlock FontSize="11" MaxWidth="96" Text="&#x5220;&#x9664;&#x7AD9;&#x70B9;&#x7EC4;" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource AccentButtonStyle}"
                                        Padding="14,7"
                                        Command="{x:Bind SiteEditor.CommitProxyBatchEditorItemCommand}"
                                        AutomationProperties.Name="提交批量入口草稿"
                                        ToolTipService.ToolTip="提交批量入口草稿">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE74E;" />
                                        <TextBlock Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" MaxWidth="128" Text="{x:Bind SiteEditor.DraftPrimaryActionText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="8" RowSpacing="8" Tag="ResponsiveStack">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Style="{StaticResource DialogCaption}" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            <ScrollViewer Grid.Column="1"
                          MaxWidth="620"
                          HorizontalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          VerticalScrollMode="Disabled"
                          ZoomMode="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Style="{StaticResource DialogToolbarButton}"
                            Command="{x:Bind ViewModel.GenerateCandidatesCommand}"
                            AutomationProperties.Name="生成透明代理候选"
                            ToolTipService.ToolTip="生成透明代理候选">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8A5;" />
                            <TextBlock FontSize="11" MaxWidth="84" Text="&#x751F;&#x6210;&#x5019;&#x9009;" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DialogToolbarButton}"
                            Command="{x:Bind ViewModel.SyncToTransparentProxyCommand}"
                            AutomationProperties.Name="同步批量入口到透明代理"
                            ToolTipService.ToolTip="同步批量入口到透明代理">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8C8;" />
                            <TextBlock FontSize="11" MaxWidth="116" Text="&#x540C;&#x6B65;&#x900F;&#x660E;&#x4EE3;&#x7406;" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource AccentButtonStyle}"
                            Padding="14,7"
                            Command="{x:Bind ViewModel.RunProxyBatchCommand}"
                            AutomationProperties.Name="开始快速批量对比"
                            ToolTipService.ToolTip="开始快速批量对比">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE768;" />
                            <TextBlock Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" MaxWidth="122" Text="&#x5F00;&#x59CB;&#x5FEB;&#x901F;&#x5BF9;&#x6BD4;" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DialogToolbarButton}"
                            Command="{x:Bind ViewModel.CloseProxyBatchEditorCommand}"
                            AutomationProperties.Name="关闭批量入口编辑器"
                            ToolTipService.ToolTip="关闭批量入口编辑器">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE711;" />
                            <TextBlock FontSize="11" MaxWidth="48" Text="&#x5173;&#x95ED;" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
    </Border>
</UserControl>
