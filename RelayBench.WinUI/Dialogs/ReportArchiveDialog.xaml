<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="RelayBench.WinUI.Dialogs.ReportArchiveDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dialogs="using:RelayBench.WinUI.Dialogs"
    Title="&#x62A5;&#x544A;&#x5F52;&#x6863;"
    CloseButtonText="&#x5173;&#x95ED;"
    DefaultButton="Close">

    <ScrollViewer MaxHeight="640"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Border Padding="16"
                CornerRadius="10"
                Background="{ThemeResource RxAcrylicOverlayBrush}"
                BorderBrush="{ThemeResource ContentDialogBorderBrush}"
                BorderThickness="1">
            <StackPanel Spacing="14" MinWidth="0" MaxWidth="900">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="10" IsStaggeringEnabled="True" />
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="42" Height="42" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1" CornerRadius="12">
                        <FontIcon HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  FontSize="20"
                                  Foreground="{ThemeResource DialogAccentChipForegroundBrush}"
                                  Glyph="&#xE8A7;" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" MinWidth="0">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="&#x62A5;&#x544A;&#x5F52;&#x6863;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind HeaderSummary, Mode=OneWay}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" />
                    </StackPanel>
                    <Button Grid.Column="2"
                            Padding="9,5"
                            Click="OnCopySummaryClick"
                            AutomationProperties.Name="复制归档摘要"
                            ToolTipService.ToolTip="复制归档摘要">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8C8;" />
                            <TextBlock FontSize="12" Text="&#x590D;&#x5236;" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="3"
                            Padding="9,5"
                            Click="OnOpenExportRootClick"
                            AutomationProperties.Name="打开归档导出目录"
                            ToolTipService.ToolTip="打开归档导出目录">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE838;" />
                            <TextBlock FontSize="12" Text="&#x76EE;&#x5F55;" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <TextBlock FontFamily="Cascadia Mono, Consolas"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind SummaryText, Mode=OneWay}"
                               TextWrapping="WrapWholeWords"
                               MaxLines="8" />
                </Border>

                <ListView x:Name="ArchiveList"
                          ItemsSource="{x:Bind Items, Mode=OneWay}"
                          SelectionMode="None"
                          MaxHeight="430">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="dialogs:ReportArchiveDialogItem">
                            <Border Padding="12,10"
                                    Margin="0,0,0,8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Width="34" Height="34">
                                        <Border Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1" CornerRadius="9" Visibility="{x:Bind ZipKindVisibility}">
                                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="15" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Glyph="{x:Bind KindGlyph}" />
                                        </Border>
                                        <Border Background="{ThemeResource DialogSuccessChipBackgroundBrush}" BorderBrush="{ThemeResource DialogSuccessChipBorderBrush}" BorderThickness="1" CornerRadius="9" Visibility="{x:Bind BundleKindVisibility}">
                                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="15" Foreground="{ThemeResource DialogSuccessChipForegroundBrush}" Glyph="{x:Bind KindGlyph}" />
                                        </Border>
                                        <Border Background="{ThemeResource DialogWarningChipBackgroundBrush}" BorderBrush="{ThemeResource DialogWarningChipBorderBrush}" BorderThickness="1" CornerRadius="9" Visibility="{x:Bind ReportKindVisibility}">
                                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="15" Foreground="{ThemeResource DialogWarningChipForegroundBrush}" Glyph="{x:Bind KindGlyph}" />
                                        </Border>
                                        <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="9" Visibility="{x:Bind FallbackKindVisibility}">
                                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="{x:Bind KindGlyph}" />
                                        </Border>
                                    </Grid>
                                    <StackPanel Grid.Column="1" Spacing="3">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Path}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="3">
                                        <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="更新时间" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11" Text="{x:Bind LastWriteTimeText}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Spacing="3">
                                        <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="大小" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11" Text="{x:Bind Size}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button Grid.Column="4"
                                            Padding="8,5"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            KeyDown="FlyoutButton_KeyDown"
                                            AutomationProperties.Name="打开归档项操作"
                                            ToolTipService.ToolTip="&#x5F52;&#x6863;&#x64CD;&#x4F5C;">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE712;" />
                                        <Button.Flyout>
                                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                <MenuFlyoutItem Text="&#x6253;&#x5F00;&#x5F52;&#x6863;&#x4F4D;&#x7F6E;" AccessKey="O" Click="OnOpenArchiveClick" Tag="{x:Bind Path}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE838;" />
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutSubItem Text="&#x590D;&#x5236;" AccessKey="C">
                                                    <MenuFlyoutSubItem.Icon>
                                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8C8;" />
                                                    </MenuFlyoutSubItem.Icon>
                                                    <MenuFlyoutItem Text="&#x5F52;&#x6863;&#x8DEF;&#x5F84;" AccessKey="P" Click="OnCopyArchivePathClick" Tag="{x:Bind Path}">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE838;" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutItem Text="&#x5F52;&#x6863;&#x6458;&#x8981;" AccessKey="S" Click="OnCopyArchiveSummaryClick" Tag="{x:Bind Summary}">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE9D9;" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                </MenuFlyoutSubItem>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border Padding="14,18"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{x:Bind EmptyVisibility, Mode=OneWay}">
                    <StackPanel HorizontalAlignment="Center" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="22" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Glyph="&#xE8A7;" />
                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x6682;&#x65E0;&#x5BFC;&#x51FA;&#x5F52;&#x6863;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="&#x5728;&#x5386;&#x53F2;&#x62A5;&#x544A;&#x91CC;&#x5BFC;&#x51FA;&#x62A5;&#x544A;&#x5305;&#x540E;&#xFF0C;&#x6700;&#x8FD1;&#x7684; zip&#x3001;bundle &#x6216;&#x5355;&#x62A5;&#x544A;&#x76EE;&#x5F55;&#x4F1A;&#x51FA;&#x73B0;&#x5728;&#x8FD9;&#x91CC;&#x3002;"
                                   TextWrapping="Wrap"
                                   MaxLines="3"
                                   TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </ScrollViewer>
</ContentDialog>
