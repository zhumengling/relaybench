<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="RelayBench.WinUI.Dialogs.RouteEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RelayBench.WinUI.ViewModels"
    Title="&#x7F16;&#x8F91;&#x8DEF;&#x7531;"
    PrimaryButtonText="&#x4FDD;&#x5B58;"
    CloseButtonText="&#x53D6;&#x6D88;"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="False">

    <ContentDialog.Resources>
        <Style x:Key="RouteEditorGlassCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="RouteEditorSubtleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="RouteEditorCompactTextBox" TargetType="TextBox">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock
                            MaxWidth="220"
                            Text="{Binding}"
                            TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RouteEditorCompactComboBox" TargetType="ComboBox">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock
                            MaxWidth="220"
                            Text="{Binding}"
                            TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RouteEditorCompactNumberBox" TargetType="NumberBox">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock
                            MaxWidth="220"
                            Text="{Binding}"
                            TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RouteEditorCompactToggleSwitch" TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="OnContent" Value="" />
            <Setter Property="OffContent" Value="" />
        </Style>
    </ContentDialog.Resources>

    <ScrollViewer MaxHeight="640"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  VerticalScrollMode="Auto"
                  ZoomMode="Disabled">
        <Border Padding="14"
                CornerRadius="10"
                Background="{ThemeResource RxAcrylicOverlayBrush}"
                BorderBrush="{ThemeResource ContentDialogBorderBrush}"
                BorderThickness="1">
    <StackPanel Spacing="16" MinWidth="0" MaxWidth="920">
        <StackPanel.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="10" IsStaggeringEnabled="True" />
                <RepositionThemeTransition />
            </TransitionCollection>
        </StackPanel.ChildrenTransitions>

        <Border Style="{StaticResource RouteEditorGlassCard}" Padding="12,10">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="34" Height="34" CornerRadius="17" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1">
                    <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="16" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Glyph="&#xE8A7;" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="2" MinWidth="0">
                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="&#x8DEF;&#x7531;&#x914D;&#x7F6E;&#x4E2D;&#x5FC3;" TextTrimming="CharacterEllipsis" />
                    <TextBlock Style="{StaticResource RouteEditorSubtleText}" Text="&#x8BBE;&#x7F6E;&#x4E0A;&#x6E38;&#x3001;&#x534F;&#x8BAE;&#x3001;&#x91CD;&#x8BD5;&#x3001;Codex OAuth &#x4E0E;&#x8BF7;&#x6C42;&#x89C4;&#x5219;&#xFF1B;&#x6240;&#x6709;&#x6539;&#x52A8;&#x4F1A;&#x4FDD;&#x5B58;&#x5230;&#x900F;&#x660E;&#x4EE3;&#x7406;&#x8DEF;&#x7531;&#x8868;&#x3002;" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" />
                </StackPanel>
                <ScrollViewer Grid.Column="2"
                              MaxWidth="240"
                              HorizontalScrollBarVisibility="Auto"
                              HorizontalScrollMode="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              VerticalScrollMode="Disabled"
                              ZoomMode="Disabled">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Border Padding="7,3" CornerRadius="10" Background="{ThemeResource DialogSuccessChipBackgroundBrush}" BorderBrush="{ThemeResource DialogSuccessChipBorderBrush}" BorderThickness="1">
                            <TextBlock FontSize="10" Foreground="{ThemeResource DialogSuccessChipForegroundBrush}" MaxWidth="86" Text="Codex OAuth" TextTrimming="CharacterEllipsis" />
                        </Border>
                        <Border Padding="7,3" CornerRadius="10" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1">
                            <TextBlock FontSize="10" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" MaxWidth="146" Text="Responses / Chat / Anthropic" TextTrimming="CharacterEllipsis" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Name field -->
        <StackPanel Spacing="4">
            <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x8DEF;&#x7531;&#x540D;&#x79F0;" TextTrimming="CharacterEllipsis" />
            <TextBox x:Name="NameBox"
                     PlaceholderText="&#x4F8B;&#x5982;: OpenAI &#x4E3B;&#x5165;&#x53E3;"
                     MaxLength="64"
                     TextChanged="OnNameChanged" />
            <TextBlock x:Name="NameError"
                       FontSize="11"
                       Foreground="{ThemeResource DialogDangerChipForegroundBrush}"
                       Visibility="Collapsed" />
        </StackPanel>

        <!-- Upstream URL field -->
        <StackPanel Spacing="4">
            <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x4E0A;&#x6E38; URL" TextTrimming="CharacterEllipsis" />
            <TextBox x:Name="UrlBox"
                     PlaceholderText="https://api.openai.com/v1"
                     TextChanged="OnUrlChanged" />
            <TextBlock x:Name="UrlError"
                       FontSize="11"
                       Foreground="{ThemeResource DialogDangerChipForegroundBrush}"
                       Visibility="Collapsed" />
        </StackPanel>

        <!-- API Key field -->
        <StackPanel Spacing="4">
            <TextBlock FontSize="13" FontWeight="SemiBold" Text="API &#x5BC6;&#x94A5;" TextTrimming="CharacterEllipsis" />
            <PasswordBox x:Name="ApiKeyBox"
                         PlaceholderText="&#x53EF;&#x9009;&#xFF0C;&#x5B58;&#x50A8;&#x65F6;&#x52A0;&#x5BC6;"
                         PasswordChanged="OnApiKeyChanged" />
        </StackPanel>

        <!-- Priority field -->
        <StackPanel Spacing="4">
            <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x4F18;&#x5148;&#x7EA7; (0&#x2013;100)" TextTrimming="CharacterEllipsis" />
            <NumberBox x:Name="PriorityBox"
                       Minimum="0"
                       Maximum="100"
                       SpinButtonPlacementMode="Compact"
                       Value="0"
                       ValueChanged="OnPriorityChanged"
                       AutomationProperties.Name="路由优先级"
                       ToolTipService.ToolTip="设置透明代理路由优先级，范围 0 到 100" />
            <TextBlock x:Name="PriorityError"
                       FontSize="11"
                       Foreground="{ThemeResource DialogDangerChipForegroundBrush}"
                       Visibility="Collapsed" />
        </StackPanel>

        <!-- Model Filter field -->
        <StackPanel Spacing="4">
            <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x6A21;&#x578B;&#x8FC7;&#x6EE4;&#x5668;" TextTrimming="CharacterEllipsis" />
            <TextBox x:Name="ModelFilterBox"
                     PlaceholderText="&#x53EF;&#x9009;&#xFF0C;&#x4F8B;&#x5982;: gpt-4*" />
            <Border Margin="0,6,0,0"
                    Padding="10"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="&#x8DEF;&#x7531;&#x6A21;&#x578B;&#x6620;&#x5C04;" TextTrimming="CharacterEllipsis" />
                            <TextBlock Style="{StaticResource RouteEditorSubtleText}"
                                       Text="&#x4F7F;&#x7528; upstream=&gt;public &#x683C;&#x5F0F;&#x7ED1;&#x5B9A;&#x8BE5;&#x8DEF;&#x7531;&#x7684;&#x4E0A;&#x6E38;&#x6A21;&#x578B;&#x4E0E;&#x5BF9;&#x5916;&#x540D;&#x79F0;&#x3002;"
                                       TextWrapping="WrapWholeWords"
                                       MaxLines="2" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Padding="8,4"
                                MinHeight="28"
                                KeyDown="FlyoutButton_KeyDown"
                                AutomationProperties.Name="打开 Thinking 后缀示例"
                                ToolTipService.ToolTip="模型别名的 Thinking 后缀示例">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Glyph="&#xE946;" />
                                <TextBlock FontSize="11" Text="Thinking" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                    <MenuFlyoutSubItem Text="Thinking 后缀" AccessKey="T">
                                        <MenuFlyoutSubItem.Icon>
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE946;" />
                                        </MenuFlyoutSubItem.Icon>
                                        <MenuFlyoutItem Text="插入 gpt-5.5(8192)" AccessKey="B" Click="OnInsertThinkingBudgetModelClick">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8EF;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="插入 gpt-5.5(high)" AccessKey="H" Click="OnInsertThinkingHighModelClick">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8A1;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="插入 claude-opus-4-6(max)" AccessKey="M" Click="OnInsertThinkingMaxModelClick">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE7C1;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="插入 gpt-5.5(auto)" AccessKey="A" Click="OnInsertThinkingAutoModelClick">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE895;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="插入 gpt-5.5(none)" AccessKey="N" Click="OnInsertThinkingNoneModelClick">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE711;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyoutSubItem>
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="复制后缀指南" AccessKey="C" Click="OnCopyThinkingSuffixGuideClick">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8C8;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <Button Grid.Column="2"
                                Padding="8,4"
                                MinHeight="28"
                                Click="OnAddModelMappingClick"
                                AutomationProperties.Name="添加路由模型映射"
                                ToolTipService.ToolTip="&#x6DFB;&#x52A0;&#x4E00;&#x6761;&#x8DEF;&#x7531;&#x7EA7;&#x6A21;&#x578B;&#x6620;&#x5C04;">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Glyph="&#xE710;" />
                                <TextBlock FontSize="11" Text="&#x6DFB;&#x52A0;" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind RouteModelMappings}"
                              MaxHeight="132"
                              Padding="0"
                              SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ModelRewriteRule">
                                <Grid Padding="0,4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox PlaceholderText="上游模型"
                                             Text="{x:Bind SourceModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Column="1"
                                             PlaceholderText="对外别名"
                                             Text="{x:Bind TargetModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2"
                                            Padding="6,4"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="OnRemoveModelMappingClick"
                                            AutomationProperties.Name="移除路由模型映射"
                                            ToolTipService.ToolTip="&#x79FB;&#x9664;&#x6620;&#x5C04;">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Glyph="&#xE74D;" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock FontSize="13" FontWeight="SemiBold" Text="&#x9AD8;&#x7EA7;&#x8DEF;&#x7531;" TextTrimming="CharacterEllipsis" />
            <Grid ColumnSpacing="8" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="PrefixBox"
                         Style="{StaticResource RouteEditorCompactTextBox}"
                         Header="&#x6A21;&#x578B;&#x524D;&#x7F00;"
                         PlaceholderText="&#x53EF;&#x9009;&#xFF0C;&#x4F8B;&#x5982; openai/" />
                <TextBox x:Name="OutboundProxyBox"
                         Grid.Column="1"
                         Style="{StaticResource RouteEditorCompactTextBox}"
                         Header="&#x51FA;&#x7AD9;&#x4EE3;&#x7406;"
                         PlaceholderText="direct / socks5h://127.0.0.1:7890"
                         TextChanged="OnOutboundProxyChanged" />

                <NumberBox x:Name="RequestRetryBox"
                           Grid.Row="1"
                           Style="{StaticResource RouteEditorCompactNumberBox}"
                           Header="&#x8BF7;&#x6C42;&#x91CD;&#x8BD5;"
                           Minimum="0"
                           Maximum="8"
                           SpinButtonPlacementMode="Compact"
                           PlaceholderText="&#x8DDF;&#x968F;&#x5168;&#x5C40;" />
                <NumberBox x:Name="RetryIntervalBox"
                           Grid.Row="1"
                           Grid.Column="1"
                           Style="{StaticResource RouteEditorCompactNumberBox}"
                           Header="&#x6700;&#x5927;&#x91CD;&#x8BD5;&#x95F4;&#x9694; (s)"
                           Minimum="1"
                           Maximum="60"
                           SpinButtonPlacementMode="Compact"
                           PlaceholderText="&#x8DDF;&#x968F;&#x5168;&#x5C40;" />

                <NumberBox x:Name="ModelCooldownBox"
                           Grid.Row="2"
                           Style="{StaticResource RouteEditorCompactNumberBox}"
                           Header="&#x6A21;&#x578B;&#x51B7;&#x5374; (s)"
                           Minimum="0"
                           Maximum="3600"
                           SpinButtonPlacementMode="Compact"
                           PlaceholderText="&#x8DDF;&#x968F;&#x5168;&#x5C40;" />
                <TextBox x:Name="ExcludedModelsBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Style="{StaticResource RouteEditorCompactTextBox}"
                         Header="&#x6392;&#x9664;&#x6A21;&#x578B;"
                         PlaceholderText="&#x9017;&#x53F7;&#x5206;&#x9694;&#xFF0C;&#x4F8B;&#x5982; *vision*, legacy*" />

                <ComboBox x:Name="PreferredWireApiBox"
                         Grid.Row="3"
                         Style="{StaticResource RouteEditorCompactComboBox}"
                         Header="&#x4F18;&#x5148;&#x534F;&#x8BAE;"
                         HorizontalAlignment="Stretch"
                         SelectedIndex="0">
                    <ComboBoxItem Tag="" Content="&#x81EA;&#x52A8;&#x63A2;&#x6D4B;" />
                    <ComboBoxItem Tag="responses" Content="Responses API" />
                    <ComboBoxItem Tag="chat" Content="OpenAI Chat" />
                    <ComboBoxItem Tag="anthropic" Content="Anthropic Messages" />
                </ComboBox>
                <ComboBox x:Name="AuthModeBox"
                         Grid.Row="3"
                         Grid.Column="1"
                         Style="{StaticResource RouteEditorCompactComboBox}"
                         Header="&#x8BA4;&#x8BC1;&#x6A21;&#x5F0F;"
                         HorizontalAlignment="Stretch"
                         SelectedIndex="0"
                         SelectionChanged="OnAuthModeChanged">
                    <ComboBoxItem Tag="ApiKey" Content="API Key" />
                    <ComboBoxItem Tag="CodexOAuth" Content="Codex OAuth" />
                </ComboBox>

                <Grid x:Name="CodexOAuthOptionsGrid"
                         Grid.Row="4"
                         Grid.ColumnSpan="2"
                         ColumnSpacing="8"
                         RowSpacing="8"
                         Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="OAuthProviderBox"
                             Style="{StaticResource RouteEditorCompactTextBox}"
                             Header="OAuth 提供方"
                             Text="codex"
                             IsReadOnly="True"
                             ToolTipService.ToolTip="&#x8DEF;&#x7531;&#x7EA7; OAuth &#x4EC5;&#x652F;&#x6301; Codex&#xFF0C;&#x4E0D;&#x66B4;&#x9732;&#x5176;&#x4ED6; OAuth &#x767B;&#x5F55;&#x9762;&#x3002;" />
                    <TextBox x:Name="OAuthCredentialIdBox"
                             Grid.Column="1"
                             Style="{StaticResource RouteEditorCompactTextBox}"
                             Header="Codex OAuth 凭据"
                             PlaceholderText="&#x53EF;&#x9009;&#xFF0C;OAuth &#x51ED;&#x636E; ID" />
                    <TextBox x:Name="CodexBackendBaseUrlBox"
                             Grid.Row="1"
                             Grid.ColumnSpan="2"
                             Style="{StaticResource RouteEditorCompactTextBox}"
                             Header="Codex 后端"
                             PlaceholderText="&#x53EF;&#x9009;&#xFF0C;&#x4F8B;&#x5982; https://chatgpt.com/backend-api/codex" />
                    <Border Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Padding="11,9"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Text="Codex OAuth FAST" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="&#x53D1;&#x9001; service_tier=&quot;priority&quot; &#x4EE5;&#x964D;&#x4F4E;&#x5EF6;&#x8FDF;&#xFF1B;&#x9ED8;&#x8BA4;&#x5173;&#x95ED;&#xFF0C;&#x4F1A;&#x66F4;&#x5FEB;&#x6D88;&#x8017; ChatGPT &#x914D;&#x989D;&#x3002;"
                                           TextWrapping="WrapWholeWords"
                                           MaxLines="3" />
                            </StackPanel>
                            <ToggleSwitch x:Name="CodexOAuthFastModeSwitch"
                                          Grid.Column="1"
                                          Style="{StaticResource RouteEditorCompactToggleSwitch}"
                                          VerticalAlignment="Center"
                                          AutomationProperties.Name="Codex OAuth 快速模式"
                                          ToolTipService.ToolTip="&#x4EC5;&#x5BF9; Codex OAuth &#x8DEF;&#x7531;&#x751F;&#x6548;&#x3002;" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            <TextBlock x:Name="OutboundProxyStatus"
                       Style="{StaticResource RouteEditorSubtleText}"
                       Text="&#x672A;&#x914D;&#x7F6E;&#x51FA;&#x7AD9;&#x4EE3;&#x7406;&#xFF0C;&#x4F7F;&#x7528;&#x7CFB;&#x7EDF;&#x76F4;&#x8FDE;"
                       TextWrapping="WrapWholeWords"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="2" />
            <StackPanel Spacing="6">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="Header JSON" TextTrimming="CharacterEllipsis" />
                    <Button Grid.Column="1"
                            Padding="8,4"
                            MinHeight="28"
                            Click="OnFormatHeadersClick"
                            AutomationProperties.Name="格式化 Header JSON"
                            ToolTipService.ToolTip="格式化 Header JSON">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Glyph="&#xE8D2;" />
                            <TextBlock FontSize="11" MaxWidth="74" Text="&#x683C;&#x5F0F;&#x5316;" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button>
                </Grid>
                <TextBox x:Name="HeadersBox"
                         PlaceholderText="&#x53EF;&#x9009;&#xFF0C;&#x4F8B;&#x5982; { &quot;x-provider&quot;: &quot;openai&quot; }"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MaxHeight="96"
                         TextChanged="OnHeadersChanged" />
                <TextBlock x:Name="HeadersStatus"
                           Style="{StaticResource RouteEditorSubtleText}"
                           Text="&#x672A;&#x914D;&#x7F6E;&#x81EA;&#x5B9A;&#x4E49; Header"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <StackPanel Spacing="6">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="Payload &#x89C4;&#x5219; JSON" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="PayloadRuleSummary"
                                   Style="{StaticResource RouteEditorSubtleText}"
                                   Text="&#x672A;&#x914D;&#x7F6E; Payload &#x89C4;&#x5219;"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Padding="8,4"
                            MinHeight="28"
                            Click="OnFormatPayloadRulesClick"
                            AutomationProperties.Name="格式化 payload 规则 JSON"
                            ToolTipService.ToolTip="格式化 payload 规则 JSON">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Glyph="&#xE8D2;" />
                            <TextBlock FontSize="11" MaxWidth="74" Text="&#x683C;&#x5F0F;&#x5316;" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2"
                            Padding="8,4"
                            MinHeight="28"
                            KeyDown="FlyoutButton_KeyDown"
                            AutomationProperties.Name="插入 payload 规则示例"
                            ToolTipService.ToolTip="插入 payload 规则示例">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Glyph="&#xE8B7;" />
                                <TextBlock FontSize="11" MaxWidth="88" Text="&#x63D2;&#x5165;&#x793A;&#x4F8B;" TextTrimming="CharacterEllipsis" />
