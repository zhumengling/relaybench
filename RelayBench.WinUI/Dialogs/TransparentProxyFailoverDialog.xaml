<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="RelayBench.WinUI.Dialogs.TransparentProxyFailoverDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RelayBench.WinUI.ViewModels"
    Title="故障转移"
    CloseButtonText="&#x5173;&#x95ED;"
    DefaultButton="Close">

    <ScrollViewer MaxHeight="640"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Border Padding="16"
                CornerRadius="10"
                Background="{ThemeResource RxAcrylicOverlayBrush}"
                BorderBrush="{ThemeResource ContentDialogBorderBrush}"
                BorderThickness="1">
            <StackPanel Spacing="14" MinWidth="0" MaxWidth="960">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="10" IsStaggeringEnabled="True" />
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="42" Height="42" Background="{ThemeResource DialogWarningChipBackgroundBrush}" BorderBrush="{ThemeResource DialogWarningChipBorderBrush}" BorderThickness="1" CornerRadius="12">
                        <FontIcon HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  FontSize="20"
                                  Foreground="{ThemeResource DialogWarningChipForegroundBrush}"
                                  Glyph="&#xE9D9;" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" MinWidth="0">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="&#x6545;&#x969C;&#x8F6C;&#x79FB;&#x4E0E;&#x7194;&#x65AD;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="&#x6309;&#x8DEF;&#x7531;&#x4F18;&#x5148;&#x7EA7;&#x6267;&#x884C;&#x56DE;&#x9000;&#xFF0C;&#x7194;&#x65AD;&#x540E;&#x4F1A;&#x6682;&#x65F6;&#x8DF3;&#x8FC7;&#x5F02;&#x5E38;&#x4E0A;&#x6E38;&#x3002;"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="2" />
                    </StackPanel>
                    <Border Grid.Column="2" MaxWidth="180" Padding="8,4" VerticalAlignment="Center" Background="{ThemeResource DialogSuccessChipBackgroundBrush}" BorderBrush="{ThemeResource DialogSuccessChipBorderBrush}" BorderThickness="1" CornerRadius="10">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource DialogSuccessChipForegroundBrush}" Text="{x:Bind ViewModel.PolicyOverviewTitle, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </Border>
                </Grid>

                <Grid ColumnSpacing="10" Tag="ResponsiveStack">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="自动故障转移" TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x5F00;&#x542F;&#x540E;&#xFF0C;&#x8BF7;&#x6C42;&#x5931;&#x8D25;&#x4F1A;&#x6309;&#x8DEF;&#x7531;&#x961F;&#x5217;&#x7EE7;&#x7EED;&#x5C1D;&#x8BD5;&#xFF1B;&#x5173;&#x95ED;&#x65F6;&#x4EC5;&#x5C1D;&#x8BD5;&#x9996;&#x4E2A;&#x547D;&#x4E2D;&#x8DEF;&#x7531;&#x3002;" TextWrapping="Wrap" MaxLines="3" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" MinWidth="0" IsOn="{x:Bind ViewModel.EnableFallback, Mode=TwoWay}"
                                              AutomationProperties.Name="启用透明代理自动故障转移"
                                              ToolTipService.ToolTip="启用或停用透明代理自动故障转移" />
                            </Grid>

                            <Grid ColumnSpacing="10" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="96" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x5168;&#x5C40;&#x91CD;&#x8BD5;" TextTrimming="CharacterEllipsis" />
                                <NumberBox Grid.Column="1" Minimum="0" Maximum="10" Value="{x:Bind ViewModel.RequestRetry, Mode=TwoWay}" SpinButtonPlacementMode="Compact"
                                           AutomationProperties.Name="透明代理全局重试次数"
                                           ToolTipService.ToolTip="设置透明代理全局重试次数" />
                                <TextBlock Grid.Row="1" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x6700;&#x5927;&#x91CD;&#x8BD5;&#x95F4;&#x9694;" TextTrimming="CharacterEllipsis" />
                                <NumberBox Grid.Row="1" Grid.Column="1" Minimum="1" Maximum="300" Value="{x:Bind ViewModel.MaxRetryIntervalSeconds, Mode=TwoWay}" SpinButtonPlacementMode="Compact"
                                           AutomationProperties.Name="透明代理最大重试间隔秒数"
                                           ToolTipService.ToolTip="设置最大重试间隔秒数" />
                                <TextBlock Grid.Row="2" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x6A21;&#x578B;&#x51B7;&#x5374;" TextTrimming="CharacterEllipsis" />
                                <NumberBox Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="1800" Value="{x:Bind ViewModel.ModelCooldownSeconds, Mode=TwoWay}" SpinButtonPlacementMode="Compact"
                                           AutomationProperties.Name="透明代理模型冷却秒数"
                                           ToolTipService.ToolTip="设置透明代理失败后的模型冷却时间" />
                                <TextBlock Grid.Row="3" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x4E0A;&#x6E38;&#x8D85;&#x65F6;" TextTrimming="CharacterEllipsis" />
                                <NumberBox Grid.Row="3" Grid.Column="1" Minimum="1" Maximum="1200" Value="{x:Bind ViewModel.UpstreamTimeoutSeconds, Mode=TwoWay}" SpinButtonPlacementMode="Compact"
                                           AutomationProperties.Name="透明代理上游超时秒数"
                                           ToolTipService.ToolTip="设置透明代理故障转移的上游超时秒数" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="&#x7B56;&#x7565;&#x6458;&#x8981;" TextTrimming="CharacterEllipsis" />
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.PolicyStatusItems, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical" Spacing="7" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TransparentProxyPolicyStatusItem">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="86" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" FontSize="11" Text="{x:Bind Detail}" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="2" Padding="6,2" CornerRadius="8" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1">
                                                <TextBlock FontSize="10" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Text="{x:Bind BadgeText}" TextTrimming="CharacterEllipsis" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="&#x8DEF;&#x7531;&#x5065;&#x5EB7;&#x961F;&#x5217;" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.ActiveRoutes, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.RouteQueue, Mode=OneWay}" SelectionMode="None" MaxHeight="330">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="MinHeight" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:RouteQueueEntry">
                                    <Grid ColumnSpacing="10" Padding="0,7" ToolTipService.ToolTip="{x:Bind DetailToolTip}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                            <ColumnDefinition Width="82" />
                                            <ColumnDefinition Width="84" />
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="1">
                                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind RouteName}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind PolicyDisplay}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" FontSize="11" Text="{x:Bind Protocol}" TextAlignment="Right" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" FontSize="11" Text="{x:Bind ReliabilityDisplay}" TextAlignment="Right" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3" FontSize="11" Text="{x:Bind ThrottleDisplay}" TextAlignment="Right" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="4" FontSize="11" Text="{x:Bind StatusText}" TextAlignment="Right" TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="5" Padding="7,4" IsEnabled="{x:Bind HasRouteId}" Click="OnResetRouteCircuitClick" AutomationProperties.Name="重置透明代理路由熔断器" ToolTipService.ToolTip="重置熔断器">
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE777;" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="15" Foreground="{ThemeResource DialogWarningChipForegroundBrush}" Glyph="&#xE946;" />
                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ResetStatusText, Mode=OneWay}" TextWrapping="Wrap" MaxLines="2" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </ScrollViewer>
</ContentDialog>
