<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="RelayBench.WinUI.Dialogs.TransparentProxyOAuthDialog"
    x:Name="ProviderDialogRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RelayBench.WinUI.ViewModels"
    Title="AI 提供商管理"
    CloseButtonText="关闭"
    DefaultButton="Close"
    MaxWidth="1280"
    HorizontalAlignment="Center"
    HorizontalContentAlignment="Center">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">420</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">1280</x:Double>

        <Style x:Key="ProviderManagerCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="ProviderManagerSubtleCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="ProviderManagerCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="ProviderManagerSectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="ProviderManagerIconButton" TargetType="Button" BasedOn="{StaticResource AppToolbarButton}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ProviderManagerRowButton" TargetType="Button" BasedOn="{StaticResource AppToolbarButton}">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ProviderManagerToggleSwitch" TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="OnContent" Value="" />
            <Setter Property="OffContent" Value="" />
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ContentDialog.Resources>

    <ScrollViewer x:Name="ProviderManagerScroll"
                  MaxHeight="820"
                  HorizontalAlignment="Stretch"
                  MaxWidth="1240"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  VerticalScrollMode="Auto"
                  ZoomMode="Disabled">
        <Border Padding="14"
                HorizontalAlignment="Stretch"
                CornerRadius="10"
                Background="{ThemeResource RxAcrylicOverlayBrush}"
                BorderBrush="{ThemeResource ContentDialogBorderBrush}"
                BorderThickness="1">
            <Grid x:Name="ProviderManagerSurface"
                  MaxWidth="1180"
                  MinWidth="0"
                  HorizontalAlignment="Stretch"
                  RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource ProviderManagerCard}" Padding="14,12">
                    <Grid ColumnSpacing="12" Tag="ResponsiveStack">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Width="44"
                                Height="44"
                                CornerRadius="12"
                                Background="{ThemeResource DialogAccentChipBackgroundBrush}"
                                BorderBrush="{ThemeResource DialogAccentChipBorderBrush}"
                                BorderThickness="1">
                            <FontIcon HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      FontFamily="{StaticResource SymbolThemeFontFamily}"
                                      FontSize="20"
                                      Foreground="{ThemeResource DialogAccentChipForegroundBrush}"
                                      Glyph="&#xE774;" />
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center" MinWidth="0">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="AI 提供商管理" TextTrimming="CharacterEllipsis" />
                            <TextBlock Style="{StaticResource ProviderManagerCaption}"
                                       Text="{x:Bind ViewModel.ProviderAccountSummary, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords"
                                       MaxLines="2" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                Style="{StaticResource AppToolbarButton}"
                                Click="OnRefreshProviderViewClick"
                                AutomationProperties.Name="刷新 AI 提供商管理状态"
                                ToolTipService.ToolTip="刷新路由、OAuth 和配额状态">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE72C;" />
                                <TextBlock FontSize="12" Text="刷新状态" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <NavigationView x:Name="ProviderNavigation"
                                Grid.Row="1"
                                MinWidth="0"
                                PaneDisplayMode="Left"
                                OpenPaneLength="216"
                                CompactPaneLength="48"
                                IsBackButtonVisible="Collapsed"
                                IsSettingsVisible="False"
                                IsPaneOpen="True"
                                AlwaysShowHeader="False"
                                CompactModeThresholdWidth="720"
                                ExpandedModeThresholdWidth="920"
                                SelectionChanged="OnProviderNavigationSelectionChanged">
                    <NavigationView.MenuItems>
                        <NavigationViewItem Content="代理设置" Tag="proxy-settings">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE713;" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem Content="提供商" Tag="providers">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8D4;" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem Content="OAuth 与配额" Tag="oauth">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE77B;" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem Content="路由策略" Tag="strategy">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE9D9;" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem Content="模型别名" Tag="aliases">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8AB;" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem Content="运行状态" Tag="status">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE9D2;" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                    </NavigationView.MenuItems>

                    <Grid Padding="12,0,0,0" MinWidth="0">
                        <Grid x:Name="ProxySettingsSection" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="10" Tag="ResponsiveStack">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel MinWidth="0" Spacing="2">
                                    <TextBlock Style="{StaticResource ProviderManagerSectionTitle}" Text="代理设置" />
                                    <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="集中管理透明代理监听、缓存、限速、重试和诊断动作。" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource AppToolbarButton}"
                                        Command="{x:Bind ViewModel.DiscoverProtocolsCommand}"
                                        AutomationProperties.Name="刷新透明代理路由协议">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE72C;" />
                                        <TextBlock FontSize="12" Text="刷新协议" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Grid.Row="1" Style="{StaticResource ProviderManagerCard}" Padding="14,12">
                                <Grid ColumnSpacing="12" RowSpacing="10" Tag="ResponsiveStack">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource ProviderManagerSubtleCard}" Padding="12,10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="监听地址" />
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{x:Bind ViewModel.ListenAddress, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="HTTP(S) / HTTP2" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource ProviderManagerSubtleCard}" Padding="12,10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="本地入口" />
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{x:Bind ViewModel.LocalEndpoint, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource ProviderManagerSubtleCard}" Padding="12,10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="运行概览" />
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{x:Bind ViewModel.TokenSpeed, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{x:Bind ViewModel.ManagementSecuritySummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2" ColumnSpacing="12" RowSpacing="12" Tag="ResponsiveStack">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource ProviderManagerCard}" Padding="14,12" MinWidth="0">
                                    <StackPanel Spacing="12" MinWidth="0">
                                        <StackPanel Spacing="2">
                                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="缓存与限速" />
                                            <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="控制代理吞吐、响应缓存和会话亲和时间。" />
                                        </StackPanel>
                                        <Grid ColumnSpacing="10" RowSpacing="8" Tag="ResponsiveStack">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="4" MinWidth="0">
                                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="每分钟限速" />
                                                <NumberBox MinWidth="0" HorizontalAlignment="Stretch" Value="{x:Bind ViewModel.RateLimitPerMinute, Mode=TwoWay}" Minimum="1" Maximum="100000" SpinButtonPlacementMode="Compact" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="4" MinWidth="0">
                                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="并发上限" />
                                                <NumberBox MinWidth="0" HorizontalAlignment="Stretch" Value="{x:Bind ViewModel.MaxConcurrency, Mode=TwoWay}" Minimum="1" Maximum="512" SpinButtonPlacementMode="Compact" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Spacing="4" MinWidth="0">
                                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="缓存 TTL (秒)" />
                                                <NumberBox MinWidth="0" HorizontalAlignment="Stretch" Value="{x:Bind ViewModel.CacheTtlSeconds, Mode=TwoWay}" Minimum="0" Maximum="86400" SpinButtonPlacementMode="Compact" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" MinWidth="0">
                                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="会话亲和 TTL (秒)" />
                                                <NumberBox MinWidth="0" HorizontalAlignment="Stretch" Value="{x:Bind ViewModel.SessionAffinityTtlSeconds, Mode=TwoWay}" Minimum="30" Maximum="86400" SpinButtonPlacementMode="Compact" />
                                            </StackPanel>
                                            <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource ProviderManagerSubtleCard}" Padding="12,10">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="当前缓存命中" />
                                                        <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{x:Bind ViewModel.ResponseCacheSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" FontSize="18" FontWeight="SemiBold" Text="{x:Bind ViewModel.CacheHitRate, Mode=OneWay}" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource ProviderManagerCard}" Padding="14,12" MinWidth="0">
                                    <StackPanel Spacing="12" MinWidth="0">
                                        <StackPanel Spacing="2">
                                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="重试与安全" />
                                            <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="设置上游超时、故障切换和 TLS 行为。" />
                                        </StackPanel>
                                        <Grid ColumnSpacing="10" RowSpacing="8" Tag="ResponsiveStack">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="4" MinWidth="0">
                                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="上游超时 (秒)" />
                                                <NumberBox MinWidth="0" HorizontalAlignment="Stretch" Value="{x:Bind ViewModel.UpstreamTimeoutSeconds, Mode=TwoWay}" Minimum="1" Maximum="300" SpinButtonPlacementMode="Compact" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="4" MinWidth="0">
                                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="全局重试" />
                                                <NumberBox MinWidth="0" HorizontalAlignment="Stretch" Value="{x:Bind ViewModel.RequestRetry, Mode=TwoWay}" Minimum="0" Maximum="10" SpinButtonPlacementMode="Compact" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Spacing="4" MinWidth="0">
                                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="最大重试间隔 (秒)" />
                                                <NumberBox MinWidth="0" HorizontalAlignment="Stretch" Value="{x:Bind ViewModel.MaxRetryIntervalSeconds, Mode=TwoWay}" Minimum="1" Maximum="300" SpinButtonPlacementMode="Compact" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" MinWidth="0">
                                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="模型冷却 (秒)" />
                                                <NumberBox MinWidth="0" HorizontalAlignment="Stretch" Value="{x:Bind ViewModel.ModelCooldownSeconds, Mode=TwoWay}" Minimum="0" Maximum="3600" SpinButtonPlacementMode="Compact" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="8">
                                                <ToggleSwitch Style="{StaticResource ProviderManagerToggleSwitch}" Header="启用故障回退" IsOn="{x:Bind ViewModel.EnableFallback, Mode=TwoWay}" />
                                                <ToggleSwitch Style="{StaticResource ProviderManagerToggleSwitch}" Header="启用响应缓存" IsOn="{x:Bind ViewModel.EnableResponseCache, Mode=TwoWay}" />
                                                <ToggleSwitch Style="{StaticResource ProviderManagerToggleSwitch}" Header="忽略上游 TLS 错误" IsOn="{x:Bind ViewModel.IgnoreTlsErrors, Mode=TwoWay}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Grid.Row="3" Style="{StaticResource ProviderManagerCard}" Padding="14,12">
                                <Grid ColumnSpacing="12" RowSpacing="10" Tag="ResponsiveStack">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3" MinWidth="0">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="日志与观测" />
                                        <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{x:Bind ViewModel.SelfTestResult, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{x:Bind ViewModel.SelfTestLatency, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        <ProgressBar IsIndeterminate="True" Visibility="{x:Bind ViewModel.IsSelfTesting, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                        <Button Style="{StaticResource ProviderManagerRowButton}" Command="{x:Bind ViewModel.RunSelfTestCommand}">
                                            <TextBlock FontSize="12" Text="自测" />
                                        </Button>
                                        <Button Style="{StaticResource ProviderManagerRowButton}" Command="{x:Bind ViewModel.ClearTransparentProxyCacheCommand}">
                                            <TextBlock FontSize="12" Text="清缓存" />
                                        </Button>
                                        <Button Style="{StaticResource ProviderManagerRowButton}" Command="{x:Bind ViewModel.DiscoverProtocolsCommand}">
                                            <TextBlock FontSize="12" Text="刷新协议" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid x:Name="ProvidersSection" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="10" Tag="ResponsiveStack">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel MinWidth="0" Spacing="2">
                                    <TextBlock Style="{StaticResource ProviderManagerSectionTitle}" Text="提供商" />
                                    <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="管理 Claude API、OpenAI 兼容与 Codex API 上游，保存后会进入透明代理路由。" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource AppAccentToolbarButton}"
                                        Click="OnStartAddProviderClick"
                                        AutomationProperties.Name="新增 AI 提供商">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE710;" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Text="新增提供商" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Grid Grid.Row="1" ColumnSpacing="12" RowSpacing="12" Tag="ResponsiveStack">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="360" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource ProviderManagerCard}" Padding="0">
                                    <Grid RowSpacing="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid Padding="12,10" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="已配置提供商" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Style="{StaticResource ProviderManagerCaption}" Text="{x:Bind RouteItems.Count, Mode=OneWay}" />
                                        </Grid>

                                        <Grid Grid.Row="1">
                                            <ListView x:Name="ProviderRouteList"
                                                      ItemsSource="{x:Bind RouteItems, Mode=OneWay}"
                                                      SelectionMode="Single"
                                                      IsItemClickEnabled="True"
                                                      SelectionChanged="OnRouteSelectionChanged"
                                                      Padding="0"
                                                      MaxHeight="560">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="MinHeight" Value="0" />
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Padding="12,9" ColumnSpacing="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" ToolTipService.ToolTip="{Binding ToolTip}">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Spacing="3" MinWidth="0">
                                                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{Binding Endpoint}" TextTrimming="CharacterEllipsis" />
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{Binding KindName}" TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="·" />
                                                                    <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{Binding ProtocolName}" TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                            <Border Grid.Column="1"
                                                                    Padding="7,3"
                                                                    CornerRadius="9"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center"
                                                                    Background="{ThemeResource DialogAccentChipBackgroundBrush}"
                                                                    BorderBrush="{ThemeResource DialogAccentChipBorderBrush}"
                                                                    BorderThickness="1">
                                                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>

                                            <Border x:Name="ProviderEmptyState" Padding="18" Visibility="Collapsed">
                                                <StackPanel Spacing="12" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                                    <FontIcon HorizontalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="30" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Glyph="&#xE710;" />
                                                    <TextBlock HorizontalAlignment="Center" FontSize="15" FontWeight="SemiBold" Text="还没有提供商" />
                                                    <TextBlock HorizontalAlignment="Center" Style="{StaticResource ProviderManagerCaption}" Text="选择一种上游类型开始配置。" TextWrapping="WrapWholeWords" />
                                                    <Button HorizontalAlignment="Stretch" Style="{StaticResource AppToolbarButton}" Click="OnQuickAddProviderClick" Tag="openai-compatible">
                                                        <TextBlock HorizontalAlignment="Center" Text="添加 OpenAI 兼容" />
                                                    </Button>
                                                    <Button HorizontalAlignment="Stretch" Style="{StaticResource AppToolbarButton}" Click="OnQuickAddProviderClick" Tag="claude-api">
                                                        <TextBlock HorizontalAlignment="Center" Text="添加 Claude API" />
                                                    </Button>
                                                    <Button HorizontalAlignment="Stretch" Style="{StaticResource AppToolbarButton}" Click="OnQuickAddProviderClick" Tag="codex-api">
                                                        <TextBlock HorizontalAlignment="Center" Text="添加 Codex API" />
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1" RowSpacing="12">
                                    <Border x:Name="RouteDetailsPanel" Style="{StaticResource ProviderManagerCard}" Padding="14,12">
                                        <Grid RowSpacing="12">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid ColumnSpacing="10" Tag="ResponsiveStack">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel MinWidth="0" Spacing="3">
                                                    <TextBlock x:Name="RouteDetailTitle" FontSize="18" FontWeight="SemiBold" Text="选择一个提供商" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock x:Name="RouteDetailSubtitle" Style="{StaticResource ProviderManagerCaption}" Text="左侧选择提供商后可以编辑、停用、拉取模型或重置冷却。" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                                    <Button x:Name="EditRouteButton" Style="{StaticResource ProviderManagerRowButton}" Click="OnEditSelectedRouteClick">
                                                        <TextBlock FontSize="12" Text="编辑" />
                                                    </Button>
                                                    <Button x:Name="ToggleRouteButton" Style="{StaticResource ProviderManagerRowButton}" Click="OnToggleSelectedRouteEnabledClick">
                                                        <TextBlock x:Name="ToggleRouteButtonText" FontSize="12" Text="停用" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>

                                            <Grid Grid.Row="1" ColumnSpacing="10" RowSpacing="10" Tag="ResponsiveStack">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Style="{StaticResource ProviderManagerSubtleCard}" Padding="12,10">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="类型 / 协议" />
                                                        <TextBlock x:Name="RouteDetailKind" FontSize="13" FontWeight="SemiBold" Text="-" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock x:Name="RouteDetailProtocol" Style="{StaticResource ProviderManagerCaption}" Text="-" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="1" Style="{StaticResource ProviderManagerSubtleCard}" Padding="12,10">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="API Key" />
                                                        <TextBlock x:Name="RouteDetailApiKey" FontSize="13" FontWeight="SemiBold" Text="-" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock x:Name="RouteDetailStatus" Style="{StaticResource ProviderManagerCaption}" Text="-" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="2" Style="{StaticResource ProviderManagerSubtleCard}" Padding="12,10">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="优先级 / 前缀" />
                                                        <TextBlock x:Name="RouteDetailPriority" FontSize="13" FontWeight="SemiBold" Text="-" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock x:Name="RouteDetailPrefix" Style="{StaticResource ProviderManagerCaption}" Text="-" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Grid Grid.Row="2" RowSpacing="9">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <StackPanel Spacing="3">
                                                    <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="上游地址" />
                                                    <TextBlock x:Name="RouteDetailEndpoint" FontSize="13" Text="-" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Spacing="3">
                                                    <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="模型" />
                                                    <TextBlock x:Name="RouteDetailModels" FontSize="13" Text="-" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="7" HorizontalAlignment="Right">
                                                    <Button x:Name="FetchModelsButton" Style="{StaticResource ProviderManagerRowButton}" Click="OnFetchSelectedRouteModelsClick">
                                                        <TextBlock FontSize="12" Text="拉取模型" />
                                                    </Button>
                                                    <Button x:Name="ResetCircuitButton" Style="{StaticResource ProviderManagerRowButton}" Click="OnResetSelectedRouteCircuitClick">
                                                        <TextBlock FontSize="12" Text="重置冷却" />
                                                    </Button>
                                                    <Button x:Name="RemoveRouteButton" Style="{StaticResource ProviderManagerRowButton}" Click="OnRemoveSelectedRouteClick">
                                                        <TextBlock FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Text="删除" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="ProviderFormPanel" Style="{StaticResource ProviderManagerCard}" Padding="14,12" Visibility="Collapsed">
                                        <Grid RowSpacing="12">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid ColumnSpacing="10" Tag="ResponsiveStack">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="3" MinWidth="0">
                                                    <TextBlock x:Name="ProviderFormTitle" FontSize="18" FontWeight="SemiBold" Text="新增提供商" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock x:Name="ProviderFormSubtitle" Style="{StaticResource ProviderManagerCaption}" Text="选择上游类型后填写地址、Key 和模型。" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Style="{StaticResource ProviderManagerRowButton}" Click="OnCancelProviderFormClick">
                                                    <TextBlock FontSize="12" Text="取消" />
                                                </Button>
                                            </Grid>

                                            <Grid Grid.Row="1" ColumnSpacing="10" RowSpacing="10" Tag="ResponsiveStack">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.1*" />
                                                    <ColumnDefinition Width="1.1*" />
                                                    <ColumnDefinition Width="1.4*" />
                                                    <ColumnDefinition Width="120" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="4">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="提供商类型" />
                                                    <ComboBox x:Name="ProviderKindBox" SelectedIndex="0" SelectionChanged="OnProviderKindChanged" HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Tag="openai-compatible" Content="OpenAI 兼容" />
                                                        <ComboBoxItem Tag="claude-api" Content="Claude API" />
                                                        <ComboBoxItem Tag="codex-api" Content="Codex API" />
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="协议" />
                                                    <ComboBox x:Name="ProviderWireApiBox" SelectedIndex="0" HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Tag="chat" Content="Chat Completions" />
                                                        <ComboBoxItem Tag="anthropic" Content="Anthropic Messages" />
                                                        <ComboBoxItem Tag="responses" Content="Responses" />
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Spacing="4">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="名称" />
                                                    <TextBox x:Name="ProviderNameBox" PlaceholderText="例如：主 OpenAI 兼容线路" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="3" Spacing="4">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="优先级" />
                                                    <NumberBox x:Name="ProviderPriorityBox" Minimum="0" Maximum="100" SmallChange="1" LargeChange="10" Value="90" SpinButtonPlacementMode="Compact" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid Grid.Row="2" ColumnSpacing="10" RowSpacing="10" Tag="ResponsiveStack">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.35*" />
                                                    <ColumnDefinition Width="1.15*" />
                                                    <ColumnDefinition Width="1.1*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="4">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="上游 API 地址" />
                                                    <TextBox x:Name="ProviderBaseUrlBox" PlaceholderText="https://api.example.com/v1" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="API Key" />
                                                    <PasswordBox x:Name="ProviderApiKeyBox" PlaceholderText="sk-..." />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Spacing="4">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="模型" />
                                                    <TextBox x:Name="ProviderModelsBox" PlaceholderText="多个模型用逗号分隔" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid Grid.Row="3" ColumnSpacing="10" RowSpacing="10" Tag="ResponsiveStack">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="4">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="入口前缀" />
                                                    <TextBox x:Name="ProviderPrefixBox" PlaceholderText="可选，例如 /claude 或 /codex" />
                                                </StackPanel>
                                                <ToggleSwitch x:Name="ProviderEnabledSwitch" Grid.Column="1" Header="启用" IsOn="True" MinWidth="92" VerticalAlignment="Bottom" />
                                                <Button Grid.Column="2" Style="{StaticResource AppAccentToolbarButton}" Click="OnSaveProviderClick" VerticalAlignment="Bottom">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE74E;" />
                                                        <TextBlock x:Name="ProviderSaveText" FontSize="12" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Text="保存提供商" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <TextBlock x:Name="ProviderFormStatus" Grid.Row="4" Style="{StaticResource ProviderManagerCaption}" Text="保存后会写入透明代理路由，应用接入和协议探测会复用这份配置。" TextWrapping="WrapWholeWords" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>

                        <Grid x:Name="OAuthSection" RowSpacing="12" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource ProviderManagerSectionTitle}" Text="OAuth 与配额" />
                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{x:Bind ViewModel.OAuthStatusText, Mode=OneWay}" />
                            </StackPanel>
                            <Border Grid.Row="1" Style="{StaticResource ProviderManagerCard}" Padding="14,12">
                                <Grid ColumnSpacing="8" RowSpacing="8" Tag="ResponsiveStack">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button HorizontalAlignment="Stretch" Style="{StaticResource AppAccentToolbarButton}" Command="{x:Bind ViewModel.StartCodexOAuthLoginCommand}">
                                        <TextBlock HorizontalAlignment="Center" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Text="登录 OpenAI/Codex" />
                                    </Button>
                                    <Button Grid.Column="1" HorizontalAlignment="Stretch" Style="{StaticResource AppToolbarButton}" Command="{x:Bind ViewModel.ImportCodexOAuthCredentialCommand}">
                                        <TextBlock HorizontalAlignment="Center" Text="导入凭据" />
                                    </Button>
                                    <Button Grid.Column="2" HorizontalAlignment="Stretch" Style="{StaticResource AppToolbarButton}" Command="{x:Bind ViewModel.RefreshCodexOAuthCredentialCommand}">
                                        <TextBlock HorizontalAlignment="Center" Text="刷新令牌" />
                                    </Button>
                                    <Button Grid.Column="3" HorizontalAlignment="Stretch" Style="{StaticResource AppToolbarButton}" Command="{x:Bind ViewModel.LogoutCodexOAuthCommand}">
                                        <TextBlock HorizontalAlignment="Center" Text="退出全部" />
                                    </Button>
                                </Grid>
                            </Border>
                            <Grid Grid.Row="2" ColumnSpacing="12" RowSpacing="12" Tag="ResponsiveStack">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="360" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource ProviderManagerCard}" Padding="14,12">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="OAuth 账号" />
                                        <ListView ItemsSource="{x:Bind OAuthAccountItems, Mode=OneWay}" SelectionMode="None" IsItemClickEnabled="False" MaxHeight="390" Padding="0">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="0,9" ColumnSpacing="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="160" />
                                                            <ColumnDefinition Width="176" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Spacing="2" MinWidth="0">
                                                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{Binding DetailDisplay}" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{Binding BindingDisplay}" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{Binding HealthDisplay}" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                            <Button Style="{StaticResource ProviderManagerIconButton}" Click="OnRefreshOAuthAccountClick" ToolTipService.ToolTip="刷新">
                                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE72C;" />
                                                            </Button>
                                                            <Button Style="{StaticResource ProviderManagerIconButton}" Click="OnDisableOAuthAccountClick" ToolTipService.ToolTip="启用/停用">
                                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE7BA;" />
                                                            </Button>
                                                            <Button Style="{StaticResource ProviderManagerIconButton}" Click="OnExportOAuthAccountClick" ToolTipService.ToolTip="导出">
                                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xEDE1;" />
                                                            </Button>
                                                            <Button Style="{StaticResource ProviderManagerIconButton}" Click="OnDeleteOAuthAccountClick" ToolTipService.ToolTip="删除">
                                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Glyph="&#xE74D;" />
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource ProviderManagerCard}" Padding="14,12">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="手动回调" />
                                        <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="浏览器无法自动回调时，把回调 URL 粘贴到这里。" TextWrapping="WrapWholeWords" />
                                        <TextBox PlaceholderText="粘贴 OAuth 回调 URL" Text="{x:Bind ViewModel.ManualCallbackUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button HorizontalAlignment="Stretch" Style="{StaticResource AppToolbarButton}" Command="{x:Bind ViewModel.SubmitCodexOAuthCallbackCommand}">
                                            <TextBlock HorizontalAlignment="Center" Text="提交回调" />
                                        </Button>
                                        <Button HorizontalAlignment="Stretch" Style="{StaticResource AppToolbarButton}" Command="{x:Bind ViewModel.CopyCodexOAuthLoginUrlCommand}">
                                            <TextBlock HorizontalAlignment="Center" Text="复制登录链接" />
                                        </Button>
                                        <Button HorizontalAlignment="Stretch" Style="{StaticResource AppToolbarButton}" Command="{x:Bind ViewModel.CancelCodexOAuthLoginCommand}">
                                            <TextBlock HorizontalAlignment="Center" Text="取消登录" />
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid x:Name="StrategySection" RowSpacing="12" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource ProviderManagerSectionTitle}" Text="路由策略" />
                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="选择透明代理如何在多个可用上游之间分配请求。" />
                            </StackPanel>
                            <Border Grid.Row="1" Style="{StaticResource ProviderManagerCard}" Padding="14,12">
                                <Grid ColumnSpacing="12" Tag="ResponsiveStack">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="320" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox ItemsSource="{x:Bind ViewModel.RouteStrategyDisplayOptions}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Key"
                                              SelectedValue="{x:Bind ViewModel.SelectedRouteStrategy, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource ProviderManagerCaption}" Text="内部仍保存英文策略 key，历史配置和运行时兼容不变。" TextWrapping="WrapWholeWords" />
                                </Grid>
                            </Border>
                            <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.RouteStrategyDisplayOptions}" SelectionMode="None" IsItemClickEnabled="False" Padding="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RouteStrategyOption">
                                        <Border Style="{StaticResource ProviderManagerCard}" Padding="12,10" Margin="0,0,0,8">
                                            <StackPanel Spacing="3">
                                                <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind Name}" />
                                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{x:Bind Description}" TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <Grid x:Name="AliasesSection" RowSpacing="12" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="8" Tag="ResponsiveStack">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Style="{StaticResource ProviderManagerSectionTitle}" Text="模型别名" />
                                    <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="把客户端请求模型映射到上游真实模型。" />
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource AppToolbarButton}" Command="{x:Bind ViewModel.AddModelRewriteRuleCommand}">
                                    <TextBlock Text="添加别名" />
                                </Button>
                            </Grid>
                            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.ModelRewriteRules, Mode=OneWay}" SelectionMode="None" IsItemClickEnabled="False" Padding="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ModelRewriteRule">
                                        <Grid Padding="0,8" ColumnSpacing="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Tag="ResponsiveStack">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{x:Bind SourceModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="客户端模型名" />
                                            <TextBox Grid.Column="1" Text="{x:Bind TargetModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="上游真实模型名" />
                                            <Button Grid.Column="2" Style="{StaticResource ProviderManagerIconButton}" Click="OnRemoveRewriteRuleClick">
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Glyph="&#xE74D;" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <Grid x:Name="StatusSection" RowSpacing="12" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource ProviderManagerSectionTitle}" Text="运行状态" />
                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="查看路由冷却、熔断、协议和近期健康状态。" />
                            </StackPanel>
                            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.RouteQueue, Mode=OneWay}" SelectionMode="None" IsItemClickEnabled="False" Padding="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RouteQueueEntry">
                                        <Grid Padding="0,9" ColumnSpacing="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="112" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="2" MinWidth="0">
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind RouteName}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{x:Bind PolicyDisplay}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock FontSize="11" FontWeight="SemiBold" Text="{x:Bind StatusText}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{x:Bind CooldownDisplay}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock FontSize="11" FontWeight="SemiBold" Text="{x:Bind Protocol}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Style="{StaticResource ProviderManagerCaption}" Text="{x:Bind LatencyDisplay}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Button Grid.Column="3" Style="{StaticResource ProviderManagerRowButton}" Click="OnResetQueueRouteCircuitClick" Tag="{Binding}">
                                                <TextBlock FontSize="12" Text="重置冷却" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </NavigationView>
            </Grid>
        </Border>
    </ScrollViewer>
</ContentDialog>
