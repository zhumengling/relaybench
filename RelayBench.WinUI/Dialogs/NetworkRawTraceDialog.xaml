<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="RelayBench.WinUI.Dialogs.NetworkRawTraceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="网络原始追踪"
    CloseButtonText="关闭"
    DefaultButton="Close">

    <ScrollViewer MaxHeight="620"
                  MaxWidth="760"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Border Padding="16"
                CornerRadius="10"
                Background="{ThemeResource RxAcrylicOverlayBrush}"
                BorderBrush="{ThemeResource ContentDialogBorderBrush}"
                BorderThickness="1">
            <StackPanel Spacing="14" MinWidth="0" MaxWidth="720">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="10" IsStaggeringEnabled="True" />
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="42"
                            Height="42"
                            CornerRadius="12"
                            Background="{ThemeResource DialogAccentChipBackgroundBrush}"
                            BorderBrush="{ThemeResource DialogAccentChipBorderBrush}"
                            BorderThickness="1">
                        <FontIcon HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  FontSize="20"
                                  Foreground="{ThemeResource DialogAccentChipForegroundBrush}"
                                  Glyph="&#xE9D9;" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" MinWidth="0">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   Text="{x:Bind TraceTitle, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1" />
                        <TextBlock FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="来自最近一次网络复核运行的原始入口追踪和语义证据。"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="2" />
                    </StackPanel>
                    <Border Grid.Column="2"
                            Padding="8,4"
                            CornerRadius="10"
                            Background="{ThemeResource DialogAccentChipBackgroundBrush}"
                            BorderBrush="{ThemeResource DialogAccentChipBorderBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            MaxWidth="132">
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource DialogAccentChipForegroundBrush}"
                                   Text="原始证据"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                </Grid>

                <Border Padding="12,10"
                        CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  FontSize="15"
                                  Foreground="{ThemeResource DialogAccentChipForegroundBrush}"
                                  Glyph="&#xE946;" />
                        <TextBlock Grid.Column="1"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="较宽的追踪 payload 会在内部滚动，不会把弹窗撑出 1080p 工作区。"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="2" />
                    </Grid>
                </Border>

                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   Text="追踪 payload"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1" />
                        <Button Grid.Column="1"
                                Padding="9,5"
                                Click="OnCopyTraceClick"
                                AutomationProperties.Name="复制网络原始追踪"
                                ToolTipService.ToolTip="复制这份网络原始追踪">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8C8;" />
                                <TextBlock FontSize="12" Text="复制" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBox Grid.Row="1"
                             Style="{StaticResource DialogTerminalTextBox}"
                             MinHeight="320"
                             MaxHeight="420"
                             Text="{x:Bind TraceContent, Mode=OneWay}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollMode="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollMode="Auto"
                             AutomationProperties.Name="网络原始追踪详情"
                             ToolTipService.ToolTip="读取原始入口追踪详情" />
                </Grid>
            </StackPanel>
        </Border>
    </ScrollViewer>
</ContentDialog>
