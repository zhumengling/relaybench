<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="RelayBench.WinUI.Dialogs.ClientApplyTargetDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RelayBench.WinUI.ViewModels"
    Title="&#x9009;&#x62E9;&#x63A5;&#x5165;&#x76EE;&#x6807;"
    PrimaryButtonText="&#x5E94;&#x7528;&#x6240;&#x9009;"
    SecondaryButtonText="&#x8FD8;&#x539F;&#x6240;&#x9009;"
    CloseButtonText="&#x5173;&#x95ED;"
    DefaultButton="Primary">

    <ScrollViewer MaxHeight="640"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Border MinWidth="0"
                MaxWidth="900"
                Padding="16"
                CornerRadius="10"
                Background="{ThemeResource RxAcrylicOverlayBrush}"
                BorderBrush="{ThemeResource ContentDialogBorderBrush}"
                BorderThickness="1">
            <StackPanel Spacing="14">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="10" IsStaggeringEnabled="True" />
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="42" Height="42" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1" CornerRadius="12">
                        <FontIcon HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  FontSize="20"
                                  Foreground="{ThemeResource DialogAccentChipForegroundBrush}"
                                  Glyph="&#xE8A7;" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" MinWidth="0">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="&#x5E94;&#x7528;&#x63A5;&#x5165;&#x76EE;&#x6807;" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind DialogSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" MaxLines="2" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Padding="9,5" Command="{x:Bind ViewModel.SelectAllClientApplyTargetsCommand}" AutomationProperties.Name="全选客户端写入目标" ToolTipService.ToolTip="&#x9009;&#x4E2D;&#x6240;&#x6709;&#x53EF;&#x5199;&#x5165;&#x76EE;&#x6807;">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8FB;" />
                        </Button>
                        <Button Padding="9,5" Command="{x:Bind ViewModel.InvertClientApplyTargetsCommand}" AutomationProperties.Name="反选客户端写入目标" ToolTipService.ToolTip="&#x53CD;&#x9009;&#x53EF;&#x5199;&#x5165;&#x76EE;&#x6807;">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8AB;" />
                        </Button>
                        <Button Padding="9,5" Click="OnClearClick" AutomationProperties.Name="清空客户端写入目标" ToolTipService.ToolTip="&#x6E05;&#x7A7A;&#x9009;&#x62E9;">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE711;" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x76EE;&#x6807;" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="{x:Bind ViewModel.TargetOverviewText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x5DF2;&#x53D1;&#x73B0;" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="{x:Bind ViewModel.InstalledTargetOverviewText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x5DF2;&#x9009;" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedTargetOverviewText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x534F;&#x8BAE;" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="{x:Bind ViewModel.ProtocolCoverageText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Padding="12,8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38" />
                                <ColumnDefinition Width="1.45*" />
                                <ColumnDefinition Width="0.7*" />
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="1.55*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x5BA2;&#x6237;&#x7AEF;" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x72B6;&#x6001;" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="3" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x534F;&#x8BAE;" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="4" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x5F53;&#x524D;&#x914D;&#x7F6E;" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="5" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x8DEF;&#x5F84; / &#x539F;&#x56E0;" TextTrimming="CharacterEllipsis" />
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Targets, Mode=OneWay}" SelectionMode="None" MaxHeight="390">
                            <ListView.Transitions>
                                <TransitionCollection>
                                    <EntranceThemeTransition FromVerticalOffset="10" IsStaggeringEnabled="True" />
                                    <RepositionThemeTransition />
                                </TransitionCollection>
                            </ListView.Transitions>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:AppTargetItem">
                                    <Grid Padding="12,9" ColumnSpacing="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38" />
                                            <ColumnDefinition Width="1.45*" />
                                            <ColumnDefinition Width="0.7*" />
                                            <ColumnDefinition Width="0.9*" />
                                            <ColumnDefinition Width="1.4*" />
                                            <ColumnDefinition Width="1.55*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox MinWidth="0"
                                                  Padding="0"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                  IsEnabled="{x:Bind IsSelectable}"
                                                  AutomationProperties.Name="{x:Bind Name}"
                                                  ToolTipService.ToolTip="{x:Bind Description}" />
                                        <Grid Grid.Column="1" ColumnSpacing="9" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid Width="32" Height="32">
                                                <Border CornerRadius="8" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind IconAccentToneVisibility, Mode=OneWay}" />
                                                <Border CornerRadius="8" Background="{ThemeResource DialogSuccessChipBackgroundBrush}" BorderBrush="{ThemeResource DialogSuccessChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind IconHealthyToneVisibility, Mode=OneWay}" />
                                                <Border CornerRadius="8" Background="{ThemeResource DialogWarningChipBackgroundBrush}" BorderBrush="{ThemeResource DialogWarningChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind IconWarningToneVisibility, Mode=OneWay}" />
                                                <Border CornerRadius="8" Background="{ThemeResource DialogDangerChipBackgroundBrush}" BorderBrush="{ThemeResource DialogDangerChipBorderBrush}" BorderThickness="1" Visibility="{x:Bind IconDangerToneVisibility, Mode=OneWay}" />
                                                <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="16" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Glyph="{x:Bind IconGlyph}" Visibility="{x:Bind IconAccentToneVisibility, Mode=OneWay}" />
                                                <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="16" Foreground="{ThemeResource DialogSuccessChipForegroundBrush}" Glyph="{x:Bind IconGlyph}" Visibility="{x:Bind IconHealthyToneVisibility, Mode=OneWay}" />
                                                <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="16" Foreground="{ThemeResource DialogWarningChipForegroundBrush}" Glyph="{x:Bind IconGlyph}" Visibility="{x:Bind IconWarningToneVisibility, Mode=OneWay}" />
                                                <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="16" Foreground="{ThemeResource DialogDangerChipForegroundBrush}" Glyph="{x:Bind IconGlyph}" Visibility="{x:Bind IconDangerToneVisibility, Mode=OneWay}" />
                                            </Grid>
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Description}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center">
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource DialogSuccessChipForegroundBrush}" Text="{x:Bind InstalledText}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind SelectabilityText}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Border Grid.Column="3" Padding="8,3" CornerRadius="10" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Text="{x:Bind Protocol}" TextTrimming="CharacterEllipsis" />
                                        </Border>
                                        <StackPanel Grid.Column="4" Spacing="1" VerticalAlignment="Center">
                                            <TextBlock FontSize="11" Text="{x:Bind CurrentConfig}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Endpoint}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="5"
                                                   FontSize="10.5"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Text="{x:Bind DialogDetailText, Mode=OneWay}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTipService.ToolTip="{x:Bind DialogDetailText, Mode=OneWay}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="15" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Glyph="&#xE946;" />
                    <TextBlock Grid.Column="1" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind DialogHint, Mode=OneWay}" TextWrapping="Wrap" MaxLines="3" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </ScrollViewer>
</ContentDialog>
