<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="RelayBench.WinUI.Dialogs.DataSafetyEvidenceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="&#x8BC1;&#x636E;&#x8BE6;&#x60C5;"
    CloseButtonText="&#x5173;&#x95ED;"
    DefaultButton="Close">

    <ScrollViewer MaxHeight="640"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Border Padding="16"
                CornerRadius="10"
                Background="{ThemeResource RxAcrylicOverlayBrush}"
                BorderBrush="{ThemeResource ContentDialogBorderBrush}"
                BorderThickness="1">
            <StackPanel Spacing="14" MinWidth="0" MaxWidth="900">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="10" IsStaggeringEnabled="True" />
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="42" Height="42" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1" CornerRadius="12">
                        <FontIcon HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  FontSize="20"
                                  Foreground="{ThemeResource DialogAccentChipForegroundBrush}"
                                  Glyph="&#xE9D5;" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" MinWidth="0">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind Result.ScenarioName, Mode=OneWay}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Result.ScenarioId, Mode=OneWay}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Border Padding="8,4" Background="{ThemeResource DialogSuccessChipBackgroundBrush}" BorderBrush="{ThemeResource DialogSuccessChipBorderBrush}" BorderThickness="1" CornerRadius="10">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource DialogSuccessChipForegroundBrush}" MaxWidth="112" Text="{x:Bind Result.ResultText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </Border>
                        <Button Padding="9,5"
                                Click="OnCopyClick"
                                AutomationProperties.Name="复制数据安全证据"
                                ToolTipService.ToolTip="复制数据安全证据">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8C8;" />
                                <TextBlock FontSize="12" Text="&#x590D;&#x5236;" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="10" RowSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x7C7B;&#x522B;" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="{x:Bind Result.Category, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x98CE;&#x9669;" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="{x:Bind Result.RiskLevelText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x98CE;&#x9669;&#x5206;" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="{x:Bind Result.RiskScore, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x8BB0;&#x5F55;&#x65F6;&#x95F4;" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="{x:Bind Result.CompletedAtText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Pivot>
                    <PivotItem>
                        <PivotItem.Header>
                            <TextBlock MaxWidth="64" Text="&#x6458;&#x8981;" TextTrimming="CharacterEllipsis" />
                        </PivotItem.Header>
                        <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                            <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="11.5" TextWrapping="Wrap" IsTextSelectionEnabled="True" Text="{x:Bind Result.DetailText, Mode=OneWay}" />
                        </ScrollViewer>
                    </PivotItem>
                    <PivotItem>
                        <PivotItem.Header>
                            <TextBlock MaxWidth="64" Text="&#x5224;&#x5B9A;" TextTrimming="CharacterEllipsis" />
                        </PivotItem.Header>
                        <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                            <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="11.5" TextWrapping="Wrap" IsTextSelectionEnabled="True" Text="{x:Bind Result.CheckEvidenceText, Mode=OneWay}" />
                        </ScrollViewer>
                    </PivotItem>
                    <PivotItem>
                        <PivotItem.Header>
                            <TextBlock MaxWidth="64" Text="&#x8BF7;&#x6C42;" TextTrimming="CharacterEllipsis" />
                        </PivotItem.Header>
                        <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                            <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="11.5" TextWrapping="Wrap" IsTextSelectionEnabled="True" Text="{x:Bind Result.RequestLogText, Mode=OneWay}" />
                        </ScrollViewer>
                    </PivotItem>
                    <PivotItem>
                        <PivotItem.Header>
                            <TextBlock MaxWidth="64" Text="&#x54CD;&#x5E94;" TextTrimming="CharacterEllipsis" />
                        </PivotItem.Header>
                        <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                            <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="11.5" TextWrapping="Wrap" IsTextSelectionEnabled="True" Text="{x:Bind Result.SanitizedLogText, Mode=OneWay}" />
                        </ScrollViewer>
                    </PivotItem>
                </Pivot>

                <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="15" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Glyph="&#xE946;" />
                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind CopyStatusText, Mode=OneWay}" TextWrapping="Wrap" MaxLines="2" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </ScrollViewer>
</ContentDialog>
