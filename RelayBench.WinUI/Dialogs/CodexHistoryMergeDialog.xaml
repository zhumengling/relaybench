<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="RelayBench.WinUI.Dialogs.CodexHistoryMergeDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="复核 Codex 历史合并"
    PrimaryButtonText="合并"
    CloseButtonText="取消"
    DefaultButton="Close">

    <ScrollViewer MaxHeight="620"
                  MaxWidth="760"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Border Padding="16"
                CornerRadius="10"
                BorderBrush="{ThemeResource ContentDialogBorderBrush}"
                BorderThickness="1"
                Background="{ThemeResource RxAcrylicOverlayBrush}">
            <StackPanel Spacing="14" MinWidth="0" MaxWidth="720">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="10" IsStaggeringEnabled="True" />
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="42"
                            Height="42"
                            CornerRadius="12"
                            Background="{ThemeResource DialogWarningChipBackgroundBrush}"
                            BorderBrush="{ThemeResource DialogWarningChipBorderBrush}"
                            BorderThickness="1">
                        <FontIcon HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  FontSize="20"
                                  Foreground="{ThemeResource DialogWarningChipForegroundBrush}"
                                  Glyph="&#xE8FD;" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" MinWidth="0">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   Text="Codex 历史合并复核"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1" />
                        <TextBlock FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="RelayBench 只会在你明确确认后合并本地 Codex 对话历史。"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="2" />
                    </StackPanel>
                    <Border Grid.Column="2"
                            Padding="8,4"
                            CornerRadius="10"
                            Background="{ThemeResource DialogWarningChipBackgroundBrush}"
                            BorderBrush="{ThemeResource DialogWarningChipBorderBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            MaxWidth="132">
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource DialogWarningChipForegroundBrush}"
                                   Text="用户已确认"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                </Grid>

                <Border Padding="12,10"
                        CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  FontSize="15"
                                  Foreground="{ThemeResource DialogWarningChipForegroundBrush}"
                                  Glyph="&#xE946;" />
                        <TextBlock Grid.Column="1"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="此操作可能改写真实的本地 Codex rollout 文件和 SQLite 记录。继续前请检查检测状态和备份。"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="3" />
                    </Grid>
                </Border>

                <StackPanel Spacing="5">
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Text="当前 Codex 历史状态"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />
                    <TextBlock FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind StatusText, Mode=OneWay}"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="3" />
                </StackPanel>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="ThirdPartyTargetButton"
                                 IsChecked="True"
                                 GroupName="CodexHistoryMergeTarget"
                                 AutomationProperties.Name="将 Codex 历史合并到 RelayBench 提供方"
                                 ToolTipService.ToolTip="将官方 Codex 历史合并到当前 RelayBench 或第三方提供方目标">
                        <Grid ColumnSpacing="8" MinWidth="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                      FontSize="14"
                                      Foreground="{ThemeResource DialogWarningChipForegroundBrush}"
                                      Glyph="&#xE8F1;" />
                            <StackPanel Grid.Column="1" Spacing="1" MinWidth="0">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="RelayBench 提供方"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1" />
                                <TextBlock FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="用于本地第三方或 Codex 兼容入口。"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="2" />
                            </StackPanel>
                        </Grid>
                    </RadioButton>
                    <RadioButton x:Name="OfficialTargetButton"
                                 Grid.Column="1"
                                 GroupName="CodexHistoryMergeTarget"
                                 AutomationProperties.Name="将 Codex 历史合并到官方 OpenAI 目标"
                                 ToolTipService.ToolTip="将本地 Codex 历史合并到官方 OpenAI 目标">
                        <Grid ColumnSpacing="8" MinWidth="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                      FontSize="14"
                                      Foreground="{ThemeResource DialogWarningChipForegroundBrush}"
                                      Glyph="&#xE8A7;" />
                            <StackPanel Grid.Column="1" Spacing="1" MinWidth="0">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="官方 OpenAI"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1" />
                                <TextBlock FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="仅在恢复或对齐官方 Codex 历史时使用。"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="2" />
                            </StackPanel>
                        </Grid>
                    </RadioButton>
                </Grid>

                <StackPanel Spacing="5">
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Text="复核详情"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />
                    <TextBox Style="{StaticResource DialogTerminalTextBox}"
                             MinHeight="210"
                             MaxHeight="280"
                             Text="{x:Bind DetailText, Mode=OneWay}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             AutomationProperties.Name="Codex 历史合并详情"
                             ToolTipService.ToolTip="合并前读取提供方数量、备份状态、变更文件、警告和错误" />
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</ContentDialog>
