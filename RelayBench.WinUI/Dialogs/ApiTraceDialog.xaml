<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="RelayBench.WinUI.Dialogs.ApiTraceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RelayBench.WinUI.ViewModels"
    Title="API 追踪"
    CloseButtonText="&#x5173;&#x95ED;"
    DefaultButton="Close">

    <ScrollViewer MaxHeight="640"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Border Padding="16"
                CornerRadius="10"
                Background="{ThemeResource RxAcrylicOverlayBrush}"
                BorderBrush="{ThemeResource ContentDialogBorderBrush}"
                BorderThickness="1">
            <StackPanel Spacing="14" MinWidth="0" MaxWidth="920">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="10" IsStaggeringEnabled="True" />
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="42" Height="42" Background="{ThemeResource DialogAccentChipBackgroundBrush}" BorderBrush="{ThemeResource DialogAccentChipBorderBrush}" BorderThickness="1" CornerRadius="12">
                        <FontIcon HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  FontSize="20"
                                  Foreground="{ThemeResource DialogAccentChipForegroundBrush}"
                                  Glyph="&#xE774;" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" MinWidth="0">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind TitleText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind SubtitleText, Mode=OneWay}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" />
                    </StackPanel>

                    <Grid Grid.Column="2" VerticalAlignment="Center">
                        <Border Padding="8,4"
                                Background="{ThemeResource DialogSuccessChipBackgroundBrush}"
                                BorderBrush="{ThemeResource DialogSuccessChipBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                MaxWidth="150"
                                Visibility="{x:Bind SupportedRegionVisibility, Mode=OneWay}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource DialogSuccessChipForegroundBrush}"
                                       Text="{x:Bind SupportText, Mode=OneWay}"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                        <Border Padding="8,4"
                                Background="{ThemeResource DialogWarningChipBackgroundBrush}"
                                BorderBrush="{ThemeResource DialogWarningChipBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                MaxWidth="150"
                                Visibility="{x:Bind UnsupportedRegionVisibility, Mode=OneWay}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource DialogWarningChipForegroundBrush}"
                                       Text="{x:Bind SupportText, Mode=OneWay}"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                    </Grid>
                </Grid>

                <Grid ColumnSpacing="10" RowSpacing="10" Tag="ResponsiveStack">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x516C;&#x7F51; IP" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{x:Bind PublicIpText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Cloudflare 节点" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Text="{x:Bind ColoText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x5730;&#x57DF;" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{x:Bind LocationText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x5FEB;&#x7167;" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{x:Bind SnapshotText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="15" Foreground="{ThemeResource DialogAccentChipForegroundBrush}" Glyph="&#xE946;" />
                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind SummaryText, Mode=OneWay}" TextWrapping="Wrap" MaxLines="3" />
                    </Grid>
                </Border>

                <Grid ColumnSpacing="10" Tag="ResponsiveStack">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition Width="0.75*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="14" FontWeight="SemiBold" Text="&#x8FFD;&#x8E2A;&#x539F;&#x59CB;&#x56DE;&#x6267;" TextTrimming="CharacterEllipsis" />
                                <Button Grid.Column="1"
                                        Padding="9,5"
                                        Click="OnCopyTraceClick"
                                        AutomationProperties.Name="复制原始 API 追踪"
                                        ToolTipService.ToolTip="复制原始 API 追踪">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE8C8;" />
                                        <TextBlock FontSize="12" Text="&#x590D;&#x5236;" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <TextBox Grid.Row="1"
                                     Style="{StaticResource DialogTerminalTextBox}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollMode="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollMode="Auto"
                                     MinHeight="320"
                                     Text="{x:Bind TraceContent, Mode=OneWay}"
                                     AutomationProperties.Name="API 追踪原始响应"
                                     ToolTipService.ToolTip="读取原始 API 追踪响应" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="14" FontWeight="SemiBold" Text="&#x89E3;&#x9501;&#x80FD;&#x529B;&#x5FEB;&#x7167;" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="&#x6765;&#x81EA;&#x540C;&#x6B21; API 追踪 &#x7684;&#x5B9E;&#x65F6;&#x68C0;&#x6D4B;&#x7ED3;&#x679C;" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <ListView Grid.Row="1" ItemsSource="{x:Bind UnlockRows, Mode=OneWay}" SelectionMode="None" MaxHeight="360">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:NetworkReviewUnlockRow">
                                        <Grid ColumnSpacing="8" Padding="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="1">
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Latency}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Padding="7,3" Background="{ThemeResource DialogSuccessChipBackgroundBrush}" BorderBrush="{ThemeResource DialogSuccessChipBorderBrush}" BorderThickness="1" CornerRadius="9">
                                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource DialogSuccessChipForegroundBrush}" Text="{x:Bind Status}" TextTrimming="CharacterEllipsis" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>
    </ScrollViewer>
</ContentDialog>
